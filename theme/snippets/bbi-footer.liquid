            <li><a href="/pages/non-profit">Non-Profit</a></li>
            <li><a href="/pages/professional-services">Professional Services</a></li>
            <li><a href="/pages/industries">All industries</a></li>
          </ul>
        </div>

        {%- comment -%} Services — 6 links incl. OECM (FIX 1b) {%- endcomment -%}
        <div class="bbi-footer__column">
          <h4>Services</h4>
          <ul>
            <li><a href="/pages/design-services">Design Services</a></li>
            <li><a href="/pages/delivery">Delivery &amp; Installation</a></li>
            <li><a href="/pages/relocation">Relocation Management</a></li>
            <li><a href="/pages/quote">Request a Quote</a></li>
            <li><a href="/pages/faq">FAQ</a></li>
            <li><a href="/pages/oecm">OECM Procurement</a></li>
          </ul>
        </div>

        {%- comment -%} Contact {%- endcomment -%}
        <div class="bbi-footer__column">
          <h4>Contact</h4>
          <div class="bbi-footer__contact-row">
            <span class="bbi-footer__contact-lbl">Phone</span>
            <a href="tel:18008359565" aria-label="Call Brant Business Interiors at 1-800-835-9565">1-800-835-9565</a>
          </div>
          <div class="bbi-footer__contact-row">
            <span class="bbi-footer__contact-lbl">Email</span>
            <a href="mailto:info@brantbusinessinteriors.com">info@brantbusinessinteriors.com</a>
          </div>
          <div class="bbi-footer__contact-row">
            <span class="bbi-footer__contact-lbl">Address</span>
            <span>295 George St N<br>Peterborough, ON K9J 3H2</span>
          </div>
        </div>

      </div>
    </div>

    {%- comment -%} OECM trust band (FIX 1a) — centre-aligned, 12px, muted {%- endcomment -%}
    <div class="bbi-footer__trust">
      <a href="/pages/oecm">OECM-eligible supplier</a> &middot; Authorized Canadian Dealer &middot; Since 1964
    </div>

    {%- comment -%} Copyright bar {%- endcomment -%}
    <div class="bbi-footer__bottom">
      <span>&copy; {{ 'now' | date: '%Y' }} Brant Business Interiors &mdash; a division of Office Central Inc. OECM Supplier Partner Agreement 2025-470.</span>
      <div class="bbi-footer__legal">
        <a href="/policies/privacy-policy">Privacy</a>
