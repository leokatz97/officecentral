        {%- comment -%} Industries {%- endcomment -%}
        <div class="bbi-footer__column">
          <h4>Industries</h4>
          <ul>
            <li><a href="/pages/healthcare">Healthcare &amp; Clinical</a></li>
            <li><a href="/pages/education">Education</a></li>
