      {%- comment -%} Right: 4-column link grid {%- endcomment -%}
      <div class="bbi-footer__columns">

        {%- comment -%} Shop — all 9 categories (FIX 2: full category list for crawlability) {%- endcomment -%}
        <div class="bbi-footer__column">
          <h4>Shop</h4>
