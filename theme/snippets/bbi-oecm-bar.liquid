{%- comment -%}
  Snippet: bbi-oecm-bar
  Purpose: Shared OECM trust band rendered on T2 (category hub) and T3 (sub-collection)
           pages in the pre-footer position, just above the phone CTA closer.
           Self-contained: owns its <style> block; all class names scoped to
           .bbi-oecm-bar to avoid polluting parent sections.
  Pattern: matches bbi-nav.liquid / bbi-footer.liquid — <style> block first,
           single <aside class="bbi-oecm-bar"> root, BEM descendants only.
  Content: OECM Supplier Partner Agreement 2025-470 · links to /pages/oecm
  DO NOT modify from ds-cc-base.liquid or any section. Edit this file only.
{%- endcomment -%}

<style>
.bbi-oecm-bar{
  --_bg:#FAFAFA;
  --_border:rgba(229,229,231,0.8);
  --_text:#0B0B0C;
  --_text-muted:rgba(11,11,12,0.65);
  --_accent:#D4252A;
  background:var(--_bg);
  border-top:1px solid var(--_border);
  border-bottom:1px solid var(--_border);
  font-family:"Inter",system-ui,-apple-system,"Segoe UI",Roboto,sans-serif;
  -webkit-font-smoothing:antialiased;
}
.bbi-oecm-bar *,.bbi-oecm-bar *::before,.bbi-oecm-bar *::after{box-sizing:border-box;}
.bbi-oecm-bar__inner{
  max-width:1280px;margin:0 auto;padding:20px 24px;
  display:flex;align-items:center;gap:16px;flex-wrap:wrap;
  justify-content:space-between;
}
.bbi-oecm-bar__left{display:flex;align-items:center;gap:12px;flex:1;min-width:0;}
.bbi-oecm-bar__dot{
  flex:0 0 auto;width:8px;height:8px;border-radius:50%;
  background:var(--_accent);
}
.bbi-oecm-bar__copy{min-width:0;}
.bbi-oecm-bar__label{
  font-family:"JetBrains Mono",ui-monospace,monospace;
  font-size:10px;letter-spacing:0.08em;text-transform:uppercase;
  color:var(--_text-muted);margin:0 0 2px;
}
.bbi-oecm-bar__heading{
  font-family:"Inter Tight","Inter",system-ui,sans-serif;
  font-size:15px;font-weight:600;line-height:1.3;
  color:var(--_text);margin:0;
}
.bbi-oecm-bar__sub{
  font-size:13px;line-height:1.45;color:var(--_text-muted);
  margin:2px 0 0;
}
.bbi-oecm-bar__link{
  flex:0 0 auto;
  font-size:13px;font-weight:600;color:var(--_text);
  text-decoration:none;white-space:nowrap;
  display:inline-flex;align-items:center;gap:4px;
}
.bbi-oecm-bar__link:hover{text-decoration:underline;text-underline-offset:2px;}
.bbi-oecm-bar__link:focus-visible{
  outline:2px solid var(--_text);outline-offset:2px;border-radius:2px;
}
@media(max-width:639px){
  .bbi-oecm-bar__inner{flex-direction:column;align-items:flex-start;gap:12px;}
  .bbi-oecm-bar__link{margin-left:20px;}
}
</style>

<aside class="bbi-oecm-bar" aria-label="OECM purchasing programme">
  <div class="bbi-oecm-bar__inner">
    <div class="bbi-oecm-bar__left">
      <span class="bbi-oecm-bar__dot" aria-hidden="true"></span>
      <div class="bbi-oecm-bar__copy">
        <p class="bbi-oecm-bar__label">Ontario procurement</p>
        <p class="bbi-oecm-bar__heading">OECM vendor of record &mdash; Supplier Partner Agreement 2025-470</p>
        <p class="bbi-oecm-bar__sub">Ontario&rsquo;s broader public sector can purchase without re-tendering. Schools, hospitals, municipalities, and not-for-profits.</p>
      </div>
    </div>
    <a class="bbi-oecm-bar__link" href="/pages/oecm">
      OECM purchasing details <span aria-hidden="true">&rarr;</span>
    </a>
  </div>
</aside>
