{%- comment -%}
  Snippet: bbi-nav
  Purpose: Shared BBI header — 5-item mega-menu nav, active-state indicator, mobile overlay
  Render:  {% render 'bbi-nav', logo: section.settings.logo, active: 'industries' %}
  Params:
    logo   {image}  — section.settings.logo image object (optional; text wordmark fallback)
    active {string} — active nav key: 'shop' | 'industries' | 'brands' | 'services' | 'about'
  Spec:    docs/strategy/bbi-nav-spec.md
  Decisions: all 5 items are dropdown-only (no click-navigate on top-level items)
{%- endcomment -%}

<style>
/* ============================================================
   bbi-nav snippet — shared header + mega-menu + mobile overlay
   Scoped to .bbi-header / .bbi-nav__* / .bbi-mobile-nav
   Falls back gracefully when section-level tokens are absent
   ============================================================ */
.bbi-header *,.bbi-header *::before,.bbi-header *::after,
.bbi-mobile-nav *,.bbi-mobile-nav *::before,.bbi-mobile-nav *::after
{box-sizing:border-box;}

/* ---- Base header bar ---- */
.bbi-header{
  background:var(--headerBg,#ffffff);
  border-bottom:1px solid var(--borderColor,#E5E5E7);
  position:sticky;top:0;z-index:200;
}
.bbi-header__inner{
  max-width:1320px;margin:0 auto;padding:0 32px;
  height:72px;display:flex;align-items:center;
}

/* ---- Logo ---- */
.bbi-header__logo{
  display:inline-flex;align-items:center;height:40px;
  text-decoration:none;flex-shrink:0;margin-right:24px;
}
.bbi-header__logo img{height:36px;width:auto;display:block;}
.bbi-header__logo-text{
  font-family:var(--headingFont,"Inter Tight","Inter",sans-serif);
  font-size:15px;font-weight:600;
  color:var(--headerColor,#0B0B0C);white-space:nowrap;
}

/* ---- Desktop nav ---- */
.bbi-header__nav{display:flex;align-items:center;margin-right:auto;}

/* Nav group wrapper */
.bbi-nav__group{position:relative;}

/* Trigger button */
.bbi-nav__item{
  display:inline-flex;align-items:center;gap:3px;
  height:72px;padding:0 14px;
  background:none;border:none;cursor:pointer;
  color:var(--headerColor,#0B0B0C);
  font-family:var(--bodyFont,"Inter",system-ui,sans-serif);
  font-size:14px;font-weight:500;
  position:relative;white-space:nowrap;
  transition:color 100ms ease;
}
.bbi-nav__item:hover{color:var(--headerHoverColor,#A81E22);}
.bbi-nav__item:focus-visible{outline:2px solid var(--saleBadgeBackground,#D4252A);outline-offset:2px;}

/* Active state — 2px brand-red underline above bottom border */
.bbi-nav__item--active::after{
  content:"";position:absolute;
  left:14px;right:14px;bottom:0;
  height:2px;background:var(--saleBadgeBackground,#D4252A);
}

/* Chevron icon */
.bbi-nav__chevron{
  width:12px;height:12px;flex-shrink:0;
  transition:transform 180ms ease;
}
.bbi-nav__group[data-open] .bbi-nav__chevron,
.bbi-nav__group:focus-within .bbi-nav__chevron{transform:rotate(180deg);}

/* Dropdown panel */
.bbi-nav__panel{
  display:none;
  position:absolute;top:calc(100% + 1px);left:0;
  min-width:210px;
  background:#ffffff;
  border:1px solid var(--borderColor,#E5E5E7);
  border-radius:6px;
  padding:6px 0;
  box-shadow:0 8px 24px rgba(11,11,12,.10);
  list-style:none;margin:0;
  z-index:201;
}
/* Show on hover or keyboard focus-within */
.bbi-nav__group:hover .bbi-nav__panel,
.bbi-nav__group:focus-within .bbi-nav__panel,
.bbi-nav__group[data-open] .bbi-nav__panel{display:block;}

/* Dropdown link items */
.bbi-nav__dd-link{
  display:block;padding:9px 18px;
  color:var(--textColor,#0B0B0C);
  font-size:14px;text-decoration:none;
  white-space:nowrap;
  transition:background-color 80ms ease,color 80ms ease;
}
.bbi-nav__dd-link:hover,.bbi-nav__dd-link:focus-visible{
  background:var(--alternateBackground,#FAFAFA);
  color:var(--headerHoverColor,#A81E22);
  outline:none;
}

/* Brands "Authorized Canadian Dealer" trust line */
.bbi-nav__dd-trust{
  display:block;padding:7px 18px 9px;
  font-size:12px;color:rgba(11,11,12,.45);
  font-style:italic;
  border-top:1px solid var(--borderColor,#E5E5E7);
  margin-top:4px;
}

/* ---- Utility bar (phone + CTA + hamburger) ---- */
.bbi-header__utility{
  display:flex;align-items:center;gap:16px;
  flex-shrink:0;font-size:14px;
}
.bbi-header__phone{
  color:var(--headerColor,#0B0B0C);text-decoration:none;
  font-weight:500;white-space:nowrap;
}
.bbi-header__phone:hover{color:var(--headerHoverColor,#A81E22);}

/* Quote CTA button — self-contained so it works on homepage (NAV-4) */
.bbi-header .bbi-btn{
  display:inline-flex;align-items:center;justify-content:center;
  gap:8px;padding:10px 18px;min-height:40px;
  font-family:var(--bodyFont,"Inter",system-ui,sans-serif);
  font-size:14px;line-height:1;font-weight:600;
  border-radius:var(--buttonRadius,4px);
  border:1px solid transparent;cursor:pointer;text-decoration:none;
  transition:background-color 120ms ease,color 120ms ease,border-color 120ms ease;
  white-space:nowrap;
}
.bbi-header .bbi-btn--primary{
  background:#0B0B0C;color:#ffffff;border-color:#0B0B0C;
}
.bbi-header .bbi-btn--primary:hover{
  background:#D4252A;color:#ffffff;border-color:#D4252A;
}

/* Hamburger — shown on mobile only */
.bbi-hamburger{
  display:none;background:none;border:none;cursor:pointer;
  padding:8px;color:var(--headerColor,#0B0B0C);
  border-radius:4px;
}
.bbi-hamburger:focus-visible{outline:2px solid var(--saleBadgeBackground,#D4252A);outline-offset:2px;}

/* ---- Mobile full-screen overlay ---- */
.bbi-mobile-nav{
  position:fixed;inset:0;z-index:500;
  background:#0B0B0C;color:#ffffff;
  display:flex;flex-direction:column;
  overflow:hidden;
}
.bbi-mobile-nav[hidden]{display:none;}

.bbi-mobile-nav__header{
  display:flex;align-items:center;justify-content:space-between;
  padding:0 24px;height:72px;flex-shrink:0;
  border-bottom:1px solid rgba(255,255,255,.12);
}
.bbi-mobile-nav__header-logo{
  display:inline-flex;align-items:center;text-decoration:none;
}
.bbi-mobile-nav__header-logo img{
  height:30px;width:auto;display:block;
  filter:brightness(0) invert(1);
}
.bbi-mobile-nav__header-logo-text{
  font-family:var(--headingFont,"Inter Tight","Inter",sans-serif);
  font-size:14px;font-weight:600;color:#ffffff;
}
.bbi-mobile-nav__close{
  display:flex;align-items:center;justify-content:center;
  width:44px;height:44px;background:none;border:none;
  cursor:pointer;color:#ffffff;border-radius:4px;
  flex-shrink:0;
}
.bbi-mobile-nav__close:focus-visible{outline:2px solid rgba(255,255,255,.6);outline-offset:2px;}

.bbi-mobile-nav__scroll{flex:1;overflow-y:auto;padding-bottom:8px;}

/* Accordion items (details/summary) */
.bbi-mobile-nav__accordion{
  border-bottom:1px solid rgba(255,255,255,.1);
}
.bbi-mobile-nav__summary{
  display:flex;align-items:center;justify-content:space-between;
  padding:16px 24px;
  font-family:var(--bodyFont,"Inter",system-ui,sans-serif);
  font-size:16px;font-weight:500;color:#ffffff;
  cursor:pointer;list-style:none;user-select:none;
}
.bbi-mobile-nav__summary::-webkit-details-marker{display:none;}
.bbi-mobile-nav__summary:focus-visible{outline:2px solid rgba(255,255,255,.6);outline-offset:-2px;}
.bbi-mobile-nav__summary-chevron{
  width:16px;height:16px;flex-shrink:0;
  transition:transform 200ms ease;color:rgba(255,255,255,.6);
}
.bbi-mobile-nav__accordion[open] .bbi-mobile-nav__summary-chevron{transform:rotate(180deg);}

.bbi-mobile-nav__panel{
  list-style:none;margin:0;padding:0 0 8px;
}
.bbi-mobile-nav__panel a{
  display:block;padding:11px 24px 11px 36px;
  color:rgba(255,255,255,.75);font-size:15px;text-decoration:none;
}
.bbi-mobile-nav__panel a:hover,.bbi-mobile-nav__panel a:focus-visible{
  color:#ffffff;outline:none;
}
.bbi-mobile-nav__panel-trust{
  padding:8px 24px 14px 36px;
  font-size:12px;color:rgba(255,255,255,.4);font-style:italic;
}

/* Mobile footer (phone + CTA) */
.bbi-mobile-nav__footer{
  flex-shrink:0;padding:20px 24px 28px;
  border-top:1px solid rgba(255,255,255,.12);
  display:flex;flex-direction:column;gap:12px;
}
.bbi-mobile-nav__footer-phone{
  color:rgba(255,255,255,.8);text-decoration:none;
  font-size:16px;font-weight:500;text-align:center;display:block;
}
.bbi-mobile-nav__quote{
  display:flex;align-items:center;justify-content:center;
  padding:14px 24px;background:#D4252A;color:#ffffff;
  border-radius:4px;text-decoration:none;
  font-size:15px;font-weight:600;
}
.bbi-mobile-nav__quote:hover{background:#A81E22;}

/* ---- Responsive breakpoints ---- */
@media(max-width:1023px){
  .bbi-header__nav,.bbi-header__phone{display:none;}
  .bbi-header .bbi-btn--primary{display:none;}
  .bbi-hamburger{display:flex;}
}
@media(min-width:1024px){
  .bbi-hamburger{display:none;}
}
</style>

