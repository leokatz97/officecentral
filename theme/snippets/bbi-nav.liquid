<script>
/* ============================================================
   BBI Nav — desktop aria-expanded sync + mobile Web Component
   Scoped IIFE; guards against double-registration.
   ============================================================ */
(function () {
  'use strict';

  /* Desktop: keep aria-expanded in sync with hover / focus state */
  document.querySelectorAll('[data-nav-group]').forEach(function (group) {
    var btn = group.querySelector('.bbi-nav__item');
    if (!btn) return;
    function setExpanded(val) { btn.setAttribute('aria-expanded', val ? 'true' : 'false'); }
    group.addEventListener('mouseenter', function () { setExpanded(true); });
    group.addEventListener('mouseleave', function () { setExpanded(false); });
    group.addEventListener('focusin',    function () { setExpanded(true); });
    group.addEventListener('focusout',   function (e) {
      if (!group.contains(e.relatedTarget)) setExpanded(false);
    });
  });

  /* Mobile: Web Component with WCAG focus trap + Escape close */
  if (customElements.get('bbi-nav-mobile')) return;

  customElements.define('bbi-nav-mobile', class extends HTMLElement {
    connectedCallback() {
      this._overlay   = this.querySelector('.bbi-mobile-nav');
      this._closeBtn  = this.querySelector('.bbi-mobile-nav__close');
      this._hamburger = document.querySelector('.bbi-hamburger');

      if (this._closeBtn) {
        this._closeBtn.addEventListener('click', this.close.bind(this));
      }
      if (this._hamburger) {
        this._hamburger.addEventListener('click', function () {
          this.isOpen ? this.close() : this.open();
        }.bind(this));
      }

      /* Keyboard handler: Escape closes; Tab cycles within overlay */
      document.addEventListener('keydown', function (e) {
        if (!this.isOpen) return;

        if (e.key === 'Escape') {
          e.preventDefault();
          this.close();
          return;
        }

        if (e.key === 'Tab') {
          var focusable = this._getFocusable();
          if (!focusable.length) return;
          var idx = focusable.indexOf(document.activeElement);
          e.preventDefault();
          if (e.shiftKey) {
            idx = idx <= 0 ? focusable.length - 1 : idx - 1;
          } else {
            idx = idx >= focusable.length - 1 ? 0 : idx + 1;
          }
          focusable[idx].focus();
        }
      }.bind(this));
    }

    get isOpen() {
      return !!(this._overlay && !this._overlay.hidden);
    }

    open() {
      if (!this._overlay) return;
      this._overlay.hidden = false;
      document.body.style.overflow = 'hidden';
      if (this._hamburger) this._hamburger.setAttribute('aria-expanded', 'true');
      /* Move focus to first focusable element in overlay */
      var focusable = this._getFocusable();
      if (focusable.length) focusable[0].focus();
    }

    close() {
      if (!this._overlay) return;
      this._overlay.hidden = true;
      document.body.style.overflow = '';
      if (this._hamburger) {
        this._hamburger.setAttribute('aria-expanded', 'false');
        this._hamburger.focus();
      }
    }

    /* Return all focusable, visible elements inside the overlay.
       Excludes content inside a closed <details> (offsetParent === null). */
    _getFocusable() {
      if (!this._overlay) return [];
      return Array.from(
        this._overlay.querySelectorAll(
          'a[href], button:not([disabled]), input:not([disabled]), [tabindex]:not([tabindex="-1"])'
        )
      ).filter(function (el) {
        /* Closed <details> content has offsetParent null; filter it out */
        if (el.offsetParent === null) return false;
        /* Double-check nothing hidden in the tree */
        if (el.closest('[hidden]')) return false;
        return true;
      });
    }
  });
}());
</script>
