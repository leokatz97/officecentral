{%- comment -%}
  Snippet: bbi-product-jsonld  (PDP-2 — absorbs Wave E AI-3)
  Purpose: Product JSON-LD for every BBI PDP. Also renders BreadcrumbList via
           bbi-breadcrumb-jsonld.liquid.
  Called from: theme/sections/ds-pdp-base.liquid
  Parameters:
    product    — the Shopify product object (required)
    cat_handle — collection handle string derived from product type:* tag (optional)
    cat_label  — human-readable category label (optional)
  Schema.org fields:
    @type: Product
    name, description, image (array), brand (Organization), sku, mpn (if present),
    additionalProperty (array) — one PropertyValue per filled specs.* metafield
    offers: { @type: Offer, price, priceCurrency: CAD, availability, url, seller }
{%- endcomment -%}

{%- liquid
  assign variant = product.selected_or_first_available_variant
  assign product_url = shop.url | append: product.url

  assign offer_availability = 'https://schema.org/InStock'
  if product.available == false
    assign offer_availability = 'https://schema.org/OutOfStock'
  elsif product.price == 0
    assign offer_availability = 'https://schema.org/InStock'
  endif

  assign offer_price = variant.price | divided_by: 100.0
  assign mpn_val = variant.sku | default: ''

  assign _ap_manufacturer  = product.metafields.specs.manufacturer.value
  assign _ap_product_line  = product.metafields.specs.product_line.value
  assign _ap_model_codes   = product.metafields.specs.model_codes.value
  assign _ap_dimensions    = product.metafields.specs.dimensions.value
  assign _ap_weight        = product.metafields.specs.weight.value
  assign _ap_weight_cap    = product.metafields.specs.weight_capacity.value
  assign _ap_materials     = product.metafields.specs.materials.value
  assign _ap_finishes      = product.metafields.specs.finishes_available.value
  assign _ap_certifications = product.metafields.specs.certifications.value
  assign _ap_warranty      = product.metafields.specs.warranty.value
  assign _ap_country       = product.metafields.specs.country_of_manufacture.value

  assign _has_ap = false
  if _ap_manufacturer or _ap_product_line or _ap_model_codes or _ap_dimensions or _ap_weight or _ap_weight_cap or _ap_materials or _ap_finishes or _ap_certifications or _ap_warranty or _ap_country
    assign _has_ap = true
  endif
-%}

<script type="application/ld+json">
{
  "@context": "https://schema.org/",
  "@type": "Product",
  "name": {{ product.title | json }},
  "description": {{ product.description | strip_html | truncate: 500 | json }},
  "image": [
    {%- for image in product.images limit: 5 -%}
      {{ image | image_url: width: 1200 | prepend: 'https:' | json }}{% unless forloop.last %},{% endunless %}
    {%- endfor -%}
  ],
  {%- if product.vendor != blank -%}
  "brand": {
    "@type": "Brand",
    "name": {{ product.vendor | json }}
  },
  {%- endif -%}
  {%- if variant.sku != blank -%}
  "sku": {{ variant.sku | json }},
  {%- endif -%}
  {%- if mpn_val != blank -%}
  "mpn": {{ mpn_val | json }},
  {%- endif -%}
  {%- if _has_ap -%}
  "additionalProperty": [
    {%- assign _ap_first = true -%}
    {%- if _ap_manufacturer != blank -%}
      {%- unless _ap_first -%},{%- endunless -%}
      {"@type":"PropertyValue","name":"Manufacturer","value":{{ _ap_manufacturer | json }}}
      {%- assign _ap_first = false -%}
    {%- endif -%}
    {%- if _ap_product_line != blank -%}
      {%- unless _ap_first -%},{%- endunless -%}
      {"@type":"PropertyValue","name":"Product Line","value":{{ _ap_product_line | json }}}
      {%- assign _ap_first = false -%}
    {%- endif -%}
    {%- if _ap_model_codes != blank and _ap_model_codes.size > 0 -%}
      {%- unless _ap_first -%},{%- endunless -%}
      {"@type":"PropertyValue","name":"Model","value":{{ _ap_model_codes | join: ', ' | json }}}
      {%- assign _ap_first = false -%}
    {%- endif -%}
    {%- if _ap_dimensions != blank -%}
      {%- unless _ap_first -%},{%- endunless -%}
      {"@type":"PropertyValue","name":"Dimensions","value":{{ _ap_dimensions | json }}}
      {%- assign _ap_first = false -%}
    {%- endif -%}
    {%- if _ap_weight != blank -%}
      {%- unless _ap_first -%},{%- endunless -%}
      {"@type":"PropertyValue","name":"Weight","value":{{ _ap_weight | json }}}
      {%- assign _ap_first = false -%}
    {%- endif -%}
    {%- if _ap_weight_cap != blank -%}
      {%- unless _ap_first -%},{%- endunless -%}
      {"@type":"PropertyValue","name":"Weight Capacity","value":{{ _ap_weight_cap | json }}}
      {%- assign _ap_first = false -%}
    {%- endif -%}
    {%- if _ap_materials != blank -%}
      {%- unless _ap_first -%},{%- endunless -%}
      {"@type":"PropertyValue","name":"Materials","value":{{ _ap_materials | json }}}
      {%- assign _ap_first = false -%}
    {%- endif -%}
    {%- if _ap_finishes != blank and _ap_finishes.size > 0 -%}
      {%- unless _ap_first -%},{%- endunless -%}
      {"@type":"PropertyValue","name":"Finishes Available","value":{{ _ap_finishes | join: ', ' | json }}}
      {%- assign _ap_first = false -%}
    {%- endif -%}
    {%- if _ap_certifications != blank and _ap_certifications.size > 0 -%}
      {%- unless _ap_first -%},{%- endunless -%}
      {"@type":"PropertyValue","name":"Certifications","value":{{ _ap_certifications | join: ', ' | json }}}
      {%- assign _ap_first = false -%}
    {%- endif -%}
    {%- if _ap_warranty != blank -%}
      {%- unless _ap_first -%},{%- endunless -%}
      {"@type":"PropertyValue","name":"Warranty","value":{{ _ap_warranty | json }}}
      {%- assign _ap_first = false -%}
    {%- endif -%}
    {%- if _ap_country != blank -%}
      {%- unless _ap_first -%},{%- endunless -%}
      {"@type":"PropertyValue","name":"Country of Manufacture","value":{{ _ap_country | json }}}
    {%- endif -%}
  ],
  {%- endif -%}
  "offers": {
    "@type": "Offer",
    "url": {{ product_url | json }},
    "priceCurrency": "CAD",
    {%- if product.price == 0 -%}
    "price": "0",
    "priceSpecification": {
      "@type": "PriceSpecification",
      "description": "Price available on request"
    },
    {%- else -%}
    "price": {{ offer_price | round: 2 | json }},
    {%- endif -%}
    "availability": {{ offer_availability | json }},
    "seller": {
      "@type": "Organization",
      "name": "Brant Business Interiors"
    }
  }
}
</script>

{%- comment -%} BreadcrumbList — 4 levels: Home > Shop Furniture > Category > Product {%- endcomment -%}
{%- assign bc_base = shop.url -%}
{%- assign bc3_n = cat_label | default: 'Other' -%}
{%- if cat_handle != blank -%}
  {%- assign bc3_u = bc_base | append: '/collections/' | append: cat_handle -%}
{%- else -%}
  {%- assign bc3_u = bc_base | append: '/collections/other' -%}
{%- endif -%}
{%- render 'bbi-breadcrumb-jsonld',
    bc1_name: 'Home',
    bc1_url: bc_base,
    bc2_name: 'Shop Furniture',
    bc2_url: bc_base | append: '/collections/business-furniture',
    bc3_name: bc3_n,
    bc3_url: bc3_u,
    bc4_name: product.title,
    bc4_url: product_url
-%}
