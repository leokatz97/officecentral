<!doctype html>
<html class="no-js" lang="{{ request.locale.iso_code }}" color-mode="light">
  <head>
    <meta charset="utf-8">
    <meta name="color-scheme" content="dark light">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="theme-color" content="">
    <meta name="robots" content="index,follow">
    {% render 'meta-tags' %}
    <link rel="canonical" href="{{ canonical_url }}">
    <link rel="preconnect" href="https://cdn.shopify.com" crossorigin>
    {%- if settings.favicon != blank -%}
      <link
        rel="icon"
        type="image/png"
        href="{{ settings.favicon | image_url: width: 32, height: 32 }}"
      >
    {%- endif -%}
    
    {%- unless settings.header_font.system? and settings.body_font.system? -%}
      <link rel="preconnect" href="https://fonts.shopifycdn.com" crossorigin>
    {%- endunless -%}
    <title>{%- if template == 'index' -%}Office Furniture for Canadian Businesses | Brant Business Interiors{%- else -%}
      {{ page_title }}
      {%- if current_tags %}
        &ndash; tagged "{{ current_tags | join: ', ' }}"
      {%- endif -%}
      {%- if current_page != 1 %}
        &ndash; Page {{ current_page -}}
      {%- endif -%}
      {%- unless page_title contains shop.name %}
        &ndash; {{ shop.name -}}
      {%- endunless -%}
    {%- endif -%}</title>

    {% if template == 'index' %}
      <meta name="description" content="Commercial office furniture for Ontario businesses, schools, hospitals, and government. ergoCentric, Keilhauer, Global Furniture Group. OECM-eligible supplier. Quote in 1 business day.">
    {% elsif page_description %}
      <meta name="description" content="{{ page_description | escape }}">
    {% endif %}

    {{ content_for_header }}

    {% render 'style-variables' %}
    {% render 'theme-variables' %}
    {%- unless settings.type_body_font.system? -%}
      <link
        rel="preload"
        as="font"
        href="{{ settings.type_body_font | font_url }}"
        type="font/woff2"
        crossorigin
      >
    {%- endunless -%}
    {%- unless settings.type_header_font.system? -%}
      <link
        rel="preload"
        as="font"
        href="{{ settings.type_header_font | font_url }}"
        type="font/woff2"
        crossorigin
      >
    {%- endunless -%}

    <script>
      document.documentElement.className = document.documentElement.className.replace('no-js', 'js');
      if (Shopify.designMode) {
        document.documentElement.classList.add('shopify-design-mode');
      }
    </script>
    {{ 'bbi-homepage.css' | asset_url | stylesheet_tag }}
</head>
  <body class="btn-hover-effect-{{ settings.button_hover_effect }}">
    <a class="unstyled-link skip-to-content-link button focus-inside{% if settings.enable_button_shadow %} button-shadow{% endif %}" href="#MainContent">
      {{ 'accessibility.skip_to_text' | t }}
    </a>
    <div class="body-wrapper">
          {%- liquid
        assign bbi_landing = false
        if template.suffix == 'oecm' or template.suffix == 'faq' or template.suffix == 'design-services' or template.suffix == 'industries' or template.suffix == 'healthcare' or template.suffix == 'education' or template.suffix == 'government' or template.suffix == 'non-profit' or template.suffix == 'professional-services' or template.suffix == 'quote'
          assign bbi_landing = true
        endif
      -%}
      {%- unless bbi_landing -%}
        {% sections 'header-group' %}
      {%- endunless -%}
      
      {% if settings.enable_dl_mode_toggle %}
        <script>
          if (localStorage.darkMode == 'true') {
            document.querySelector('html').setAttribute('color-mode', 'dark');
            const dlTogglecheckboxes = document.querySelectorAll('[data-dark-toggle]');
            Array.from(dlTogglecheckboxes).forEach(function(checkbox){
              checkbox.checked = true;
            })
          }
        </script>
      {% endif %}

      <main id="MainContent" class="content-for-layout focus-none" role="main" tabindex="-1">
        {{ content_for_layout }}
      </main>
      {% liquid
          unless bbi_landing
    sections 'footer-group'
  endunless
        section 'age-verification'
        section 'newsletter-offer-popup'
        if settings.quickview
          section 'product-quick-view'
        endif
        section 'compare-products-content'
        section 'information-drawer'
                if template != 'cart' and bbi_landing == false
          render 'cart-drawer'
        endif
        render 'scroll-top'
      %}
    {% unless settings.atc_alert == 'none' %}
      <audio id="cartAlert">
        {% assign tuneURL = settings.atc_alert | append: '.mp3' | asset_url %}
        <source src="{{ tuneURL }}" type="audio/mpeg">
      </audio>
    {% endunless %}
    </div>
    {% if template == 'cart' and settings.enable_confetti_effect %}    
      <div class="confetti-container-wrapper">
          <div class="confetti-container"></div>
      </div>
    {% endif %}
    <script>
      document.addEventListener("DOMContentLoaded", function () {
        AOS.init({
          easing: 'ease',
          once: true,
          duration: 1000,
          offset: 60
        });  
        setTimeout(function () {
          if (AOS) {
            AOS.refresh();
          }
        }, 1000);
        new universalParallax().init({
          speed:10
        });
      })
    </script>
  </body>
</html>
