    "bbi-industries": {
      "type": "custom-liquid",
      "settings": {
        "custom_liquid": "<section class=\"bbi-section bbi-section--alt hp-industries\">\n  <div class=\"bbi-container\">\n    <div class=\"bbi-section-head\">\n      <div>\n        <p class=\"bbi-section-head__eyebrow\">Who we serve</p>\n        <h2 class=\"bbi-section-head__title\">Five sectors. One Ontario partner.</h2>\n      </div>\n      <p class=\"bbi-section-head__sub\">From private offices to school boards to hospitals — commercial-grade furniture quoted, delivered, and installed by the same Ontario team.</p>\n    </div>\n    <div class=\"hp-industries__grid\">\n      <a class=\"hp-industry\" href=\"/pages/healthcare\">\n        <div class=\"hp-industry__media\">\n          <img src=\"https://cdn.shopify.com/s/files/1/0859/0413/0361/t/24/assets/bbi-hp-healthcare.jpg\" alt=\"Healthcare furniture\" loading=\"lazy\">\n        </div>\n        <div class=\"hp-industry__body\">\n          <span class=\"bbi-mono hp-industry__num\">01</span>\n          <h3 class=\"hp-industry__title\">Healthcare</h3>\n          <p class=\"hp-industry__note\">Exam · waiting · acute care · OECM</p>\n        </div>\n      </a>\n      <a class=\"hp-industry\" href=\"/pages/education\">\n        <div class=\"hp-industry__media\">\n          <img src=\"https://cdn.shopify.com/s/files/1/0859/0413/0361/t/24/assets/bbi-hp-education.jpg\" alt=\"Education furniture\" loading=\"lazy\">\n        </div>\n        <div class=\"hp-industry__body\">\n          <span class=\"bbi-mono hp-industry__num\">02</span>\n          <h3 class=\"hp-industry__title\">Education</h3>\n          <p class=\"hp-industry__note\">K-12 · post-secondary · libraries</p>\n        </div>\n      </a>\n      <a class=\"hp-industry\" href=\"/pages/government\">\n        <div class=\"hp-industry__media\">\n          <img src=\"https://cdn.shopify.com/s/files/1/0859/0413/0361/t/24/assets/bbi-hp-government.jpg\" alt=\"Government office furniture\" loading=\"lazy\">\n        </div>\n        <div class=\"hp-industry__body\">\n          <span class=\"bbi-mono hp-industry__num\">03</span>\n          <h3 class=\"hp-industry__title\">Government</h3>\n          <p class=\"hp-industry__note\">Municipal · provincial · OECM</p>\n        </div>\n      </a>\n      <a class=\"hp-industry\" href=\"/pages/non-profit\">\n        <div class=\"hp-industry__media\">\n          <img src=\"https://cdn.shopify.com/s/files/1/0859/0413/0361/t/24/assets/bbi-hp-non-profit.jpg\" alt=\"Non-profit organization furniture\" loading=\"lazy\">\n        </div>\n        <div class=\"hp-industry__body\">\n          <span class=\"bbi-mono hp-industry__num\">04</span>\n          <h3 class=\"hp-industry__title\">Non-Profit</h3>\n          <p class=\"hp-industry__note\">Community services · housing · social</p>\n        </div>\n      </a>\n      <a class=\"hp-industry\" href=\"/pages/professional-services\">\n        <div class=\"hp-industry__media\">\n          <img src=\"https://cdn.shopify.com/s/files/1/0859/0413/0361/t/24/assets/bbi-hp-pro-services.jpg\" alt=\"Professional services office furniture\" loading=\"lazy\">\n        </div>\n        <div class=\"hp-industry__body\">\n          <span class=\"bbi-mono hp-industry__num\">05</span>\n          <h3 class=\"hp-industry__title\">Professional Services</h3>\n          <p class=\"hp-industry__note\">Law · accounting · medical · dental</p>\n        </div>\n      </a>\n    </div>\n  </div>\n</section>",
