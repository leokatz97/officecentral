    "bbi-services": {
      "type": "custom-liquid",
      "settings": {
        "custom_liquid": "<section class=\"bbi-section hp-services\">\n  <div class=\"bbi-container\">\n    <div class=\"bbi-section-head\">\n      <div>\n        <p class=\"bbi-section-head__eyebrow\">More than a catalog</p>\n        <h2 class=\"bbi-section-head__title\">Three services that come with every quote.</h2>\n      </div>\n      <p class=\"bbi-section-head__sub\">Every order — single chair or full fit-out — ships with planning, installation, and warranty handled by the same Ontario team that quoted it.</p>\n    </div>\n    <div class=\"hp-services__grid\">\n      <article class=\"hp-service\">\n        <span class=\"bbi-mono hp-service__num\">01</span>\n        <h3 class=\"hp-service__title\">Space planning</h3>\n        <p class=\"hp-service__body\">We take your floor plan or square footage and return a fully-specced layout — with seat counts, sightlines, and freight logistics accounted for.</p>\n        <ul class=\"hp-service__list\">\n          <li>AutoCAD or PDF accepted</li>\n          <li>On-site measure available</li>\n          <li>Turn-around: 5 business days</li>\n        </ul>\n        <a class=\"bbi-btn bbi-btn--tertiary hp-service__cta\" href=\"/pages/design-services\">\n          <span class=\"label\">Book a planning call</span><span class=\"arrow\">→</span>\n        </a>\n      </article>\n      <article class=\"hp-service\">\n        <span class=\"bbi-mono hp-service__num\">02</span>\n        <h3 class=\"hp-service__title\">Installation</h3>\n        <p class=\"hp-service__body\">Brant Business Interiors' own install crew handles delivery, assembly, levelling, and removal of old furniture. No third-party logistics, no surprises on dock day.</p>\n        <ul class=\"hp-service__list\">\n          <li>W5-cleared installers</li>\n          <li>After-hours &amp; weekend available</li>\n          <li>Old-furniture removal included</li>\n        </ul>\n        <a class=\"bbi-btn bbi-btn--tertiary hp-service__cta\" href=\"/pages/delivery\">\n          <span class=\"label\">Read the install spec</span><span class=\"arrow\">→</span>\n        </a>\n      </article>\n      <article class=\"hp-service\">\n        <span class=\"bbi-mono hp-service__num\">03</span>\n        <h3 class=\"hp-service__title\">Warranty &amp; service</h3>\n        <p class=\"hp-service__body\">We file the manufacturer claim on your behalf and keep the piece in service. ergoCentric chairs carry a 12-year mechanism warranty — managed end-to-end by our Ontario team.</p>\n        <ul class=\"hp-service__list\">\n          <li>12-year mechanism on ergoCentric</li>\n          <li>Loaner chairs during repair</li>\n          <li>One service contact, ON-based</li>\n        </ul>\n        <a class=\"bbi-btn bbi-btn--tertiary hp-service__cta\" href=\"/pages/quote\">\n          <span class=\"label\">View warranty terms</span><span class=\"arrow\">→</span>\n        </a>\n      </article>\n    </div>\n  </div>\n</section>",
