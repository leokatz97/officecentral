{%- comment -%}
  Section: ds-lp-brands-obusforme
  Purpose: ObusForme brand landing page — ergonomic back-support seating specialist, GFG-family distribution, OECM eligible. Thin catalog (6 active products, all seating) — positioned as ergonomic specialty paired with BBI's broader institutional catalog.
  Used by: page.brands-obusforme.json (template suffix: brands-obusforme)
  Gate: theme.liquid bbi_landing gate — suppresses Starlite header/footer/cart
  Notes: NO Made-in-Canada framing (country-of-manufacture not blanket-verifiable); no maple-leaf accents. Do NOT invent warranty specifics.
{%- endcomment -%}

{% # theme-check-disable RemoteAsset %}
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Inter+Tight:wght@600&family=Inter:wght@400;500;600&family=JetBrains+Mono:wght@400&display=swap" rel="stylesheet">
{% # theme-check-enable RemoteAsset %}

<style>
:root{--bodyFont:"Inter",system-ui,-apple-system,"Segoe UI",Roboto,sans-serif;--headingFont:"Inter Tight","Inter",system-ui,sans-serif;--headingFontWeight:600;--space-1:4px;--space-2:8px;--space-3:12px;--space-4:16px;--space-6:24px;--space-8:32px;--space-12:48px;--inputRadius:4px;--buttonRadius:4px;--cardRadius:8px;--shadow-sm:0 1px 2px rgba(11,11,12,.04),0 2px 8px rgba(11,11,12,.05);--shadow-md:0 2px 4px rgba(11,11,12,.05),0 12px 32px rgba(11,11,12,.08);--saleBadgeBackground:#D4252A;--saleBadgeBackground-rgb:212,37,42;--fs-h0:44px;--lh-h0:1.05;--fs-h1:32px;--lh-h1:1.1;--ls-h1:-0.015em;--fs-h2:24px;--lh-h2:1.15;--ls-h2:-0.01em;--fs-h3:18px;--lh-h3:1.25;--ls-h3:-0.005em;--fs-body:16px;--lh-body:1.55;--fs-button:15px;--lh-button:1;--ls-button:0.01em;}
@media(min-width:768px){:root{--fs-h0:72px;--fs-h1:48px;--lh-h1:1.05;--fs-h2:32px;--lh-h2:1.1;--fs-h3:22px;--lh-h3:1.2;}}
.lp-obusforme.scheme-default{--background:#FFFFFF;--background-rgb:255,255,255;--alternateBackground:#FAFAFA;--alternateBackground-rgb:250,250,250;--cardBackground:#FFFFFF;--cardBackground-rgb:255,255,255;--textColor:#0B0B0C;--textColor-rgb:11,11,12;--linkColor:#0B0B0C;--headingColor:#0B0B0C;--headingColor-rgb:11,11,12;--buttonBackground:#0B0B0C;--buttonColor:#FFFFFF;--buttonBorder:#0B0B0C;--buttonBackgroundHover:#D4252A;--buttonColorHover:#FFFFFF;--buttonBorderHover:#D4252A;--alternateButtonBackground:#FFFFFF;--alternateButtonColor:#0B0B0C;--alternateButtonBorder:#0B0B0C;--alternateButtonBackgroundHover:#0B0B0C;--alternateButtonColorHover:#FFFFFF;--borderColor:#E5E5E7;--borderColor-rgb:229,229,231;--shadowColor:#0B0B0C;--shadowColor-rgb:11,11,12;--headerBg:#FFFFFF;--headerColor:#0B0B0C;--headerHoverColor:#D4252A;}
.lp-obusforme .scheme-inverse{--background:#0B0B0C;--background-rgb:11,11,12;--alternateBackground:#161618;--textColor:#FFFFFF;--textColor-rgb:255,255,255;--linkColor:#FFFFFF;--headingColor:#FFFFFF;--headingColor-rgb:255,255,255;--buttonBackground:#FFFFFF;--buttonColor:#0B0B0C;--buttonBorder:#FFFFFF;--buttonBackgroundHover:#D4252A;--buttonColorHover:#FFFFFF;--buttonBorderHover:#D4252A;--alternateButtonBackground:transparent;--alternateButtonColor:#FFFFFF;--alternateButtonBorder:#FFFFFF;--borderColor:#1F1F21;--borderColor-rgb:31,31,33;--shadowColor:#000000;--shadowColor-rgb:0,0,0;}
.lp-obusforme *,.lp-obusforme *::before,.lp-obusforme *::after{box-sizing:border-box;}
.lp-obusforme{font-family:var(--bodyFont);font-size:var(--fs-body);line-height:var(--lh-body);color:var(--textColor);background:var(--background);-webkit-font-smoothing:antialiased;}
.lp-obusforme img{display:block;max-width:100%;height:auto;}
.lp-obusforme a{color:var(--linkColor);text-decoration:none;}
.lp-obusforme .bbi-mono{font-family:"JetBrains Mono",ui-monospace,monospace;font-size:11px;letter-spacing:0.08em;text-transform:uppercase;}
.lp-obusforme .bbi-btn{display:inline-flex;align-items:center;justify-content:center;gap:var(--space-2);padding:12px 20px;min-height:44px;font-family:var(--bodyFont);font-size:var(--fs-button);line-height:var(--lh-button);letter-spacing:var(--ls-button);font-weight:600;border-radius:var(--buttonRadius);border:1px solid transparent;cursor:pointer;text-decoration:none;transition:background-color 120ms ease,color 120ms ease,border-color 120ms ease;white-space:nowrap;}
.lp-obusforme .bbi-btn:focus{outline:none;}.lp-obusforme .bbi-btn:focus-visible{outline:2px solid var(--textColor);outline-offset:2px;}
.lp-obusforme .bbi-btn--lg{min-height:52px;padding:16px 24px;font-size:16px;}
.lp-obusforme .bbi-btn--primary{background:var(--buttonBackground);color:var(--buttonColor);border-color:var(--buttonBorder);}
.lp-obusforme .bbi-btn--primary:hover{background:var(--buttonBackgroundHover);color:var(--buttonColorHover);border-color:var(--buttonBorderHover);}
.lp-obusforme .bbi-btn--secondary{background:var(--alternateButtonBackground);color:var(--alternateButtonColor);border-color:var(--alternateButtonBorder);}
.lp-obusforme .bbi-btn--secondary:hover{background:var(--alternateButtonBackgroundHover);color:var(--alternateButtonColorHover);}
.lp-obusforme .bbi-btn--tertiary{background:transparent;color:var(--textColor);border-color:transparent;padding-left:4px;padding-right:4px;}
.lp-obusforme .bbi-btn--tertiary .label{position:relative;}
.lp-obusforme .bbi-btn--tertiary .label::after{content:"";position:absolute;left:0;right:0;bottom:-2px;height:1px;background:currentColor;}
.lp-obusforme .bbi-btn .arrow{display:inline-block;transform:translateY(-0.5px);}
.lp-obusforme .bbi-header{background:var(--headerBg);border-bottom:1px solid var(--borderColor);position:relative;z-index:10;}
.lp-obusforme .bbi-header__inner{max-width:1320px;margin:0 auto;padding:0 32px;height:72px;display:flex;align-items:center;gap:32px;}
.lp-obusforme .bbi-header__logo{display:inline-flex;align-items:center;height:40px;text-decoration:none;}
.lp-obusforme .bbi-header__logo img{height:36px;width:auto;}
.lp-obusforme .bbi-header__nav{display:flex;align-items:center;gap:4px;margin-left:16px;}
.lp-obusforme .bbi-nav-item{display:inline-flex;align-items:center;height:72px;padding:0 14px;color:var(--headerColor);font-size:14px;font-weight:500;text-decoration:none;position:relative;}
.lp-obusforme .bbi-nav-item:hover{color:var(--headerHoverColor);}
.lp-obusforme .bbi-nav-item.is-current::after{content:"";position:absolute;left:14px;right:14px;bottom:18px;height:1px;background:var(--textColor);}
.lp-obusforme .bbi-header__utility{margin-left:auto;display:flex;align-items:center;gap:16px;font-size:14px;}
.lp-obusforme .bbi-header__utility a:not(.bbi-btn){color:var(--headerColor);text-decoration:none;}
.lp-obusforme .lp-hero{padding:var(--space-12) 0;border-bottom:1px solid rgba(var(--borderColor-rgb),0.6);}
.lp-obusforme .lp-hero__inner{max-width:1280px;margin:0 auto;padding:0 var(--space-6);display:grid;grid-template-columns:minmax(0,1.05fr) minmax(0,1fr);gap:var(--space-12);align-items:center;}
.lp-obusforme .lp-hero__text{max-width:560px;}
.lp-obusforme .lp-hero__eyebrow{display:inline-flex;align-items:center;gap:var(--space-2);margin-bottom:var(--space-4);}
.lp-obusforme .lp-hero__eyebrow::before{content:"";display:inline-block;width:18px;height:1px;background:var(--saleBadgeBackground);}
.lp-obusforme .lp-hero__eyebrow-label{color:rgba(var(--textColor-rgb),0.6);}
.lp-obusforme .lp-hero__badge{display:inline-flex;align-items:center;gap:var(--space-2);padding:6px 12px;border:1px solid rgba(var(--borderColor-rgb),0.8);border-radius:999px;margin-bottom:var(--space-6);font-size:12px;color:rgba(var(--textColor-rgb),0.78);}
.lp-obusforme .lp-hero__badge-dot{width:6px;height:6px;border-radius:50%;background:var(--saleBadgeBackground);}
.lp-obusforme .lp-hero h1{font-family:var(--headingFont);font-size:var(--fs-h1);line-height:var(--lh-h1);letter-spacing:var(--ls-h1);font-weight:600;color:var(--headingColor);margin:0 0 var(--space-4);text-wrap:balance;}
.lp-obusforme .lp-hero__standfirst{font-size:18px;line-height:1.55;color:rgba(var(--textColor-rgb),0.78);margin:0 0 var(--space-6);}
.lp-obusforme .lp-hero__cta-row{display:flex;gap:var(--space-3);flex-wrap:wrap;}
.lp-obusforme .lp-hero__media{position:relative;aspect-ratio:5/4;background:var(--alternateBackground);border-radius:var(--cardRadius);overflow:hidden;}
.lp-obusforme .lp-hero__media img{width:100%;height:100%;object-fit:cover;}
.lp-obusforme .lp-hero__ph{position:absolute;inset:0;display:flex;align-items:center;justify-content:center;background:repeating-linear-gradient(135deg,rgba(var(--shadowColor-rgb),.03) 0 8px,rgba(var(--shadowColor-rgb),.07) 8px 16px),var(--alternateBackground);color:rgba(var(--textColor-rgb),.5);font-family:"JetBrains Mono",ui-monospace,monospace;font-size:11px;letter-spacing:0.08em;text-transform:uppercase;}
.lp-obusforme .lp-hero__caption{position:absolute;left:var(--space-4);bottom:var(--space-4);background:rgba(var(--shadowColor-rgb),.7);color:#fff;padding:6px 10px;border-radius:4px;font-size:12px;display:inline-flex;align-items:center;gap:var(--space-2);}
.lp-obusforme .lp-hero__caption-dot{width:4px;height:4px;border-radius:50%;background:var(--saleBadgeBackground);}
.lp-obusforme .lp-intro{padding:var(--space-12) 0;}
.lp-obusforme .lp-intro__inner{max-width:880px;margin:0 auto;padding:0 var(--space-6);}
.lp-obusforme .lp-intro__eyebrow{display:inline-flex;align-items:center;gap:var(--space-2);color:rgba(var(--textColor-rgb),0.6);margin-bottom:var(--space-4);}
.lp-obusforme .lp-intro__eyebrow::before{content:"";display:inline-block;width:18px;height:1px;background:var(--saleBadgeBackground);}
.lp-obusforme .lp-intro h2{font-family:var(--headingFont);font-size:var(--fs-h2);line-height:var(--lh-h2);letter-spacing:var(--ls-h2);font-weight:600;color:var(--headingColor);margin:0 0 var(--space-6);}
.lp-obusforme .lp-intro__body p{font-size:17px;line-height:1.65;color:rgba(var(--textColor-rgb),0.78);margin:0 0 var(--space-4);}
.lp-obusforme .lp-diff{padding:var(--space-12) 0;background:var(--alternateBackground);border-top:1px solid rgba(var(--borderColor-rgb),0.5);border-bottom:1px solid rgba(var(--borderColor-rgb),0.5);}
.lp-obusforme .lp-diff__inner{max-width:1280px;margin:0 auto;padding:0 var(--space-6);}
.lp-obusforme .lp-diff__head{margin-bottom:var(--space-8);}
.lp-obusforme .lp-diff__eyebrow{display:inline-flex;align-items:center;gap:var(--space-2);color:rgba(var(--textColor-rgb),0.6);margin-bottom:var(--space-4);}
.lp-obusforme .lp-diff__eyebrow::before{content:"";display:inline-block;width:18px;height:1px;background:var(--saleBadgeBackground);}
.lp-obusforme .lp-diff h2{font-family:var(--headingFont);font-size:var(--fs-h2);line-height:var(--lh-h2);font-weight:600;color:var(--headingColor);margin:0;max-width:44ch;}
.lp-obusforme .lp-diff__grid{display:grid;grid-template-columns:repeat(4,1fr);gap:var(--space-6);}
.lp-obusforme .lp-diff-card{background:var(--cardBackground);border:1px solid rgba(var(--borderColor-rgb),0.6);border-radius:var(--cardRadius);padding:var(--space-6);display:flex;flex-direction:column;gap:var(--space-3);}
.lp-obusforme .lp-diff-card__num{font-family:"JetBrains Mono",ui-monospace,monospace;font-size:13px;color:var(--saleBadgeBackground);font-weight:400;}
.lp-obusforme .lp-diff-card__label{font-family:var(--headingFont);font-size:var(--fs-h3);line-height:var(--lh-h3);font-weight:600;color:var(--headingColor);margin:0;}
.lp-obusforme .lp-diff-card__sentence{font-size:14px;line-height:1.6;color:rgba(var(--textColor-rgb),0.72);margin:0;}
.lp-obusforme .lp-crosslinks{padding:var(--space-12) 0;}
.lp-obusforme .lp-crosslinks__inner{max-width:1280px;margin:0 auto;padding:0 var(--space-6);}
.lp-obusforme .lp-crosslinks__head{margin-bottom:var(--space-8);}
.lp-obusforme .lp-crosslinks__eyebrow{display:inline-flex;align-items:center;gap:var(--space-2);color:rgba(var(--textColor-rgb),0.6);margin-bottom:var(--space-4);}
.lp-obusforme .lp-crosslinks__eyebrow::before{content:"";display:inline-block;width:18px;height:1px;background:var(--saleBadgeBackground);}
.lp-obusforme .lp-crosslinks h2{font-family:var(--headingFont);font-size:var(--fs-h2);line-height:var(--lh-h2);font-weight:600;color:var(--headingColor);margin:0;}
.lp-obusforme .lp-crosslinks__grid{display:grid;grid-template-columns:repeat(3,1fr);gap:var(--space-4);}
.lp-obusforme .lp-crosslinks__tile{display:flex;align-items:center;gap:var(--space-4);padding:20px var(--space-6);border:1px solid rgba(var(--borderColor-rgb),0.6);border-radius:var(--cardRadius);text-decoration:none;color:var(--textColor);transition:box-shadow 140ms ease;}
.lp-obusforme .lp-crosslinks__tile:hover{box-shadow:var(--shadow-sm);}
.lp-obusforme .lp-crosslinks__tile-icon{color:rgba(var(--textColor-rgb),0.5);flex-shrink:0;}
.lp-obusforme .lp-crosslinks__tile-label{flex:1;}
.lp-obusforme .lp-crosslinks__tile-name{display:block;font-size:15px;font-weight:600;color:var(--headingColor);}
.lp-obusforme .lp-crosslinks__tile-meta{display:block;font-size:12px;color:rgba(var(--textColor-rgb),0.55);margin-top:2px;}
.lp-obusforme .lp-crosslinks__tile-arrow{color:rgba(var(--textColor-rgb),0.4);transition:transform 120ms ease;}
.lp-obusforme .lp-crosslinks__tile:hover .lp-crosslinks__tile-arrow{transform:translateX(3px);}
.lp-obusforme .lp-oecm-bar{background:var(--alternateBackground);border-top:1px solid rgba(var(--borderColor-rgb),0.5);border-bottom:1px solid rgba(var(--borderColor-rgb),0.5);padding:var(--space-8) 0;}
.lp-obusforme .lp-oecm-bar__inner{max-width:1280px;margin:0 auto;padding:0 var(--space-6);display:flex;align-items:center;gap:var(--space-8);flex-wrap:wrap;}
.lp-obusforme .lp-oecm-badge{display:inline-flex;align-items:center;gap:var(--space-2);padding:6px 12px;border:1px solid rgba(var(--borderColor-rgb),0.8);border-radius:999px;font-size:12px;white-space:nowrap;color:rgba(var(--textColor-rgb),0.78);}
.lp-obusforme .lp-oecm-badge .dot{width:6px;height:6px;border-radius:50%;background:var(--saleBadgeBackground);flex-shrink:0;}
.lp-obusforme .lp-oecm-bar__lead{display:flex;align-items:flex-start;gap:var(--space-4);flex:1 1 400px;flex-wrap:wrap;}
.lp-obusforme .lp-oecm-bar__copy{font-size:15px;line-height:1.55;color:rgba(var(--textColor-rgb),0.78);margin:0;max-width:62ch;}
.lp-obusforme .lp-oecm-bar__meta{flex-shrink:0;}
.lp-obusforme .lp-faq{padding:var(--space-12) 0;border-top:1px solid rgba(var(--borderColor-rgb),0.5);}
.lp-obusforme .lp-faq__inner{max-width:860px;margin:0 auto;padding:0 var(--space-6);}
.lp-obusforme .lp-faq__head{margin-bottom:var(--space-8);}
.lp-obusforme .lp-faq__eyebrow{display:inline-flex;align-items:center;gap:var(--space-2);color:rgba(var(--textColor-rgb),0.6);margin-bottom:var(--space-4);}
.lp-obusforme .lp-faq__eyebrow::before{content:"";display:inline-block;width:18px;height:1px;background:var(--saleBadgeBackground);}
.lp-obusforme .lp-faq h2{font-family:var(--headingFont);font-size:var(--fs-h2);line-height:var(--lh-h2);font-weight:600;color:var(--headingColor);margin:0 0 var(--space-4);}
.lp-obusforme .lp-faq__cta{font-size:15px;color:rgba(var(--textColor-rgb),0.72);margin:0;}
.lp-obusforme .lp-faq__cta a{color:var(--textColor);text-decoration:underline;}
.lp-obusforme .lp-faq-item{border-bottom:1px solid rgba(var(--borderColor-rgb),0.6);}
.lp-obusforme .lp-faq-item summary{list-style:none;display:flex;align-items:baseline;gap:var(--space-4);padding:var(--space-6) 0;cursor:pointer;}
.lp-obusforme .lp-faq-item summary::-webkit-details-marker{display:none;}
.lp-obusforme .lp-faq-item__num{font-family:"JetBrains Mono",ui-monospace,monospace;font-size:11px;color:rgba(var(--textColor-rgb),0.4);flex-shrink:0;width:24px;}
.lp-obusforme .lp-faq-item__q{flex:1;font-size:16px;font-weight:500;color:var(--headingColor);line-height:1.4;}
.lp-obusforme .lp-faq-item__icon{flex-shrink:0;width:20px;height:20px;border-radius:50%;border:1px solid rgba(var(--borderColor-rgb),0.8);display:flex;align-items:center;justify-content:center;font-size:14px;color:rgba(var(--textColor-rgb),0.5);transition:transform 160ms ease;}
.lp-obusforme details[open] .lp-faq-item__icon{transform:rotate(45deg);}
.lp-obusforme .lp-faq-item__icon::after{content:"+";}
.lp-obusforme .lp-faq-item__body{padding:0 0 var(--space-6) calc(24px + var(--space-4));}
.lp-obusforme .lp-faq-item__body p{font-size:15px;line-height:1.65;color:rgba(var(--textColor-rgb),0.78);margin:0;}
.lp-obusforme .lp-closer{background:var(--background);color:var(--textColor);}
.lp-obusforme .lp-closer__inner{max-width:1320px;margin:0 auto;padding:96px 32px;display:grid;grid-template-columns:1.2fr 1fr;gap:64px;align-items:center;}
.lp-obusforme .lp-closer__eyebrow{font-family:"JetBrains Mono",ui-monospace,monospace;font-size:12px;letter-spacing:0.08em;text-transform:uppercase;color:rgba(var(--textColor-rgb),0.7);margin:0 0 16px;}
.lp-obusforme .lp-closer__heading{font-family:var(--headingFont);font-size:clamp(32px,4.2vw,56px);line-height:1.05;letter-spacing:-0.015em;font-weight:600;margin:0 0 20px;text-wrap:balance;}
.lp-obusforme .lp-closer__sub{font-size:17px;line-height:1.55;color:rgba(var(--textColor-rgb),0.78);max-width:52ch;margin:0;}
.lp-obusforme .lp-closer__actions{display:flex;flex-direction:column;gap:16px;align-items:flex-start;}
.lp-obusforme .lp-closer__trust{display:flex;align-items:flex-start;gap:10px;font-size:14px;color:rgba(var(--textColor-rgb),0.78);}
.lp-obusforme .lp-closer__trust .dot{flex:0 0 auto;margin-top:7px;width:6px;height:6px;border-radius:99px;background:var(--saleBadgeBackground);}
.lp-obusforme .lp-closer__trust b{color:var(--textColor);font-weight:600;}
.lp-obusforme .lp-closer__trust a{color:var(--textColor);text-decoration:underline;}
@media(max-width:1024px){.lp-obusforme .lp-diff__grid{grid-template-columns:repeat(2,1fr);}.lp-obusforme .lp-crosslinks__grid{grid-template-columns:repeat(2,1fr);}}
@media(max-width:768px){.lp-obusforme .lp-hero__inner{grid-template-columns:1fr;}.lp-obusforme .lp-hero__media{display:none;}.lp-obusforme .lp-diff__grid{grid-template-columns:1fr;}.lp-obusforme .lp-crosslinks__grid{grid-template-columns:1fr;}.lp-obusforme .lp-closer__inner{grid-template-columns:1fr;padding:64px 24px;}.lp-obusforme .bbi-header__nav{display:none;}}
</style>

<div class="lp-obusforme scheme-default">

  {%- render 'bbi-nav', logo: section.settings.logo, active: 'brands' -%}
  {%- render 'bbi-crumbs', c2_label: 'Brands', c2_href: '/pages/brands', c3_label: 'ObusForme' -%}


  <section class="lp-hero" aria-label="Hero">
    <div class="lp-hero__inner">
      <div class="lp-hero__text">
        <p class="lp-hero__eyebrow bbi-mono">
          <span class="lp-hero__eyebrow-label">Brand &middot; Authorized ObusForme Dealer</span>
        </p>
        <span class="lp-hero__badge">
          <span class="lp-hero__badge-dot"></span>
          Authorized ObusForme Dealer &middot; Ergonomic back-support specialist
        </span>
        <h1>{{ section.settings.heading | default: 'ObusForme — ergonomic back-support seating specialist.' }}</h1>
        <p class="lp-hero__standfirst">{{ section.settings.subheading | default: 'ObusForme builds ergonomic back-support and task seating with a consumer-recognizable focus on lumbar support and long-day comfort. Distributed in the Global Furniture Group family — and available alongside BBI&rsquo;s broader institutional seating catalog under OECM Agreement 2025-470.' }}</p>
        <div class="lp-hero__cta-row">
          <a class="bbi-btn bbi-btn--primary bbi-btn--lg" href="/pages/quote">
            Request a Quote <span class="arrow">&#8594;</span>
          </a>
          <a class="bbi-btn bbi-btn--secondary bbi-btn--lg" href="/collections/obusforme-chairs">
            Browse ObusForme Seating
          </a>
        </div>
      </div>
      <div class="lp-hero__media" aria-hidden="true">
        {%- if section.settings.hero_image != blank -%}
          {%- assign of_alt = 'ObusForme ergonomic back-support seating by Brant Business Interiors' -%}
          {{ section.settings.hero_image | image_url: width: 1200 | image_tag: loading: 'eager', alt: of_alt, width: 1200 }}
        {%- else -%}
          <div class="lp-hero__ph">Hero image &middot; 5:4 &middot; upload obusforme-space.jpg</div>
        {%- endif -%}
        <div class="lp-hero__caption">
          <span class="lp-hero__caption-dot"></span>
          <span>ObusForme &mdash; ergonomic back-support specialist</span>
        </div>
