{%- comment -%}
  Section: ds-lp-faq
  Purpose: FAQ landing page — procurement, OECM, delivery, returns, design services.
  Self-contained: BBI header + footer embedded; no ds-site-header or ds-site-footer needed.
{%- endcomment -%}

{% # theme-check-disable RemoteAsset %}
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Inter+Tight:wght@600&family=Inter:wght@400;500;600&family=JetBrains+Mono:wght@400&display=swap" rel="stylesheet">
{% # theme-check-enable RemoteAsset %}

<style>
/* ============================================================
   BBI Design Tokens — DS v2
   ============================================================ */
:root {
  --bodyFont: "Inter", system-ui, -apple-system, "Segoe UI", Roboto, sans-serif;
  --headingFont: "Inter Tight", "Inter", system-ui, sans-serif;
  --space-1: 4px; --space-2: 8px; --space-3: 12px; --space-4: 16px;
  --space-6: 24px; --space-8: 32px; --space-12: 48px; --space-16: 64px;
  --inputRadius: 4px; --buttonRadius: 4px; --cardRadius: 8px;
  --shadow-sm: 0 1px 2px rgba(11,11,12,.04), 0 2px 8px rgba(11,11,12,.05);
  --saleBadgeBackground: #D4252A;
  --saleBadgeBackground-rgb: 212,37,42;
  --fs-h1: 32px; --lh-h1: 1.1; --ls-h1: -0.015em;
  --fs-h2: 24px; --lh-h2: 1.15; --ls-h2: -0.01em;
  --fs-h3: 18px; --lh-h3: 1.25;
  --fs-body: 16px; --lh-body: 1.55;
  --fs-small: 13px;
  --fs-button: 15px; --lh-button: 1; --ls-button: 0.01em;
}
@media (min-width: 768px) {
  :root {
    --fs-h1: 48px; --lh-h1: 1.05;
    --fs-h2: 32px; --lh-h2: 1.1;
    --fs-h3: 22px; --lh-h3: 1.2;
    --fs-small: 14px;
  }
}
.bbi-lp-faq.scheme-default {
  --background: #FFFFFF; --background-rgb: 255,255,255;
  --alternateBackground: #FAFAFA; --alternateBackground-rgb: 250,250,250;
  --cardBackground: #FFFFFF;
  --textColor: #0B0B0C; --textColor-rgb: 11,11,12;
  --linkColor: #0B0B0C; --headingColor: #0B0B0C; --headingColor-rgb: 11,11,12;
  --buttonBackground: #0B0B0C; --buttonColor: #FFFFFF; --buttonBorder: #0B0B0C;
  --buttonBackgroundHover: #D4252A; --buttonColorHover: #FFFFFF; --buttonBorderHover: #D4252A;
  --borderColor: #E5E5E7; --borderColor-rgb: 229,229,231;
  --shadowColor: #0B0B0C; --shadowColor-rgb: 11,11,12;
  --headerBg: #FFFFFF; --headerColor: #0B0B0C; --headerHoverColor: #D4252A;
}

/* ============================================================
   Base
   ============================================================ */
.bbi-lp-faq *, .bbi-lp-faq *::before, .bbi-lp-faq *::after { box-sizing: border-box; }
.bbi-lp-faq { font-family: var(--bodyFont); font-size: var(--fs-body); line-height: var(--lh-body); color: var(--textColor); background: var(--background); -webkit-font-smoothing: antialiased; }
.bbi-lp-faq img { display: block; max-width: 100%; height: auto; }
.bbi-lp-faq a { color: var(--linkColor); }

/* Breadcrumbs */
.bbi-lp-faq .lp-crumbs-band { border-bottom: 1px solid rgba(var(--borderColor-rgb),.6); }
.bbi-lp-faq .lp-crumbs-band__inner { max-width: 1280px; margin: 0 auto; padding: var(--space-3) var(--space-6); }
.bbi-lp-faq .bbi-crumbs { display: flex; flex-wrap: wrap; gap: 8px; align-items: center; font-size: 13px; color: var(--textColor); margin: 0; padding: 0; list-style: none; }
.bbi-lp-faq .bbi-crumbs li { display: inline-flex; align-items: center; gap: 8px; }
.bbi-lp-faq .bbi-crumbs li:not(:last-child)::after { content: ">"; opacity: 0.4; }
.bbi-lp-faq .bbi-crumbs a { color: var(--textColor); opacity: 0.65; text-decoration: none; }
.bbi-lp-faq .bbi-crumbs a:hover { opacity: 1; text-decoration: underline; }
.bbi-lp-faq .bbi-crumbs li:last-child { font-weight: 500; }

/* ============================================================
   FAQ Hero
   ============================================================ */
.bbi-lp-faq .faq-hero { padding: 56px 0 48px; border-bottom: 1px solid var(--borderColor); background: var(--background); }
.bbi-lp-faq .faq-hero__inner { max-width: 880px; margin: 0 auto; padding: 0 24px; }
.bbi-lp-faq .faq-hero__eyebrow { display: inline-flex; align-items: center; gap: 10px; font-family: "JetBrains Mono", ui-monospace, monospace; font-size: 11px; letter-spacing: 0.08em; text-transform: uppercase; color: rgba(var(--textColor-rgb),0.6); margin: 0 0 20px; }
.bbi-lp-faq .faq-hero__eyebrow::before { content: ""; display: inline-block; width: 18px; height: 1px; background: var(--saleBadgeBackground); }
.bbi-lp-faq .faq-hero h1 { font-family: var(--headingFont); font-size: clamp(32px, 5vw, 52px); line-height: 1.05; letter-spacing: -0.02em; font-weight: 600; color: var(--headingColor); margin: 0 0 20px; text-wrap: balance; }
.bbi-lp-faq .faq-hero__lede { font-size: 17px; line-height: 1.6; color: rgba(var(--textColor-rgb),0.78); max-width: 68ch; margin: 0; text-wrap: pretty; }
.bbi-lp-faq .faq-hero__lede a { color: var(--textColor); text-decoration: underline; }

/* ============================================================
   FAQ Body + Groups
   ============================================================ */
.bbi-lp-faq .faq-body { padding: 0 0 64px; background: var(--background); }
.bbi-lp-faq .faq-body__inner { max-width: 880px; margin: 0 auto; padding: 0 24px; }
.bbi-lp-faq .faq-group { padding: 48px 0 32px; border-bottom: 1px solid rgba(var(--borderColor-rgb),0.6); }
.bbi-lp-faq .faq-group:last-child { border-bottom: none; padding-bottom: 0; }
.bbi-lp-faq .faq-group__heading { font-family: var(--headingFont); font-size: var(--fs-h2); line-height: var(--lh-h2); font-weight: 600; color: var(--headingColor); margin: 0 0 24px; display: flex; align-items: center; gap: 14px; }
.bbi-lp-faq .faq-group__heading::before { content: ""; display: inline-block; width: 18px; height: 1px; background: var(--saleBadgeBackground); flex-shrink: 0; }
.bbi-lp-faq .faq-nudge { margin-top: 20px; font-size: 14px; color: rgba(var(--textColor-rgb),0.6); padding-left: calc(28px + 16px); }
.bbi-lp-faq .faq-nudge a { color: var(--textColor); text-decoration: underline; }

/* lp-faq accordion */
.bbi-lp-faq .lp-faq__list { border-top: 1px solid rgba(var(--borderColor-rgb),.8); }
.bbi-lp-faq .lp-faq__item { border-bottom: 1px solid rgba(var(--borderColor-rgb),.8); }
.bbi-lp-faq button.lp-faq__trigger {
  all: unset !important; box-sizing: border-box !important;
  display: grid !important; grid-template-columns: auto 1fr auto !important;
  align-items: center !important; gap: 16px !important; width: 100% !important;
  padding: 24px 0 !important; background: transparent !important; border: none !important;
  text-align: left !important; cursor: pointer !important;
  font-family: var(--headingFont) !important; font-size: 17px !important;
  font-weight: 600 !important; color: var(--headingColor) !important;
  border-radius: 0 !important; min-height: unset !important; letter-spacing: normal !important;
}
.bbi-lp-faq button.lp-faq__trigger .lp-faq__trigger-num {
  font-family: "JetBrains Mono", ui-monospace, monospace !important;
  font-size: 11px !important; letter-spacing: 0.08em !important;
  color: rgba(var(--textColor-rgb),0.55) !important; font-weight: 400 !important;
  width: 28px !important; text-transform: none !important;
}
.bbi-lp-faq button.lp-faq__trigger .lp-faq__chevron {
  width: 16px !important; height: 16px !important;
  color: rgba(var(--textColor-rgb),0.55) !important;
  transition: transform 200ms ease, color 160ms ease !important;
  flex-shrink: 0 !important; fill: none !important;
  stroke: currentColor !important; stroke-width: 1.5px !important;
}
.bbi-lp-faq .lp-faq__item--open button.lp-faq__trigger .lp-faq__chevron {
  transform: rotate(180deg) !important; color: var(--textColor) !important;
}
.bbi-lp-faq .lp-faq__item--open button.lp-faq__trigger .lp-faq__trigger-num {
  color: var(--textColor) !important;
}
.bbi-lp-faq .lp-faq__answer { font-size: 15px; line-height: 1.6; color: rgba(var(--textColor-rgb),.78); padding: 0 0 20px calc(28px + 16px); }
.bbi-lp-faq .lp-faq__answer p { margin: 0 0 12px; text-wrap: pretty; }
.bbi-lp-faq .lp-faq__answer p:last-child { margin-bottom: 0; }
.bbi-lp-faq .lp-faq__answer a { color: var(--linkColor); text-decoration: underline; text-underline-offset: 3px; }

@media(max-width:980px){
  .bbi-lp-faq .bbi-header__nav,.bbi-lp-faq .bbi-header__utility .bbi-btn{display:none;}
  .bbi-lp-faq .bbi-footer__top{grid-template-columns:1fr;gap:var(--space-8);}
  .bbi-lp-faq .bbi-footer__cols{grid-template-columns:repeat(2,1fr);}
}
@media(max-width:640px){
  .bbi-lp-faq .bbi-header__inner{padding:0 16px;}
  .bbi-lp-faq .faq-hero{padding:40px 0 32px;}
  .bbi-lp-faq .faq-hero h1{font-size:32px;}
  .bbi-lp-faq .faq-hero__lede{font-size:15px;}
  .bbi-lp-faq .bbi-footer__cols{grid-template-columns:1fr;}
}
</style>

<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    { "@type": "Question", "name": "How do I place an order?", "acceptedAnswer": { "@type": "Answer", "text": "Call 1-800-835-9565 or submit a quote request online. We'll confirm product availability, pricing, and delivery timeline — typically within 1 business day." } },
    { "@type": "Question", "name": "Do you offer NET 30 terms?", "acceptedAnswer": { "@type": "Answer", "text": "Yes. Credit accounts with NET 30 terms are available to approved institutional buyers — municipalities, school boards, healthcare organizations, and registered non-profits." } },
    { "@type": "Question", "name": "What is OECM and how does it benefit my organization?", "acceptedAnswer": { "@type": "Answer", "text": "OECM is a group purchasing organization for Ontario's education and broader public sector. As an OECM Supplier Partner (Agreement 2025-470), Brant Business Interiors offers pre-negotiated pricing that eligible institutions can access without issuing an open tender." } },
    { "@type": "Question", "name": "Do you deliver across Ontario?", "acceptedAnswer": { "@type": "Answer", "text": "Yes. We deliver furniture to addresses across Ontario. Delivery timelines vary by product availability and location." } },
    { "@type": "Question", "name": "Do you offer space planning?", "acceptedAnswer": { "@type": "Answer", "text": "Yes — free of charge for qualifying projects. Our design team will produce a scaled floor plan showing furniture placement, traffic flow, and sightlines. Qualifying projects are typically 5 or more workstations or a full-room fit-out." } }
  ]
}
</script>

<div class="bbi-lp-faq scheme-default">

  {%- render 'bbi-nav', logo: section.settings.logo, active: 'services' -%}

  {%- comment -%}BREADCRUMBS{%- endcomment -%}
  <div class="lp-crumbs-band">
    <div class="lp-crumbs-band__inner">
      <ol class="bbi-crumbs" aria-label="Breadcrumb">
        <li><a href="/">Home</a></li>
        <li>FAQ</li>
      </ol>
    </div>
  </div>

  <!-- ═══ HERO ═══ -->
  <div class="faq-hero">
    <div class="faq-hero__inner">
      <p class="faq-hero__eyebrow">Procurement &amp; ordering</p>
      <h1>Frequently Asked Questions</h1>
      <p class="faq-hero__lede">
        Brant Business Interiors is an OECM Supplier Partner (Agreement 2025-470) serving Ontario institutions, municipalities, and businesses. We offer NET 30 terms for approved accounts, deliver across Ontario, and include free space planning for qualifying projects. For questions not answered below, call <a href="tel:18008359565">1-800-835-9565</a> — we respond to quote requests within 1 business day.
      </p>
    </div>
  </div>

  <!-- ═══ FAQ BODY ═══ -->
  <div class="faq-body">
    <div class="faq-body__inner">

      <!-- Group 1: Ordering & Payment -->
      <div class="faq-group">
        <h2 class="faq-group__heading">Ordering &amp; Payment</h2>
        <div class="lp-faq__list" role="list">

          <div class="lp-faq__item" role="listitem">
            <button class="lp-faq__trigger" aria-expanded="false" data-faq-trigger>
              <span class="lp-faq__trigger-num">01</span>
              How do I place an order?
              <svg class="lp-faq__chevron" viewBox="0 0 16 16" fill="none" aria-hidden="true">
                <path d="M4 6l4 4 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </button>
            <div class="lp-faq__answer" hidden>
              <p>Call <a href="tel:18008359565">1-800-835-9565</a> or submit a quote request online. We'll confirm product availability, pricing, and delivery timeline — typically within 1 business day. For standard in-stock items you can also order directly through the website.</p>
            </div>
          </div>

          <div class="lp-faq__item" role="listitem">
            <button class="lp-faq__trigger" aria-expanded="false" data-faq-trigger>
              <span class="lp-faq__trigger-num">02</span>
              Do you offer NET 30 terms?
              <svg class="lp-faq__chevron" viewBox="0 0 16 16" fill="none" aria-hidden="true">
                <path d="M4 6l4 4 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </button>
            <div class="lp-faq__answer" hidden>
              <p>Yes. Credit accounts with NET 30 terms are available to approved institutional buyers — municipalities, school boards, healthcare organizations, and registered non-profits. Contact us to apply. For new accounts, first orders are prepaid by credit card or EFT.</p>
            </div>
          </div>

          <div class="lp-faq__item" role="listitem">
            <button class="lp-faq__trigger" aria-expanded="false" data-faq-trigger>
              <span class="lp-faq__trigger-num">03</span>
              What payment methods do you accept?
              <svg class="lp-faq__chevron" viewBox="0 0 16 16" fill="none" aria-hidden="true">
                <path d="M4 6l4 4 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </button>
            <div class="lp-faq__answer" hidden>
              <p>Visa, Mastercard, EFT, cheque, and purchase orders (approved accounts). We do not accept American Express.</p>
            </div>
          </div>

          <div class="lp-faq__item" role="listitem">
            <button class="lp-faq__trigger" aria-expanded="false" data-faq-trigger>
              <span class="lp-faq__trigger-num">04</span>
              Can I use a purchase order?
              <svg class="lp-faq__chevron" viewBox="0 0 16 16" fill="none" aria-hidden="true">
                <path d="M4 6l4 4 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </button>
            <div class="lp-faq__answer" hidden>
              <p>Yes — PO-based ordering is available for approved institutional accounts. Send your PO to <a href="mailto:info@brantbusinessinteriors.com">info@brantbusinessinteriors.com</a> with your order details. We'll issue an order confirmation and invoice against the PO.</p>
            </div>
          </div>

          <div class="lp-faq__item" role="listitem">
            <button class="lp-faq__trigger" aria-expanded="false" data-faq-trigger>
              <span class="lp-faq__trigger-num">05</span>
              Do prices include delivery and installation?
              <svg class="lp-faq__chevron" viewBox="0 0 16 16" fill="none" aria-hidden="true">
                <path d="M4 6l4 4 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </button>
            <div class="lp-faq__answer" hidden>
              <p>No. Delivery and installation are quoted separately based on location, order size, and site conditions. We'll include a delivery estimate with your quote. Call <a href="tel:18008359565">1-800-835-9565</a> for a combined furniture + delivery quote.</p>
            </div>
          </div>

        </div>
        <p class="faq-nudge">Still have questions? <a href="tel:18008359565">Call 1-800-835-9565</a> or <a href="/pages/quote">request a quote &rarr;</a></p>
      </div>

      <!-- Group 2: OECM -->
      <div class="faq-group">
        <h2 class="faq-group__heading">OECM Procurement</h2>
        <div class="lp-faq__list" role="list">

          <div class="lp-faq__item" role="listitem">
            <button class="lp-faq__trigger" aria-expanded="false" data-faq-trigger>
              <span class="lp-faq__trigger-num">01</span>
              What is OECM and how does it benefit my organization?
              <svg class="lp-faq__chevron" viewBox="0 0 16 16" fill="none" aria-hidden="true">
                <path d="M4 6l4 4 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </button>
            <div class="lp-faq__answer" hidden>
              <p>OECM (Ontario Education Collaborative Marketplace) is a group purchasing organization for Ontario's education and broader public sector. As an OECM Supplier Partner (Agreement 2025-470), Brant Business Interiors offers pre-negotiated pricing that eligible institutions can access without issuing an open tender — saving procurement time and satisfying purchasing compliance requirements.</p>
            </div>
          </div>

          <div class="lp-faq__item" role="listitem">
            <button class="lp-faq__trigger" aria-expanded="false" data-faq-trigger>
              <span class="lp-faq__trigger-num">02</span>
              Which organizations are eligible to purchase through OECM?
              <svg class="lp-faq__chevron" viewBox="0 0 16 16" fill="none" aria-hidden="true">
                <path d="M4 6l4 4 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </button>
            <div class="lp-faq__answer" hidden>
              <p>Ontario school boards, colleges, universities, hospitals, municipalities, and other BPS (broader public sector) organizations. If your organization is an OECM member, you can order from us directly under Agreement 2025-470.</p>
            </div>
          </div>

          <div class="lp-faq__item" role="listitem">
            <button class="lp-faq__trigger" aria-expanded="false" data-faq-trigger>
              <span class="lp-faq__trigger-num">03</span>
              How do I order through the OECM agreement?
              <svg class="lp-faq__chevron" viewBox="0 0 16 16" fill="none" aria-hidden="true">
                <path d="M4 6l4 4 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </button>
            <div class="lp-faq__answer" hidden>
              <p>Contact us at <a href="tel:18008359565">1-800-835-9565</a> or <a href="mailto:info@brantbusinessinteriors.com">info@brantbusinessinteriors.com</a>. Reference Agreement 2025-470 and provide your organization name. We'll confirm pricing, generate an OECM-compliant quote, and process your PO.</p>
            </div>
          </div>

          <div class="lp-faq__item" role="listitem">
            <button class="lp-faq__trigger" aria-expanded="false" data-faq-trigger>
              <span class="lp-faq__trigger-num">04</span>
              Can I use OECM pricing for a small order?
              <svg class="lp-faq__chevron" viewBox="0 0 16 16" fill="none" aria-hidden="true">
                <path d="M4 6l4 4 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </button>
            <div class="lp-faq__answer" hidden>
              <p>Yes — there is no minimum order requirement under the agreement. OECM pricing applies whether you're ordering a single chair or furnishing an entire building.</p>
            </div>
          </div>

        </div>
        <p class="faq-nudge">Still have questions? <a href="tel:18008359565">Call 1-800-835-9565</a> or <a href="/pages/quote">request a quote &rarr;</a></p>
      </div>

      <!-- Group 3: Delivery & Installation -->
      <div class="faq-group">
        <h2 class="faq-group__heading">Delivery &amp; Installation</h2>
        <div class="lp-faq__list" role="list">

          <div class="lp-faq__item" role="listitem">
            <button class="lp-faq__trigger" aria-expanded="false" data-faq-trigger>
              <span class="lp-faq__trigger-num">01</span>
              Do you deliver across Ontario?
              <svg class="lp-faq__chevron" viewBox="0 0 16 16" fill="none" aria-hidden="true">
                <path d="M4 6l4 4 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </button>
            <div class="lp-faq__answer" hidden>
              <p>Yes. We deliver furniture to addresses across Ontario. Delivery timelines vary by product availability and location — call <a href="tel:18008359565">1-800-835-9565</a> for a lead time on your specific items.</p>
            </div>
          </div>

          <div class="lp-faq__item" role="listitem">
            <button class="lp-faq__trigger" aria-expanded="false" data-faq-trigger>
              <span class="lp-faq__trigger-num">02</span>
              Do you offer installation?
              <svg class="lp-faq__chevron" viewBox="0 0 16 16" fill="none" aria-hidden="true">
                <path d="M4 6l4 4 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </button>
            <div class="lp-faq__answer" hidden>
              <p>Yes. Professional installation is available for most furniture categories including workstations, storage, and seating. Installation is quoted separately — include it in your quote request and we'll add it to the estimate.</p>
            </div>
          </div>

          <div class="lp-faq__item" role="listitem">
            <button class="lp-faq__trigger" aria-expanded="false" data-faq-trigger>
              <span class="lp-faq__trigger-num">03</span>
              How long does delivery take?
              <svg class="lp-faq__chevron" viewBox="0 0 16 16" fill="none" aria-hidden="true">
                <path d="M4 6l4 4 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </button>
            <div class="lp-faq__answer" hidden>
              <p>Lead times vary by product and manufacturer availability. We'll confirm current lead times with your quote. Call <a href="tel:18008359565">1-800-835-9565</a> for time-sensitive orders.</p>
            </div>
          </div>

          <div class="lp-faq__item" role="listitem">
            <button class="lp-faq__trigger" aria-expanded="false" data-faq-trigger>
              <span class="lp-faq__trigger-num">04</span>
              What if my order arrives damaged?
              <svg class="lp-faq__chevron" viewBox="0 0 16 16" fill="none" aria-hidden="true">
                <path d="M4 6l4 4 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </button>
            <div class="lp-faq__answer" hidden>
              <p>Inspect delivery on arrival and note any damage on the delivery record before the driver leaves. Contact us within 5 business days at <a href="mailto:info@brantbusinessinteriors.com">info@brantbusinessinteriors.com</a> with photos. We'll arrange replacement or repair at no cost for manufacturer-caused damage.</p>
            </div>
          </div>

        </div>
        <p class="faq-nudge">Still have questions? <a href="tel:18008359565">Call 1-800-835-9565</a> or <a href="/pages/quote">request a quote &rarr;</a></p>
      </div>

      <!-- Group 4: Returns & Warranty -->
      <div class="faq-group">
        <h2 class="faq-group__heading">Returns &amp; Warranty</h2>
        <div class="lp-faq__list" role="list">

          <div class="lp-faq__item" role="listitem">
            <button class="lp-faq__trigger" aria-expanded="false" data-faq-trigger>
              <span class="lp-faq__trigger-num">01</span>
              What is your return policy?
              <svg class="lp-faq__chevron" viewBox="0 0 16 16" fill="none" aria-hidden="true">
                <path d="M4 6l4 4 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </button>
            <div class="lp-faq__answer" hidden>
              <p>Standard stocked items may be returned within 14 days of delivery in original, unassembled condition. Custom-configured, special-order, and assembled items are non-returnable. Contact us before returning anything — all returns require prior authorization.</p>
            </div>
          </div>

          <div class="lp-faq__item" role="listitem">
            <button class="lp-faq__trigger" aria-expanded="false" data-faq-trigger>
              <span class="lp-faq__trigger-num">02</span>
              What warranty coverage applies to BBI furniture?
              <svg class="lp-faq__chevron" viewBox="0 0 16 16" fill="none" aria-hidden="true">
                <path d="M4 6l4 4 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </button>
            <div class="lp-faq__answer" hidden>
              <p>Warranty terms vary by manufacturer and product line. Most commercial-grade furniture carries a 5–10 year limited warranty on structural components. Specific warranty documentation is available on request — ask when you place your order or call <a href="tel:18008359565">1-800-835-9565</a>.</p>
            </div>
          </div>

          <div class="lp-faq__item" role="listitem">
            <button class="lp-faq__trigger" aria-expanded="false" data-faq-trigger>
              <span class="lp-faq__trigger-num">03</span>
              Who do I contact for a warranty claim?
              <svg class="lp-faq__chevron" viewBox="0 0 16 16" fill="none" aria-hidden="true">
                <path d="M4 6l4 4 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </button>
            <div class="lp-faq__answer" hidden>
              <p>Contact Brant Business Interiors directly at <a href="mailto:info@brantbusinessinteriors.com">info@brantbusinessinteriors.com</a> or <a href="tel:18008359565">1-800-835-9565</a>. We handle warranty claims on your behalf with the manufacturer — you don't need to contact the manufacturer directly.</p>
            </div>
          </div>

        </div>
        <p class="faq-nudge">Still have questions? <a href="tel:18008359565">Call 1-800-835-9565</a> or <a href="/pages/quote">request a quote &rarr;</a></p>
      </div>

      <!-- Group 5: Design Services -->
      <div class="faq-group">
        <h2 class="faq-group__heading">Design Services</h2>
        <div class="lp-faq__list" role="list">

          <div class="lp-faq__item" role="listitem">
            <button class="lp-faq__trigger" aria-expanded="false" data-faq-trigger>
              <span class="lp-faq__trigger-num">01</span>
              Do you offer space planning?
              <svg class="lp-faq__chevron" viewBox="0 0 16 16" fill="none" aria-hidden="true">
                <path d="M4 6l4 4 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </button>
            <div class="lp-faq__answer" hidden>
              <p>Yes — free of charge for qualifying projects. Our design team will produce a scaled floor plan showing furniture placement, traffic flow, and sightlines. Qualifying projects are typically 5 or more workstations or a full-room fit-out. <a href="/pages/quote">Request a quote &rarr;</a> to get started.</p>
            </div>
          </div>

          <div class="lp-faq__item" role="listitem">
            <button class="lp-faq__trigger" aria-expanded="false" data-faq-trigger>
              <span class="lp-faq__trigger-num">02</span>
              What does the design process look like?
              <svg class="lp-faq__chevron" viewBox="0 0 16 16" fill="none" aria-hidden="true">
                <path d="M4 6l4 4 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </button>
            <div class="lp-faq__answer" hidden>
              <p>We collect your room dimensions and requirements (by phone, email, or on-site visit), produce a layout in CAD, revise based on your feedback, and provide a furniture spec list tied to the layout. Most projects go from intake to first draft in 5–7 business days.</p>
            </div>
          </div>

          <div class="lp-faq__item" role="listitem">
            <button class="lp-faq__trigger" aria-expanded="false" data-faq-trigger>
              <span class="lp-faq__trigger-num">03</span>
              Is there a cost for a site visit?
              <svg class="lp-faq__chevron" viewBox="0 0 16 16" fill="none" aria-hidden="true">
                <path d="M4 6l4 4 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </button>
            <div class="lp-faq__answer" hidden>
              <p>Site visits are complimentary for projects in the Peterborough region. For locations outside our service area, travel costs may apply — ask when you request a quote.</p>
            </div>
          </div>

          <div class="lp-faq__item" role="listitem">
            <button class="lp-faq__trigger" aria-expanded="false" data-faq-trigger>
              <span class="lp-faq__trigger-num">04</span>
              Can you match existing furniture?
              <svg class="lp-faq__chevron" viewBox="0 0 16 16" fill="none" aria-hidden="true">
                <path d="M4 6l4 4 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </button>
            <div class="lp-faq__answer" hidden>
              <p>Often yes. Provide the manufacturer, product line, and finish of your existing pieces and we'll identify compatible options from our catalog. Call <a href="tel:18008359565">1-800-835-9565</a> for a match consultation.</p>
            </div>
          </div>

        </div>
        <p class="faq-nudge">Still have questions? <a href="tel:18008359565">Call 1-800-835-9565</a> or <a href="/pages/quote">request a quote &rarr;</a></p>
      </div>

    </div><!-- /faq-body__inner -->
  </div><!-- /faq-body -->

  <script>
    document.querySelectorAll('[data-faq-trigger]').forEach(function(btn) {
      btn.addEventListener('click', function() {
        var item = btn.closest('.lp-faq__item');
        var answer = item.querySelector('.lp-faq__answer');
        var isOpen = item.classList.contains('lp-faq__item--open');
        item.classList.toggle('lp-faq__item--open', !isOpen);
        btn.setAttribute('aria-expanded', String(!isOpen));
        answer.hidden = isOpen;
      });
    });
  </script>

  {%- render 'bbi-footer', logo: section.settings.logo -%}

</div><!-- /bbi-lp-faq -->

{% schema %}
{
  "name": "FAQ Landing Page",
  "class": "ds-lp-faq",
  "settings": [
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Header logo"
    }
  ],
  "presets": [
    {
      "name": "FAQ Landing Page"
    }
  ]
}
{% endschema %}
