{%- comment -%}
  Section: ds-lp-quote
  Purpose: Request a Quote landing page — primary CTA destination for all site buttons.
  Sections: breadcrumbs → hero → intro → contact/form explainer + OECM callout → differentiators → proof bar → FAQ → CTA closer
  Schema: hero copy, contact channel toggles, FAQ accordion blocks
  JSON-LD: Service + FAQPage structured data
{%- endcomment -%}

{% # theme-check-disable RemoteAsset %}
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Inter+Tight:wght@600&family=Inter:wght@400;500;600&family=JetBrains+Mono:wght@400&display=swap" rel="stylesheet">
{% # theme-check-enable RemoteAsset %}

<style>
/* ============================================================
   BBI Design Tokens — DS v2
   ============================================================ */
:root {
  --bodyFont: "Inter", system-ui, -apple-system, "Segoe UI", Roboto, sans-serif;
  --headingFont: "Inter Tight", "Inter", system-ui, sans-serif;
  --space-1: 4px; --space-2: 8px; --space-3: 12px; --space-4: 16px;
  --space-6: 24px; --space-8: 32px; --space-12: 48px; --space-16: 64px;
  --inputRadius: 4px; --buttonRadius: 4px; --cardRadius: 8px;
  --shadow-sm: 0 1px 2px rgba(11,11,12,.04), 0 2px 8px rgba(11,11,12,.05);
  --saleBadgeBackground: #D4252A;
  --saleBadgeBackground-rgb: 212,37,42;
  --fs-h1: 32px; --lh-h1: 1.1; --ls-h1: -0.015em;
  --fs-h2: 24px; --lh-h2: 1.15; --ls-h2: -0.01em;
  --fs-h3: 18px; --lh-h3: 1.25;
  --fs-body: 16px; --lh-body: 1.55;
  --fs-small: 13px;
  --fs-button: 15px; --lh-button: 1; --ls-button: 0.01em;
}
@media (min-width: 768px) {
  :root {
    --fs-h1: 48px; --lh-h1: 1.05;
    --fs-h2: 32px; --lh-h2: 1.1;
    --fs-h3: 22px; --lh-h3: 1.2;
    --fs-small: 14px;
  }
}
.bbi-lp-quote.scheme-default {
  --background: #FFFFFF; --background-rgb: 255,255,255;
  --alternateBackground: #FAFAFA; --alternateBackground-rgb: 250,250,250;
  --cardBackground: #FFFFFF;
  --textColor: #0B0B0C; --textColor-rgb: 11,11,12;
  --linkColor: #0B0B0C; --headingColor: #0B0B0C; --headingColor-rgb: 11,11,12;
  --buttonBackground: #0B0B0C; --buttonColor: #FFFFFF; --buttonBorder: #0B0B0C;
  --buttonBackgroundHover: #D4252A; --buttonColorHover: #FFFFFF; --buttonBorderHover: #D4252A;
  --alternateButtonBackground: #FFFFFF; --alternateButtonColor: #0B0B0C; --alternateButtonBorder: #0B0B0C;
  --alternateButtonBackgroundHover: #0B0B0C; --alternateButtonColorHover: #FFFFFF; --alternateButtonBorderHover: #0B0B0C;
  --borderColor: #E5E5E7; --borderColor-rgb: 229,229,231;
  --shadowColor: #0B0B0C; --shadowColor-rgb: 11,11,12;
}
.bbi-lp-quote .scheme-inverse {
  --background: #0B0B0C; --background-rgb: 11,11,12;
  --alternateBackground: #161618;
  --textColor: #FFFFFF; --textColor-rgb: 255,255,255;
  --linkColor: #FFFFFF; --headingColor: #FFFFFF; --headingColor-rgb: 255,255,255;
  --buttonBackground: #FFFFFF; --buttonColor: #0B0B0C; --buttonBorder: #FFFFFF;
  --buttonBackgroundHover: #D4252A; --buttonColorHover: #FFFFFF; --buttonBorderHover: #D4252A;
  --alternateButtonBackground: transparent; --alternateButtonColor: #FFFFFF; --alternateButtonBorder: #FFFFFF;
  --alternateButtonBackgroundHover: #FFFFFF; --alternateButtonColorHover: #0B0B0C; --alternateButtonBorderHover: #FFFFFF;
  --borderColor: #1F1F21; --borderColor-rgb: 31,31,33;
  --shadowColor: #000000; --shadowColor-rgb: 0,0,0;
}

/* ============================================================
   Base + Shared Components
   ============================================================ */
.bbi-lp-quote *, .bbi-lp-quote *::before, .bbi-lp-quote *::after { box-sizing: border-box; }
.bbi-lp-quote { font-family: var(--bodyFont); font-size: var(--fs-body); line-height: var(--lh-body); color: var(--textColor); background: var(--background); -webkit-font-smoothing: antialiased; }
.bbi-lp-quote img { display: block; max-width: 100%; height: auto; }
.bbi-lp-quote a { color: var(--linkColor); }
.bbi-lp-quote .bbi-mono { font-family: "JetBrains Mono", ui-monospace, monospace; font-size: 11px; letter-spacing: 0.08em; text-transform: uppercase; }
.bbi-lp-quote .bbi-btn {
  display: inline-flex; align-items: center; justify-content: center;
  gap: var(--space-2); padding: 12px 20px; min-height: 44px;
  font-family: var(--bodyFont); font-size: var(--fs-button); line-height: var(--lh-button);
  letter-spacing: var(--ls-button); font-weight: 600; border-radius: var(--buttonRadius);
  border: 1px solid transparent; cursor: pointer; text-decoration: none;
  transition: background-color 120ms ease, color 120ms ease, border-color 120ms ease;
  white-space: nowrap;
}
.bbi-lp-quote .bbi-btn:focus-visible { outline: 2px solid var(--textColor); outline-offset: 2px; }
.bbi-lp-quote .bbi-btn--lg { min-height: 52px; padding: 16px 24px; font-size: 16px; }
.bbi-lp-quote .bbi-btn--full { width: 100%; }
.bbi-lp-quote .bbi-btn--primary { background: var(--buttonBackground); color: var(--buttonColor); border-color: var(--buttonBorder); }
.bbi-lp-quote .bbi-btn--primary:hover { background: var(--buttonBackgroundHover); color: var(--buttonColorHover); border-color: var(--buttonBorderHover); }
.bbi-lp-quote .bbi-btn--secondary { background: var(--alternateButtonBackground); color: var(--alternateButtonColor); border-color: var(--alternateButtonBorder); }
.bbi-lp-quote .bbi-btn--secondary:hover { background: var(--alternateButtonBackgroundHover); color: var(--alternateButtonColorHover); border-color: var(--alternateButtonBorderHover); }
.bbi-lp-quote .arrow { display: inline-block; transition: transform 120ms ease; }
.bbi-lp-quote .bbi-btn:hover .arrow { transform: translateX(3px); }
.bbi-lp-quote .bbi-crumbs { display: flex; flex-wrap: wrap; gap: 8px; align-items: center; font-size: 13px; color: var(--textColor); margin: 0; padding: 0; list-style: none; }
.bbi-lp-quote .bbi-crumbs li { display: inline-flex; align-items: center; gap: 8px; }
.bbi-lp-quote .bbi-crumbs li:not(:last-child)::after { content: ">"; opacity: 0.4; }
.bbi-lp-quote .bbi-crumbs a { color: var(--textColor); opacity: 0.65; text-decoration: none; }
.bbi-lp-quote .bbi-crumbs a:hover { opacity: 1; text-decoration: underline; }
.bbi-lp-quote .bbi-crumbs li:last-child { font-weight: 500; }

/* CTA Section */
.bbi-lp-quote .bbi-cta-section { background: var(--background); color: var(--textColor); }
.bbi-lp-quote .bbi-cta-section__inner { max-width: 1320px; margin: 0 auto; padding: 96px 32px; display: grid; grid-template-columns: 1.2fr 1fr; gap: 64px; align-items: center; }
.bbi-lp-quote .bbi-cta-section__inner > * { min-width: 0; }
.bbi-lp-quote .lp-contact__inner > * { min-width: 0; }
.bbi-lp-quote .bbi-cta-section__eyebrow { font-family: "JetBrains Mono", ui-monospace, monospace; font-size: 12px; letter-spacing: 0.08em; text-transform: uppercase; color: rgba(var(--textColor-rgb),.7); margin: 0 0 16px; }
.bbi-lp-quote .bbi-cta-section__heading { font-family: var(--headingFont); font-size: clamp(32px,4.2vw,56px); line-height: 1.05; letter-spacing: -0.015em; font-weight: 600; margin: 0 0 20px; text-wrap: balance; }
.bbi-lp-quote .bbi-cta-section__sub { font-size: 17px; line-height: 1.55; color: rgba(var(--textColor-rgb),.78); max-width: 52ch; margin: 0; }
.bbi-lp-quote .bbi-cta-section__actions { display: flex; flex-direction: column; gap: 16px; align-items: flex-start; }
.bbi-lp-quote .bbi-cta-section__trust { display: flex; align-items: flex-start; gap: 10px; font-size: 14px; color: rgba(var(--textColor-rgb),.78); }
.bbi-lp-quote .bbi-cta-section__trust .dot { flex: 0 0 auto; margin-top: 7px; width: 6px; height: 6px; border-radius: 99px; background: var(--saleBadgeBackground); }
.bbi-lp-quote .bbi-cta-section__trust b { color: var(--textColor); font-weight: 600; }
.bbi-lp-quote .bbi-cta-section__trust a { color: var(--textColor); text-decoration: underline; }

/* ============================================================
   Landing Page Sections
   ============================================================ */
.bbi-lp-quote .lp-crumbs-band { border-bottom: 1px solid rgba(var(--borderColor-rgb),.6); }
.bbi-lp-quote .lp-crumbs-band__inner { max-width: 1280px; margin: 0 auto; padding: var(--space-3) var(--space-6); }

/* Hero */
.bbi-lp-quote .lp-hero { padding: var(--space-12) 0; border-bottom: 1px solid rgba(var(--borderColor-rgb),.6); }
.bbi-lp-quote .lp-hero__inner { max-width: 1280px; margin: 0 auto; padding: 0 var(--space-6); display: grid; grid-template-columns: minmax(0,1.05fr) minmax(0,1fr); gap: var(--space-12); align-items: center; }
.bbi-lp-quote .lp-hero__text { max-width: 560px; }
.bbi-lp-quote .lp-hero__eyebrow { display: inline-flex; align-items: center; gap: var(--space-2); margin-bottom: var(--space-4); }
.bbi-lp-quote .lp-hero__eyebrow::before { content: ""; display: inline-block; width: 18px; height: 1px; background: var(--saleBadgeBackground); }
.bbi-lp-quote .lp-hero__eyebrow-label { color: rgba(var(--textColor-rgb),.6); }
.bbi-lp-quote .lp-hero__badge { display: inline-flex; align-items: center; gap: var(--space-2); padding: 6px 12px; border: 1px solid rgba(var(--borderColor-rgb),.8); border-radius: 999px; margin-bottom: var(--space-6); font-size: 12px; color: rgba(var(--textColor-rgb),.78); }
.bbi-lp-quote .lp-hero__badge-dot { width: 6px; height: 6px; border-radius: 50%; background: var(--saleBadgeBackground); }
.bbi-lp-quote .lp-hero h1 { font-family: var(--headingFont); font-size: var(--fs-h1); line-height: var(--lh-h1); letter-spacing: var(--ls-h1); font-weight: 600; color: var(--headingColor); margin: 0 0 var(--space-4); text-wrap: balance; }
.bbi-lp-quote .lp-hero__standfirst { font-size: 18px; line-height: 1.55; color: rgba(var(--textColor-rgb),.78); margin: 0 0 var(--space-6); text-wrap: pretty; }
.bbi-lp-quote .lp-hero__cta-row { display: flex; gap: var(--space-3); flex-wrap: wrap; }
.bbi-lp-quote .lp-hero__media { position: relative; aspect-ratio: 5 / 4; background: var(--alternateBackground); border-radius: var(--cardRadius); overflow: hidden; }
.bbi-lp-quote .lp-hero__media img { width: 100%; height: 100%; object-fit: cover; }
.bbi-lp-quote .lp-hero__media-placeholder { position: absolute; inset: 0; display: flex; align-items: center; justify-content: center; background: repeating-linear-gradient(135deg,rgba(var(--shadowColor-rgb),.03) 0 8px,rgba(var(--shadowColor-rgb),.07) 8px 16px),var(--alternateBackground); color: rgba(var(--textColor-rgb),.5); font-family: "JetBrains Mono",ui-monospace,monospace; font-size: 11px; letter-spacing: 0.08em; text-transform: uppercase; }

/* Intro */
.bbi-lp-quote .lp-intro { padding: var(--space-12) 0; }
.bbi-lp-quote .lp-intro__inner { max-width: 880px; margin: 0 auto; padding: 0 var(--space-6); }
.bbi-lp-quote .lp-intro__eyebrow { display: inline-flex; align-items: center; gap: var(--space-2); color: rgba(var(--textColor-rgb),.6); margin-bottom: var(--space-4); }
.bbi-lp-quote .lp-intro__eyebrow::before { content: ""; display: inline-block; width: 18px; height: 1px; background: var(--saleBadgeBackground); }
.bbi-lp-quote .lp-intro h2 { font-family: var(--headingFont); font-size: var(--fs-h2); line-height: var(--lh-h2); font-weight: 600; color: var(--headingColor); margin: 0 0 var(--space-6); text-wrap: balance; }
.bbi-lp-quote .lp-intro__body p { font-size: 17px; line-height: 1.6; color: rgba(var(--textColor-rgb),.78); margin: 0 0 var(--space-4); text-wrap: pretty; }
.bbi-lp-quote .lp-intro__body a { color: var(--linkColor); text-decoration: underline; text-underline-offset: 3px; }

/* Contact section */
.bbi-lp-quote .lp-contact { padding: var(--space-12) 0; background: var(--alternateBackground); border-top: 1px solid rgba(var(--borderColor-rgb),.6); border-bottom: 1px solid rgba(var(--borderColor-rgb),.6); }
.bbi-lp-quote .lp-contact__inner { max-width: 1280px; margin: 0 auto; padding: 0 var(--space-6); display: grid; grid-template-columns: 1fr 1fr; gap: var(--space-12); align-items: start; }
.bbi-lp-quote .lp-contact__eyebrow { display: inline-flex; align-items: center; gap: var(--space-2); color: rgba(var(--textColor-rgb),.6); margin-bottom: var(--space-3); }
.bbi-lp-quote .lp-contact__eyebrow::before { content: ""; display: inline-block; width: 18px; height: 1px; background: var(--saleBadgeBackground); }
.bbi-lp-quote .lp-contact h2 { font-family: var(--headingFont); font-size: var(--fs-h2); line-height: var(--lh-h2); font-weight: 600; color: var(--headingColor); margin: 0 0 var(--space-3); text-wrap: balance; }
.bbi-lp-quote .lp-contact__body { font-size: 16px; line-height: 1.6; color: rgba(var(--textColor-rgb),.78); margin: 0 0 var(--space-6); }
.bbi-lp-quote .lp-contact__channels { display: flex; flex-direction: column; gap: var(--space-3); }
.bbi-lp-quote .lp-contact__channel { display: flex; align-items: center; gap: var(--space-3); padding: var(--space-4) var(--space-6); background: var(--cardBackground); border: 1px solid rgba(var(--borderColor-rgb),.8); border-radius: var(--cardRadius); text-decoration: none; color: var(--textColor); transition: border-color 160ms ease; }
.bbi-lp-quote .lp-contact__channel:hover { border-color: var(--textColor); }
.bbi-lp-quote .lp-contact__channel-icon { width: 20px; height: 20px; color: rgba(var(--textColor-rgb),.6); flex-shrink: 0; }
.bbi-lp-quote .lp-contact__channel-label { display: flex; flex-direction: column; gap: 2px; flex: 1; min-width: 0; }
.bbi-lp-quote .lp-contact__channel-name { font-family: var(--headingFont); font-size: 15px; font-weight: 600; color: var(--headingColor); }
.bbi-lp-quote .lp-contact__channel-meta { font-size: 13px; color: rgba(var(--textColor-rgb),.6); }
.bbi-lp-quote .lp-contact__channel-arrow { color: rgba(var(--textColor-rgb),.4); transition: transform 160ms ease; }
.bbi-lp-quote .lp-contact__channel:hover .lp-contact__channel-arrow { transform: translateX(3px); color: var(--textColor); }
.bbi-lp-quote .lp-oecm-callout { padding: var(--space-8); background: var(--cardBackground); border: 1px solid rgba(var(--borderColor-rgb),.8); border-left: 3px solid var(--saleBadgeBackground); border-radius: var(--cardRadius); }
.bbi-lp-quote .lp-oecm-callout__eyebrow { display: flex; align-items: center; gap: var(--space-2); margin-bottom: var(--space-4); font-family: "JetBrains Mono", ui-monospace, monospace; font-size: 11px; letter-spacing: 0.08em; text-transform: uppercase; color: var(--saleBadgeBackground); }
.bbi-lp-quote .lp-oecm-callout__dot { width: 6px; height: 6px; border-radius: 50%; background: var(--saleBadgeBackground); flex-shrink: 0; }
.bbi-lp-quote .lp-oecm-callout h3 { font-family: var(--headingFont); font-size: 20px; font-weight: 600; color: var(--headingColor); margin: 0 0 var(--space-3); line-height: 1.3; }
.bbi-lp-quote .lp-oecm-callout__body { font-size: 15px; line-height: 1.6; color: rgba(var(--textColor-rgb),.78); margin: 0 0 var(--space-4); }
.bbi-lp-quote .lp-oecm-callout__detail { font-size: 12px; line-height: 1.55; color: rgba(var(--textColor-rgb),.65); padding: var(--space-3) var(--space-4); background: rgba(var(--saleBadgeBackground-rgb),.04); border-radius: 4px; margin-bottom: var(--space-6); font-family: "JetBrains Mono", ui-monospace, monospace; letter-spacing: 0.03em; }

/* Differentiators */
.bbi-lp-quote .lp-diff { padding: var(--space-12) 0; border-top: 1px solid rgba(var(--borderColor-rgb),.6); border-bottom: 1px solid rgba(var(--borderColor-rgb),.6); }
.bbi-lp-quote .lp-diff__inner { max-width: 1280px; margin: 0 auto; padding: 0 var(--space-6); }
.bbi-lp-quote .lp-diff__head { margin-bottom: var(--space-8); max-width: 640px; }
.bbi-lp-quote .lp-diff__eyebrow { display: inline-flex; align-items: center; gap: var(--space-2); color: rgba(var(--textColor-rgb),.6); margin-bottom: var(--space-3); }
.bbi-lp-quote .lp-diff__eyebrow::before { content: ""; display: inline-block; width: 18px; height: 1px; background: var(--saleBadgeBackground); }
.bbi-lp-quote .lp-diff h2 { font-family: var(--headingFont); font-size: var(--fs-h2); line-height: var(--lh-h2); font-weight: 600; color: var(--headingColor); margin: 0; text-wrap: balance; }
.bbi-lp-quote .lp-diff__grid { display: grid; grid-template-columns: repeat(2,1fr); border-top: 1px solid rgba(var(--borderColor-rgb),.6); border-left: 1px solid rgba(var(--borderColor-rgb),.6); }
.bbi-lp-quote .lp-diff-card { background: var(--cardBackground); padding: var(--space-8); border-right: 1px solid rgba(var(--borderColor-rgb),.6); border-bottom: 1px solid rgba(var(--borderColor-rgb),.6); border-radius: 0; display: grid; grid-template-rows: auto auto auto 1fr; gap: var(--space-3); transition: background-color 160ms ease; }
.bbi-lp-quote .lp-diff-card:hover { background: rgba(var(--shadowColor-rgb),.02); }
.bbi-lp-quote .lp-diff-card__num { font-family: "JetBrains Mono",ui-monospace,monospace; font-size: 11px; letter-spacing: 0.08em; color: rgba(var(--textColor-rgb),.6); }
.bbi-lp-quote .lp-diff-card__icon { width: 32px; height: 32px; color: var(--textColor); display: flex; align-items: center; }
.bbi-lp-quote .lp-diff-card__label { font-family: var(--headingFont); font-size: 22px; line-height: 1.3; font-weight: 600; color: var(--headingColor); margin: 0; display: flex; flex-direction: column; gap: var(--space-2); }
.bbi-lp-quote .lp-diff-card__label::after { content: ""; display: block; width: 24px; height: 1px; background: var(--saleBadgeBackground); }
.bbi-lp-quote .lp-diff-card__sentence { font-size: 15px; line-height: 1.55; color: rgba(var(--textColor-rgb),.7); margin: 0; text-wrap: pretty; }

/* Proof bar */
.bbi-lp-quote .lp-proof-bar { background: var(--alternateBackground); border-top: 1px solid rgba(var(--borderColor-rgb),.6); border-bottom: 1px solid rgba(var(--borderColor-rgb),.6); }
.bbi-lp-quote .lp-proof-bar__inner { max-width: 1280px; margin: 0 auto; padding: var(--space-8) var(--space-6); display: grid; grid-template-columns: repeat(3,1fr); gap: var(--space-8); }
.bbi-lp-quote .lp-proof-bar__stat { display: flex; flex-direction: column; gap: var(--space-2); }
.bbi-lp-quote .lp-proof-bar__stat + .lp-proof-bar__stat { border-left: 1px solid rgba(var(--borderColor-rgb),.6); padding-left: var(--space-8); }
.bbi-lp-quote .lp-proof-bar__stat-num { font-family: var(--headingFont); font-size: 40px; line-height: 1; font-weight: 600; color: var(--headingColor); display: flex; align-items: center; gap: var(--space-3); }
.bbi-lp-quote .lp-proof-bar__stat-num::before { content: ""; display: inline-block; width: 14px; height: 1px; background: var(--saleBadgeBackground); }
.bbi-lp-quote .lp-proof-bar__stat-label { font-size: 13px; color: rgba(var(--textColor-rgb),.6); font-family: "JetBrains Mono",ui-monospace,monospace; letter-spacing: 0.04em; text-transform: uppercase; }
.bbi-lp-quote .lp-proof-bar__stat-detail { font-size: 14px; color: rgba(var(--textColor-rgb),.78); line-height: 1.5; margin-top: var(--space-2); }

/* OECM callout CTA spacing */
.bbi-lp-quote .lp-oecm-callout .bbi-btn--primary { margin-bottom: var(--space-3); }

/* FAQ */
.bbi-lp-quote .lp-faq { padding: var(--space-12) 0; background: var(--background); border-top: 1px solid rgba(var(--borderColor-rgb),.6); }
.bbi-lp-quote .lp-faq__inner { max-width: 880px; margin: 0 auto; padding: 0 var(--space-6); }
.bbi-lp-quote .lp-faq__head { margin-bottom: var(--space-6); }
.bbi-lp-quote .lp-faq__eyebrow { display: inline-flex; align-items: center; gap: var(--space-2); color: rgba(var(--textColor-rgb),.6); margin-bottom: var(--space-3); }
.bbi-lp-quote .lp-faq__eyebrow::before { content: ""; display: inline-block; width: 18px; height: 1px; background: var(--saleBadgeBackground); }
.bbi-lp-quote .lp-faq h2 { font-family: var(--headingFont); font-size: var(--fs-h2); line-height: var(--lh-h2); font-weight: 600; color: var(--headingColor); margin: 0; text-wrap: balance; }
.bbi-lp-quote .lp-faq__list { border-top: 1px solid rgba(var(--borderColor-rgb),.8); }
.bbi-lp-quote .lp-faq__item { border-bottom: 1px solid rgba(var(--borderColor-rgb),.8); }
.bbi-lp-quote .lp-faq__trigger { display: grid; grid-template-columns: auto 1fr auto; align-items: center; gap: var(--space-4); width: 100%; padding: var(--space-6) 0; background: transparent; border: none; text-align: left; cursor: pointer; font-family: var(--headingFont); font-size: 17px; font-weight: 600; color: var(--headingColor); }
.bbi-lp-quote .lp-faq__trigger:focus { outline: none; }
.bbi-lp-quote .lp-faq__trigger:focus-visible { outline: 2px solid var(--textColor); outline-offset: 2px; }
.bbi-lp-quote .lp-contact__channel:focus-visible { outline: 2px solid var(--textColor); outline-offset: 2px; border-color: var(--textColor); }
.bbi-lp-quote .lp-faq__trigger-num { font-family: "JetBrains Mono",ui-monospace,monospace; font-size: 11px; letter-spacing: 0.08em; color: rgba(var(--textColor-rgb),.55); font-weight: 400; }
.bbi-lp-quote .lp-faq__chevron { width: 16px; height: 16px; color: rgba(var(--textColor-rgb),.55); transition: transform 200ms ease; }
.bbi-lp-quote .lp-faq__item--open .lp-faq__chevron { transform: rotate(180deg); color: var(--textColor); }
.bbi-lp-quote .lp-faq__answer { display: none; padding: var(--space-4) 0 var(--space-5) calc(36px + var(--space-4)); font-size: 15px; line-height: 1.6; color: rgba(var(--textColor-rgb),.78); }
.bbi-lp-quote .lp-faq__item--open .lp-faq__answer { display: block; }
.bbi-lp-quote .lp-faq__answer p { margin: 0 0 var(--space-3); text-wrap: pretty; }
.bbi-lp-quote .lp-faq__answer p:last-child { margin-bottom: 0; }
.bbi-lp-quote .lp-faq__answer a { color: var(--linkColor); text-decoration: underline; text-underline-offset: 3px; }

/* Responsive */
@media (max-width: 980px) {
  .bbi-lp-quote .lp-hero__inner { grid-template-columns: 1fr; gap: var(--space-8); }
  .bbi-lp-quote .lp-hero__media { aspect-ratio: 16 / 10; }
  .bbi-lp-quote .lp-contact__inner { grid-template-columns: 1fr; gap: var(--space-8); }
  .bbi-lp-quote .lp-diff__grid { grid-template-columns: 1fr; }
  .bbi-lp-quote .lp-proof-bar__inner { grid-template-columns: 1fr; gap: var(--space-6); }
  .bbi-lp-quote .lp-proof-bar__stat + .lp-proof-bar__stat { border-left: none; border-top: 1px solid rgba(var(--borderColor-rgb),.6); padding-left: 0; padding-top: var(--space-6); }
  .bbi-lp-quote .bbi-cta-section__inner { grid-template-columns: 1fr; gap: 48px; }
}
@media (max-width: 640px) {
  .bbi-lp-quote .lp-hero { padding: var(--space-8) 0; }
  .bbi-lp-quote .lp-hero h1 { font-size: 32px; }
  .bbi-lp-quote .lp-hero__standfirst { font-size: 16px; }
  .bbi-lp-quote .lp-intro, .bbi-lp-quote .lp-diff, .bbi-lp-quote .lp-faq,
  .bbi-lp-quote .lp-contact { padding: var(--space-8) 0; }
  .bbi-lp-quote .lp-diff-card { padding: var(--space-6); }
  .bbi-lp-quote .lp-proof-bar__stat-num { font-size: 32px; }
  .bbi-lp-quote .bbi-cta-section__inner { padding: 64px 24px; }
}

/* ---- Header ---- */
.bbi-lp-quote .bbi-header{background:var(--headerBg);border-bottom:1px solid var(--borderColor);position:relative;z-index:10;}
.bbi-lp-quote .bbi-header__inner{max-width:1320px;margin:0 auto;padding:0 32px;height:72px;display:flex;align-items:center;gap:32px;}
.bbi-lp-quote .bbi-header__logo{display:inline-flex;align-items:center;height:40px;text-decoration:none;}
.bbi-lp-quote .bbi-header__logo img{height:36px;width:auto;}
.bbi-lp-quote .bbi-header__nav{display:flex;align-items:center;gap:4px;margin-left:16px;}
.bbi-lp-quote .bbi-nav-item{display:inline-flex;align-items:center;height:72px;padding:0 14px;color:var(--headerColor);font-size:14px;font-weight:500;text-decoration:none;position:relative;}
.bbi-lp-quote .bbi-nav-item:hover{color:var(--headerHoverColor);}
.bbi-lp-quote .bbi-nav-item.is-current::after{content:"";position:absolute;left:14px;right:14px;bottom:18px;height:1px;background:var(--textColor);}
.bbi-lp-quote .bbi-header__utility{margin-left:auto;display:flex;align-items:center;gap:16px;font-size:14px;}
.bbi-lp-quote .bbi-header__utility a:not(.bbi-btn){color:var(--headerColor);text-decoration:none;}

/* ---- Footer ---- */
.bbi-lp-quote .bbi-footer{--background:#0B0B0C;--background-rgb:11,11,12;--textColor:#FFFFFF;--textColor-rgb:255,255,255;--borderColor:#1F1F21;--borderColor-rgb:31,31,33;background:var(--background);color:var(--textColor);}
.bbi-lp-quote .bbi-footer__inner{max-width:1320px;margin:0 auto;padding:64px 32px 24px;}
.bbi-lp-quote .bbi-footer__top{display:grid;grid-template-columns:1.1fr 3fr;gap:64px;padding-bottom:48px;border-bottom:1px solid var(--borderColor);}
.bbi-lp-quote .bbi-footer__brand-plate{display:inline-block;background:#FFFFFF;padding:16px 20px;border-radius:8px;}
.bbi-lp-quote .bbi-footer__brand-plate img{height:44px;width:auto;display:block;}
.bbi-lp-quote .bbi-footer__tagline{margin:20px 0 16px;font-size:14px;line-height:1.55;max-width:32ch;color:rgba(var(--textColor-rgb),0.78);}
.bbi-lp-quote .bbi-footer__canadian{display:inline-flex;align-items:center;gap:8px;font-size:13px;}
.bbi-lp-quote .bbi-footer__canadian .leaf{width:14px;height:14px;color:#D4252A;}
.bbi-lp-quote .bbi-footer__cols{display:grid;grid-template-columns:repeat(4,1fr);gap:32px;}
.bbi-lp-quote .bbi-footer__col h4{font-family:var(--headingFont);font-size:13px;font-weight:600;letter-spacing:0.08em;text-transform:uppercase;margin:0 0 16px;}
.bbi-lp-quote .bbi-footer__col ul{list-style:none;margin:0;padding:0;display:flex;flex-direction:column;gap:8px;}
.bbi-lp-quote .bbi-footer__col a{color:rgba(var(--textColor-rgb),0.78);text-decoration:none;font-size:14px;}
.bbi-lp-quote .bbi-footer__col a:hover{color:var(--textColor);text-decoration:underline;}
.bbi-lp-quote .bbi-footer__col--contact .row{display:grid;grid-template-columns:80px 1fr;gap:8px;font-size:14px;margin-bottom:12px;line-height:1.45;}
.bbi-lp-quote .bbi-footer__col--contact .lbl{font-family:"JetBrains Mono",ui-monospace,monospace;font-size:11px;letter-spacing:0.06em;text-transform:uppercase;color:rgba(var(--textColor-rgb),0.55);padding-top:2px;}
.bbi-lp-quote .bbi-footer__col--contact .row a,.bbi-lp-quote .bbi-footer__col--contact .row span:not(.lbl){color:var(--textColor);}
.bbi-lp-quote .bbi-footer__bottom{padding-top:24px;display:flex;justify-content:space-between;align-items:center;font-size:12px;color:rgba(var(--textColor-rgb),0.55);}
.bbi-lp-quote .bbi-footer__legal{display:flex;gap:24px;}
.bbi-lp-quote .bbi-footer__legal a{color:rgba(var(--textColor-rgb),0.55);text-decoration:none;}
.bbi-lp-quote .bbi-footer__legal a:hover{color:var(--textColor);}
@media(max-width:980px){
  .bbi-lp-quote .bbi-footer__top{grid-template-columns:1fr;gap:var(--space-8);}
  .bbi-lp-quote .bbi-footer__cols{grid-template-columns:repeat(2,1fr);}
}
@media(max-width:640px){
  .bbi-lp-quote .bbi-footer__cols{grid-template-columns:1fr;}
}
</style>

