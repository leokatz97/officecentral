  ]
}
</script>

{%- assign _cta_url = section.settings.cta_primary_url | default: '/pages/contact' -%}
{%- assign _form_url = section.settings.form_url | default: '/pages/contact' -%}
{%- assign _email = section.settings.email | default: 'info@brantbusinessinteriors.com' -%}
{%- assign _hero_alt = section.settings.hero_image.alt | default: '' -%}

<div class="lp-quote scheme-default">

  {%- render 'bbi-nav', logo: section.settings.logo, active: 'services' -%}

  {%- render 'bbi-crumbs', c2_label: 'Request a Quote' -%}


  {%- comment -%} HERO {%- endcomment -%}
  <section class="lp-hero" aria-label="Hero">
    <div class="lp-hero__inner">
      <div class="lp-hero__text">
        <p class="lp-hero__eyebrow bbi-mono">
          <span class="lp-hero__eyebrow-label">{{ section.settings.hero_eyebrow }}</span>
        </p>
        <span class="lp-hero__badge">
          <span class="lp-hero__badge-dot"></span>
          {{ section.settings.hero_badge | default: 'We respond within 1 business day' }}
        </span>
        <h1>{{ section.settings.hero_heading | default: 'Your quote, back within 24 hours.' }}</h1>
        <p class="lp-hero__standfirst">{{ section.settings.hero_standfirst }}</p>
        <div class="lp-hero__cta-row">
          <a class="bbi-btn bbi-btn--primary bbi-btn--lg" href="{{ _cta_url }}">{{ section.settings.cta_primary_label | default: 'Request a Quote' }} <span class="arrow" aria-hidden="true">→</span></a>
          <a class="bbi-btn bbi-btn--secondary bbi-btn--lg" href="tel:{{ section.settings.phone_href }}" aria-label="Call Brant Business Interiors at {{ section.settings.phone }}">Call {{ section.settings.phone }}</a>
        </div>
      </div>
      <div class="lp-hero__media" aria-hidden="true">
        {%- if section.settings.hero_image != blank -%}
          {{ section.settings.hero_image | image_url: width: 900 | image_tag: loading: 'eager', width: 900, alt: _hero_alt }}
        {%- else -%}
          <div class="lp-hero__media-placeholder">Hero · 5:4 · Ontario workspace fit-out</div>
        {%- endif -%}
      </div>
    </div>
  </section>

  {%- comment -%} INTRO {%- endcomment -%}
  <section class="lp-intro" aria-label="How quoting works">
    <div class="lp-intro__inner">
      <p class="lp-intro__eyebrow bbi-mono">How it works</p>
      <h2>{{ section.settings.intro_heading | default: 'Send a scope. Get a quote. Place a PO.' }}</h2>
      <div class="lp-intro__body">
        <p>{{ section.settings.intro_para1 }}</p>
        <p>{{ section.settings.intro_para2 }}</p>
        <p>For larger fit-outs — full offices, multi-room schools, healthcare waiting areas — our designers work from your floor plan and return a furniture layout with the quote so you can show your team exactly what you&#8217;re buying before the PO is cut. <a href="/pages/design-services">Learn about our free design layout service &#x2192;</a></p>
      </div>
    </div>
  </section>

  {%- comment -%} BROWSE CATEGORIES (Session A standardization) {%- endcomment -%}
  <section class="lp-crosslinks" aria-label="Browse furniture categories before requesting a quote">
    <div class="lp-crosslinks__inner">
      <div class="lp-crosslinks__head">
        <p class="lp-crosslinks__eyebrow bbi-mono">Browse categories</p>
        <h2>Not sure what you need? Browse the catalog first.</h2>
      </div>
      <div class="lp-crosslinks__grid">

        <a href="/collections/seating" class="lp-crosslinks__tile">
          <span class="lp-crosslinks__tile-icon">
            <svg width="28" height="28" viewBox="0 0 28 28" fill="none" stroke="currentColor" stroke-width="1.3" aria-hidden="true"><path d="M7 13 V6 a3 3 0 0 1 3 -3 h8 a3 3 0 0 1 3 3 V13"/><path d="M5 13 H23 v6 H5 Z"/><path d="M8 19 V25 M20 19 V25"/></svg>
          </span>
          <span class="lp-crosslinks__tile-label">
            <span class="lp-crosslinks__tile-name">Seating</span>
            <span class="lp-crosslinks__tile-meta">Task &middot; executive &middot; lounge &middot; bariatric</span>
          </span>
          <span class="lp-crosslinks__tile-arrow">
            <svg width="18" height="18" viewBox="0 0 18 18" fill="none" stroke="currentColor" stroke-width="1.4" aria-hidden="true"><path d="M3 9 H15"/><path d="M10 4 L15 9 L10 14"/></svg>
          </span>
        </a>

        <a href="/collections/desks" class="lp-crosslinks__tile">
          <span class="lp-crosslinks__tile-icon">
            <svg width="28" height="28" viewBox="0 0 28 28" fill="none" stroke="currentColor" stroke-width="1.3" aria-hidden="true"><path d="M3 11 H25"/><path d="M5 11 V23 M23 11 V23"/><path d="M3 8 H25 V11 H3 Z"/></svg>
          </span>
          <span class="lp-crosslinks__tile-label">
            <span class="lp-crosslinks__tile-name">Desks &amp; Workstations</span>
            <span class="lp-crosslinks__tile-meta">Single &middot; L-shape &middot; sit-stand &middot; benching</span>
          </span>
          <span class="lp-crosslinks__tile-arrow">
            <svg width="18" height="18" viewBox="0 0 18 18" fill="none" stroke="currentColor" stroke-width="1.4" aria-hidden="true"><path d="M3 9 H15"/><path d="M10 4 L15 9 L10 14"/></svg>
          </span>
        </a>

        <a href="/collections/business-furniture" class="lp-crosslinks__tile">
          <span class="lp-crosslinks__tile-icon">
            <svg width="28" height="28" viewBox="0 0 28 28" fill="none" stroke="currentColor" stroke-width="1.3" aria-hidden="true"><rect x="4" y="6" width="20" height="16" rx="2"/><path d="M4 12 H24"/><path d="M10 6 V22 M18 6 V22"/></svg>
          </span>
          <span class="lp-crosslinks__tile-label">
            <span class="lp-crosslinks__tile-name">Full catalog</span>
            <span class="lp-crosslinks__tile-meta">Storage &middot; tables &middot; acoustic &middot; accessories</span>
          </span>
          <span class="lp-crosslinks__tile-arrow">
            <svg width="18" height="18" viewBox="0 0 18 18" fill="none" stroke="currentColor" stroke-width="1.4" aria-hidden="true"><path d="M3 9 H15"/><path d="M10 4 L15 9 L10 14"/></svg>
          </span>
        </a>

      </div>
    </div>
  </section>

  {%- comment -%} CONTACT SECTION + OECM CALLOUT {%- endcomment -%}
  <section class="lp-contact" aria-label="How to reach us">
    <div class="lp-contact__inner">

      <div>
        <p class="lp-contact__eyebrow bbi-mono">Get in touch</p>
        <h2>{{ section.settings.contact_heading | default: 'Three ways to start your quote.' }}</h2>
        <p class="lp-contact__body">{{ section.settings.contact_body }}</p>
        <div class="lp-contact__channels">

          <a class="lp-contact__channel" href="{{ _form_url }}">
            <span class="lp-contact__channel-icon">
              <svg width="20" height="20" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.4" aria-hidden="true"><rect x="2" y="4" width="16" height="13" rx="2"/><path d="M2 7 L10 12 L18 7"/></svg>
            </span>
            <span class="lp-contact__channel-label">
              <span class="lp-contact__channel-name">{{ section.settings.form_label | default: 'Online quote form' }}</span>
              <span class="lp-contact__channel-meta">{{ section.settings.form_meta }}</span>
            </span>
