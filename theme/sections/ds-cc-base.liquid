{%- comment -%}
  Section: ds-cc-base
  Purpose: Base section for all collection.category.json templates — the
           shared scaffold used by the Business Furniture vertical page and all
           9 category pages (Seating, Desks, Storage, Tables, Boardroom,
           Ergonomic Products, Panels & Dividers, Accessories, Quiet Spaces).
  Template: collection.category.json (base/fallback, empty blocks).
            Per-collection templates (collection.seating.json etc.) each pre-
            populate their own tile and brand_callout blocks via P2-* builds.
  Gate: theme.liquid bbi_landing gate — template == 'collection.category'
        suppresses Starlite header/footer (PB-9).
  Active nav: 'shop' — Shop Furniture is always the active item on category pages.
  Blocks:
    tile          (max 20) — sub-collection card: title, image, link, description
    brand_callout (max  2) — featured brand spotlight: name, logo, body, link
  Brand callout pairings (spec'd in site-architecture):
    Seating              → Keilhauer + ergoCentric
    Boardroom            → Keilhauer
    Ergonomic Products   → ergoCentric
    Desks & Workstations → Global / Teknion
    Panels & Dividers    → Global / Teknion
    All others           → none
  FIX-1: view_all CTA at bottom of tile grid (show_view_all_cta checkbox).
  Renders bbi-nav + bbi-footer snippets from NAV-2.
{%- endcomment -%}

{% # theme-check-disable RemoteAsset %}
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Inter+Tight:wght@600&family=Inter:wght@400;500;600&family=JetBrains+Mono:wght@400&display=swap" rel="stylesheet">
{% # theme-check-enable RemoteAsset %}

<style>
/* ============================================================
   BBI Design Tokens — DS v2
   ============================================================ */
:root {
  --bodyFont:"Inter",system-ui,-apple-system,"Segoe UI",Roboto,sans-serif;
  --headingFont:"Inter Tight","Inter",system-ui,sans-serif;
  --headingFontWeight:600;
  --space-1:4px;--space-2:8px;--space-3:12px;--space-4:16px;
  --space-6:24px;--space-8:32px;--space-12:48px;--space-16:64px;
  --inputRadius:4px;--buttonRadius:4px;--cardRadius:8px;--imageRadius:4px;
  --shadow-sm:0 1px 2px rgba(11,11,12,0.04),0 2px 8px rgba(11,11,12,0.05);
  --shadow-md:0 2px 4px rgba(11,11,12,0.05),0 12px 32px rgba(11,11,12,0.08);
  --saleBadgeBackground:#D4252A;--saleBadgeBackground-rgb:212,37,42;
  --fs-h0:44px;--lh-h0:1.05;--ls-h0:-0.02em;
  --fs-h1:32px;--lh-h1:1.1;--ls-h1:-0.015em;
  --fs-h2:24px;--lh-h2:1.15;--ls-h2:-0.01em;
  --fs-h3:18px;--lh-h3:1.25;--ls-h3:-0.005em;
  --fs-body:16px;--lh-body:1.55;--ls-body:0;
  --fs-small:13px;--lh-small:1.5;
  --fs-button:15px;--lh-button:1;--ls-button:0.01em;
  --headerBg:#FFFFFF;--headerColor:#0B0B0C;--headerHoverColor:#A81E22;
}
@media(min-width:768px){
  :root{
    --fs-h1:48px;--lh-h1:1.05;
    --fs-h2:32px;--lh-h2:1.1;
    --fs-h3:22px;--lh-h3:1.2;
    --fs-small:14px;
  }
}

/* ---- Page scope ---- */
.ds-cc{
  --background:#FFFFFF;--background-rgb:255,255,255;
  --alternateBackground:#FAFAFA;--alternateBackground-rgb:250,250,250;
  --cardBackground:#FFFFFF;--cardBackground-rgb:255,255,255;
  --textColor:#0B0B0C;--textColor-rgb:11,11,12;
  --linkColor:#0B0B0C;--linkColor-rgb:11,11,12;
  --headingColor:#0B0B0C;--headingColor-rgb:11,11,12;
  --buttonBackground:#0B0B0C;--buttonBackground-rgb:11,11,12;
  --buttonColor:#FFFFFF;--buttonColor-rgb:255,255,255;
  --buttonBorder:#0B0B0C;
  --buttonBackgroundHover:#D4252A;--buttonColorHover:#FFFFFF;--buttonBorderHover:#D4252A;
  --alternateButtonBackground:#FFFFFF;--alternateButtonColor:#0B0B0C;
  --alternateButtonBorder:#0B0B0C;
  --alternateButtonBackgroundHover:#0B0B0C;--alternateButtonColorHover:#FFFFFF;
  --borderColor:#E5E5E7;--borderColor-rgb:229,229,231;
  --shadowColor:#0B0B0C;--shadowColor-rgb:11,11,12;
  background:var(--background);color:var(--textColor);
  font-family:var(--bodyFont);font-size:var(--fs-body);
  line-height:var(--lh-body);-webkit-font-smoothing:antialiased;
}
.ds-cc *,.ds-cc *::before,.ds-cc *::after{box-sizing:border-box;}
.ds-cc img{display:block;max-width:100%;height:auto;}
.ds-cc a{color:var(--linkColor);}
.ds-cc .bbi-mono{font-family:"JetBrains Mono",ui-monospace,monospace;font-size:11px;letter-spacing:0.08em;text-transform:uppercase;}

/* ---- Shared inner container ---- */
.ds-cc__inner{max-width:1280px;margin:0 auto;padding:0 var(--space-6);}

/* ---- Buttons ---- */
.ds-cc .bbi-btn{
  display:inline-flex;align-items:center;justify-content:center;
  gap:var(--space-2);padding:12px 20px;min-height:44px;
  font-family:var(--bodyFont);font-size:var(--fs-button);
  line-height:var(--lh-button);letter-spacing:var(--ls-button);
  font-weight:600;border-radius:var(--buttonRadius);
  border:1px solid transparent;cursor:pointer;text-decoration:none;
  transition:background-color 120ms ease,color 120ms ease,border-color 120ms ease;
  white-space:nowrap;
}
.ds-cc .bbi-btn--lg{min-height:52px;padding:16px 24px;font-size:16px;}
.ds-cc .bbi-btn--primary{background:var(--buttonBackground);color:var(--buttonColor);border-color:var(--buttonBorder);}
.ds-cc .bbi-btn--primary:hover{background:var(--buttonBackgroundHover);color:var(--buttonColorHover);border-color:var(--buttonBorderHover);}
.ds-cc .bbi-btn--secondary{background:var(--alternateButtonBackground);color:var(--alternateButtonColor);border-color:var(--alternateButtonBorder);}
.ds-cc .bbi-btn--secondary:hover{background:var(--alternateButtonBackgroundHover);color:var(--alternateButtonColorHover);}
.ds-cc .bbi-btn--tertiary{background:transparent;color:var(--textColor);border-color:transparent;padding-left:4px;padding-right:4px;}
.ds-cc .bbi-btn--tertiary .label{position:relative;}
.ds-cc .bbi-btn--tertiary .label::after{content:"";position:absolute;left:0;right:0;bottom:-2px;height:1px;background:currentColor;}
.ds-cc .bbi-btn .arrow{display:inline-block;transform:translateY(-0.5px);}

/* ---- Hero ---- */
.ds-cc__hero{padding:var(--space-12) 0;border-bottom:1px solid rgba(var(--borderColor-rgb),0.6);}
.ds-cc__hero-inner{max-width:1280px;margin:0 auto;padding:0 var(--space-6);
  display:grid;grid-template-columns:minmax(0,1.05fr) minmax(0,1fr);
  gap:var(--space-12);align-items:center;}
.ds-cc__hero-text{max-width:560px;}
.ds-cc__hero-eyebrow{display:inline-flex;align-items:center;gap:var(--space-2);
  margin-bottom:var(--space-4);}
.ds-cc__hero-eyebrow::before{content:"";display:inline-block;width:18px;height:1px;
  background:var(--saleBadgeBackground);}
.ds-cc__hero-eyebrow-lbl{color:rgba(var(--textColor-rgb),0.6);}
.ds-cc__hero h1{font-family:var(--headingFont);font-size:var(--fs-h1);
  line-height:var(--lh-h1);letter-spacing:var(--ls-h1);font-weight:600;
  color:var(--headingColor);margin:0 0 var(--space-4);text-wrap:balance;}
.ds-cc__hero-standfirst{font-size:18px;line-height:1.55;
  color:rgba(var(--textColor-rgb),0.78);margin:0 0 var(--space-6);text-wrap:pretty;}
.ds-cc__hero-cta-row{display:flex;gap:var(--space-3);flex-wrap:wrap;margin-bottom:var(--space-4);}
.ds-cc__hero-micro{font-size:13px;color:rgba(var(--textColor-rgb),0.6);margin:0;}
.ds-cc__hero-micro a{color:var(--textColor);font-weight:600;text-decoration:none;}
.ds-cc__hero-micro a:hover{text-decoration:underline;}
.ds-cc__hero-media{position:relative;aspect-ratio:5/4;
  background:var(--alternateBackground);border-radius:var(--cardRadius);overflow:hidden;}
.ds-cc__hero-media img{width:100%;height:100%;object-fit:cover;}
.ds-cc__hero-ph{position:absolute;inset:0;display:flex;align-items:center;
  justify-content:center;
  background:repeating-linear-gradient(135deg,rgba(11,11,12,.04) 0 8px,rgba(11,11,12,.07) 8px 16px),var(--alternateBackground);
  font-family:"JetBrains Mono",ui-monospace,monospace;font-size:11px;
  letter-spacing:0.08em;text-transform:uppercase;color:rgba(var(--textColor-rgb),0.5);}

/* ---- Hero stats strip ---- */
.ds-cc__hero-stats{
  display:flex;flex-wrap:wrap;gap:var(--space-4) var(--space-6);
  margin-bottom:var(--space-6);list-style:none;padding:0;margin-top:0;
}
.ds-cc__hero-stats__item{flex:0 0 auto;}
.ds-cc__hero-stats__item dt{
  font-family:"JetBrains Mono",ui-monospace,monospace;
  font-size:10px;letter-spacing:0.08em;text-transform:uppercase;
  color:rgba(var(--textColor-rgb),0.5);margin:0 0 2px;
}
.ds-cc__hero-stats__item dd{
  font-family:var(--headingFont);font-size:22px;font-weight:600;
  line-height:1.1;letter-spacing:-0.01em;
  color:var(--headingColor);margin:0;
}
@media(min-width:768px){
  .ds-cc__hero-stats__item dd{font-size:26px;}
}

/* ---- Skip-by-sector bar ---- */
.ds-cc__skip-bar{padding:12px 0;border-bottom:1px solid rgba(var(--borderColor-rgb),0.6);background:var(--alternateBackground);}
.ds-cc__skip-bar-inner{display:flex;align-items:center;gap:var(--space-4);flex-wrap:wrap;}
.ds-cc__skip-bar-lbl{flex:0 0 auto;font-size:10px;color:rgba(var(--textColor-rgb),0.5);}
.ds-cc__skip-bar-chips{display:flex;gap:var(--space-2);flex-wrap:wrap;}
.ds-cc__skip-chip{
  display:inline-block;padding:6px 14px;
  border:1px solid rgba(var(--borderColor-rgb),0.9);border-radius:999px;
  font-size:13px;font-weight:500;color:var(--textColor);text-decoration:none;
  background:var(--cardBackground);white-space:nowrap;
  transition:border-color 120ms ease,background 120ms ease;
}
.ds-cc__skip-chip:hover{border-color:rgba(var(--textColor-rgb),0.4);background:var(--alternateBackground);}
.ds-cc__skip-chip:focus-visible{outline:2px solid var(--textColor);outline-offset:2px;}

/* ---- 30+ brands band ---- */
.ds-cc__brands-band{padding:14px 0;border-bottom:1px solid rgba(var(--borderColor-rgb),0.6);}
.ds-cc__brands-band-inner{display:flex;align-items:center;justify-content:space-between;gap:var(--space-4);flex-wrap:wrap;}
.ds-cc__brands-band-copy{font-size:14px;color:rgba(var(--textColor-rgb),0.7);margin:0;}
.ds-cc__brands-band-link{font-size:14px;font-weight:600;color:var(--textColor);text-decoration:none;white-space:nowrap;}
.ds-cc__brands-band-link:hover{text-decoration:underline;text-underline-offset:2px;}
.ds-cc__brands-band-link:focus-visible{outline:2px solid var(--textColor);outline-offset:2px;}

/* ---- Intro ---- */
.ds-cc__intro{padding:var(--space-12) 0;border-bottom:1px solid rgba(var(--borderColor-rgb),0.6);}
.ds-cc__intro-inner{max-width:880px;margin:0 auto;padding:0 var(--space-6);}
.ds-cc__intro-inner p{font-size:17px;line-height:1.6;
  color:rgba(var(--textColor-rgb),0.78);margin:0 0 var(--space-4);text-wrap:pretty;}
.ds-cc__intro-inner p:last-child{margin-bottom:0;}

/* ---- Sub-cat filter bar ---- */
.ds-cc__filter-bar{padding:var(--space-4) 0;border-bottom:1px solid rgba(var(--borderColor-rgb),0.6);}
.ds-cc__filter-bar-inner{display:flex;gap:var(--space-2);flex-wrap:wrap;align-items:center;overflow-x:auto;-webkit-overflow-scrolling:touch;scrollbar-width:none;}
.ds-cc__filter-bar-inner::-webkit-scrollbar{display:none;}
.ds-cc__filter-chip{
  display:inline-block;padding:7px 16px;
  border:1px solid rgba(var(--borderColor-rgb),0.9);border-radius:999px;
  font-size:13px;font-weight:500;color:var(--textColor);text-decoration:none;
  background:var(--cardBackground);white-space:nowrap;flex:0 0 auto;
  transition:border-color 120ms ease,background 120ms ease;
}
.ds-cc__filter-chip:hover{border-color:rgba(var(--textColor-rgb),0.4);background:var(--alternateBackground);}
.ds-cc__filter-chip:focus-visible{outline:2px solid var(--textColor);outline-offset:2px;}
.ds-cc__filter-pill-count{
  font-family:"JetBrains Mono",ui-monospace,monospace;
  font-size:11px;letter-spacing:0.04em;
  color:rgba(var(--textColor-rgb),0.55);
  margin-left:var(--space-1);
}

/* ---- Tile grid section ---- */
.ds-cc__tiles-section{padding:var(--space-12) 0;}
.ds-cc__tiles-grid{
  display:grid;
  grid-template-columns:repeat(auto-fill,minmax(220px,1fr));
  gap:var(--space-4);
  margin-bottom:var(--space-8);
}
/* Constrain very large grids so tiles don't get too wide */
@media(min-width:1200px){
  .ds-cc__tiles-grid{grid-template-columns:repeat(4,1fr);}
}

/* ---- Tile card ---- */
.ds-cc__tile{
  display:flex;flex-direction:column;
  background:var(--cardBackground);
  border:1px solid rgba(var(--borderColor-rgb),0.8);
  border-radius:var(--cardRadius);
  overflow:hidden;text-decoration:none;color:var(--textColor);
  transition:box-shadow 160ms ease,border-color 160ms ease,transform 160ms ease;
}
.ds-cc__tile:hover{
  box-shadow:var(--shadow-md);border-color:rgba(var(--borderColor-rgb),1);
  transform:translateY(-2px);
}
.ds-cc__tile-media{
  aspect-ratio:4/3;background:var(--alternateBackground);
  overflow:hidden;position:relative;flex:0 0 auto;
}
.ds-cc__tile-media img{width:100%;height:100%;object-fit:cover;
  transition:transform 240ms ease;}
.ds-cc__tile:hover .ds-cc__tile-media img{transform:scale(1.03);}
.ds-cc__tile-ph{
  position:absolute;inset:0;display:flex;align-items:center;justify-content:center;
  background:repeating-linear-gradient(45deg,rgba(var(--shadowColor-rgb),.04) 0 2px,transparent 2px 12px);
  font-family:"JetBrains Mono",ui-monospace,monospace;
  font-size:10px;letter-spacing:0.06em;text-transform:uppercase;
  color:rgba(var(--textColor-rgb),0.4);text-align:center;padding:8px;
}
.ds-cc__tile-body{
  padding:var(--space-4) var(--space-4) var(--space-4);
  display:flex;flex-direction:column;gap:4px;flex:1;
}
.ds-cc__tile-title{
  font-family:var(--headingFont);font-size:16px;font-weight:600;
  line-height:1.25;color:var(--headingColor);margin:0;
}
.ds-cc__tile-desc{
  font-size:13px;line-height:1.45;color:rgba(var(--textColor-rgb),0.65);
  margin:0;text-wrap:pretty;
}
.ds-cc__tile-arrow{
  font-size:14px;color:rgba(var(--textColor-rgb),0.4);margin-top:auto;
  display:inline-block;padding-top:var(--space-2);
  transition:transform 160ms ease,color 160ms ease;
}
.ds-cc__tile:hover .ds-cc__tile-arrow{transform:translateX(3px);color:var(--textColor);}

/* ---- Tile grid empty placeholder (Theme Editor only) ---- */
.ds-cc__tiles-empty{
  padding:var(--space-12);text-align:center;
  font-family:"JetBrains Mono",ui-monospace,monospace;
  font-size:11px;letter-spacing:0.08em;text-transform:uppercase;
  color:rgba(var(--textColor-rgb),0.35);
  border:1px dashed rgba(var(--borderColor-rgb),0.6);
  border-radius:var(--cardRadius);
}

/* ---- View all CTA ---- */
.ds-cc__view-all{text-align:center;padding-top:var(--space-4);}

/* ---- Brand callouts ---- */
.ds-cc__brands{
  padding:var(--space-12) 0;
  background:var(--alternateBackground);
  border-top:1px solid rgba(var(--borderColor-rgb),0.6);
  border-bottom:1px solid rgba(var(--borderColor-rgb),0.6);
}
.ds-cc__brands-grid{
  display:grid;gap:var(--space-6);
  grid-template-columns:repeat(auto-fill,minmax(320px,1fr));
}
.ds-cc__brand-card{
  background:var(--cardBackground);
  border:1px solid rgba(var(--borderColor-rgb),0.8);
  border-radius:var(--cardRadius);
  padding:var(--space-8);
  display:flex;flex-direction:column;gap:var(--space-3);
}
.ds-cc__brand-logo{margin-bottom:var(--space-2);}
.ds-cc__brand-logo img{height:36px;width:auto;}
.ds-cc__brand-name{
  font-family:var(--headingFont);font-size:var(--fs-h3);font-weight:600;
  color:var(--headingColor);margin:0;line-height:1.25;
}
.ds-cc__brand-body{
  font-size:15px;line-height:1.55;color:rgba(var(--textColor-rgb),0.75);
  margin:0;text-wrap:pretty;flex:1;
}

/* ---- Brand plates (8 per hub) ---- */
.ds-cc__brand-plates{
  padding:var(--space-12) 0;
  border-top:1px solid rgba(var(--borderColor-rgb),0.6);
}
.ds-cc__brand-plates-head{margin-bottom:var(--space-8);}
.ds-cc__brand-plates-eyebrow{
  font-family:"JetBrains Mono",ui-monospace,monospace;
  font-size:10px;letter-spacing:0.08em;text-transform:uppercase;
  color:rgba(var(--textColor-rgb),0.5);margin:0 0 var(--space-2);
  display:inline-flex;align-items:center;gap:var(--space-2);
}
.ds-cc__brand-plates-eyebrow::before{content:"";display:inline-block;width:18px;height:1px;background:var(--saleBadgeBackground);}
.ds-cc__brand-plates-heading{
  font-family:var(--headingFont);font-size:var(--fs-h3);font-weight:600;
  color:var(--headingColor);margin:0;
}
.ds-cc__brand-plates-grid{
  display:grid;
  grid-template-columns:repeat(auto-fill,minmax(180px,1fr));
  gap:var(--space-4);
}
@media(min-width:1200px){.ds-cc__brand-plates-grid{grid-template-columns:repeat(4,1fr);}}
.ds-cc__brand-plate{
  display:flex;flex-direction:column;gap:var(--space-2);
  background:var(--cardBackground);
  border:1px solid rgba(var(--borderColor-rgb),0.8);
  border-radius:var(--cardRadius);
  padding:var(--space-6) var(--space-4);
  text-decoration:none;color:var(--textColor);
  transition:box-shadow 160ms ease,border-color 160ms ease;
}
.ds-cc__brand-plate:hover{box-shadow:var(--shadow-sm);border-color:rgba(var(--textColor-rgb),0.2);}
.ds-cc__brand-plate:focus-visible{outline:2px solid var(--textColor);outline-offset:2px;}
.ds-cc__brand-plate-logo{height:32px;object-fit:contain;object-position:left center;}
.ds-cc__brand-plate-name{
  font-family:var(--headingFont);font-size:14px;font-weight:600;
  color:var(--headingColor);margin:0;
}
.ds-cc__brand-plate-badges{display:flex;gap:var(--space-2);flex-wrap:wrap;margin-top:var(--space-1);}
.bbi-badge--canadian{
  display:inline-flex;align-items:center;gap:4px;
  padding:3px 8px;
  border:1px solid rgba(var(--textColor-rgb),0.4);border-radius:4px;
  font-family:"JetBrains Mono",ui-monospace,monospace;
  font-size:10px;letter-spacing:0.06em;text-transform:uppercase;
  color:var(--textColor);background:transparent;
}
.bbi-badge--canadian .leaf{width:10px;height:10px;flex:0 0 auto;color:var(--saleBadgeBackground);}
.bbi-badge--oem{
  display:inline-flex;align-items:center;gap:4px;
  padding:3px 8px;
  border:1px solid rgba(var(--borderColor-rgb),1);border-radius:4px;
  font-family:"JetBrains Mono",ui-monospace,monospace;
  font-size:10px;letter-spacing:0.06em;text-transform:uppercase;
  color:rgba(var(--textColor-rgb),0.6);background:transparent;
}
@media(max-width:767px){.ds-cc__brand-plates-grid{grid-template-columns:repeat(2,1fr);}}

/* ---- Phone CTA closer ---- */
.ds-cc__phone-cta{
  --background:#0B0B0C;--background-rgb:11,11,12;
  --textColor:#FFFFFF;--textColor-rgb:255,255,255;
  --headingColor:#FFFFFF;--headingColor-rgb:255,255,255;
  --buttonBackground:#FFFFFF;--buttonColor:#0B0B0C;--buttonBorder:#FFFFFF;
  --buttonBackgroundHover:#D4252A;--buttonColorHover:#FFFFFF;--buttonBorderHover:#D4252A;
  background:var(--background);color:var(--textColor);
}
.ds-cc__phone-cta-inner{
  padding:var(--space-12) var(--space-6);
  display:flex;justify-content:space-between;align-items:center;
  gap:var(--space-8);flex-wrap:wrap;
}
.ds-cc__phone-cta-label{
  font-family:"JetBrains Mono",ui-monospace,monospace;
  font-size:11px;letter-spacing:0.08em;text-transform:uppercase;
  color:rgba(255,255,255,0.6);margin:0 0 var(--space-3);
}
.ds-cc__phone-num{
  display:block;font-family:var(--headingFont);font-size:var(--fs-h2);
  font-weight:600;color:#FFFFFF;text-decoration:none;line-height:1.1;
  margin-bottom:var(--space-2);
}
.ds-cc__phone-num:hover{text-decoration:underline;}
.ds-cc__phone-sub{font-size:13px;color:rgba(255,255,255,0.55);margin:0;}

/* ---- Product grid (paginated) ---- */
.ds-cc__product-grid-section{padding:var(--space-12) 0;border-top:1px solid rgba(var(--borderColor-rgb),0.6);}
.ds-cc__product-grid{
  display:grid;
  grid-template-columns:repeat(auto-fill,minmax(220px,1fr));
  gap:var(--space-4);
  margin-bottom:var(--space-8);
}
@media(min-width:1200px){.ds-cc__product-grid{grid-template-columns:repeat(4,1fr);}}
.ds-cc__product-card{
  display:flex;flex-direction:column;
  background:var(--cardBackground);
  border:1px solid rgba(var(--borderColor-rgb),0.8);
  border-radius:var(--cardRadius);
  overflow:hidden;text-decoration:none;color:var(--textColor);
  transition:box-shadow 160ms ease,border-color 160ms ease;
}
.ds-cc__product-card:hover{box-shadow:var(--shadow-sm);border-color:rgba(var(--textColor-rgb),0.2);}
.ds-cc__product-card-media{
  aspect-ratio:4/5;background:var(--alternateBackground);
  overflow:hidden;position:relative;flex:0 0 auto;
}
.ds-cc__product-card-media img{width:100%;height:100%;object-fit:cover;transition:transform 240ms ease;}
.ds-cc__product-card:hover .ds-cc__product-card-media img{transform:scale(1.03);}
.ds-cc__product-card-ph{
  position:absolute;inset:0;display:flex;align-items:center;justify-content:center;
  background:repeating-linear-gradient(45deg,rgba(var(--shadowColor-rgb),.03) 0 2px,transparent 2px 12px);
  font-family:"JetBrains Mono",ui-monospace,monospace;font-size:10px;
  letter-spacing:0.06em;text-transform:uppercase;color:rgba(var(--textColor-rgb),0.4);
  text-align:center;padding:8px;
}
.ds-cc__product-card-body{
  padding:var(--space-4);display:flex;flex-direction:column;gap:4px;flex:1;
}
.ds-cc__product-card-brand{font-size:11px;letter-spacing:0.06em;text-transform:uppercase;color:rgba(var(--textColor-rgb),0.55);margin:0;}
.ds-cc__product-card-title{font-family:var(--headingFont);font-size:14px;font-weight:600;line-height:1.3;color:var(--headingColor);margin:0;}
.ds-cc__product-card-price{font-size:13px;color:rgba(var(--textColor-rgb),0.7);margin:0;}
.ds-cc__product-card-cta{
  margin-top:auto;padding-top:var(--space-3);
}
.ds-cc__product-card-cta .bbi-btn{width:100%;justify-content:center;min-height:40px;font-size:13px;padding:10px 16px;}
.ds-cc__badge{
  position:absolute;top:var(--space-2);left:var(--space-2);
  padding:3px 8px;border-radius:4px;
  font-family:"JetBrains Mono",ui-monospace,monospace;
  font-size:10px;letter-spacing:0.06em;text-transform:uppercase;font-weight:600;
}
.ds-cc__badge--sold{background:rgba(90,90,94,1);color:#fff;}
.ds-cc__badge--sale{background:var(--saleBadgeBackground);color:#fff;}
/* Pagination */
.ds-cc__pagination{display:flex;justify-content:center;gap:var(--space-2);flex-wrap:wrap;}
.ds-cc__pagination a,.ds-cc__pagination span{
  display:inline-flex;align-items:center;justify-content:center;
  min-width:40px;min-height:40px;padding:8px 12px;
  border:1px solid rgba(var(--borderColor-rgb),0.9);border-radius:var(--buttonRadius);
  font-size:14px;font-weight:600;color:var(--textColor);text-decoration:none;
}
.ds-cc__pagination a:hover{background:var(--alternateBackground);}
.ds-cc__pagination span.current{background:var(--textColor);color:var(--buttonColor);border-color:var(--textColor);}
.ds-cc__pagination a:focus-visible{outline:2px solid var(--textColor);outline-offset:2px;}

/* ---- Responsive ---- */
@media(max-width:1023px){
  .ds-cc__hero-inner{grid-template-columns:1fr;gap:var(--space-8);}
  .ds-cc__hero-text{max-width:none;}
  .ds-cc__hero-media{aspect-ratio:16/9;}
}
@media(max-width:767px){
  .ds-cc__tiles-grid{grid-template-columns:repeat(2,1fr);gap:var(--space-3);}
  .ds-cc__brands-grid{grid-template-columns:1fr;}
  .ds-cc__phone-cta-inner{flex-direction:column;align-items:flex-start;}
  .ds-cc__inner{padding:0 var(--space-4);}
  .ds-cc__product-grid{grid-template-columns:repeat(2,1fr);gap:var(--space-3);}
}
@media(max-width:479px){
  .ds-cc__tiles-grid{grid-template-columns:1fr;}
  .ds-cc__product-grid{grid-template-columns:1fr;}
}
</style>

{%- comment -%}PAGE{%- endcomment -%}
<div class="ds-cc">

  {%- comment -%} ── Shared nav ── {%- endcomment -%}
  {%- render 'bbi-nav', logo: section.settings.logo, active: 'shop' -%}

  {%- liquid
    assign _cc_title      = section.settings.hero_title | default: collection.title
    assign _cc_parent_href = section.settings.breadcrumb_parent_url | default: '/collections/business-furniture'
  -%}
  {%- if section.settings.breadcrumb_parent_label != blank -%}
    {%- render 'bbi-crumbs', c2_label: section.settings.breadcrumb_parent_label, c2_href: _cc_parent_href, c3_label: _cc_title -%}
  {%- else -%}
    {%- render 'bbi-crumbs', c2_label: _cc_title -%}
  {%- endif -%}

  {%- comment -%} ── Hero ── {%- endcomment -%}
  <section class="ds-cc__hero" aria-labelledby="cc-hero-title">
    <div class="ds-cc__hero-inner">
      <div class="ds-cc__hero-text">
        <p class="ds-cc__hero-eyebrow">
          <span class="ds-cc__hero-eyebrow-lbl bbi-mono">Shop Furniture</span>
        </p>
        <h1 id="cc-hero-title">{{ section.settings.hero_title | default: collection.title | escape }}</h1>
        {%- if section.settings.hero_subtitle != blank -%}
          <p class="ds-cc__hero-standfirst">{{ section.settings.hero_subtitle | escape }}</p>
        {%- endif -%}

        {%- comment -%} Hero stats strip: derived from collection data + lead_time schema setting {%- endcomment -%}
        {%- liquid
          assign _stat_models = collection.products_count | default: 0
          assign _stat_brands = collection.products | map: 'vendor' | uniq | size
          assign _stat_canadian = 0
          for p in collection.products
            if p.tags contains 'canadian-made'
              assign _stat_canadian = _stat_canadian | plus: 1
            endif
          endfor
          assign _stat_instock = collection.products | where: 'available', true | size
          assign _stat_lead = section.settings.lead_time | default: '2–6 weeks'
        -%}
        <dl class="ds-cc__hero-stats">
          <div class="ds-cc__hero-stats__item">
            <dt>Models</dt>
            <dd>{{ _stat_models }}</dd>
          </div>
          <div class="ds-cc__hero-stats__item">
            <dt>Brands</dt>
            <dd>{{ _stat_brands }}</dd>
          </div>
          <div class="ds-cc__hero-stats__item">
            <dt>Canadian&#8209;made</dt>
            <dd>{{ _stat_canadian }}</dd>
          </div>
          <div class="ds-cc__hero-stats__item">
            <dt>In stock</dt>
            <dd>{{ _stat_instock }}</dd>
          </div>
          <div class="ds-cc__hero-stats__item">
            <dt>Lead time</dt>
            <dd>{{ _stat_lead }}</dd>
          </div>
        </dl>

        <div class="ds-cc__hero-cta-row">
          <a href="/collections/{{ collection.handle }}" class="bbi-btn bbi-btn--primary bbi-btn--lg">
            {{ section.settings.cta_label | default: 'Shop all ' | escape }}{{ section.settings.hero_title | default: collection.title | escape }}
          </a>
        </div>
        <p class="ds-cc__hero-micro">
          or call <a href="tel:18008359565"><strong>1-800-835-9565</strong></a>
        </p>
      </div>
      <div class="ds-cc__hero-media" aria-hidden="true">
        {%- if section.settings.hero_image != blank -%}
          {{- section.settings.hero_image | image_url: width: 840 | image_tag:
              loading: 'eager',
              widths: '400,600,840',
              alt: section.settings.hero_title | default: collection.title -}}
        {%- else -%}
          <div class="ds-cc__hero-ph">{{ section.settings.hero_title | default: collection.title | escape }}</div>
        {%- endif -%}
      </div>
    </div>
  </section>

  {%- comment -%} ── Skip-by-sector bar ── {%- endcomment -%}
  {%- if section.settings.show_sector_bar -%}
  <nav class="ds-cc__skip-bar" aria-label="Shop by sector">
    <div class="ds-cc__inner ds-cc__skip-bar-inner">
      <span class="ds-cc__skip-bar-lbl bbi-mono">Shop by sector</span>
      <div class="ds-cc__skip-bar-chips">
        <a class="ds-cc__skip-chip" href="/pages/healthcare">Healthcare</a>
        <a class="ds-cc__skip-chip" href="/pages/education">Education</a>
        <a class="ds-cc__skip-chip" href="/pages/government">Government</a>
        <a class="ds-cc__skip-chip" href="/pages/non-profit">Non-Profit</a>
        <a class="ds-cc__skip-chip" href="/pages/professional-services">Professional Services</a>
      </div>
    </div>
  </nav>
  {%- endif -%}

  {%- comment -%} ── 30+ brands band ── {%- endcomment -%}
  {%- if section.settings.show_brands_band -%}
  <div class="ds-cc__brands-band">
    <div class="ds-cc__inner ds-cc__brands-band-inner">
      <p class="ds-cc__brands-band-copy">30+ commercial furniture brands across 3 dealer tiers &middot; Ontario OECM partner</p>
      <a class="ds-cc__brands-band-link" href="/pages/brands">View all brands <span aria-hidden="true">&rarr;</span></a>
    </div>
  </div>
  {%- endif -%}

  {%- comment -%} ── Intro text (hidden when blank) ── {%- endcomment -%}
  {%- if section.settings.intro_text != blank -%}
    <section class="ds-cc__intro">
      <div class="ds-cc__intro-inner">
        {{ section.settings.intro_text }}
      </div>
    </section>
  {%- endif -%}

  {%- comment -%} ── Tile grid (rendered when grid_mode = tiles | both) ── {%- endcomment -%}
  {%- assign _grid_mode_tiles = section.settings.grid_mode | default: 'both' -%}
  {%- assign tile_count = 0 -%}
  {%- for block in section.blocks -%}
    {%- if block.type == 'tile' -%}{%- assign tile_count = tile_count | plus: 1 -%}{%- endif -%}
  {%- endfor -%}

  {%- comment -%} ── Sub-cat filter chips (nav pills, sourced from tile block links) ── {%- endcomment -%}
  {%- assign _filter_tiles = section.blocks | where: 'type', 'tile' -%}
  {%- if _filter_tiles.size > 1 and section.settings.show_filter_chips -%}
  <nav class="ds-cc__filter-bar" aria-label="Sub-categories">
    <div class="ds-cc__inner ds-cc__filter-bar-inner">
      {%- comment -%} "All" pill links to parent collection, shows total count {%- endcomment -%}
      <a class="ds-cc__filter-chip" href="{{ collection.url }}">
        All
        <span class="ds-cc__filter-pill-count">{{ collection.products_count }}</span>
      </a>
      {%- for block in section.blocks -%}
        {%- if block.type == 'tile' and block.settings.link != blank -%}
          {%- liquid
            assign _sub_raw = block.settings.link | remove: '/collections/'
            assign _sub_handle = _sub_raw | remove: '/'
            assign _sub_col = collections[_sub_handle]
          -%}
          <a class="ds-cc__filter-chip" href="{{ block.settings.link }}">
            {{ block.settings.title | escape }}
            {%- if _sub_col != nil -%}
              <span class="ds-cc__filter-pill-count">{{ _sub_col.products_count }}</span>
            {%- endif -%}
          </a>
        {%- endif -%}
      {%- endfor -%}
    </div>
  </nav>
  {%- endif -%}

  {%- if _grid_mode_tiles != 'products' -%}
  <section class="ds-cc__tiles-section" aria-labelledby="cc-tiles-heading">
    <div class="ds-cc__inner">
      {%- comment -%} Visually hidden heading for accessibility {%- endcomment -%}
      <h2 id="cc-tiles-heading" class="visually-hidden">{{ section.settings.hero_title | default: collection.title | escape }} categories</h2>

      {%- if tile_count > 0 -%}
        <div class="ds-cc__tiles-grid">
          {%- for block in section.blocks -%}
            {%- if block.type == 'tile' -%}
              <a href="{{ block.settings.link }}" class="ds-cc__tile" {{ block.shopify_attributes }}>
                <div class="ds-cc__tile-media">
                  {%- if block.settings.image != blank -%}
                    {{- block.settings.image | image_url: width: 600 | image_tag:
                        loading: 'lazy',
                        widths: '280,400,600',
                        alt: block.settings.title -}}
                  {%- else -%}
                    <div class="ds-cc__tile-ph">{{ block.settings.title | escape }}</div>
                  {%- endif -%}
                </div>
                <div class="ds-cc__tile-body">
                  <h3 class="ds-cc__tile-title">{{ block.settings.title | escape }}</h3>
                  {%- if block.settings.description != blank -%}
                    <p class="ds-cc__tile-desc">{{ block.settings.description | escape }}</p>
                  {%- endif -%}
                  <span class="ds-cc__tile-arrow" aria-hidden="true">→</span>
                </div>
              </a>
            {%- endif -%}
          {%- endfor -%}
        </div>
      {%- else -%}
        {%- comment -%} Placeholder visible only in Theme Editor before tiles are populated {%- endcomment -%}
        <div class="ds-cc__tiles-empty" aria-hidden="true">Add sub-category tiles in the Theme Editor</div>
      {%- endif -%}

      {%- comment -%} View all CTA — FIX 1: smart-collection escape hatch {%- endcomment -%}
      {%- if section.settings.show_view_all_cta -%}
        <div class="ds-cc__view-all">
          <a href="/collections/{{ collection.handle }}" class="bbi-btn bbi-btn--secondary">
            {{ section.settings.view_all_label | default: 'View all' | escape }}
          </a>
        </div>
      {%- endif -%}

    </div>
  </section>
  {%- endif -%}

  {%- comment -%} ── Product grid (grid_mode: products | both; suppressed for tiles-only) ── {%- endcomment -%}
  {%- assign _grid_mode = section.settings.grid_mode | default: 'both' -%}
  {%- if _grid_mode == 'products' or _grid_mode == 'both' -%}
    {%- assign _per_page = section.settings.products_per_page | default: 12 -%}
    {%- paginate collection.products by _per_page -%}
      {%- if collection.products_count > 0 -%}
      <section class="ds-cc__product-grid-section" aria-labelledby="cc-products-heading">
        <div class="ds-cc__inner">
          <h2 id="cc-products-heading" class="visually-hidden">{{ section.settings.hero_title | default: collection.title | escape }} products</h2>
          <div class="ds-cc__product-grid">
            {%- for product in collection.products -%}
              {%- liquid
                assign _buyable = true
                if product.available == false
                  assign _buyable = false
                endif
                if product.price == 0
                  assign _buyable = false
                endif
                if product.tags contains 'showcase'
                  assign _buyable = false
                endif
              -%}
              <a class="ds-cc__product-card" href="{{ product.url }}">
                <div class="ds-cc__product-card-media">
                  {%- if product.featured_image != blank -%}
                    {{- product.featured_image | image_url: width: 600 | image_tag:
                        loading: 'lazy',
                        widths: '280,400,600',
                        alt: product.featured_image.alt | default: product.title -}}
                  {%- else -%}
                    <div class="ds-cc__product-card-ph">{{ product.title | escape }}</div>
                  {%- endif -%}
                  {%- unless product.available -%}
                    <span class="ds-cc__badge ds-cc__badge--sold">Sold</span>
                  {%- endunless -%}
                  {%- if product.compare_at_price > product.price and product.available -%}
                    <span class="ds-cc__badge ds-cc__badge--sale">Sale</span>
                  {%- endif -%}
                </div>
                <div class="ds-cc__product-card-body">
                  {%- if product.vendor != blank -%}
                    <p class="ds-cc__product-card-brand">{{ product.vendor | escape }}</p>
                  {%- endif -%}
                  <p class="ds-cc__product-card-title">{{ product.title | escape }}</p>
                  {%- if _buyable -%}
                    <p class="ds-cc__product-card-price">From {{ product.price | money }}</p>
                  {%- endif -%}
                  <div class="ds-cc__product-card-cta">
                    {%- if _buyable -%}
                      <span class="bbi-btn bbi-btn--secondary">View product</span>
                    {%- else -%}
                      <span class="bbi-btn bbi-btn--primary">Request a Quote</span>
                    {%- endif -%}
                  </div>
                </div>
              </a>
            {%- endfor -%}
          </div>
          {%- if paginate.pages > 1 -%}
            <nav class="ds-cc__pagination" aria-label="Product pages">
              {%- if paginate.previous -%}
                <a href="{{ paginate.previous.url }}" aria-label="Previous page">&larr;</a>
              {%- endif -%}
              {%- for part in paginate.parts -%}
                {%- if part.is_link -%}
                  <a href="{{ part.url }}">{{ part.title }}</a>
                {%- else -%}
                  <span class="current">{{ part.title }}</span>
                {%- endif -%}
              {%- endfor -%}
              {%- if paginate.next -%}
                <a href="{{ paginate.next.url }}" aria-label="Next page">&rarr;</a>
              {%- endif -%}
            </nav>
          {%- endif -%}
        </div>
      </section>
      {%- endif -%}
    {%- endpaginate -%}
  {%- endif -%}

  {%- comment -%} ── Brand callouts (optional — max 2 per spec) ── {%- endcomment -%}
  {%- assign brand_count = 0 -%}
  {%- for block in section.blocks -%}
    {%- if block.type == 'brand_callout' -%}{%- assign brand_count = brand_count | plus: 1 -%}{%- endif -%}
  {%- endfor -%}

  {%- if brand_count > 0 -%}
    <section class="ds-cc__brands">
      <div class="ds-cc__inner">
        <div class="ds-cc__brands-grid">
          {%- for block in section.blocks -%}
            {%- if block.type == 'brand_callout' -%}
              <div class="ds-cc__brand-card" {{ block.shopify_attributes }}>
                {%- if block.settings.brand_logo != blank -%}
                  <div class="ds-cc__brand-logo">
                    {{- block.settings.brand_logo | image_url: width: 200 | image_tag:
                        loading: 'lazy',
                        widths: '100,200',
                        alt: block.settings.brand_name -}}
                  </div>
                {%- endif -%}
                {%- if block.settings.brand_name != blank -%}
                  <h3 class="ds-cc__brand-name">{{ block.settings.brand_name | escape }}</h3>
                {%- endif -%}
                {%- if block.settings.body != blank -%}
                  <p class="ds-cc__brand-body">{{ block.settings.body | escape }}</p>
                {%- endif -%}
                {%- if block.settings.link != blank -%}
                  <a href="{{ block.settings.link }}" class="bbi-btn bbi-btn--tertiary">
                    <span class="label">{{ block.settings.link_label | default: 'View brand' | escape }}</span>
                    <span class="arrow" aria-hidden="true">→</span>
                  </a>
                {%- endif -%}
              </div>
            {%- endif -%}
          {%- endfor -%}
        </div>
      </div>
    </section>
  {%- endif -%}

  {%- comment -%} ── Brand plates (8 per hub, data-derived from Phase 2) ── {%- endcomment -%}
  {%- assign brand_plate_count = 0 -%}
  {%- for block in section.blocks -%}
    {%- if block.type == 'brand_plate' and block.settings.brand_plate_name != blank -%}
      {%- assign brand_plate_count = brand_plate_count | plus: 1 -%}
    {%- endif -%}
  {%- endfor -%}
  {%- if brand_plate_count > 0 -%}
  <section class="ds-cc__brand-plates" aria-labelledby="cc-brand-plates-heading">
    <div class="ds-cc__inner">
      <div class="ds-cc__brand-plates-head">
        <p class="ds-cc__brand-plates-eyebrow">Authorized dealers</p>
        <h2 id="cc-brand-plates-heading" class="ds-cc__brand-plates-heading">Brands in this category</h2>
      </div>
      <div class="ds-cc__brand-plates-grid">
        {%- for block in section.blocks -%}
          {%- if block.type == 'brand_plate' and block.settings.brand_plate_name != blank -%}
            {%- assign _bp_href = block.settings.brand_plate_link | default: '/pages/brands' -%}
            <a class="ds-cc__brand-plate" href="{{ _bp_href }}" {{ block.shopify_attributes }}>
              {%- if block.settings.brand_plate_logo != blank -%}
                {{- block.settings.brand_plate_logo | image_url: width: 360 | image_tag:
                    class: 'ds-cc__brand-plate-logo',
                    loading: 'lazy',
                    widths: '180,360',
                    alt: block.settings.brand_plate_name -}}
              {%- endif -%}
              <p class="ds-cc__brand-plate-name">{{ block.settings.brand_plate_name | escape }}</p>
              <div class="ds-cc__brand-plate-badges">
                {%- if block.settings.brand_plate_canadian -%}
                  <span class="bbi-badge bbi-badge--canadian">
                    <svg class="leaf" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 2l1.2 4 3.4-1.2-1.2 3.4L19 10l-4 1.5 1 3-4-1.5-1 4-1-4-4 1.5 1-3-4-1.5 3.6-1.8L5.4 4.8 8.8 6 10 2z"/></svg>
                    Canadian
                  </span>
                {%- endif -%}
                <span class="bbi-badge bbi-badge--oem">Authorized</span>
              </div>
            </a>
          {%- endif -%}
        {%- endfor -%}
      </div>
    </div>
  </section>
  {%- endif -%}

  {%- comment -%} ── OECM bar (shared snippet) ── {%- endcomment -%}
  {%- render 'bbi-oecm-bar' -%}

  {%- comment -%} ── Phone CTA closer ── {%- endcomment -%}
  {%- if section.settings.show_phone_cta -%}
    <section class="ds-cc__phone-cta" aria-label="Contact">
      <div class="ds-cc__inner ds-cc__phone-cta-inner">
        <div>
          <p class="ds-cc__phone-cta-label bbi-mono">{{ section.settings.phone_cta_label | default: 'Speak with a furniture consultant' | escape }}</p>
          <a class="ds-cc__phone-num" href="tel:18008359565">1-800-835-9565</a>
          <p class="ds-cc__phone-sub">Mon–Fri 8am–5pm ET &middot; We respond within 1 business day</p>
        </div>
        <div>
          <a href="/pages/quote" class="bbi-btn bbi-btn--primary bbi-btn--lg">
            Request a Quote <span class="arrow" aria-hidden="true">→</span>
          </a>
        </div>
      </div>
    </section>
  {%- endif -%}

  {%- comment -%} ── Shared footer ── {%- endcomment -%}
  {%- render 'bbi-footer', logo: section.settings.logo -%}

</div>

{% schema %}
{
  "name": "BBI Category Page",
  "class": "shopify-section-ds-cc-base",
  "settings": [
    {
      "type": "header",
      "content": "Logo"
    },
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Logo",
      "info": "Appears in nav and footer. Leave blank to use text wordmark."
    },
    {
      "type": "header",
      "content": "Breadcrumb"
    },
    {
      "type": "text",
      "id": "breadcrumb_parent_label",
      "label": "Parent label",
      "info": "E.g. \"Shop Furniture\". Leave blank for 2-level breadcrumb (Home > [title])."
    },
    {
      "type": "url",
      "id": "breadcrumb_parent_url",
      "label": "Parent URL",
      "info": "E.g. /collections/business-furniture"
    },
    {
      "type": "header",
      "content": "Hero"
    },
    {
      "type": "text",
      "id": "hero_title",
      "label": "Title",
      "info": "Defaults to collection.title if blank."
    },
    {
      "type": "text",
      "id": "hero_subtitle",
      "label": "Subtitle / standfirst"
    },
    {
      "type": "image_picker",
      "id": "hero_image",
      "label": "Hero image",
      "info": "5:4 ratio recommended. Leave blank for placeholder."
    },
    {
      "type": "text",
      "id": "lead_time",
