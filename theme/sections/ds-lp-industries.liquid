{%- comment -%}
  Section: ds-lp-industries
  Purpose: Industries hub landing page — links to all 5 vertical pages
  Sections: breadcrumbs → hero → intro → differentiators (2×2) → trust photos → industry tiles → testimonial strip → CTA closer
  Used by: page.industries.json (template suffix: industries)
  Gate: theme.liquid bbi_landing gate — suppresses Starlite header/footer/cart
{%- endcomment -%}

{% # theme-check-disable RemoteAsset %}
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Inter+Tight:wght@600&family=Inter:wght@400;500;600&family=JetBrains+Mono:wght@400&display=swap" rel="stylesheet">
{% # theme-check-enable RemoteAsset %}

<style>
/* ============================================================
   BBI Design Tokens — DS v2
   ============================================================ */
:root {
  --bodyFont: "Inter", system-ui, -apple-system, "Segoe UI", Roboto, sans-serif;
  --headingFont: "Inter Tight", "Inter", system-ui, sans-serif;
  --headingFontWeight: 600;
  --space-1:4px;--space-2:8px;--space-3:12px;--space-4:16px;
  --space-6:24px;--space-8:32px;--space-12:48px;--space-16:64px;
  --inputRadius:4px;--buttonRadius:4px;--cardRadius:8px;
  --saleBadgeBackground:#D4252A;--saleBadgeBackground-rgb:212,37,42;
  --fs-h0:44px;--lh-h0:1.05;--ls-h0:-0.02em;
  --fs-h1:32px;--lh-h1:1.1;--ls-h1:-0.015em;
  --fs-h2:24px;--lh-h2:1.15;--ls-h2:-0.01em;
  --fs-h3:18px;--lh-h3:1.25;--ls-h3:-0.005em;
  --fs-body:16px;--lh-body:1.55;--ls-body:0;
  --fs-small:13px;--lh-small:1.5;
  --fs-button:15px;--lh-button:1;--ls-button:0.01em;
  --headerBg:#FFFFFF;--headerColor:#0B0B0C;
  --headerHoverColor:#A81E22;
}
@media(min-width:768px){
  :root{
    --fs-h1:48px;--lh-h1:1.05;
    --fs-h2:32px;--lh-h2:1.1;
    --fs-h3:22px;--lh-h3:1.2;
    --fs-small:14px;
  }
}
.lp-ind{
  --background:#FFFFFF;--background-rgb:255,255,255;
  --alternateBackground:#FAFAFA;--alternateBackground-rgb:250,250,250;
  --cardBackground:#FFFFFF;--cardBackground-rgb:255,255,255;
  --textColor:#0B0B0C;--textColor-rgb:11,11,12;
  --linkColor:#0B0B0C;--linkColor-rgb:11,11,12;
  --headingColor:#0B0B0C;--headingColor-rgb:11,11,12;
  --buttonBackground:#0B0B0C;--buttonBackground-rgb:11,11,12;
  --buttonColor:#FFFFFF;--buttonColor-rgb:255,255,255;
  --buttonBorder:#0B0B0C;
  --buttonBackgroundHover:#D4252A;--buttonColorHover:#FFFFFF;--buttonBorderHover:#D4252A;
  --alternateButtonBackground:#FFFFFF;--alternateButtonColor:#0B0B0C;
  --alternateButtonBorder:#0B0B0C;
  --alternateButtonBackgroundHover:#0B0B0C;--alternateButtonColorHover:#FFFFFF;
  --borderColor:#E5E5E7;--borderColor-rgb:229,229,231;
  --shadowColor:#0B0B0C;--shadowColor-rgb:11,11,12;
  background:var(--background);
  color:var(--textColor);
  font-family:var(--bodyFont);
  font-size:var(--fs-body);
  line-height:var(--lh-body);
  -webkit-font-smoothing:antialiased;
}
.lp-ind *,
.lp-ind *::before,
.lp-ind *::after{box-sizing:border-box;}
.lp-ind img{display:block;max-width:100%;height:auto;}
.lp-ind a{color:var(--linkColor);}

/* ---- Mono utility ---- */
.lp-ind .bbi-mono{
  font-family:"JetBrains Mono",ui-monospace,monospace;
  font-size:11px;letter-spacing:0.08em;text-transform:uppercase;
}

/* ---- Buttons ---- */
.lp-ind .bbi-btn{
  display:inline-flex;align-items:center;justify-content:center;
  gap:var(--space-2);padding:12px 20px;min-height:44px;
  font-family:var(--bodyFont);font-size:var(--fs-button);
  line-height:var(--lh-button);letter-spacing:var(--ls-button);
  font-weight:600;border-radius:var(--buttonRadius);
  border:1px solid transparent;cursor:pointer;text-decoration:none;
  transition:background-color 120ms ease,color 120ms ease,border-color 120ms ease;
  white-space:nowrap;
}
.lp-ind .bbi-btn--lg{min-height:52px;padding:16px 24px;font-size:16px;}
.lp-ind .bbi-btn--primary{
  background:var(--buttonBackground);color:var(--buttonColor);border-color:var(--buttonBorder);
}
.lp-ind .bbi-btn--primary:hover{
  background:var(--buttonBackgroundHover);color:var(--buttonColorHover);border-color:var(--buttonBorderHover);
}
.lp-ind .bbi-btn--secondary{
  background:var(--alternateButtonBackground);color:var(--alternateButtonColor);border-color:var(--alternateButtonBorder);
}
.lp-ind .bbi-btn--secondary:hover{
  background:var(--alternateButtonBackgroundHover);color:var(--alternateButtonColorHover);
}
.lp-ind .bbi-btn .arrow{display:inline-block;transform:translateY(-0.5px);}

/* ---- Crumbs ---- */
  display:flex;flex-wrap:wrap;gap:8px;align-items:center;
  font-size:13px;margin:0;padding:0;list-style:none;
}

/* ---- Hero ---- */
.lp-ind .lp-hero{padding:var(--space-12) 0;border-bottom:1px solid rgba(var(--borderColor-rgb),0.6);}
.lp-ind .lp-hero__inner{
  max-width:1280px;margin:0 auto;padding:0 var(--space-6);
  display:grid;grid-template-columns:minmax(0,1.05fr) minmax(0,1fr);
  gap:var(--space-12);align-items:center;
}
.lp-ind .lp-hero__text{max-width:560px;}
.lp-ind .lp-hero__eyebrow{
  display:inline-flex;align-items:center;gap:var(--space-2);margin-bottom:var(--space-4);
}
.lp-ind .lp-hero__eyebrow::before{
  content:"";display:inline-block;width:18px;height:1px;background:var(--saleBadgeBackground);
}
.lp-ind .lp-hero__eyebrow-label{color:rgba(var(--textColor-rgb),0.6);}
.lp-ind .lp-hero h1{
  font-family:var(--headingFont);font-size:var(--fs-h1);
  line-height:var(--lh-h1);letter-spacing:var(--ls-h1);
  font-weight:600;color:var(--headingColor);margin:0 0 var(--space-4);text-wrap:balance;
}
.lp-ind .lp-hero__standfirst{
  font-size:18px;line-height:1.55;color:rgba(var(--textColor-rgb),0.78);
  margin:0 0 var(--space-6);text-wrap:pretty;
}
.lp-ind .lp-hero__badge{
  display:inline-flex;align-items:center;gap:var(--space-2);
  padding:6px 12px;border:1px solid rgba(var(--borderColor-rgb),0.8);
  border-radius:999px;margin-bottom:var(--space-6);
  font-size:12px;color:rgba(var(--textColor-rgb),0.78);
}
.lp-ind .lp-hero__badge-dot{width:6px;height:6px;border-radius:50%;background:var(--saleBadgeBackground);}
.lp-ind .lp-hero__cta-row{display:flex;gap:var(--space-3);flex-wrap:wrap;}
.lp-ind .lp-hero__media{
  position:relative;aspect-ratio:5/4;
  background:var(--alternateBackground);border-radius:var(--cardRadius);overflow:hidden;
}
.lp-ind .lp-hero__media img{width:100%;height:100%;object-fit:cover;}
.lp-ind .lp-hero__ph{
  position:absolute;inset:0;display:flex;align-items:center;justify-content:center;
  background:repeating-linear-gradient(135deg,rgba(11,11,12,.04) 0 8px,rgba(11,11,12,.07) 8px 16px),var(--alternateBackground);
  font-family:"JetBrains Mono",ui-monospace,monospace;font-size:11px;
  letter-spacing:0.08em;text-transform:uppercase;color:rgba(var(--textColor-rgb),0.5);
}
.lp-ind .lp-hero__caption{
  position:absolute;left:var(--space-4);bottom:var(--space-4);
  background:rgba(var(--shadowColor-rgb),0.7);color:var(--background);
  padding:6px 10px;border-radius:4px;font-size:12px;
  display:inline-flex;align-items:center;gap:var(--space-2);
}
.lp-ind .lp-hero__caption-dot{width:4px;height:4px;border-radius:50%;background:var(--saleBadgeBackground);}

/* ---- Intro ---- */
.lp-ind .lp-intro{padding:var(--space-12) 0;}
.lp-ind .lp-intro__inner{max-width:1280px;margin:0 auto;padding:0 var(--space-6);}
.lp-ind .lp-intro__eyebrow{
  display:inline-flex;align-items:center;gap:var(--space-2);
  color:rgba(var(--textColor-rgb),0.6);margin-bottom:var(--space-4);
}
.lp-ind .lp-intro__eyebrow::before{
  content:"";display:inline-block;width:18px;height:1px;background:var(--saleBadgeBackground);
}
.lp-ind .lp-intro h2{
  font-family:var(--headingFont);font-size:var(--fs-h2);
  line-height:var(--lh-h2);font-weight:600;color:var(--headingColor);
  margin:0 0 var(--space-6);text-wrap:balance;
}
.lp-ind .lp-intro__body p{
  font-size:17px;line-height:1.6;color:rgba(var(--textColor-rgb),0.78);
  margin:0 0 var(--space-4);text-wrap:pretty;
}

/* ---- Differentiators ---- */
.lp-ind .lp-diff{
  padding:var(--space-12) 0;background:var(--alternateBackground);
  border-top:1px solid rgba(var(--borderColor-rgb),0.6);
  border-bottom:1px solid rgba(var(--borderColor-rgb),0.6);
}
.lp-ind .lp-diff__inner{max-width:1280px;margin:0 auto;padding:0 var(--space-6);}
.lp-ind .lp-diff__head{margin-bottom:var(--space-8);max-width:640px;}
.lp-ind .lp-diff__eyebrow{
  display:inline-flex;align-items:center;gap:var(--space-2);
  color:rgba(var(--textColor-rgb),0.6);margin-bottom:var(--space-3);
}
.lp-ind .lp-diff__eyebrow::before{
  content:"";display:inline-block;width:18px;height:1px;background:var(--saleBadgeBackground);
}
.lp-ind .lp-diff h2{
  font-family:var(--headingFont);font-size:var(--fs-h2);
  line-height:var(--lh-h2);font-weight:600;color:var(--headingColor);margin:0;text-wrap:balance;
}
.lp-ind .lp-diff__grid{
  display:grid;grid-template-columns:repeat(2,1fr);gap:0;
  border-top:1px solid rgba(var(--borderColor-rgb),0.6);
  border-left:1px solid rgba(var(--borderColor-rgb),0.6);
}
.lp-ind .lp-diff-card{
  background:var(--cardBackground);padding:var(--space-8);
  border-right:1px solid rgba(var(--borderColor-rgb),0.6);
  border-bottom:1px solid rgba(var(--borderColor-rgb),0.6);
  border-radius:0;display:grid;grid-template-rows:auto auto auto 1fr;
  gap:var(--space-3);transition:background-color 160ms ease;
}
.lp-ind .lp-diff-card:hover{background:rgba(var(--shadowColor-rgb),0.02);}
.lp-ind .lp-diff-card__num{
  font-family:"JetBrains Mono",ui-monospace,monospace;font-size:11px;
  letter-spacing:0.08em;color:rgba(var(--textColor-rgb),0.6);
}
.lp-ind .lp-diff-card__icon{width:32px;height:32px;color:var(--textColor);display:flex;align-items:center;}
.lp-ind .lp-diff-card__label{
  font-family:var(--headingFont);font-size:22px;line-height:1.3;font-weight:600;
  color:var(--headingColor);margin:0;display:flex;flex-direction:column;gap:var(--space-2);
}
.lp-ind .lp-diff-card__label::after{
  content:"";display:block;width:24px;height:1px;background:var(--saleBadgeBackground);
}
.lp-ind .lp-diff-card__sentence{
  font-size:15px;line-height:1.55;color:rgba(var(--textColor-rgb),0.7);margin:0;text-wrap:pretty;
}

/* ---- Trust row ---- */
.lp-ind .lp-trust-row{padding:var(--space-12) 0;}
.lp-ind .lp-trust-row__inner{max-width:1280px;margin:0 auto;padding:0 var(--space-6);}
.lp-ind .lp-trust-row__head{margin-bottom:var(--space-6);max-width:640px;}
.lp-ind .lp-trust-row__eyebrow{
  display:inline-flex;align-items:center;gap:var(--space-2);
  color:rgba(var(--textColor-rgb),0.6);margin-bottom:var(--space-3);
}
.lp-ind .lp-trust-row__eyebrow::before{
  content:"";display:inline-block;width:18px;height:1px;background:var(--saleBadgeBackground);
}
.lp-ind .lp-trust-row h2{
  font-family:var(--headingFont);font-size:var(--fs-h3);
  line-height:var(--lh-h3);font-weight:600;color:var(--headingColor);margin:0;
}
.lp-ind .lp-trust-row__grid{display:grid;grid-template-columns:repeat(3,1fr);gap:var(--space-4);}
.lp-ind .lp-trust-row__cell{
  position:relative;aspect-ratio:4/3;
  background:var(--alternateBackground);border-radius:var(--cardRadius);overflow:hidden;
}
.lp-ind .lp-trust-row__cell img{width:100%;height:100%;object-fit:cover;}
.lp-ind .lp-trust-row__ph{
  position:absolute;inset:0;display:flex;align-items:center;justify-content:center;
  background:repeating-linear-gradient(45deg,rgba(var(--shadowColor-rgb),.04) 0 2px,transparent 2px 12px);
  font-family:"JetBrains Mono",ui-monospace,monospace;font-size:11px;
  letter-spacing:0.08em;text-transform:uppercase;color:rgba(var(--textColor-rgb),0.5);
}
.lp-ind .lp-trust-row__caption{
  position:absolute;left:0;right:0;bottom:0;
  background:rgba(var(--shadowColor-rgb),0.85);color:#FFFFFF;
  padding:10px 14px;font-size:12px;line-height:1.4;
  display:flex;flex-direction:column;gap:2px;
}
.lp-ind .lp-trust-row__caption-key{
  font-family:"JetBrains Mono",ui-monospace,monospace;font-size:10px;
  letter-spacing:0.08em;text-transform:uppercase;color:rgba(255,255,255,0.6);
}

/* ---- Industry tiles ---- */
.lp-ind .lp-industries{
  padding:var(--space-12) 0;background:var(--alternateBackground);
  border-top:1px solid rgba(var(--borderColor-rgb),0.6);
}
.lp-ind .lp-industries__inner{max-width:1280px;margin:0 auto;padding:0 var(--space-6);}
.lp-ind .lp-industries__head{margin-bottom:var(--space-6);}
.lp-ind .lp-industries__eyebrow{
  display:inline-flex;align-items:center;gap:var(--space-2);
  color:rgba(var(--textColor-rgb),0.6);margin-bottom:var(--space-3);
}
.lp-ind .lp-industries__eyebrow::before{
  content:"";display:inline-block;width:18px;height:1px;background:var(--saleBadgeBackground);
}
.lp-ind .lp-industries h2{
  font-family:var(--headingFont);font-size:var(--fs-h3);
  line-height:var(--lh-h3);font-weight:600;color:var(--headingColor);margin:0;
}
.lp-ind .lp-industries__grid{display:grid;grid-template-columns:repeat(3,1fr);gap:var(--space-4);}
.lp-ind .bbi-card--collection{
  position:relative;display:block;aspect-ratio:4/3;
  text-decoration:none;color:inherit;overflow:hidden;
  border-radius:var(--cardRadius);background:var(--alternateBackground);
}
.lp-ind .bbi-card--collection .card-media{
  width:100%;height:100%;
}
.lp-ind .bbi-card--collection .card-media img{
  width:100%;height:100%;object-fit:cover;transition:transform 300ms ease;
}
.lp-ind .bbi-card--collection:hover .card-media img{transform:scale(1.03);}
.lp-ind .bbi-card--collection .card-ph{
  position:absolute;inset:0;
  background:repeating-linear-gradient(135deg,rgba(11,11,12,.04) 0 8px,rgba(11,11,12,.07) 8px 16px),var(--alternateBackground);
  display:flex;align-items:center;justify-content:center;
  font-family:"JetBrains Mono",ui-monospace,monospace;font-size:11px;
  letter-spacing:0.08em;text-transform:uppercase;color:rgba(var(--textColor-rgb),0.5);
}
.lp-ind .bbi-card--collection .card-overlay{
  position:absolute;left:0;right:0;bottom:0;
  padding:20px 20px 16px;
  background:linear-gradient(to top,rgba(var(--shadowColor-rgb),0.85),rgba(var(--shadowColor-rgb),0));
  color:#FFFFFF;
}
.lp-ind .bbi-card--collection .card-overlay h3{
  font-family:var(--headingFont);font-size:18px;font-weight:600;
  margin:0;line-height:1.2;letter-spacing:-0.01em;
}
.lp-ind .bbi-card--collection .card-overlay .card-meta{
  font-family:"JetBrains Mono",ui-monospace,monospace;
  font-size:11px;letter-spacing:0.08em;text-transform:uppercase;
  color:rgba(255,255,255,0.7);display:block;margin-top:2px;
}

/* ---- Testimonial strip ---- */
.lp-ind .lp-quote-strip{
  background:var(--alternateBackground);
  border-top:1px solid rgba(var(--borderColor-rgb),0.6);
  border-bottom:1px solid rgba(var(--borderColor-rgb),0.6);
  padding:var(--space-8) 0;
}
.lp-ind .lp-quote-strip__inner{
  max-width:1280px;margin:0 auto;padding:0 var(--space-6);
  display:flex;align-items:center;gap:var(--space-12);
}
.lp-ind .lp-quote-strip__quote{
  flex:1;font-size:18px;line-height:1.5;font-style:italic;
  color:rgba(var(--textColor-rgb),0.78);
}
.lp-ind .lp-quote-strip__quote cite{
  display:block;margin-top:var(--space-4);font-style:normal;
  font-size:13px;font-weight:600;color:rgba(var(--textColor-rgb),0.6);
  font-family:"JetBrains Mono",ui-monospace,monospace;
  letter-spacing:0.05em;text-transform:uppercase;
}
.lp-ind .lp-quote-strip__logo img{
  height:48px;width:auto;filter:grayscale(100%);opacity:0.65;
}

/* ---- CTA closer (inverse) ---- */
.lp-ind .lp-closer{
  --background:#0B0B0C;--background-rgb:11,11,12;
  --textColor:#FFFFFF;--textColor-rgb:255,255,255;
  --headingColor:#FFFFFF;--headingColor-rgb:255,255,255;
  --buttonBackground:#FFFFFF;--buttonColor:#0B0B0C;--buttonBorder:#FFFFFF;
  --buttonBackgroundHover:#D4252A;--buttonColorHover:#FFFFFF;--buttonBorderHover:#D4252A;
  background:var(--background);color:var(--textColor);
}
.lp-ind .lp-closer__inner{
  max-width:1320px;margin:0 auto;padding:96px 32px;
  display:grid;grid-template-columns:1.2fr 1fr;gap:64px;align-items:center;
}
.lp-ind .lp-closer__eyebrow{
  font-family:"JetBrains Mono",ui-monospace,monospace;font-size:12px;
  letter-spacing:0.08em;text-transform:uppercase;
  color:rgba(var(--textColor-rgb),0.7);margin:0 0 16px;
}
.lp-ind .lp-closer__heading{
  font-family:var(--headingFont);font-size:clamp(32px,4.2vw,56px);
  line-height:1.05;letter-spacing:-0.015em;font-weight:600;
  color:var(--headingColor);margin:0 0 20px;text-wrap:balance;
}
.lp-ind .lp-closer__sub{
  font-size:17px;line-height:1.55;color:rgba(var(--textColor-rgb),0.78);max-width:52ch;margin:0;
}
.lp-ind .lp-closer__actions{display:flex;flex-direction:column;gap:16px;align-items:flex-start;}
.lp-ind .lp-closer__trust{
  display:flex;align-items:flex-start;gap:10px;
  font-size:14px;color:rgba(var(--textColor-rgb),0.78);
}
.lp-ind .lp-closer__trust .dot{
  flex:0 0 auto;margin-top:7px;width:6px;height:6px;
  border-radius:99px;background:var(--saleBadgeBackground);
}
.lp-ind .lp-closer__trust b{color:var(--textColor);font-weight:600;}
.lp-ind .lp-closer__trust a{color:var(--textColor);text-decoration:underline;}

}
.lp-ind .bbi-footer__inner{max-width:1320px;margin:0 auto;padding:64px 32px 24px;}
.lp-ind .bbi-footer__top{
  display:grid;grid-template-columns:1.1fr 3fr;gap:64px;
  padding-bottom:48px;border-bottom:1px solid var(--borderColor);
}
.lp-ind .bbi-footer__brand-plate{
  display:inline-block;background:#FFFFFF;padding:16px 20px;border-radius:8px;
}
.lp-ind .bbi-footer__brand-plate img{height:44px;width:auto;display:block;}
.lp-ind .bbi-footer__tagline{
  margin:20px 0 16px;font-size:14px;line-height:1.55;
  max-width:32ch;color:rgba(var(--textColor-rgb),0.78);
}
.lp-ind .bbi-footer__canadian{display:inline-flex;align-items:center;gap:8px;font-size:13px;}
.lp-ind .bbi-footer__canadian .leaf{width:14px;height:14px;color:#D4252A;}
.lp-ind .bbi-footer__cols{display:grid;grid-template-columns:repeat(4,1fr);gap:32px;}
.lp-ind .bbi-footer__col h4{
  font-family:var(--headingFont);font-size:13px;font-weight:600;
  letter-spacing:0.08em;text-transform:uppercase;margin:0 0 16px;
}
.lp-ind .bbi-footer__col ul{list-style:none;margin:0;padding:0;display:flex;flex-direction:column;gap:8px;}
.lp-ind .bbi-footer__col a{color:rgba(var(--textColor-rgb),0.78);text-decoration:none;font-size:14px;}
.lp-ind .bbi-footer__col a:hover{color:var(--textColor);text-decoration:underline;}
.lp-ind .bbi-footer__col--contact .row{
  display:grid;grid-template-columns:80px 1fr;gap:8px;
  font-size:14px;margin-bottom:12px;line-height:1.45;
}
.lp-ind .bbi-footer__col--contact .lbl{
  font-family:"JetBrains Mono",ui-monospace,monospace;font-size:11px;
  letter-spacing:0.06em;text-transform:uppercase;color:rgba(var(--textColor-rgb),0.55);padding-top:2px;
}
.lp-ind .bbi-footer__col--contact .row a,.lp-ind .bbi-footer__col--contact .row span:not(.lbl){
  color:var(--textColor);
}
.lp-ind .bbi-footer__bottom{
  padding-top:24px;display:flex;justify-content:space-between;align-items:center;
  font-size:12px;color:rgba(var(--textColor-rgb),0.55);
}
.lp-ind .bbi-footer__legal{display:flex;gap:24px;}
.lp-ind .bbi-footer__legal a{color:rgba(var(--textColor-rgb),0.55);text-decoration:none;}
.lp-ind .bbi-footer__legal a:hover{color:var(--textColor);}

/* ---- Browse the catalogue ---- */
.lp-ind .lp-catalogue{
  padding:var(--space-12) 0;
