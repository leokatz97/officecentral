  .lp-ind .bbi-footer__top{grid-template-columns:1fr;gap:var(--space-8);}
  .lp-ind .bbi-footer__cols{grid-template-columns:repeat(2,1fr);}
  .lp-ind .lp-closer__inner{grid-template-columns:1fr;gap:var(--space-8);}
  .lp-ind .lp-quote-strip__inner{flex-direction:column;gap:var(--space-6);}
}
@media(max-width:640px){
