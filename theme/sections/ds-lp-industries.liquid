.lp-ind .bbi-footer__col a:hover{color:var(--textColor);text-decoration:underline;}
.lp-ind .bbi-footer__col--contact .row{
  display:grid;grid-template-columns:80px 1fr;gap:8px;
  font-size:14px;margin-bottom:12px;line-height:1.45;
}
.lp-ind .bbi-footer__col--contact .lbl{
