  .lp-ind .bbi-footer__cols{grid-template-columns:1fr;}
  .lp-ind .lp-closer__inner{padding:64px 24px;}
}

/* ---- Accessibility ---- */
.lp-ind :where(a,button,[role="button"]):focus-visible{
