{{ 'media-gallery.css' | asset_url | stylesheet_tag }}

<div class="scheme-{{ section.settings.color_scheme }} section-padding{% if section.settings.enable_gradient %} gradiant{% endif %}">
    <div class="{{ settings.layout_style }}">
      {% if section.settings.heading != blank %}
        {%- capture highlightPrefix -%}
          <span class="line-marker {% if section.settings.highlight_style == 'background' %}highlight-background {% if section.settings.bg__color == 'gradient' %}highlight-background-gradient{% else %}highlight-background-solid{% endif %}{% endif %}">
        {%- endcapture -%}
        {%- capture highlightSuffix -%}
          {% if section.settings.highlight_style != 'background' %}
            {% render 'marker', marker: section.settings.highlight_style %}
          {% endif %}
          </span>
        {%- endcapture -%}
        <div class="section-title {{ section.settings.heading_alignment }}">
              <{{ section.settings.seo_heading }} class="{{ section.settings.heading_size }} section-heading{% if section.settings.heading_animation %} linear-animation{% endif %}">
                {% if section.settings.heading_animation %}
                  {{ section.settings.heading }}
              {% else %} 
              {{ section.settings.heading | replace:"[", highlightPrefix | replace:"]",highlightSuffix }}
                {% endif %}
            </{{ section.settings.seo_heading }}>
        </div>
      {% endif %}
      {% if section.blocks.size > 0 %}
        <div class="media-gallery-wrapper{% if section.settings.enable_overlay %} enable-overlay{% endif %}">
          {% for block in section.blocks %}
            {%- liquid
           
            assign gridImageSize = section.settings.image_size
            if gridImageSize == 'landscape'
              assign gridImageRatio = 'var(--img-landscape)'
            elsif gridImageSize == 'square'
              assign gridImageRatio = 'var(--img-square)'
            elsif gridImageSize == 'portrait'
              assign gridImageRatio = 'var(--img-portrait)'
            else
              if block.settings.image != blank
                assign gridImageRatio = 1 | divided_by: block.settings.image.aspect_ratio | times: 100 | append: '%'
              elsif section.settings.video.preview_image != _blank
                assign gridImageRatio = 1 | divided_by: block.settings.video.preview_image.aspect_ratio | times: 100 | append: '%'
              else
                assign gridImageRatio = 100 | append: '%'
              endif
            endif
          -%}
            {%  capture blockHeading %} 
                <{{ block.settings.seo_heading }} class="media-gallery-heading {{ block.settings.heading_size }}">
                {{ block.settings.heading | replace:"[", highlightPrefix | replace:"]",highlightSuffix }}
                </{{ block.settings.seo_heading }}>
            {% endcapture %}
            <div class="media-gallery-item" id="media-gallery-{{ block.id }}">
                <div class="media-gallery-item-inner">
                  {% if block.settings.image != blank or block.settings.video != blank %}
                    <div class="media-gallery-image">
                        <div class="media" style="--imageRatio:{{ gridImageRatio }}" data-media="{% if block.settings.video != blank %}video{% else %}image{% endif %}">
                          {% if block.settings.video != blank %}
                            <deferred-media class="deferred-media">
                                <template style="display:none">
        
                                  {{ block.settings.video | video_tag:  image_size: '1100x',
                                    class: 'tabbed-collage-video', 
                                    autoplay: true,
                                    loop: true,
                                    controls: false,
                                    muted: true
                                }}
                                
                                </template>
                                  <div class="deferred-media-placeholder">
                                    {% render 'lazy-image', image: block.settings.video.preview_image, imageSize: 1920 %}
                                  </div>
                                 <noscript>
                                <a
                                  href="{{ block.settings.video | external_video_url }}"
                                  target="_blank"
                                  class="unstyled-link"
                                  aria-label="{{ block.settings.video.alt | default: product.title | strip_html }}"
                                >

                                  <img
                                    src="{{ block.settings.video.preview_image | image_url: width: 2048 }}"
                                    alt="{{ block.settings.video.preview_image.alt | escape }}"
                                    loading="lazy"
                                  >
                   
                                </a>
                              </noscript>
                              </deferred-media>
                            {% else block.settings.media_image != blank %}
                            {% render 'lazy-image', image: block.settings.image, class: 'media_image'%}
                          {% endif %}
                        </div>
                    </div>
                  {% else %}
                    <div class="media-gallery-image">
                      <div class="media" style="--imageRatio:{{ gridImageRatio }}">
                        {{ 'collection-apparel-' | append: forloop.index |placeholder_svg_tag: 'placeholder-svg' }}
                      </div>
                    </div>
                  {% endif %}
                  {% if block.settings.heading != blank %}
                    <div class="media-gallery-content">
                       {{ blockHeading }}
                    </div>
                  {% endif %}
                </div>
                {%liquid
                  assign show_des_div = false
                  if block.settings.heading != blank or block.settings.description != blank
                    assign show_des_div = true
                  elsif block.settings.btn_link != blank and block.settings.btn_text != blank
                    assign show_des_div = true
                  endif
                %}
                {% if show_des_div %}
                  <div class="media-gallery-hover-content">
                    {% if block.settings.heading != blank %}
                      {{ blockHeading }}
                    {% endif %}
                      {% if block.settings.description != blank %}
                        <p class="media-gallery-desc">{{ block.settings.description}}</p>
                      {% endif %}
                      {% if block.settings.btn_link != blank and block.settings.btn_text != blank %}
                        <div class="media-gallery-btn">
                        <a href="{{ block.settings.btn_link }}" class="{% if block.settings.button_as_link %}hyperlink {% else %} button medium-btn{% if settings.enable_button_shadow %} button-shadow{% endif %}{% endif %} " aria-label="{{ block.settings.btn_text }} " title="{{ block.settings.btn_text }}">{{block.settings.btn_text}}</a>
                        </div>
                      {% endif %}
                  </div>
                {% endif %}
            </div>
          {% endfor %}

        </div>
      {% endif %}
</div>
<style>
   {% if section.blocks.size > 0 %}
    {% for block in section.blocks %}
      #media-gallery-{{ block.id }}{
        --overlayBackground:{{ block.settings.background_color }};
        --headingColor:{{ block.settings.heading_color }};
        --textColor:{{ block.settings.text_color }};
      }
      {% endfor %}
    {% endif %}
   #shopify-section-{{ section.id }}{
    --padding-top: {{ section.settings.top_space_desktop}}px;
    --padding-bottom: {{ section.settings.bottom_space_desktop}}px;
  } 

  @media only screen and (max-width:767px) {
    #shopify-section-{{ section.id }}{
      --padding-top: {{ section.settings.top_space_mobile }}px !important;
      --padding-bottom: {{ section.settings.bottom_space_mobile }}px !important;
    }
  }
  {% if section.settings.section_visibility == 'large' %}
    @media (max-width: 767px) {
      #shopify-section-{{ section.id }}{
        display: none !important;
      }
    }
  {% elsif section.settings.section_visibility == 'small' %}
    @media (min-width: 768px) {
      #shopify-section-{{ section.id }}{
        display: none !important;
      }
    }
{% endif %}
</style>




{% schema %}
  {
    "name": "t:sections.media-gallery.name",
    "tag": "section",
    "class": "media-gallery-section",
    "disabled_on": {
      "groups": ["header", "footer"]
    },
    "max_blocks": 2,
    "settings": [
      {
        "type": "header",
        "content": "t:global.general_labels.general"
      },
      {
        "type": "select",
        "id": "section_visibility",
        "label": "t:global.section_visibility.label",
        "default": "always",
        "options": [
          {
            "label": "t:global.section_visibility.options.always.label",
            "value": "always"
          },
          { 
            "label": "t:global.section_visibility.options.small.label",
            "value": "small"
          },
          {
            "label": "t:global.section_visibility.options.large.label",
            "value": "large"
          }
        ]
      },
      {
      "type": "inline_richtext",
      "id": "heading",
      "label": "t:global.heading.label",
      "info": "t:global.heading.info",
      "default": "Media gallery"
    },
    {
      "type": "select",
      "id": "highlight_style",
      "label": "t:global.highlight_style.label",
      "default": "underline",
      "options": [
        {
          "value": "underline",
          "label": "t:global.highlight_style.options.underline.label"
        },
        {
          "value": "shape_2",
          "label": "t:global.highlight_style.options.shape_2.label"
        },
        {
          "value": "shape_3",
          "label": "t:global.highlight_style.options.shape_3.label"
        },
        {
          "value": "shape_4",
          "label": "t:global.highlight_style.options.shape_4.label"
        },
        {
          "value": "shape_5",
          "label": "t:global.highlight_style.options.shape_5.label"
        },
        {
          "value": "shape_6",
          "label": "t:global.highlight_style.options.shape_6.label"
        },
        {
          "value": "background",
          "label": "t:global.highlight_style.options.background.label"
        },
          {
            "value": "no_shape",
            "label": "t:global.highlight_style.options.no_shape.label"
          }
      ]
    },
    {
      "type": "select",
      "id": "bg__color",
      "label": "t:global.bg__color.label",
      "default": "gradient",
      "options": [
        {
          "value": "gradient",
          "label": "t:global.bg__color.options.gradient.label"
        },
        {
          "value": "solid",
          "label": "t:global.bg__color.options.solid.label"
        }
      ]
    },
    {
      "type":"checkbox",
      "id":"heading_animation",
      "label":"t:global.heading_animation.label",
      "info":"t:global.heading_animation.info"
    },
    {
      "type": "select",
      "id": "heading_size",
      "label": "t:global.heading.heading_size.label",
      "default": "h2",
      "options": [
        {
          "value": "h1",
          "label": "H1"
        },
        {
          "value": "h2",
          "label": "H2"
        },
        {
          "value": "h3",
          "label": "H3"
        },
        {
          "value": "h4",
          "label": "H4"
        },
        {
          "value": "h5",
          "label": "H5"
        },
        {
          "value": "h6",
          "label": "H6"
        }
      ]
    },
    {
      "type": "select",
      "id": "seo_heading",
      "default": "h2",
      "label": "t:global.heading.heading_tag.label",
      "info": "t:global.heading.heading_tag.info",
      "options": [
        {
          "value": "h1",
          "label": "H1"
        },
        {
          "value": "h2",
          "label": "H2"
        },
        {
          "value": "h3",
          "label": "H3"
        },
        {
          "value": "h4",
          "label": "H4"
        },
        {
          "value": "h5",
          "label": "H5"
        },
        {
          "value": "h6",
          "label": "H6"
        }
      ]
    },
    {
      "type": "select",
      "id": "heading_alignment",
      "label": "t:global.heading_alignment.label",
      "default": "text-left",
      "options": [
        {
          "label": "t:global.heading_alignment.options.left.label",
          "value": "text-left"
        },
        {
          "label": "t:global.heading_alignment.options.center.label",
          "value": "text-center"
        },
        {
          "label": "t:global.heading_alignment.options.right.label",
          "value": "text-right"
        }
      ]
    },
    {
        "type": "select",
        "id": "image_size",
        "label": "t:global.product_image_size.label",
        "default": "landscape",
        "options": [
          {
            "value": "auto",
            "label": "t:global.grid_image_size.options.auto.label"
          },
          {
            "value": "landscape",
            "label": "t:global.grid_image_size.options.landscape.label"
          },
          {
            "value": "portrait",
            "label": "t:global.grid_image_size.options.portrait.label"
          },
          {
            "value": "square",
            "label": "t:global.grid_image_size.options.square.label"
          }
        ]
      },
      {
      "type": "header",
      "content": "t:global.general_labels.color"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "default": "primary",
      "label": "t:global.color_scheme.label"
    },
    {
      "type": "checkbox",
      "id": "enable_gradient",
      "label": "t:global.general_labels.gradient",
      "default": false
    },
    {
      "type":"checkbox",
      "label":"t:sections.media-gallery.settings.enable_overlay.label",
      "default": true,
      "id": "enable_overlay"
    },
    {
      "type": "header",
      "content": "t:global.section_padding.label"
    },
    {
      "type": "range",
      "id": "top_space_desktop",
      "label": "t:global.section_padding.options.top_space_desktop.label",
      "default": 70,
      "min": 0,
      "max": 150,
      "step": 5
    },
    {
      "type": "range",
      "id": "bottom_space_desktop",
      "label": "t:global.section_padding.options.bottom_space_desktop.label",
      "default": 70,
      "min": 0,
      "max": 150,
      "step": 5
    },
    {
      "type": "range",
      "id": "top_space_mobile",
      "label": "t:global.section_padding.options.top_space_mobile.label",
      "default": 40,
      "min": 0,
      "max": 100,
      "step": 5
    },
    {
      "type": "range",
      "id": "bottom_space_mobile",
      "label": "t:global.section_padding.options.bottom_space_mobile.label",
      "default": 40,
      "min": 0,
      "max": 100,
      "step": 5
    }
      
    ],
    "blocks": [
      {
        "type": "card",
        "name": "t:sections.media-gallery.blocks.card.name",
        "limit":2,
        "settings": [
            {
              "type": "header",
              "content":"t:sections.media-gallery.blocks.card.settings.content.label"
            },
            {
              "type": "image_picker",
              "id": "image",
              "label": "t:global.general_labels.image"
            },
            {
              "type": "video",
              "id": "video",
              "label": "t:global.general_labels.shopify_video"
            },
            {
              "type": "header",
              "content":"t:global.general_labels.content"
            },
            {
              "type": "inline_richtext",
              "id": "heading",
              "label": "t:global.general_labels.heading",
              "default": "Heading"
            },
            {
              "type": "select",
              "id": "heading_size",
              "label": "t:global.heading.heading_size.label",
              "default": "h2",
              "options": [
                {
                  "value": "h1",
                  "label": "H1"
                },
                {
                  "value": "h2",
                  "label": "H2"
                },
                {
                  "value": "h3",
                  "label": "H3"
                },
                {
                  "value": "h4",
                  "label": "H4"
                },
                {
                  "value": "h5",
                  "label": "H5"
                },
                {
                  "value": "h6",
                  "label": "H6"
                }
              ]
            },
            {
              "type": "select",
              "id": "seo_heading",
              "default": "h2",
              "label": "t:global.heading.heading_tag.label",
              "info": "t:global.heading.heading_tag.info",
              "options": [
                {
                  "value": "h1",
                  "label": "H1"
                },
                {
                  "value": "h2",
                  "label": "H2"
                },
                {
                  "value": "h3",
                  "label": "H3"
                },
                {
                  "value": "h4",
                  "label": "H4"
                },
                {
                  "value": "h5",
                  "label": "H5"
                },
                {
                  "value": "h6",
                  "label": "H6"
                }
              ]
            },
            {
              "type": "inline_richtext",
              "id": "description",
              "label": "t:global.general_labels.description",
              "default": "Add short description here"
            },
            {
              "type": "header",
              "content": "t:global.general_labels.button"
            },
            {
              "type": "text",
              "id": "btn_text",
              "label": "t:global.general_labels.text",
              "default": "Button label"
            },
            {
              "type": "url",
              "id": "btn_link",
              "label": "t:global.general_labels.link"
            },
            {
              "type": "checkbox",
              "id": "button_as_link",
              "label": "t:global.general_labels.button_as_link",
              "default": false
            },
            {
            "type": "header",
            "content": "t:global.general_labels.colors"
            },
            {
              "type": "color",
              "id": "heading_color",
              "label": "t:global.general_labels.heading",
              "default": "#ffffff"
            },
            {
              "type": "color",
              "id": "text_color",
              "label": "t:global.general_labels.description",
              "default": "#ffffff"
            },
            {
              "type": "color",
              "id": "background_color",
              "label": "t:global.general_labels.background",
              "default": "#000000",
              "info":"t:sections.media-gallery.settings.enable_overlay.info"
            }
           
        ]
      }
    ],
    "presets": [
      {
        "name": "t:sections.media-gallery.name",
        "blocks":[
          {
            "type":"card"
          },
          {
            "type":"card"
          }
        ]
      }
    ]
  }
{% endschema %}