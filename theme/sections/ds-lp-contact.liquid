{%- comment -%}
  Section: ds-lp-contact
  Purpose: Contact page — location, phone, email, hours; directs to quote form
  Used by: page.contact.json (template suffix: contact)
  Gate: theme.liquid bbi_landing gate
{%- endcomment -%}

{% # theme-check-disable RemoteAsset %}
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Inter+Tight:wght@600&family=Inter:wght@400;500;600&family=JetBrains+Mono:wght@400&display=swap" rel="stylesheet">
{% # theme-check-enable RemoteAsset %}

<style>
:root{--bodyFont:"Inter",system-ui,-apple-system,"Segoe UI",Roboto,sans-serif;--headingFont:"Inter Tight","Inter",system-ui,sans-serif;--space-1:4px;--space-2:8px;--space-3:12px;--space-4:16px;--space-6:24px;--space-8:32px;--space-12:48px;--space-16:64px;--inputRadius:4px;--buttonRadius:4px;--cardRadius:8px;--saleBadgeBackground:#D4252A;--saleBadgeBackground-rgb:212,37,42;--fs-h0:44px;--lh-h0:1.05;--fs-h1:32px;--lh-h1:1.1;--ls-h1:-0.015em;--fs-h2:24px;--lh-h2:1.15;--fs-h3:18px;--lh-h3:1.25;--fs-body:16px;--lh-body:1.55;--fs-button:15px;--lh-button:1;--ls-button:0.01em;}
@media(min-width:768px){:root{--fs-h1:48px;--fs-h2:32px;--fs-h3:22px;}}
.lp-contact.scheme-default{--background:#FFFFFF;--background-rgb:255,255,255;--alternateBackground:#FAFAFA;--alternateBackground-rgb:250,250,250;--cardBackground:#FFFFFF;--textColor:#0B0B0C;--textColor-rgb:11,11,12;--linkColor:#0B0B0C;--headingColor:#0B0B0C;--headingColor-rgb:11,11,12;--buttonBackground:#0B0B0C;--buttonColor:#FFFFFF;--buttonBorder:#0B0B0C;--buttonBackgroundHover:#D4252A;--buttonColorHover:#FFFFFF;--buttonBorderHover:#D4252A;--alternateButtonBackground:#FFFFFF;--alternateButtonColor:#0B0B0C;--alternateButtonBorder:#0B0B0C;--alternateButtonBackgroundHover:#0B0B0C;--alternateButtonColorHover:#FFFFFF;--borderColor:#E5E5E7;--borderColor-rgb:229,229,231;--shadowColor:#0B0B0C;--shadowColor-rgb:11,11,12;--headerBg:#FFFFFF;--headerColor:#0B0B0C;--headerHoverColor:#D4252A;}
.lp-contact .scheme-inverse{--background:#0B0B0C;--textColor:#FFFFFF;--textColor-rgb:255,255,255;--linkColor:#FFFFFF;--headingColor:#FFFFFF;--headingColor-rgb:255,255,255;--buttonBackground:#FFFFFF;--buttonColor:#0B0B0C;--buttonBorder:#FFFFFF;--buttonBackgroundHover:#D4252A;--buttonColorHover:#FFFFFF;--buttonBorderHover:#D4252A;--alternateButtonBackground:transparent;--alternateButtonColor:#FFFFFF;--alternateButtonBorder:#FFFFFF;--borderColor:#1F1F21;}
.lp-contact *,.lp-contact *::before,.lp-contact *::after{box-sizing:border-box;}
.lp-contact{font-family:var(--bodyFont);font-size:var(--fs-body);line-height:var(--lh-body);color:var(--textColor);background:var(--background);-webkit-font-smoothing:antialiased;}
.lp-contact img{display:block;max-width:100%;height:auto;}
.lp-contact a{color:var(--linkColor);}
.lp-contact .bbi-mono{font-family:"JetBrains Mono",ui-monospace,monospace;font-size:11px;letter-spacing:0.08em;text-transform:uppercase;}
.lp-contact .bbi-btn{display:inline-flex;align-items:center;justify-content:center;gap:var(--space-2);padding:12px 20px;min-height:44px;font-family:var(--bodyFont);font-size:var(--fs-button);font-weight:600;border-radius:var(--buttonRadius);border:1px solid transparent;cursor:pointer;text-decoration:none;transition:background-color 120ms ease,color 120ms ease,border-color 120ms ease;white-space:nowrap;}
.lp-contact .bbi-btn:focus-visible{outline:2px solid var(--textColor);outline-offset:2px;}
.lp-contact .bbi-btn--lg{min-height:52px;padding:16px 24px;font-size:16px;}
.lp-contact .bbi-btn--primary{background:var(--buttonBackground);color:var(--buttonColor);border-color:var(--buttonBorder);}
.lp-contact .bbi-btn--primary:hover{background:var(--buttonBackgroundHover);color:var(--buttonColorHover);border-color:var(--buttonBorderHover);}
.lp-contact .bbi-btn--secondary{background:var(--alternateButtonBackground);color:var(--alternateButtonColor);border-color:var(--alternateButtonBorder);}
.lp-contact .bbi-btn--secondary:hover{background:var(--alternateButtonBackgroundHover);color:var(--alternateButtonColorHover);}
.lp-contact .bbi-crumbs{display:flex;flex-wrap:wrap;gap:8px;align-items:center;font-size:13px;margin:0;padding:0;list-style:none;}
.lp-contact .bbi-crumbs li{display:inline-flex;align-items:center;gap:8px;}
.lp-contact .bbi-crumbs li:not(:last-child)::after{content:">";opacity:0.4;}
.lp-contact .bbi-crumbs a{color:var(--textColor);opacity:0.65;text-decoration:none;}
.lp-contact .bbi-crumbs a:hover{opacity:1;text-decoration:underline;}
.lp-contact .bbi-crumbs li:last-child{font-weight:500;}
.lp-contact .lp-crumbs-band{border-bottom:1px solid rgba(var(--borderColor-rgb),0.6);}
.lp-contact .lp-crumbs-band__inner{max-width:1280px;margin:0 auto;padding:var(--space-3) var(--space-6);}
.lp-contact .lp-page-head{padding:var(--space-12) 0 var(--space-8);border-bottom:1px solid rgba(var(--borderColor-rgb),0.6);}
.lp-contact .lp-page-head__inner{max-width:1280px;margin:0 auto;padding:0 var(--space-6);}
.lp-contact .lp-page-head__eyebrow{display:inline-flex;align-items:center;gap:var(--space-2);margin-bottom:var(--space-4);}
.lp-contact .lp-page-head__eyebrow::before{content:"";display:inline-block;width:18px;height:1px;background:var(--saleBadgeBackground);}
.lp-contact .lp-page-head__eyebrow-label{color:rgba(var(--textColor-rgb),0.6);}
.lp-contact .lp-page-head h1{font-family:var(--headingFont);font-size:var(--fs-h1);line-height:var(--lh-h1);letter-spacing:var(--ls-h1);font-weight:600;color:var(--headingColor);margin:0 0 var(--space-4);max-width:22ch;}
.lp-contact .lp-page-head__sub{font-size:18px;line-height:1.55;color:rgba(var(--textColor-rgb),0.72);margin:0 0 var(--space-6);max-width:56ch;}
.lp-contact .lp-contact-main{padding:var(--space-12) 0;}
.lp-contact .lp-contact-main__inner{max-width:1280px;margin:0 auto;padding:0 var(--space-6);display:grid;grid-template-columns:1fr 1fr;gap:var(--space-12);}
.lp-contact .lp-contact-info{display:flex;flex-direction:column;gap:var(--space-8);}
.lp-contact .lp-contact-group{display:flex;flex-direction:column;gap:var(--space-3);}
.lp-contact .lp-contact-group__label{font-size:11px;font-family:"JetBrains Mono",ui-monospace,monospace;letter-spacing:0.08em;text-transform:uppercase;color:rgba(var(--textColor-rgb),0.5);margin:0;}
.lp-contact .lp-contact-group__value{font-size:17px;font-weight:600;color:var(--headingColor);margin:0;}
.lp-contact .lp-contact-group__value a{color:var(--headingColor);text-decoration:none;}
.lp-contact .lp-contact-group__value a:hover{color:var(--saleBadgeBackground);}
.lp-contact .lp-contact-group__detail{font-size:14px;color:rgba(var(--textColor-rgb),0.6);margin:0;}
.lp-contact .lp-contact-cta{background:var(--alternateBackground);border:1px solid rgba(var(--borderColor-rgb),0.6);border-radius:var(--cardRadius);padding:var(--space-8);display:flex;flex-direction:column;gap:var(--space-4);align-self:start;}
.lp-contact .lp-contact-cta__eyebrow{font-size:11px;font-family:"JetBrains Mono",ui-monospace,monospace;letter-spacing:0.08em;text-transform:uppercase;color:rgba(var(--textColor-rgb),0.5);margin:0;}
.lp-contact .lp-contact-cta h2{font-family:var(--headingFont);font-size:var(--fs-h2);font-weight:600;color:var(--headingColor);margin:0;}
.lp-contact .lp-contact-cta__body{font-size:16px;line-height:1.65;color:rgba(var(--textColor-rgb),0.72);margin:0;}
.lp-contact .lp-contact-cta__actions{display:flex;flex-direction:column;gap:var(--space-3);}
.lp-contact .lp-contact-cta__trust{font-size:12px;color:rgba(var(--textColor-rgb),0.5);}
.lp-contact .lp-oecm-bar{padding:var(--space-8) 0;background:rgba(var(--saleBadgeBackground-rgb),0.04);border-top:1px solid rgba(var(--saleBadgeBackground-rgb),0.12);border-bottom:1px solid rgba(var(--saleBadgeBackground-rgb),0.12);}
.lp-contact .lp-oecm-bar__inner{max-width:1280px;margin:0 auto;padding:0 var(--space-6);display:flex;align-items:center;gap:var(--space-6);flex-wrap:wrap;}
.lp-contact .lp-oecm-bar__badge{display:inline-flex;align-items:center;padding:6px 12px;background:var(--saleBadgeBackground);color:#fff;border-radius:4px;font-size:12px;font-weight:600;letter-spacing:0.04em;text-transform:uppercase;white-space:nowrap;}
.lp-contact .lp-oecm-bar__text{font-size:15px;color:rgba(var(--textColor-rgb),0.78);}
.lp-contact .lp-oecm-bar__text strong{color:var(--textColor);}
@media(max-width:1023px){.lp-contact .lp-contact-main__inner{grid-template-columns:1fr;}}
</style>

<div class="lp-contact scheme-default">
  {%- render 'bbi-nav', logo: section.settings.logo, active: 'about' -%}

  {%- comment -%} Breadcrumbs {%- endcomment -%}
  <div class="lp-crumbs-band">
    <div class="lp-crumbs-band__inner">
      <ol class="bbi-crumbs">
        <li><a href="/">Home</a></li>
        <li>Contact</li>
      </ol>
    </div>
  </div>

  {%- comment -%} Page Heading {%- endcomment -%}
  <section class="lp-page-head">
    <div class="lp-page-head__inner">
      <div class="lp-page-head__eyebrow">
        <span class="bbi-mono lp-page-head__eyebrow-label">Get in touch</span>
      </div>
      <h1>We're here — reach us by phone, email, or the quote form</h1>
      <p class="lp-page-head__sub">For product questions, project pricing, or a conversation about your space — the fastest path is a quote request. We respond within 1 business day.</p>
    </div>
  </section>

  {%- comment -%} Contact Info + CTA {%- endcomment -%}
  <section class="lp-contact-main">
    <div class="lp-contact-main__inner">

      <div class="lp-contact-info">
        <div class="lp-contact-group">
          <p class="lp-contact-group__label">Phone</p>
          <p class="lp-contact-group__value"><a href="tel:18008359565">1-800-835-9565</a></p>
          <p class="lp-contact-group__detail">Toll-free across Canada</p>
        </div>
        <div class="lp-contact-group">
          <p class="lp-contact-group__label">Email</p>
          <p class="lp-contact-group__value"><a href="mailto:info@brantbusinessinteriors.com">info@brantbusinessinteriors.com</a></p>
          <p class="lp-contact-group__detail">General inquiries, quotes, and project questions</p>
        </div>
        <div class="lp-contact-group">
          <p class="lp-contact-group__label">Showroom &amp; Head Office</p>
          <p class="lp-contact-group__value">295 George St N<br>Peterborough, ON K9J 3H2</p>
          <p class="lp-contact-group__detail">Brant Business Interiors · Part of the Office Central Group</p>
        </div>
        <div class="lp-contact-group">
          <p class="lp-contact-group__label">Business Hours</p>
          <p class="lp-contact-group__value">Monday – Friday, 8:00 am – 5:00 pm ET</p>
          <p class="lp-contact-group__detail">Closed statutory holidays</p>
        </div>
        <div class="lp-contact-group">
          <p class="lp-contact-group__label">OECM Purchasing</p>
          <p class="lp-contact-group__value"><a href="/pages/oecm">Agreement 2025-470</a></p>
          <p class="lp-contact-group__detail">Ontario public-sector buyers — purchase without open tender</p>
        </div>
      </div>

      <div class="lp-contact-cta">
        <p class="lp-contact-cta__eyebrow">Fastest path to a response</p>
        <h2>Request a quote — response in 1 business day</h2>
        <p class="lp-contact-cta__body">Tell us what you need — product type, quantity, timeline, and delivery location. Our team will put together a quote and reach out directly. No obligation.</p>
        <div class="lp-contact-cta__actions">
          <a href="/pages/quote" class="bbi-btn bbi-btn--primary bbi-btn--lg">Request a Quote <span style="display:inline-block;transform:translateY(-0.5px);">→</span></a>
          <a href="tel:18008359565" class="bbi-btn bbi-btn--secondary bbi-btn--lg">Call 1-800-835-9565</a>
        </div>
        <p class="lp-contact-cta__trust">OECM-eligible · Canadian-owned · Ontario-wide delivery</p>
      </div>

    </div>
  </section>

  {%- comment -%} OECM Bar {%- endcomment -%}
  <div class="lp-oecm-bar">
    <div class="lp-oecm-bar__inner">
      <span class="lp-oecm-bar__badge">OECM Supplier</span>
      <p class="lp-oecm-bar__text"><strong>OECM Agreement 2025-470</strong> — Ontario schools, hospitals, and government offices can purchase without an open tender process. <a href="/pages/oecm" style="color:var(--saleBadgeBackground);font-weight:600;text-decoration:none;">Learn about OECM purchasing →</a></p>
    </div>
  </div>
  {%- render 'bbi-footer', logo: section.settings.logo -%}

</div>

{% schema %}
{
  "name": "Contact Page",
  "class": "ds-lp-contact",
  "settings": [
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Logo"
    }
  ],
  "presets": [
    {
      "name": "Contact Page"
    }
  ]
}
{% endschema %}
