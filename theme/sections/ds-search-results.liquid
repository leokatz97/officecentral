{%- comment -%}
  Section: ds-search-results
  Purpose: BBI-styled search results page — products only, same card grid as ds-collection-base.
  Template: search.json
  Note: form passes type=product so search.results contains only products.
{%- endcomment -%}

<style>
.bbi-search {
  --background: #FFFFFF;
  --alternateBackground: #FAFAFA;
  --textColor: #0B0B0C;
  --borderColor: #E5E5E7;
  --cardBackground: #FFFFFF;
  --buttonBackground: #0B0B0C;
  --buttonColor: #FFFFFF;
  --buttonBackgroundHover: #D4252A;
  --saleBadgeBackground: #D4252A;
  --headerHoverColor: #A81E22;
  background: var(--background);
  color: var(--textColor);
  min-height: 60vh;
}
.bbi-search__inner {
  max-width: 1320px;
  margin: 0 auto;
  padding: 28px 32px 80px;
}

/* ── Breadcrumb ── */
.bbi-search__crumbs {
  display: flex;
  align-items: center;
  gap: 6px;
  font-size: 13px;
  color: rgba(11,11,12,.45);
  margin-bottom: 24px;
}
.bbi-search__crumbs a { color: rgba(11,11,12,.45); text-decoration: none; }
.bbi-search__crumbs a:hover { color: var(--textColor); }
.bbi-search__crumbs span { font-size: 11px; opacity: .6; }

/* ── Header ── */
.bbi-search__header { margin-bottom: 32px; }
.bbi-search__title {
  font-family: var(--headingFont, "Inter Tight", "Inter", sans-serif);
  font-size: clamp(22px, 3vw, 32px);
  font-weight: 700;
  letter-spacing: -0.02em;
  margin: 0 0 6px;
  line-height: 1.1;
}
.bbi-search__count {
  font-size: 13px;
  color: rgba(11,11,12,.45);
  margin: 0;
}

/* ── Refine search bar ── */
.bbi-search__refine {
  margin-bottom: 36px;
}
.bbi-search__refine-form {
  display: flex;
  align-items: center;
  max-width: 520px;
  height: 44px;
  border: 1.5px solid var(--borderColor);
  border-radius: 6px;
  background: #F7F7F8;
  overflow: hidden;
  transition: border-color 140ms ease, background 140ms ease;
}
.bbi-search__refine-form:focus-within {
  border-color: #0B0B0C;
  background: #ffffff;
}
.bbi-search__refine-icon {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 42px;
  flex-shrink: 0;
  color: rgba(11,11,12,.4);
  pointer-events: none;
}
.bbi-search__refine-input {
  flex: 1;
  min-width: 0;
  padding: 0 12px 0 0;
  height: 100%;
  font-family: var(--bodyFont, "Inter", system-ui, sans-serif);
  font-size: 14px;
  color: var(--textColor);
  background: none;
  border: none;
  outline: none;
}
.bbi-search__refine-input::placeholder { color: rgba(11,11,12,.38); }
.bbi-search__refine-submit {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 0 18px;
  height: 100%;
  background: var(--buttonBackground);
  color: var(--buttonColor);
  border: none;
  cursor: pointer;
  font-family: var(--bodyFont, "Inter", system-ui, sans-serif);
  font-size: 13px;
  font-weight: 600;
  flex-shrink: 0;
  transition: background-color 120ms ease;
}
.bbi-search__refine-submit:hover { background: #D4252A; }

/* ── Card image ── */
.bbi-search__grid .bbi-card__media {
  aspect-ratio: 1 / 1;
}
.bbi-search__grid .bbi-card__media img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  object-position: center;
}

/* ── Product grid ── */
.bbi-search__grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 20px;
}
@media (min-width: 640px) {
  .bbi-search__grid { grid-template-columns: repeat(3, 1fr); }
}
@media (min-width: 960px) {
  .bbi-search__grid { grid-template-columns: repeat(4, 1fr); }
}

/* ── Card price + quote ── */
.bbi-card__price {
  font-family: var(--headingFont, "Inter Tight", "Inter", sans-serif);
  font-size: 15px;
  font-weight: 700;
  margin: 4px 0 0;
  letter-spacing: -0.01em;
}
.bbi-card__price-compare {
  font-size: 12px;
  font-weight: 400;
  color: rgba(11,11,12,.4);
  text-decoration: line-through;
  margin-left: 6px;
}
.bbi-card__quote {
  display: inline-flex;
  align-items: center;
  margin-top: 8px;
  font-size: 13px;
  font-weight: 600;
  color: var(--textColor);
  text-decoration: none;
  gap: 4px;
}
.bbi-card__quote:hover { color: var(--headerHoverColor); }

/* ── Pagination ── */
.bbi-search__pagination {
  display: flex;
  justify-content: center;
  align-items: center;
  gap: 6px;
  padding-top: 48px;
}
.bbi-search__pagination a,
.bbi-search__pagination span {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 36px; height: 36px;
  border-radius: var(--buttonRadius, 4px);
  font-size: 14px;
  font-weight: 500;
  text-decoration: none;
  color: var(--textColor);
  border: 1px solid var(--borderColor);
  background: var(--background);
  transition: background-color 100ms ease, color 100ms ease;
}
.bbi-search__pagination a:hover { background: var(--alternateBackground); }
.bbi-search__pagination span.current {
  background: var(--buttonBackground);
  color: var(--buttonColor);
  border-color: var(--buttonBackground);
}
.bbi-search__pagination .prev,
.bbi-search__pagination .next { width: auto; padding: 0 14px; gap: 4px; }

/* ── Empty state ── */
.bbi-search__empty {
  text-align: center;
  padding: 80px 24px;
}
.bbi-search__empty-heading {
  font-family: var(--headingFont, "Inter Tight", "Inter", sans-serif);
  font-size: clamp(20px, 2.5vw, 26px);
  font-weight: 700;
  margin: 0 0 12px;
}
.bbi-search__empty-sub {
  font-size: 15px;
  color: rgba(11,11,12,.5);
  margin: 0 0 28px;
}

@media (max-width: 600px) {
  .bbi-search__inner { padding: 20px 16px 60px; }
  .bbi-search__grid { gap: 12px; }
}
</style>

{%- paginate search.results by 28 -%}

<div class="bbi-search">
  <div class="bbi-search__inner">

    {%- comment -%} Breadcrumb {%- endcomment -%}
    <nav class="bbi-search__crumbs" aria-label="Breadcrumb">
      <a href="/">Home</a>
      <span aria-hidden="true">›</span>
      <span>Search</span>
    </nav>

    {%- comment -%} Header {%- endcomment -%}
    <div class="bbi-search__header">
      {%- if search.performed and search.terms != blank -%}
        <h1 class="bbi-search__title">Results for "{{ search.terms | escape }}"</h1>
        <p class="bbi-search__count">{{ search.results_count }} product{%- if search.results_count != 1 -%}s{%- endif -%}</p>
      {%- else -%}
        <h1 class="bbi-search__title">Search Products</h1>
      {%- endif -%}
    </div>

    {%- comment -%} Refine search bar {%- endcomment -%}
    <div class="bbi-search__refine">
      <form class="bbi-search__refine-form" action="/search" method="get" role="search">
        <input type="hidden" name="type" value="product">
        <span class="bbi-search__refine-icon" aria-hidden="true">
          <svg width="16" height="16" viewBox="0 0 18 18" fill="none">
            <circle cx="7.5" cy="7.5" r="5.25" stroke="currentColor" stroke-width="1.75"/>
            <path d="M11.25 11.25L15.75 15.75" stroke="currentColor" stroke-width="1.75" stroke-linecap="round"/>
          </svg>
        </span>
        <input class="bbi-search__refine-input" type="search" name="q"
          value="{{ search.terms | escape }}"
          placeholder="Search chairs, desks, storage…"
          autocomplete="off" autocorrect="off" spellcheck="false"
          aria-label="Refine search">
        <button class="bbi-search__refine-submit" type="submit">Search</button>
      </form>
    </div>

    {%- if search.performed -%}

      {%- if search.results_count == 0 -%}

        <div class="bbi-search__empty">
          <p class="bbi-search__empty-heading">No products found for "{{ search.terms | escape }}"</p>
          <p class="bbi-search__empty-sub">Try a different search term, or browse all products below.</p>
          <a href="/collections/all" class="bbi-btn bbi-btn--primary">Browse all products</a>
        </div>

      {%- else -%}

        <div class="bbi-search__grid">
          {%- for item in search.results -%}

            {%- assign product = item -%}

            {%- comment -%} Skip products in the Other junk-drawer collections {%- endcomment -%}
            {%- assign in_other = false -%}
            {%- for coll in product.collections -%}
              {%- if coll.handle == 'other' or coll.handle == 'other-1' -%}
                {%- assign in_other = true -%}
              {%- endif -%}
            {%- endfor -%}
            {%- if in_other -%}{%- continue -%}{%- endif -%}

            {%- assign quote_only = false -%}
            {%- if product.price == 0 or product.available == false -%}
              {%- assign quote_only = true -%}
            {%- endif -%}

            {%- assign on_sale = false -%}
            {%- if product.compare_at_price > product.price and product.compare_at_price != blank -%}
              {%- assign on_sale = true -%}
            {%- endif -%}

            <article class="bbi-card bbi-card--product">

              <a href="{{ product.url }}" class="bbi-card__media" aria-label="{{ product.title | escape }}" tabindex="-1">
                {%- if product.featured_image != blank -%}
                  {%- assign img_alt = product.featured_image.alt | default: product.title | escape -%}
                  {{- product.featured_image | image_url: width: 600 | image_tag: loading: 'lazy', alt: img_alt, width: 600, height: 600 -}}
                {%- else -%}
                  {{ 'product-1' | placeholder_svg_tag: 'placeholder-svg' }}
                {%- endif -%}

                {%- if on_sale and quote_only == false -%}
                  <span class="bbi-badge bbi-badge--sale" aria-label="On sale">Sale</span>
                {%- endif -%}
              </a>

              <div class="bbi-card__body">
                {%- if product.vendor != blank -%}
                  <p class="bbi-card__brand">{{ product.vendor | escape }}</p>
                {%- endif -%}

                <h2 class="bbi-card__title">
                  <a href="{{ product.url }}">{{ product.title | escape }}</a>
                </h2>

                {%- if quote_only -%}
                  <a href="/pages/quote" class="bbi-card__quote">Request a Quote →</a>
                {%- else -%}
                  <p class="bbi-card__price">
                    {%- if product.price_varies -%}From {% endif -%}
                    {{- product.price | money -}}
                    {%- if on_sale -%}
                      <span class="bbi-card__price-compare">{{ product.compare_at_price | money }}</span>
                    {%- endif -%}
                  </p>
                {%- endif -%}
              </div>

            </article>

          {%- endfor -%}
        </div>

        {%- if paginate.pages > 1 -%}
          <nav class="bbi-search__pagination" aria-label="Pagination">
            {%- if paginate.previous -%}
              <a href="{{ paginate.previous.url }}" class="prev" aria-label="Previous page">← Prev</a>
            {%- endif -%}
            {%- for part in paginate.parts -%}
              {%- if part.is_link -%}
                <a href="{{ part.url }}">{{ part.title }}</a>
              {%- else -%}
                {%- if part.title == paginate.current_page -%}
                  <span class="current" aria-current="page">{{ part.title }}</span>
                {%- else -%}
                  <span>{{ part.title }}</span>
                {%- endif -%}
              {%- endif -%}
            {%- endfor -%}
            {%- if paginate.next -%}
              <a href="{{ paginate.next.url }}" class="next" aria-label="Next page">Next →</a>
            {%- endif -%}
          </nav>
        {%- endif -%}

      {%- endif -%}

    {%- endif -%}

  </div>
</div>

{%- endpaginate -%}

{% schema %}
{
  "name": "BBI Search Results",
  "class": "shopify-section-ds-search-results",
  "presets": [{ "name": "BBI Search Results" }]
}
{% endschema %}
