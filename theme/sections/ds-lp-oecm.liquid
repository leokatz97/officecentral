{%- comment -%}
  Section: ds-lp-oecm
  Purpose: OECM purchasing landing page — BBI Design System v2
  Sections: breadcrumbs → hero → intro → differentiators → trust row → proof bar → cross-links → FAQ → CTA closer
  JSON-LD: GovernmentService + FAQPage structured data
{%- endcomment -%}

{% # theme-check-disable RemoteAsset %}
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Inter+Tight:wght@600&family=Inter:wght@400;500;600&family=JetBrains+Mono:wght@400&display=swap" rel="stylesheet">
{% # theme-check-enable RemoteAsset %}

<style>
/* ============================================================
   BBI Design Tokens — DS v2
   ============================================================ */
:root {
  --bodyFont: "Inter", system-ui, -apple-system, "Segoe UI", Roboto, sans-serif;
  --headingFont: "Inter Tight", "Inter", system-ui, sans-serif;
  --headingFontWeight: 600;
  --headingFontLineHeight: 1.1;
  --space-1: 4px; --space-2: 8px; --space-3: 12px; --space-4: 16px;
  --space-6: 24px; --space-8: 32px; --space-12: 48px; --space-16: 64px;
  --inputRadius: 4px; --buttonRadius: 4px; --cardRadius: 8px;
  --shadow-sm: 0 1px 2px rgba(11,11,12,.04), 0 2px 8px rgba(11,11,12,.05);
  --shadow-md: 0 2px 4px rgba(11,11,12,.05), 0 12px 32px rgba(11,11,12,.08);
  --saleBadgeBackground: #D4252A;
  --saleBadgeBackground-rgb: 212,37,42;
  --fs-h0: 44px; --lh-h0: 1.05; --ls-h0: -0.02em;
  --fs-h1: 32px; --lh-h1: 1.1;  --ls-h1: -0.015em;
  --fs-h2: 24px; --lh-h2: 1.15; --ls-h2: -0.01em;
  --fs-h3: 18px; --lh-h3: 1.25; --ls-h3: -0.005em;
  --fs-body: 16px; --lh-body: 1.55;
  --fs-small: 13px; --lh-small: 1.5;
  --fs-button: 15px; --lh-button: 1; --ls-button: 0.01em;
}
@media (min-width: 768px) {
  :root {
    --fs-h0: 72px; --fs-h1: 48px; --lh-h1: 1.05;
    --fs-h2: 32px; --lh-h2: 1.1;
    --fs-h3: 22px; --lh-h3: 1.2;
    --fs-small: 14px;
  }
}
.bbi-lp-oecm.scheme-default {
  --background: #FFFFFF; --background-rgb: 255,255,255;
  --alternateBackground: #FAFAFA; --alternateBackground-rgb: 250,250,250;
  --cardBackground: #FFFFFF; --cardBackground-rgb: 255,255,255;
  --textColor: #0B0B0C; --textColor-rgb: 11,11,12;
  --linkColor: #0B0B0C; --headingColor: #0B0B0C; --headingColor-rgb: 11,11,12;
  --buttonBackground: #0B0B0C; --buttonBackground-rgb: 11,11,12;
  --buttonColor: #FFFFFF; --buttonBorder: #0B0B0C;
  --buttonBackgroundHover: #D4252A; --buttonColorHover: #FFFFFF; --buttonBorderHover: #D4252A;
  --alternateButtonBackground: #FFFFFF; --alternateButtonColor: #0B0B0C; --alternateButtonBorder: #0B0B0C;
  --alternateButtonBackgroundHover: #0B0B0C; --alternateButtonColorHover: #FFFFFF; --alternateButtonBorderHover: #0B0B0C;
  --borderColor: #E5E5E7; --borderColor-rgb: 229,229,231;
  --shadowColor: #0B0B0C; --shadowColor-rgb: 11,11,12;
}
.bbi-lp-oecm .scheme-inverse {
  --background: #0B0B0C; --background-rgb: 11,11,12;
  --alternateBackground: #161618; --alternateBackground-rgb: 22,22,24;
  --textColor: #FFFFFF; --textColor-rgb: 255,255,255;
  --linkColor: #FFFFFF; --headingColor: #FFFFFF; --headingColor-rgb: 255,255,255;
  --buttonBackground: #FFFFFF; --buttonBackground-rgb: 255,255,255;
  --buttonColor: #0B0B0C; --buttonBorder: #FFFFFF;
  --buttonBackgroundHover: #D4252A; --buttonColorHover: #FFFFFF; --buttonBorderHover: #D4252A;
  --alternateButtonBackground: transparent; --alternateButtonColor: #FFFFFF; --alternateButtonBorder: #FFFFFF;
  --alternateButtonBackgroundHover: #FFFFFF; --alternateButtonColorHover: #0B0B0C; --alternateButtonBorderHover: #FFFFFF;
  --borderColor: #1F1F21; --borderColor-rgb: 31,31,33;
  --shadowColor: #000000; --shadowColor-rgb: 0,0,0;
}

/* ============================================================
   Base + Shared Components
   ============================================================ */
.bbi-lp-oecm *, .bbi-lp-oecm *::before, .bbi-lp-oecm *::after { box-sizing: border-box; }
.bbi-lp-oecm { font-family: var(--bodyFont); font-size: var(--fs-body); line-height: var(--lh-body); color: var(--textColor); background: var(--background); -webkit-font-smoothing: antialiased; }
.bbi-lp-oecm img { display: block; max-width: 100%; height: auto; }
.bbi-lp-oecm a { color: var(--linkColor); text-decoration: none; }
.bbi-lp-oecm .bbi-mono { font-family: "JetBrains Mono", ui-monospace, monospace; font-size: 11px; letter-spacing: 0.08em; text-transform: uppercase; }
.bbi-lp-oecm .bbi-btn {
  display: inline-flex; align-items: center; justify-content: center;
  gap: var(--space-2); padding: 12px 20px; min-height: 44px;
  font-family: var(--bodyFont); font-size: var(--fs-button); line-height: var(--lh-button);
  letter-spacing: var(--ls-button); font-weight: 600; border-radius: var(--buttonRadius);
  border: 1px solid transparent; cursor: pointer; text-decoration: none;
  transition: background-color 120ms ease, color 120ms ease, border-color 120ms ease;
  white-space: nowrap;
}
.bbi-lp-oecm .bbi-btn:focus { outline: none; }
.bbi-lp-oecm .bbi-btn:focus-visible { outline: 2px solid var(--textColor); outline-offset: 2px; }
.bbi-lp-oecm .bbi-btn--lg { min-height: 52px; padding: 16px 24px; font-size: 16px; }
.bbi-lp-oecm .bbi-btn--primary { background: var(--buttonBackground); color: var(--buttonColor); border-color: var(--buttonBorder); }
.bbi-lp-oecm .bbi-btn--primary:hover { background: var(--buttonBackgroundHover); color: var(--buttonColorHover); border-color: var(--buttonBorderHover); }
.bbi-lp-oecm .bbi-btn--secondary { background: var(--alternateButtonBackground); color: var(--alternateButtonColor); border-color: var(--alternateButtonBorder); }
.bbi-lp-oecm .bbi-btn--secondary:hover { background: var(--alternateButtonBackgroundHover); color: var(--alternateButtonColorHover); border-color: var(--alternateButtonBorderHover); }

/* ============================================================
   CTA Section (reused by closer)
   ============================================================ */
.bbi-lp-oecm .bbi-cta-section { background: var(--background); color: var(--textColor); }
.bbi-lp-oecm .bbi-cta-section__inner {
  max-width: 1320px; margin: 0 auto; padding: 96px 32px;
  display: grid; grid-template-columns: 1.2fr 1fr; gap: 64px; align-items: center;
}
.bbi-lp-oecm .bbi-cta-section__eyebrow { font-family: "JetBrains Mono", ui-monospace, monospace; font-size: 12px; letter-spacing: 0.08em; text-transform: uppercase; color: rgba(var(--textColor-rgb),.7); margin: 0 0 16px; }
.bbi-lp-oecm .bbi-cta-section__heading { font-family: var(--headingFont); font-size: clamp(32px,4.2vw,56px); line-height: 1.05; letter-spacing: -0.015em; font-weight: 600; margin: 0 0 20px; text-wrap: balance; }
.bbi-lp-oecm .bbi-cta-section__sub { font-size: 17px; line-height: 1.55; color: rgba(var(--textColor-rgb),.78); max-width: 52ch; margin: 0; }
.bbi-lp-oecm .bbi-cta-section__actions { display: flex; flex-direction: column; gap: 16px; align-items: flex-start; }
.bbi-lp-oecm .bbi-cta-section__trust { display: flex; align-items: flex-start; gap: 10px; font-size: 14px; color: rgba(var(--textColor-rgb),.78); }
.bbi-lp-oecm .bbi-cta-section__trust .dot { flex: 0 0 auto; margin-top: 7px; width: 6px; height: 6px; border-radius: 99px; background: var(--saleBadgeBackground); }
.bbi-lp-oecm .bbi-cta-section__trust b { color: var(--textColor); font-weight: 600; }
.bbi-lp-oecm .bbi-cta-section__trust a { color: var(--textColor); text-decoration: underline; }

/* ============================================================
   Landing Page Sections
   ============================================================ */

/* Hero */
.bbi-lp-oecm .lp-hero { padding: var(--space-12) 0; border-bottom: 1px solid rgba(var(--borderColor-rgb),.6); }
.bbi-lp-oecm .lp-hero__inner { max-width: 1280px; margin: 0 auto; padding: 0 var(--space-6); display: grid; grid-template-columns: minmax(0,1.05fr) minmax(0,1fr); gap: var(--space-12); align-items: center; }
.bbi-lp-oecm .lp-hero__text { max-width: 560px; }
.bbi-lp-oecm .lp-hero__eyebrow { display: inline-flex; align-items: center; gap: var(--space-2); margin-bottom: var(--space-4); }
.bbi-lp-oecm .lp-hero__eyebrow::before { content: ""; display: inline-block; width: 18px; height: 1px; background: var(--saleBadgeBackground); }
.bbi-lp-oecm .lp-hero__eyebrow-label { color: rgba(var(--textColor-rgb),.6); }
.bbi-lp-oecm .lp-hero h1 { font-family: var(--headingFont); font-size: var(--fs-h1); line-height: var(--lh-h1); letter-spacing: var(--ls-h1); font-weight: 600; color: var(--headingColor); margin: 0 0 var(--space-4); text-wrap: balance; }
.bbi-lp-oecm .lp-hero__standfirst { font-size: 18px; line-height: 1.55; color: rgba(var(--textColor-rgb),.78); margin: 0 0 var(--space-6); text-wrap: pretty; }
.bbi-lp-oecm .lp-hero__badge { display: inline-flex; align-items: center; gap: var(--space-2); padding: 6px 12px; border: 1px solid rgba(var(--borderColor-rgb),.8); border-radius: 999px; margin-bottom: var(--space-6); font-size: 12px; color: rgba(var(--textColor-rgb),.78); }
.bbi-lp-oecm .lp-hero__badge-dot { width: 6px; height: 6px; border-radius: 50%; background: var(--saleBadgeBackground); }
.bbi-lp-oecm .lp-hero__cta-row { display: flex; gap: var(--space-3); flex-wrap: wrap; }
.bbi-lp-oecm .lp-hero__media { position: relative; aspect-ratio: 5 / 4; background: var(--alternateBackground); border-radius: var(--cardRadius); overflow: hidden; }
.bbi-lp-oecm .lp-hero__media img { width: 100%; height: 100%; object-fit: cover; }
.bbi-lp-oecm .lp-hero__media-placeholder { position: absolute; inset: 0; display: flex; align-items: center; justify-content: center; background: repeating-linear-gradient(135deg,rgba(var(--shadowColor-rgb),.03) 0 8px,rgba(var(--shadowColor-rgb),.07) 8px 16px),var(--alternateBackground); color: rgba(var(--textColor-rgb),.5); font-family: "JetBrains Mono",ui-monospace,monospace; font-size: 11px; letter-spacing: 0.08em; text-transform: uppercase; }
.bbi-lp-oecm .lp-hero__caption { position: absolute; left: var(--space-4); bottom: var(--space-4); background: rgba(var(--shadowColor-rgb),.7); color: #fff; padding: 6px 10px; border-radius: 4px; font-size: 12px; display: inline-flex; align-items: center; gap: var(--space-2); }
.bbi-lp-oecm .lp-hero__caption-dot { width: 4px; height: 4px; border-radius: 50%; background: var(--saleBadgeBackground); }

/* Intro */
.bbi-lp-oecm .lp-intro { padding: var(--space-12) 0; }
.bbi-lp-oecm .lp-intro__inner { max-width: 880px; margin: 0 auto; padding: 0 var(--space-6); }
.bbi-lp-oecm .lp-intro__eyebrow { display: inline-flex; align-items: center; gap: var(--space-2); color: rgba(var(--textColor-rgb),.6); margin-bottom: var(--space-4); }
.bbi-lp-oecm .lp-intro__eyebrow::before { content: ""; display: inline-block; width: 18px; height: 1px; background: var(--saleBadgeBackground); }
.bbi-lp-oecm .lp-intro h2 { font-family: var(--headingFont); font-size: var(--fs-h2); line-height: var(--lh-h2); font-weight: 600; color: var(--headingColor); margin: 0 0 var(--space-6); text-wrap: balance; }
.bbi-lp-oecm .lp-intro__body p { font-size: 17px; line-height: 1.6; color: rgba(var(--textColor-rgb),.78); margin: 0 0 var(--space-4); text-wrap: pretty; }
.bbi-lp-oecm .lp-intro__body a { color: var(--linkColor); text-decoration: underline; text-underline-offset: 3px; }

/* Differentiators */
.bbi-lp-oecm .lp-diff { padding: var(--space-12) 0; background: var(--alternateBackground); border-top: 1px solid rgba(var(--borderColor-rgb),.6); border-bottom: 1px solid rgba(var(--borderColor-rgb),.6); }
.bbi-lp-oecm .lp-diff__inner { max-width: 1280px; margin: 0 auto; padding: 0 var(--space-6); }
.bbi-lp-oecm .lp-diff__head { margin-bottom: var(--space-8); max-width: 640px; }
.bbi-lp-oecm .lp-diff__eyebrow { display: inline-flex; align-items: center; gap: var(--space-2); color: rgba(var(--textColor-rgb),.6); margin-bottom: var(--space-3); }
.bbi-lp-oecm .lp-diff__eyebrow::before { content: ""; display: inline-block; width: 18px; height: 1px; background: var(--saleBadgeBackground); }
.bbi-lp-oecm .lp-diff h2 { font-family: var(--headingFont); font-size: var(--fs-h2); line-height: var(--lh-h2); font-weight: 600; color: var(--headingColor); margin: 0; text-wrap: balance; }
.bbi-lp-oecm .lp-diff__grid { display: grid; grid-template-columns: repeat(2,1fr); border-top: 1px solid rgba(var(--borderColor-rgb),.6); border-left: 1px solid rgba(var(--borderColor-rgb),.6); }
.bbi-lp-oecm .lp-diff-card { background: var(--cardBackground); padding: var(--space-8); border-right: 1px solid rgba(var(--borderColor-rgb),.6); border-bottom: 1px solid rgba(var(--borderColor-rgb),.6); border-radius: 0; display: grid; grid-template-rows: auto auto auto 1fr; gap: var(--space-3); transition: background-color 160ms ease; }
.bbi-lp-oecm .lp-diff-card:hover { background: rgba(var(--shadowColor-rgb),.02); }
.bbi-lp-oecm .lp-diff-card__num { font-family: "JetBrains Mono",ui-monospace,monospace; font-size: 11px; letter-spacing: 0.08em; color: rgba(var(--textColor-rgb),.6); }
.bbi-lp-oecm .lp-diff-card__icon { width: 32px; height: 32px; color: var(--textColor); display: flex; align-items: center; }
.bbi-lp-oecm .lp-diff-card__label { font-family: var(--headingFont); font-size: 22px; line-height: 1.3; font-weight: 600; color: var(--headingColor); margin: 0; display: flex; flex-direction: column; gap: var(--space-2); }
.bbi-lp-oecm .lp-diff-card__label::after { content: ""; display: block; width: 24px; height: 1px; background: var(--saleBadgeBackground); }
.bbi-lp-oecm .lp-diff-card__sentence { font-size: 15px; line-height: 1.55; color: rgba(var(--textColor-rgb),.7); margin: 0; text-wrap: pretty; }

/* Trust row */
.bbi-lp-oecm .lp-trust-row { padding: var(--space-12) 0; }
.bbi-lp-oecm .lp-trust-row__inner { max-width: 1280px; margin: 0 auto; padding: 0 var(--space-6); }
.bbi-lp-oecm .lp-trust-row__head { margin-bottom: var(--space-6); max-width: 640px; }
.bbi-lp-oecm .lp-trust-row__eyebrow { display: inline-flex; align-items: center; gap: var(--space-2); color: rgba(var(--textColor-rgb),.6); margin-bottom: var(--space-3); }
.bbi-lp-oecm .lp-trust-row__eyebrow::before { content: ""; display: inline-block; width: 18px; height: 1px; background: var(--saleBadgeBackground); }
.bbi-lp-oecm .lp-trust-row h2 { font-family: var(--headingFont); font-size: var(--fs-h3); line-height: var(--lh-h3); font-weight: 600; color: var(--headingColor); margin: 0; }
.bbi-lp-oecm .lp-trust-row__grid { display: grid; grid-template-columns: repeat(3,1fr); gap: var(--space-4); }
.bbi-lp-oecm .lp-trust-row__cell { position: relative; aspect-ratio: 4 / 3; background: var(--alternateBackground); border-radius: var(--cardRadius); overflow: hidden; }
.bbi-lp-oecm .lp-trust-row__cell img { width: 100%; height: 100%; object-fit: cover; }
.bbi-lp-oecm .lp-trust-row__cell-placeholder { position: absolute; inset: 0; display: flex; align-items: center; justify-content: center; background: repeating-linear-gradient(45deg,rgba(var(--shadowColor-rgb),.04) 0px,rgba(var(--shadowColor-rgb),.04) 2px,transparent 2px,transparent 12px); color: rgba(var(--textColor-rgb),.5); font-family: "JetBrains Mono",ui-monospace,monospace; font-size: 11px; letter-spacing: 0.08em; text-transform: uppercase; }
.bbi-lp-oecm .lp-trust-row__caption { position: absolute; left: 0; right: 0; bottom: 0; background: rgba(var(--shadowColor-rgb),.85); color: #fff; padding: 10px 14px; font-size: 12px; line-height: 1.4; display: flex; flex-direction: column; gap: 2px; }
.bbi-lp-oecm .lp-trust-row__caption-key { font-family: "JetBrains Mono",ui-monospace,monospace; font-size: 10px; letter-spacing: 0.08em; text-transform: uppercase; color: rgba(255,255,255,.6); }

/* Proof bar */
.bbi-lp-oecm .lp-proof-bar { background: var(--alternateBackground); border-top: 1px solid rgba(var(--borderColor-rgb),.6); border-bottom: 1px solid rgba(var(--borderColor-rgb),.6); }
.bbi-lp-oecm .lp-proof-bar__inner { max-width: 1280px; margin: 0 auto; padding: var(--space-8) var(--space-6); display: grid; grid-template-columns: repeat(3,1fr); gap: var(--space-8); }
.bbi-lp-oecm .lp-proof-bar__stat { display: flex; flex-direction: column; gap: var(--space-2); }
.bbi-lp-oecm .lp-proof-bar__stat + .lp-proof-bar__stat { border-left: 1px solid rgba(var(--borderColor-rgb),.6); padding-left: var(--space-8); }
.bbi-lp-oecm .lp-proof-bar__stat-num { font-family: var(--headingFont); font-size: 40px; line-height: 1; font-weight: 600; color: var(--headingColor); display: flex; align-items: center; gap: var(--space-3); }
.bbi-lp-oecm .lp-proof-bar__stat-num::before { content: ""; display: inline-block; width: 14px; height: 1px; background: var(--saleBadgeBackground); }
.bbi-lp-oecm .lp-proof-bar__stat-label { font-size: 13px; color: rgba(var(--textColor-rgb),.6); font-family: "JetBrains Mono",ui-monospace,monospace; letter-spacing: 0.04em; text-transform: uppercase; }
.bbi-lp-oecm .lp-proof-bar__stat-detail { font-size: 14px; color: rgba(var(--textColor-rgb),.78); line-height: 1.5; margin-top: var(--space-2); }

/* Cross-links */
.bbi-lp-oecm .lp-crosslinks { padding: var(--space-12) 0; }
.bbi-lp-oecm .lp-crosslinks__inner { max-width: 1280px; margin: 0 auto; padding: 0 var(--space-6); }
.bbi-lp-oecm .lp-crosslinks__head { margin-bottom: var(--space-6); }
.bbi-lp-oecm .lp-crosslinks__eyebrow { display: inline-flex; align-items: center; gap: var(--space-2); color: rgba(var(--textColor-rgb),.6); margin-bottom: var(--space-3); }
.bbi-lp-oecm .lp-crosslinks__eyebrow::before { content: ""; display: inline-block; width: 18px; height: 1px; background: var(--saleBadgeBackground); }
.bbi-lp-oecm .lp-crosslinks h2 { font-family: var(--headingFont); font-size: var(--fs-h3); line-height: var(--lh-h3); font-weight: 600; color: var(--headingColor); margin: 0; }
.bbi-lp-oecm .lp-crosslinks__grid { display: grid; grid-template-columns: repeat(3,1fr); gap: var(--space-4); }
.bbi-lp-oecm .lp-crosslinks__tile { display: grid; grid-template-columns: auto 1fr auto; align-items: center; gap: var(--space-4); padding: var(--space-6); background: var(--background); border: 1px solid rgba(var(--borderColor-rgb),.8); border-radius: var(--cardRadius); text-decoration: none; color: var(--textColor); transition: background-color 160ms ease, border-color 160ms ease; }
.bbi-lp-oecm .lp-crosslinks__tile:hover { background: var(--alternateBackground); border-color: rgba(var(--borderColor-rgb),1); }
.bbi-lp-oecm .lp-crosslinks__tile-icon { width: 28px; height: 28px; color: rgba(var(--textColor-rgb),.55); }
.bbi-lp-oecm .lp-crosslinks__tile-label { display: flex; flex-direction: column; gap: 2px; min-width: 0; }
.bbi-lp-oecm .lp-crosslinks__tile-name { font-family: var(--headingFont); font-size: 18px; font-weight: 600; color: var(--headingColor); }
.bbi-lp-oecm .lp-crosslinks__tile-meta { font-size: 13px; color: rgba(var(--textColor-rgb),.6); font-family: "JetBrains Mono",ui-monospace,monospace; letter-spacing: 0.04em; }
.bbi-lp-oecm .lp-crosslinks__tile-arrow { width: 18px; height: 18px; color: rgba(var(--textColor-rgb),.55); transition: transform 160ms ease; }
.bbi-lp-oecm .lp-crosslinks__tile:hover .lp-crosslinks__tile-arrow { transform: translateX(4px); color: var(--textColor); }

/* FAQ */
.bbi-lp-oecm .lp-faq { padding: var(--space-12) 0; background: var(--background); border-top: 1px solid rgba(var(--borderColor-rgb),.6); }
.bbi-lp-oecm .lp-faq__inner { max-width: 880px; margin: 0 auto; padding: 0 var(--space-6); }
.bbi-lp-oecm .lp-faq__head { margin-bottom: var(--space-6); }
.bbi-lp-oecm .lp-faq__eyebrow { display: inline-flex; align-items: center; gap: var(--space-2); color: rgba(var(--textColor-rgb),.6); margin-bottom: var(--space-3); }
.bbi-lp-oecm .lp-faq__eyebrow::before { content: ""; display: inline-block; width: 18px; height: 1px; background: var(--saleBadgeBackground); }
.bbi-lp-oecm .lp-faq h2 { font-family: var(--headingFont); font-size: var(--fs-h2); line-height: var(--lh-h2); font-weight: 600; color: var(--headingColor); margin: 0; }
.bbi-lp-oecm .lp-faq__list { border-top: 1px solid rgba(var(--borderColor-rgb),.8); }
.bbi-lp-oecm .lp-faq__item { border-bottom: 1px solid rgba(var(--borderColor-rgb),.8); }
.bbi-lp-oecm .lp-faq__trigger { display: grid; grid-template-columns: auto 1fr auto; align-items: center; gap: var(--space-4); width: 100%; padding: var(--space-6) 0; background: transparent; border: none; text-align: left; cursor: pointer; font-family: var(--headingFont); font-size: 17px; font-weight: 600; color: var(--headingColor); }
.bbi-lp-oecm .lp-faq__trigger:focus { outline: none; }
.bbi-lp-oecm .lp-faq__trigger:focus-visible { outline: 2px solid var(--textColor); outline-offset: 2px; }
.bbi-lp-oecm .lp-faq__trigger-num { font-family: "JetBrains Mono",ui-monospace,monospace; font-size: 11px; letter-spacing: 0.08em; color: rgba(var(--textColor-rgb),.55); font-weight: 400; }
.bbi-lp-oecm .lp-faq__chevron { width: 16px; height: 16px; color: rgba(var(--textColor-rgb),.55); transition: transform 200ms ease; }
.bbi-lp-oecm .lp-faq__item--open .lp-faq__chevron { transform: rotate(180deg); color: var(--textColor); }
.bbi-lp-oecm .lp-faq__answer { display: none; padding: var(--space-4) 0 var(--space-5) calc(36px + var(--space-4)); font-size: 15px; line-height: 1.6; color: rgba(var(--textColor-rgb),.78); }
.bbi-lp-oecm .lp-faq__item--open .lp-faq__answer { display: block; }
.bbi-lp-oecm .lp-faq__answer p { margin: 0 0 var(--space-3); text-wrap: pretty; }
.bbi-lp-oecm .lp-faq__answer p:last-child { margin-bottom: 0; }

/* Responsive */
@media (max-width: 980px) {
  .bbi-lp-oecm .lp-hero__inner { grid-template-columns: 1fr; gap: var(--space-8); }
  .bbi-lp-oecm .lp-hero__media { aspect-ratio: 16 / 10; }
  .bbi-lp-oecm .lp-diff__grid { grid-template-columns: 1fr; }
  .bbi-lp-oecm .lp-trust-row__grid { grid-template-columns: 1fr; }
  .bbi-lp-oecm .lp-proof-bar__inner { grid-template-columns: 1fr; gap: var(--space-6); }
  .bbi-lp-oecm .lp-proof-bar__stat + .lp-proof-bar__stat { border-left: none; border-top: 1px solid rgba(var(--borderColor-rgb),.6); padding-left: 0; padding-top: var(--space-6); }
  .bbi-lp-oecm .lp-crosslinks__grid { grid-template-columns: 1fr; }
  .bbi-lp-oecm .bbi-cta-section__inner { grid-template-columns: 1fr; gap: 48px; }
}
@media (max-width: 640px) {
  .bbi-lp-oecm .lp-hero { padding: var(--space-8) 0; }
  .bbi-lp-oecm .lp-hero h1 { font-size: 32px; }
  .bbi-lp-oecm .lp-intro, .bbi-lp-oecm .lp-diff, .bbi-lp-oecm .lp-trust-row,
  .bbi-lp-oecm .lp-crosslinks, .bbi-lp-oecm .lp-faq { padding: var(--space-8) 0; }
  .bbi-lp-oecm .lp-diff-card { padding: var(--space-6); }
  .bbi-lp-oecm .lp-proof-bar__stat-num { font-size: 32px; }
}

@media(max-width:980px){
  .bbi-lp-oecm .bbi-footer__top{grid-template-columns:1fr;gap:var(--space-8);}
  .bbi-lp-oecm .bbi-footer__cols{grid-template-columns:repeat(2,1fr);}
}
@media(max-width:640px){
  .bbi-lp-oecm .bbi-footer__cols{grid-template-columns:1fr;}
}
</style>

