{%- comment -%}
  Section: ds-pdp-base
  Purpose: BBI product detail page — gallery, spec table, Quote/Cart CTA, related products, breadcrumb.
  Template: product.json
  Gate: template == 'product' (already in bbi_landing gate in theme.liquid — PB-PDP-1).
  Schema: logo (image_picker).
  JSON-LD: wired in PDP-2 via bbi-product-jsonld.liquid snippet (rendered from this section).

  BBI Rule #2: unbuyable items stay live as lead-capture pages.
    Quote CTA auto-renders when product.price == 0 OR product.available == false.

  Spec metafields (PE-2, namespace: specs):
    manufacturer, product_line, model_codes, dimensions, weight, weight_capacity,
    materials, finishes_available, key_features, certifications, warranty,
    country_of_manufacture
{%- endcomment -%}

{% # theme-check-disable RemoteAsset %}
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Inter+Tight:wght@600&family=Inter:wght@400;500;600&family=JetBrains+Mono:wght@400&display=swap" rel="stylesheet">
{% # theme-check-enable RemoteAsset %}

<style>
/* ============================================================
   BBI Design Tokens — DS v2
   ============================================================ */
:root {
  --bodyFont: "Inter", system-ui, -apple-system, "Segoe UI", Roboto, sans-serif;
  --headingFont: "Inter Tight", "Inter", system-ui, sans-serif;
  --space-1: 4px; --space-2: 8px; --space-3: 12px; --space-4: 16px;
  --space-6: 24px; --space-8: 32px; --space-12: 48px; --space-16: 64px;
  --inputRadius: 4px; --buttonRadius: 4px; --cardRadius: 8px;
  --shadow-sm: 0 1px 2px rgba(11,11,12,.04), 0 2px 8px rgba(11,11,12,.05);
  --saleBadgeBackground: #D4252A;
  --saleBadgeBackground-rgb: 212,37,42;
  --fs-h1: 32px; --lh-h1: 1.1; --ls-h1: -0.015em;
  --fs-h2: 24px; --lh-h2: 1.15; --ls-h2: -0.01em;
  --fs-h3: 18px; --lh-h3: 1.25;
  --fs-body: 16px; --lh-body: 1.55;
  --fs-small: 13px;
  --fs-button: 15px; --lh-button: 1; --ls-button: 0.01em;
}
@media (min-width: 768px) {
  :root {
    --fs-h1: 48px; --lh-h1: 1.05;
    --fs-h2: 32px; --lh-h2: 1.1;
    --fs-h3: 22px; --lh-h3: 1.2;
    --fs-small: 14px;
  }
}
.bbi-pdp.scheme-default {
  --background: #FFFFFF; --background-rgb: 255,255,255;
  --alternateBackground: #FAFAFA; --alternateBackground-rgb: 250,250,250;
  --cardBackground: #FFFFFF;
  --textColor: #0B0B0C; --textColor-rgb: 11,11,12;
  --linkColor: #0B0B0C; --headingColor: #0B0B0C; --headingColor-rgb: 11,11,12;
  --buttonBackground: #0B0B0C; --buttonColor: #FFFFFF; --buttonBorder: #0B0B0C;
  --buttonBackgroundHover: #D4252A; --buttonColorHover: #FFFFFF; --buttonBorderHover: #D4252A;
  --alternateButtonBackground: #FFFFFF; --alternateButtonColor: #0B0B0C; --alternateButtonBorder: #0B0B0C;
  --borderColor: #E5E5E7; --borderColor-rgb: 229,229,231;
  --shadowColor: #0B0B0C; --shadowColor-rgb: 11,11,12;
}

/* ── Base ────────────────────────────────────────────────────────────────── */
.bbi-pdp *, .bbi-pdp *::before, .bbi-pdp *::after { box-sizing: border-box; }
.bbi-pdp { font-family: var(--bodyFont); font-size: var(--fs-body); line-height: var(--lh-body); color: var(--textColor); background: var(--background); -webkit-font-smoothing: antialiased; }
.bbi-pdp img { display: block; max-width: 100%; height: auto; }
.bbi-pdp a { color: var(--linkColor); }

/* ── Breadcrumb ──────────────────────────────────────────────────────────── */
.pdp-breadcrumb { padding: 16px 0; border-bottom: 1px solid var(--borderColor); }
.pdp-breadcrumb__inner { max-width: 1200px; margin: 0 auto; padding: 0 24px; font-size: 13px; color: rgba(var(--textColor-rgb),0.5); display: flex; flex-wrap: wrap; gap: 4px 6px; align-items: center; }
.pdp-breadcrumb__inner a { color: inherit; text-decoration: none; }
.pdp-breadcrumb__inner a:hover { color: var(--saleBadgeBackground); }
.pdp-breadcrumb__sep { color: rgba(var(--textColor-rgb),0.3); }

/* ── Product layout ──────────────────────────────────────────────────────── */
.pdp-main { max-width: 1200px; margin: 0 auto; padding: 40px 24px 64px; display: grid; grid-template-columns: 1fr; gap: 40px; }
@media (min-width: 768px) { .pdp-main { grid-template-columns: 1fr 1fr; gap: 56px; } }
@media (min-width: 1024px) { .pdp-main { grid-template-columns: 1.1fr 0.9fr; } }

/* ── Gallery ─────────────────────────────────────────────────────────────── */
.pdp-gallery {}
.pdp-gallery__main { border: 1px solid var(--borderColor); border-radius: var(--cardRadius); overflow: hidden; background: var(--alternateBackground); aspect-ratio: 4/3; display: flex; align-items: center; justify-content: center; }
.pdp-gallery__main-img { width: 100%; height: 100%; object-fit: contain; transition: opacity 0.2s; cursor: zoom-in; }
.pdp-gallery__thumbs { display: flex; flex-wrap: wrap; gap: 8px; margin-top: 12px; }
.pdp-gallery__thumb { width: 72px; height: 72px; border: 1px solid var(--borderColor); border-radius: 6px; overflow: hidden; cursor: pointer; background: var(--alternateBackground); padding: 0; transition: border-color 0.15s; flex-shrink: 0; }
.pdp-gallery__thumb:hover, .pdp-gallery__thumb[aria-pressed="true"] { border-color: var(--saleBadgeBackground); }
.pdp-gallery__thumb img { width: 100%; height: 100%; object-fit: cover; }
.pdp-gallery__no-image { width: 100%; height: 100%; display: flex; align-items: center; justify-content: center; color: rgba(var(--textColor-rgb),0.3); font-size: 13px; }

/* ── Info panel ──────────────────────────────────────────────────────────── */
.pdp-info {}
.pdp-info__vendor { font-size: 12px; font-weight: 500; letter-spacing: 0.06em; text-transform: uppercase; color: rgba(var(--textColor-rgb),0.5); margin: 0 0 8px; }
.pdp-info__title { font-family: var(--headingFont); font-size: clamp(22px, 3vw, 32px); font-weight: 600; line-height: 1.1; letter-spacing: -0.015em; color: var(--headingColor); margin: 0 0 16px; }
.pdp-info__sku { font-family: "JetBrains Mono", ui-monospace, monospace; font-size: 11px; letter-spacing: 0.06em; color: rgba(var(--textColor-rgb),0.4); margin: 0 0 20px; }

/* Availability badge */
.pdp-badge { display: inline-flex; align-items: center; gap: 6px; font-size: 12px; font-weight: 500; padding: 4px 10px; border-radius: 100px; margin-bottom: 20px; }
.pdp-badge--available { background: rgba(22,163,74,0.1); color: #15803D; }
.pdp-badge--unavailable { background: rgba(var(--saleBadgeBackground-rgb),0.1); color: var(--saleBadgeBackground); }
.pdp-badge__dot { width: 6px; height: 6px; border-radius: 50%; background: currentColor; flex-shrink: 0; }

/* Price */
.pdp-price { font-family: var(--headingFont); font-size: 28px; font-weight: 600; color: var(--headingColor); margin: 0 0 8px; }
.pdp-price--zero { font-size: 16px; font-weight: 500; color: rgba(var(--textColor-rgb),0.6); }
.pdp-price__compare { font-size: 16px; font-weight: 400; color: rgba(var(--textColor-rgb),0.45); text-decoration: line-through; margin-left: 8px; }

/* Description */
.pdp-info__desc { font-size: 15px; line-height: 1.65; color: rgba(var(--textColor-rgb),0.78); margin: 0 0 24px; }

/* Variant picker (simple — colour swatches) */
.pdp-variants { margin-bottom: 24px; }
.pdp-variants__label { font-size: 13px; font-weight: 500; margin-bottom: 10px; }
.pdp-variants__options { display: flex; flex-wrap: wrap; gap: 8px; }
.pdp-variant-opt { display: inline-flex; align-items: center; justify-content: center; min-width: 36px; height: 36px; padding: 0 12px; border: 1px solid var(--borderColor); border-radius: var(--buttonRadius); font-size: 13px; cursor: pointer; background: var(--background); color: var(--textColor); transition: border-color 0.15s; }
.pdp-variant-opt.selected, .pdp-variant-opt:hover { border-color: var(--textColor); }

/* CTA buttons */
.pdp-cta { display: flex; flex-direction: column; gap: 10px; }
.pdp-btn { display: flex; align-items: center; justify-content: center; height: 52px; border-radius: var(--buttonRadius); font-family: var(--bodyFont); font-size: 16px; font-weight: 500; letter-spacing: 0.01em; text-decoration: none; border: 1px solid transparent; cursor: pointer; transition: background 0.15s, border-color 0.15s; }
.pdp-btn--primary { background: var(--buttonBackground); color: var(--buttonColor); border-color: var(--buttonBorder); }
.pdp-btn--primary:hover { background: var(--saleBadgeBackground); border-color: var(--saleBadgeBackground); color: #fff; }
.pdp-btn--outline { background: transparent; color: var(--textColor); border-color: var(--borderColor); }
.pdp-btn--outline:hover { border-color: var(--textColor); }
.pdp-btn--quote { background: var(--saleBadgeBackground); color: #fff; border-color: var(--saleBadgeBackground); }
.pdp-btn--quote:hover { opacity: 0.9; }

/* Trust pills */
.pdp-trust { display: flex; flex-wrap: wrap; gap: 8px; margin-top: 20px; padding-top: 20px; border-top: 1px solid var(--borderColor); }
.pdp-trust__pill { font-size: 12px; font-weight: 500; color: rgba(var(--textColor-rgb),0.65); display: inline-flex; align-items: center; gap: 5px; }
.pdp-trust__pill::before { content: "✓"; color: #15803D; font-size: 13px; }

/* Phone nudge */
.pdp-phone-nudge { margin-top: 12px; font-size: 13px; color: rgba(var(--textColor-rgb),0.5); text-align: center; }
.pdp-phone-nudge a { color: var(--textColor); font-weight: 500; text-decoration: none; }
.pdp-phone-nudge a:hover { color: var(--saleBadgeBackground); }

/* ── Spec table ──────────────────────────────────────────────────────────── */
.pdp-specs { max-width: 1200px; margin: 0 auto; padding: 0 24px 64px; }
.pdp-specs__heading { font-family: var(--headingFont); font-size: var(--fs-h2); font-weight: 600; color: var(--headingColor); margin: 0 0 24px; letter-spacing: -0.01em; }
.pdp-specs-table { width: 100%; border-collapse: collapse; border: 1px solid var(--borderColor); border-radius: var(--cardRadius); overflow: hidden; }
.pdp-specs-table tr { border-bottom: 1px solid var(--borderColor); }
.pdp-specs-table tr:last-child { border-bottom: none; }
.pdp-specs-table tr:nth-child(even) { background: var(--alternateBackground); }
.pdp-specs-table th { width: 200px; font-size: 13px; font-weight: 600; text-align: left; padding: 12px 16px; color: var(--textColor); background: var(--alternateBackground); white-space: nowrap; vertical-align: top; }
.pdp-specs-table td { font-size: 14px; padding: 12px 16px; color: rgba(var(--textColor-rgb),0.85); vertical-align: top; }
.pdp-specs-table ul { margin: 0; padding: 0 0 0 18px; }
.pdp-specs-table li { margin-bottom: 4px; }
@media (max-width: 640px) {
  .pdp-specs-table, .pdp-specs-table tbody, .pdp-specs-table tr, .pdp-specs-table th, .pdp-specs-table td { display: block; width: 100%; }
  .pdp-specs-table th { background: var(--alternateBackground); padding-bottom: 4px; }
  .pdp-specs-table td { padding-top: 4px; }
}

/* ── Key features list ───────────────────────────────────────────────────── */
.pdp-features { max-width: 1200px; margin: 0 auto; padding: 0 24px 64px; }
.pdp-features__heading { font-family: var(--headingFont); font-size: var(--fs-h2); font-weight: 600; color: var(--headingColor); margin: 0 0 20px; letter-spacing: -0.01em; }
.pdp-features__list { list-style: none; margin: 0; padding: 0; display: grid; grid-template-columns: 1fr; gap: 10px; }
@media (min-width: 640px) { .pdp-features__list { grid-template-columns: 1fr 1fr; } }
.pdp-features__item { display: flex; gap: 10px; font-size: 15px; line-height: 1.4; }
.pdp-features__item::before { content: "→"; color: var(--saleBadgeBackground); font-weight: 600; flex-shrink: 0; }

/* ── Related products ────────────────────────────────────────────────────── */
.pdp-related { padding: 56px 0; background: var(--alternateBackground); border-top: 1px solid var(--borderColor); }
.pdp-related__inner { max-width: 1200px; margin: 0 auto; padding: 0 24px; }
.pdp-related__header { display: flex; align-items: baseline; justify-content: space-between; gap: 16px; margin-bottom: 28px; flex-wrap: wrap; }
.pdp-related h2 { font-family: var(--headingFont); font-size: var(--fs-h2); font-weight: 600; color: var(--headingColor); margin: 0; letter-spacing: -0.01em; }
.pdp-related__view-all { font-size: 14px; font-weight: 500; color: rgba(var(--textColor-rgb),0.6); text-decoration: none; }
.pdp-related__view-all:hover { color: var(--saleBadgeBackground); }
.pdp-related__grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 16px; }
@media (min-width: 640px) { .pdp-related__grid { grid-template-columns: repeat(4, 1fr); } }

/* Product card (reused pattern) */
.pdp-prod-card { display: flex; flex-direction: column; border: 1px solid var(--borderColor); border-radius: var(--cardRadius); overflow: hidden; background: var(--cardBackground); text-decoration: none; color: var(--textColor); transition: box-shadow 0.15s, border-color 0.15s; }
.pdp-prod-card:hover { box-shadow: var(--shadow-sm); border-color: rgba(var(--textColor-rgb),0.25); }
.pdp-prod-card__img-wrap { aspect-ratio: 4/3; overflow: hidden; background: var(--alternateBackground); }
.pdp-prod-card__img { width: 100%; height: 100%; object-fit: cover; transition: transform 0.4s; }
.pdp-prod-card:hover .pdp-prod-card__img { transform: scale(1.04); }
.pdp-prod-card__body { padding: 12px 14px 16px; flex: 1; display: flex; flex-direction: column; gap: 4px; }
.pdp-prod-card__vendor { font-size: 11px; color: rgba(var(--textColor-rgb),0.45); text-transform: uppercase; letter-spacing: 0.06em; }
.pdp-prod-card__title { font-size: 14px; font-weight: 500; line-height: 1.3; color: var(--headingColor); }
.pdp-prod-card__price { font-size: 14px; font-weight: 600; }

/* ── Phone CTA closer ────────────────────────────────────────────────────── */
.pdp-cta-closer { padding: 56px 24px; text-align: center; border-top: 1px solid var(--borderColor); }
.pdp-cta-closer__inner { max-width: 560px; margin: 0 auto; }
.pdp-cta-closer h2 { font-family: var(--headingFont); font-size: var(--fs-h2); font-weight: 600; color: var(--headingColor); margin: 0 0 8px; letter-spacing: -0.01em; }
.pdp-cta-closer p { font-size: 16px; color: rgba(var(--textColor-rgb),0.7); margin: 0 0 24px; }
.pdp-cta-closer__btn { display: inline-flex; align-items: center; justify-content: center; height: 48px; padding: 0 28px; background: var(--buttonBackground); color: var(--buttonColor); border: 1px solid var(--buttonBorder); border-radius: var(--buttonRadius); font-family: var(--bodyFont); font-size: var(--fs-button); font-weight: 500; letter-spacing: var(--ls-button); text-decoration: none; transition: background 0.15s; }
.pdp-cta-closer__btn:hover { background: var(--saleBadgeBackground); border-color: var(--saleBadgeBackground); color: #fff; }
.pdp-cta-closer__phone { margin-top: 16px; font-size: 14px; color: rgba(var(--textColor-rgb),0.6); }
.pdp-cta-closer__phone a { color: var(--textColor); font-weight: 500; text-decoration: none; }
.pdp-cta-closer__phone a:hover { color: var(--saleBadgeBackground); }
</style>

{%- comment -%}
  Breadcrumb: derive category from product.type tag
  type:chairs → /collections/seating  "Seating"
  type:desks  → /collections/desks   "Desks & Workstations"
  etc.
{%- endcomment -%}
{%- liquid
  assign cat_handle = ''
  assign cat_label  = ''
  for tag in product.tags
    if tag == 'type:chairs'
      assign cat_handle = 'seating'
      assign cat_label  = 'Seating'
    elsif tag == 'type:desks'
      assign cat_handle = 'desks'
      assign cat_label  = 'Desks & Workstations'
    elsif tag == 'type:storage'
      assign cat_handle = 'storage'
      assign cat_label  = 'Storage & Filing'
    elsif tag == 'type:tables'
      assign cat_handle = 'tables'
      assign cat_label  = 'Tables'
    elsif tag == 'type:boardroom'
      assign cat_handle = 'boardroom'
      assign cat_label  = 'Boardroom'
    elsif tag == 'type:ergonomic'
      assign cat_handle = 'ergonomic-products'
      assign cat_label  = 'Ergonomic Products'
    elsif tag == 'type:panels'
      assign cat_handle = 'panels-room-dividers'
      assign cat_label  = 'Panels & Dividers'
    elsif tag == 'type:accessories'
      assign cat_handle = 'accessories'
      assign cat_label  = 'Accessories'
    elsif tag == 'type:quiet-spaces'
      assign cat_handle = 'quiet-spaces'
      assign cat_label  = 'Quiet Spaces'
    endif
  endfor
  assign is_unbuyable = false
  if product.price == 0 or product.available == false
    assign is_unbuyable = true
  endif
-%}

{%- render 'bbi-product-jsonld', product: product, cat_handle: cat_handle, cat_label: cat_label -%}

<div class="bbi-pdp scheme-default">
  {%- render 'bbi-nav', logo: section.settings.logo, active: 'shop' -%}

  <main id="MainContent">

    <!-- Breadcrumb (4-level: Home > Shop Furniture > Category > Product) -->
    <nav class="pdp-breadcrumb" aria-label="Breadcrumb">
      <div class="pdp-breadcrumb__inner">
        <a href="/">Home</a>
        <span class="pdp-breadcrumb__sep" aria-hidden="true">/</span>
        <a href="/collections/business-furniture">Shop Furniture</a>
        {%- if cat_handle != blank -%}
          <span class="pdp-breadcrumb__sep" aria-hidden="true">/</span>
          <a href="/collections/{{ cat_handle }}">{{ cat_label }}</a>
        {%- endif -%}
        <span class="pdp-breadcrumb__sep" aria-hidden="true">/</span>
        <span aria-current="page">{{ product.title }}</span>
      </div>
    </nav>

    <!-- Product hero: gallery + info -->
    <div class="pdp-main">

      <!-- Gallery -->
      <bbi-pdp-gallery class="pdp-gallery">
        <div class="pdp-gallery__main">
          {%- if product.images.size > 0 -%}
            {{- product.images[0]
                | image_url: width: 900
                | image_tag:
                    id: 'pdp-main-img',
                    class: 'pdp-gallery__main-img',
                    loading: 'eager',
                    width: product.images[0].width,
                    height: product.images[0].height,
                    alt: product.images[0].alt | default: product.title | escape -}}
          {%- else -%}
            <span class="pdp-gallery__no-image">No image available</span>
          {%- endif -%}
        </div>

        {%- if product.images.size > 1 -%}
          <div class="pdp-gallery__thumbs" role="list">
            {%- for image in product.images limit: 8 -%}
              <button
                class="pdp-gallery__thumb"
                type="button"
                aria-label="View image {{ forloop.index }}"
                aria-pressed="{{ forloop.first }}"
                data-src="{{ image | image_url: width: 900 }}"
                data-full="{{ image | image_url: width: 1400 }}"
                role="listitem"
              >
                {{- image
                    | image_url: width: 144
                    | image_tag:
                        loading: 'lazy',
                        width: 72,
                        height: 72,
                        alt: image.alt | default: product.title | escape -}}
              </button>
            {%- endfor -%}
          </div>
        {%- endif -%}
      </bbi-pdp-gallery>

      <!-- Info panel -->
      <div class="pdp-info">
        {%- if product.vendor != blank -%}
          <p class="pdp-info__vendor">{{ product.vendor }}</p>
        {%- endif -%}

        <h1 class="pdp-info__title">{{ product.title }}</h1>

        {%- if product.selected_or_first_available_variant.sku != blank -%}
          <p class="pdp-info__sku">SKU: {{ product.selected_or_first_available_variant.sku }}</p>
        {%- endif -%}

        <!-- Availability badge -->
        {%- if is_unbuyable -%}
          <span class="pdp-badge pdp-badge--unavailable">
            <span class="pdp-badge__dot" aria-hidden="true"></span>
            {%- if product.price == 0 -%}Showcase — Quote required{%- else -%}Sold out — Quote available{%- endif -%}
          </span>
        {%- else -%}
          <span class="pdp-badge pdp-badge--available">
            <span class="pdp-badge__dot" aria-hidden="true"></span>
            In stock
          </span>
        {%- endif -%}

        <!-- Price -->
        {%- if is_unbuyable -%}
          <p class="pdp-price pdp-price--zero">Contact us for pricing</p>
        {%- else -%}
          <p class="pdp-price">
            {{ product.price | money }}
            {%- if product.compare_at_price > product.price -%}
              <span class="pdp-price__compare">{{ product.compare_at_price | money }}</span>
            {%- endif -%}
          </p>
        {%- endif -%}

        <!-- Short description -->
        {%- if product.description != blank -%}
          <div class="pdp-info__desc">
            {{ product.description | strip_html | truncate: 280 }}
          </div>
        {%- endif -%}

        <!-- Variant options (non-colour) -->
        {%- unless product.has_only_default_variant -%}
          {%- for option in product.options_with_values -%}
            {%- unless option.name == 'Color' or option.name == 'Colour' -%}
              <div class="pdp-variants">
                <p class="pdp-variants__label">{{ option.name }}</p>
                <div class="pdp-variants__options">
                  {%- for value in option.values -%}
                    <span class="pdp-variant-opt{% if forloop.first %} selected{% endif %}">{{ value }}</span>
                  {%- endfor -%}
                </div>
              </div>
            {%- endunless -%}
          {%- endfor -%}
        {%- endunless -%}

        <!-- CTA block -->
        <div class="pdp-cta">
          {%- if is_unbuyable -%}
            <!-- BBI Rule #2: unbuyable products → Quote CTA only (not hidden) -->
            <a href="/pages/quote?product={{ product.handle | url_encode }}&amp;title={{ product.title | url_encode }}" class="pdp-btn pdp-btn--quote">
              Request a Quote for This Product
            </a>
          {%- else -%}
            <!-- In-stock: Add to cart + Quote -->
            {%- form 'product', product, id: 'pdp-add-to-cart' -%}
              <input type="hidden" name="id" value="{{ product.selected_or_first_available_variant.id }}">
              <button type="submit" class="pdp-btn pdp-btn--primary"
                {%- if product.selected_or_first_available_variant.available == false %} disabled{%- endif -%}>
                {%- if product.selected_or_first_available_variant.available -%}Add to Cart{%- else -%}Unavailable{%- endif -%}
              </button>
            {%- endform -%}
            <a href="/pages/quote?product={{ product.handle | url_encode }}&amp;title={{ product.title | url_encode }}" class="pdp-btn pdp-btn--outline">
              Request a Quote Instead
            </a>
          {%- endif -%}
        </div>

        <!-- Trust pills -->
        <div class="pdp-trust">
          <span class="pdp-trust__pill">Delivered across Ontario</span>
          <span class="pdp-trust__pill">OECM-eligible supplier</span>
          <span class="pdp-trust__pill">Since 1964</span>
        </div>

        <p class="pdp-phone-nudge">
          Questions? Call <a href="tel:18008359565">1-800-835-9565</a>
        </p>
      </div>
    </div>

    <!-- Key Features (from spec metafields) -->
    {%- assign kf = product.metafields.specs.key_features.value -%}
    {%- if kf != blank and kf.size > 0 -%}
      <section class="pdp-features">
        <h2 class="pdp-features__heading">Key Features</h2>
        <ul class="pdp-features__list">
          {%- for feature in kf -%}
            <li class="pdp-features__item">{{ feature | escape }}</li>
          {%- endfor -%}
        </ul>
      </section>
    {%- endif -%}

    <!-- Spec table (from PE-2 metafields, namespace: specs) -->
    {%- liquid
      assign has_specs = false
      assign s_manufacturer = product.metafields.specs.manufacturer.value
      assign s_product_line = product.metafields.specs.product_line.value
      assign s_model_codes  = product.metafields.specs.model_codes.value
      assign s_dimensions   = product.metafields.specs.dimensions.value
      assign s_weight       = product.metafields.specs.weight.value
      assign s_weight_cap   = product.metafields.specs.weight_capacity.value
      assign s_materials    = product.metafields.specs.materials.value
      assign s_finishes     = product.metafields.specs.finishes_available.value
      assign s_certs        = product.metafields.specs.certifications.value
      assign s_warranty     = product.metafields.specs.warranty.value
      assign s_country      = product.metafields.specs.country_of_manufacture.value
      if s_manufacturer or s_dimensions or s_weight or s_materials or s_finishes or s_warranty
        assign has_specs = true
      endif
    -%}
    {%- if has_specs -%}
      <section class="pdp-specs">
        <h2 class="pdp-specs__heading">Specifications</h2>
        <table class="pdp-specs-table">
          <tbody>
            {%- if s_manufacturer != blank -%}
              <tr><th scope="row">Manufacturer</th><td>{{ s_manufacturer | escape }}</td></tr>
            {%- endif -%}
            {%- if s_product_line != blank -%}
              <tr><th scope="row">Product Line</th><td>{{ s_product_line | escape }}</td></tr>
            {%- endif -%}
            {%- if s_model_codes != blank and s_model_codes.size > 0 -%}
              <tr><th scope="row">Model</th><td>{{ s_model_codes | join: ', ' | escape }}</td></tr>
            {%- endif -%}
            {%- if s_dimensions != blank -%}
              <tr><th scope="row">Dimensions</th><td>{{ s_dimensions | escape }}</td></tr>
            {%- endif -%}
            {%- if s_weight != blank -%}
              <tr><th scope="row">Weight</th><td>{{ s_weight | escape }}</td></tr>
            {%- endif -%}
            {%- if s_weight_cap != blank -%}
              <tr><th scope="row">Weight Capacity</th><td>{{ s_weight_cap | escape }}</td></tr>
            {%- endif -%}
            {%- if s_materials != blank -%}
              <tr><th scope="row">Materials</th><td>{{ s_materials | escape | newline_to_br }}</td></tr>
            {%- endif -%}
            {%- if s_finishes != blank and s_finishes.size > 0 -%}
              <tr><th scope="row">Finishes Available</th>
                <td>
                  <ul>
                    {%- for f in s_finishes -%}<li>{{ f | escape }}</li>{%- endfor -%}
                  </ul>
                </td>
              </tr>
            {%- endif -%}
            {%- if s_certs != blank and s_certs.size > 0 -%}
              <tr><th scope="row">Certifications</th>
                <td>
                  <ul>
                    {%- for c in s_certs -%}<li>{{ c | escape }}</li>{%- endfor -%}
                  </ul>
                </td>
              </tr>
            {%- endif -%}
            {%- if s_warranty != blank -%}
              <tr><th scope="row">Warranty</th><td>{{ s_warranty | escape }}</td></tr>
            {%- endif -%}
            {%- if s_country != blank -%}
              <tr><th scope="row">Made In</th><td>{{ s_country | escape }}</td></tr>
            {%- endif -%}
          </tbody>
        </table>
      </section>
    {%- endif -%}

    <!-- Related products (same type tag, max 4) -->
    {%- if cat_handle != blank -%}
      {%- assign related_col = collections[cat_handle] -%}
      {%- if related_col != blank -%}
        {%- assign related_products = related_col.products | where: 'id', product.id | map: 'id' -%}
        <section class="pdp-related">
          <div class="pdp-related__inner">
            <div class="pdp-related__header">
              <h2>More {{ cat_label }}</h2>
              <a href="/collections/{{ cat_handle }}" class="pdp-related__view-all">View all {{ cat_label }} →</a>
            </div>
            <div class="pdp-related__grid">
              {%- assign shown = 0 -%}
              {%- for rp in related_col.products -%}
                {%- if rp.id != product.id and shown < 4 -%}
                  {%- assign shown = shown | plus: 1 -%}
                  <a href="{{ rp.url }}" class="pdp-prod-card">
                    {%- if rp.featured_image -%}
                      <div class="pdp-prod-card__img-wrap">
                        {{- rp.featured_image
                            | image_url: width: 480
                            | image_tag:
                                class: 'pdp-prod-card__img',
                                loading: 'lazy',
                                width: rp.featured_image.width,
                                height: rp.featured_image.height,
                                alt: rp.featured_image.alt | default: rp.title | escape -}}
                      </div>
                    {%- endif -%}
                    <div class="pdp-prod-card__body">
                      {%- if rp.vendor != blank -%}
                        <p class="pdp-prod-card__vendor">{{ rp.vendor }}</p>
                      {%- endif -%}
                      <p class="pdp-prod-card__title">{{ rp.title }}</p>
                      <p class="pdp-prod-card__price">
                        {%- if rp.price == 0 or rp.available == false -%}Quote only
                        {%- else -%}{{ rp.price | money }}{%- endif -%}
                      </p>
                    </div>
                  </a>
                {%- endif -%}
              {%- endfor -%}
            </div>
          </div>
        </section>
      {%- endif -%}
    {%- endif -%}

    <!-- CTA closer -->
    <section class="pdp-cta-closer">
      <div class="pdp-cta-closer__inner">
        <h2>Need a custom configuration?</h2>
        <p>Our team quotes single items to full office buildouts — usually within one business day.</p>
        <a href="/pages/quote" class="pdp-cta-closer__btn">Request a Quote</a>
        <p class="pdp-cta-closer__phone">Or call <a href="tel:18008359565">1-800-835-9565</a></p>
      </div>
    </section>

  </main>

  {%- render 'bbi-footer', logo: section.settings.logo -%}
</div>

<script>
/* bbi-pdp-gallery — Web Component for thumbnail image swap */
class BbiPdpGallery extends HTMLElement {
  connectedCallback() {
    this.mainImg = this.querySelector('#pdp-main-img');
    if (!this.mainImg) return;
    this.querySelectorAll('.pdp-gallery__thumb').forEach(btn => {
      btn.addEventListener('click', () => this._swap(btn));
      btn.addEventListener('keydown', e => { if (e.key === 'Enter' || e.key === ' ') { e.preventDefault(); this._swap(btn); } });
    });
  }
  _swap(btn) {
    this.mainImg.src = btn.dataset.src;
    this.mainImg.setAttribute('data-full', btn.dataset.full);
    this.querySelectorAll('.pdp-gallery__thumb').forEach(b => b.setAttribute('aria-pressed', 'false'));
    btn.setAttribute('aria-pressed', 'true');
  }
}
customElements.define('bbi-pdp-gallery', BbiPdpGallery);
</script>

{% schema %}
{
  "name": "Product Detail Page",
  "class": "bbi-pdp-section",
  "settings": [
    {
      "type": "image_picker",
      "id": "logo",
      "label": "BBI Logo"
    }
  ],
  "presets": [
    {
      "name": "Product Detail Page"
    }
  ]
}
{% endschema %}
