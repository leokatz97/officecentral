{%- comment -%}
  Section: ds-pdp-base
  Purpose: BBI product detail page — gallery, spec table, Quote/Cart CTA, related products, breadcrumb.
  Template: product.json
  Gate: template == 'product' (already in bbi_landing gate in theme.liquid — PB-PDP-1).
  Schema: logo (image_picker).
  JSON-LD: wired in PDP-2 via bbi-product-jsonld.liquid snippet (rendered from this section).

  BBI Rule #2: unbuyable items stay live as lead-capture pages.
    Quote CTA auto-renders when product.price == 0 OR product.available == false.

  Spec metafields (PE-2, namespace: specs):
    manufacturer, product_line, model_codes, dimensions, weight, weight_capacity,
    materials, finishes_available, key_features, certifications, warranty,
    country_of_manufacture
{%- endcomment -%}

{% # theme-check-disable RemoteAsset %}
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Inter+Tight:wght@600&family=Inter:wght@400;500;600&family=JetBrains+Mono:wght@400&display=swap" rel="stylesheet">
{% # theme-check-enable RemoteAsset %}

<style>
/* ============================================================
   BBI Design Tokens — DS v2
   ============================================================ */
:root {
  --bodyFont: "Inter", system-ui, -apple-system, "Segoe UI", Roboto, sans-serif;
  --headingFont: "Inter Tight", "Inter", system-ui, sans-serif;
  --space-1: 4px; --space-2: 8px; --space-3: 12px; --space-4: 16px;
  --space-6: 24px; --space-8: 32px; --space-12: 48px; --space-16: 64px;
  --inputRadius: 4px; --buttonRadius: 4px; --cardRadius: 8px;
  --shadow-sm: 0 1px 2px rgba(11,11,12,.04), 0 2px 8px rgba(11,11,12,.05);
  --saleBadgeBackground: #D4252A;
  --saleBadgeBackground-rgb: 212,37,42;
  --fs-h1: 32px; --lh-h1: 1.1; --ls-h1: -0.015em;
  --fs-h2: 24px; --lh-h2: 1.15; --ls-h2: -0.01em;
  --fs-h3: 18px; --lh-h3: 1.25;
  --fs-body: 16px; --lh-body: 1.55;
  --fs-small: 13px;
  --fs-button: 15px; --lh-button: 1; --ls-button: 0.01em;
}
@media (min-width: 768px) {
  :root {
    --fs-h1: 48px; --lh-h1: 1.05;
    --fs-h2: 32px; --lh-h2: 1.1;
    --fs-h3: 22px; --lh-h3: 1.2;
    --fs-small: 14px;
  }
}
.bbi-pdp.scheme-default {
  --background: #FFFFFF; --background-rgb: 255,255,255;
  --alternateBackground: #FAFAFA; --alternateBackground-rgb: 250,250,250;
  --cardBackground: #FFFFFF;
  --textColor: #0B0B0C; --textColor-rgb: 11,11,12;
  --linkColor: #0B0B0C; --headingColor: #0B0B0C; --headingColor-rgb: 11,11,12;
  --buttonBackground: #0B0B0C; --buttonColor: #FFFFFF; --buttonBorder: #0B0B0C;
  --buttonBackgroundHover: #D4252A; --buttonColorHover: #FFFFFF; --buttonBorderHover: #D4252A;
  --alternateButtonBackground: #FFFFFF; --alternateButtonColor: #0B0B0C; --alternateButtonBorder: #0B0B0C;
  --borderColor: #E5E5E7; --borderColor-rgb: 229,229,231;
  --shadowColor: #0B0B0C; --shadowColor-rgb: 11,11,12;
}

/* Strip Starlite's content-for-layout constraints on BBI pages */
.content-for-layout--bbi {
  max-width: none !important;
  padding: 0 !important;
  margin: 0 !important;
}

/* Override Starlite's dark body scheme on product pages */
body { background: #FFFFFF !important; }

/* ── Base ────────────────────────────────────────────────────────────────── */
.bbi-pdp *, .bbi-pdp *::before, .bbi-pdp *::after { box-sizing: border-box; }
.bbi-pdp { font-family: var(--bodyFont); font-size: var(--fs-body); line-height: var(--lh-body); color: var(--textColor); background: var(--background); min-height: 100vh; -webkit-font-smoothing: antialiased; }
.bbi-pdp img { display: block; max-width: 100%; height: auto; }
.bbi-pdp a { color: var(--linkColor); }

/* ── Breadcrumb ──────────────────────────────────────────────────────────── */
.pdp-breadcrumb { padding: 16px 0; border-bottom: 1px solid var(--borderColor); }
.pdp-breadcrumb__inner { max-width: 1320px; margin: 0 auto; padding: 0 24px; font-size: 13px; color: rgba(var(--textColor-rgb),0.5); display: flex; flex-wrap: wrap; gap: 4px 6px; align-items: center; }
.pdp-breadcrumb__inner a { color: inherit; text-decoration: none; }
.pdp-breadcrumb__inner a:hover { color: var(--saleBadgeBackground); }
.pdp-breadcrumb__sep { color: rgba(var(--textColor-rgb),0.3); }

/* ── Product layout ──────────────────────────────────────────────────────── */
.pdp-main { max-width: 1320px; margin: 0 auto; padding: 40px 24px 64px; display: grid; grid-template-columns: 1fr; gap: 40px; }
@media (min-width: 768px) { .pdp-main { grid-template-columns: 1fr 1fr; gap: 56px; } }
@media (min-width: 1024px) { .pdp-main { grid-template-columns: minmax(0, 1.5fr) minmax(0, 1fr); } }

/* ── Gallery ─────────────────────────────────────────────────────────────── */
.pdp-gallery {}
.pdp-gallery__main { border: 1px solid var(--borderColor); border-radius: var(--cardRadius); background: #FFFFFF; aspect-ratio: 1/1; display: flex; align-items: center; justify-content: center; padding: 16px; }
@media (min-width: 768px) { .pdp-gallery__main { aspect-ratio: 4/5; } }
.pdp-gallery__main-img { max-width: 100%; max-height: 100%; width: auto; height: auto; object-fit: contain; transition: opacity 0.2s; cursor: zoom-in; display: block; }
.pdp-gallery__thumbs { display: grid; grid-template-columns: repeat(6, 1fr); gap: 8px; margin-top: 12px; }
.pdp-gallery__thumb { width: 72px; height: 72px; border: 1px solid var(--borderColor); border-radius: 6px; overflow: hidden; cursor: pointer; background: #FFFFFF; padding: 0; transition: border-color 0.15s; flex-shrink: 0; }
.pdp-gallery__thumb:hover, .pdp-gallery__thumb[aria-pressed="true"] { border-color: var(--saleBadgeBackground); }
.pdp-gallery__thumb img { width: 100%; height: 100%; object-fit: contain; object-position: center; padding: 4px; }
.pdp-gallery__no-image { width: 100%; height: 100%; display: flex; align-items: center; justify-content: center; color: rgba(var(--textColor-rgb),0.3); font-size: 13px; }

/* ── Info panel ──────────────────────────────────────────────────────────── */
.pdp-info { position: sticky; top: 24px; align-self: start; }
.pdp-info__vendor { font-size: 12px; font-weight: 500; letter-spacing: 0.06em; text-transform: uppercase; color: rgba(var(--textColor-rgb),0.5); margin: 0 0 8px; }
.pdp-info__title { font-family: var(--headingFont); font-size: clamp(22px, 3vw, 32px); font-weight: 600; line-height: 1.1; letter-spacing: -0.015em; color: var(--headingColor); margin: 0 0 16px; }
.pdp-info__sku { font-family: "JetBrains Mono", ui-monospace, monospace; font-size: 11px; letter-spacing: 0.06em; color: rgba(var(--textColor-rgb),0.4); margin: 0 0 4px; }
.pdp-info__variant-count { font-family: "JetBrains Mono", ui-monospace, monospace; font-size: 11px; letter-spacing: 0.06em; color: rgba(var(--textColor-rgb),0.35); margin: 0 0 16px; }

/* Availability badge */
.pdp-badge { display: inline-flex; align-items: center; gap: 6px; font-size: 12px; font-weight: 500; padding: 4px 10px; border-radius: 100px; }
.pdp-badge--available { background: rgba(22,163,74,0.1); color: #15803D; }
.pdp-badge--unavailable { background: rgba(var(--saleBadgeBackground-rgb),0.1); color: var(--saleBadgeBackground); }
.pdp-badge__dot { width: 6px; height: 6px; border-radius: 50%; background: currentColor; flex-shrink: 0; }

/* OECM / Canadian / availability badges row */
.pdp-badges-row { display: flex; flex-wrap: wrap; gap: 8px; align-items: center; margin-bottom: 20px; }
.pdp-tag-pill { font-size: 11px; font-weight: 600; letter-spacing: 0.06em; text-transform: uppercase; border: 1px solid; border-radius: 100px; padding: 3px 10px; display: inline-flex; align-items: center; gap: 5px; }
.pdp-tag-pill--oecm { border-color: #15803D; color: #15803D; }
.pdp-tag-pill--canadian { border-color: var(--saleBadgeBackground); color: var(--saleBadgeBackground); }

/* Short description in right column */
.pdp-info__short-desc { font-size: 15px; line-height: 1.65; color: rgba(var(--textColor-rgb),0.78); margin: 0 0 24px; }
.pdp-info__short-desc p { margin: 0 0 12px; }
.pdp-info__short-desc p:last-child { margin-bottom: 0; }

/* Section eyebrow */
.pdp-section-eyebrow { font-family: "JetBrains Mono", ui-monospace, monospace; font-size: 11px; letter-spacing: 0.1em; text-transform: uppercase; color: rgba(var(--textColor-rgb),0.5); margin: 0 0 8px; }
.pdp-section-eyebrow::before { content: ''; display: block; width: 18px; height: 1px; background: var(--saleBadgeBackground); margin-bottom: 8px; }

/* Variant picker */
.pdp-variants { margin-bottom: 24px; }
.pdp-variants__label { font-size: 13px; font-weight: 500; margin-bottom: 10px; }
.pdp-variants__options { display: flex; flex-wrap: wrap; gap: 8px; }
.pdp-variant-opt { display: inline-flex; align-items: center; justify-content: center; min-width: 36px; height: 36px; padding: 0 12px; border: 1px solid var(--borderColor); border-radius: var(--buttonRadius); font-size: 13px; cursor: pointer; background: var(--background); color: var(--textColor); transition: border-color 0.15s, background 0.15s; font-family: var(--bodyFont); }
.pdp-variant-opt.selected { border-color: var(--textColor); background: var(--textColor); color: var(--background); }
.pdp-variant-opt:hover:not(.selected) { border-color: var(--textColor); }
/* Validation state: red outline on unselected group, chips stay horizontal */
/* !important required: Starlite leftover flex reset overrides class-only specificity */
.pdp-variants.needs-selection .pdp-variants__options { display: flex !important; flex-wrap: wrap !important; outline: 2px solid var(--saleBadgeBackground); border-radius: var(--buttonRadius); padding: 6px; }

/* CTA buttons */
.pdp-btn { display: flex; align-items: center; justify-content: center; width: 100%; border-radius: var(--buttonRadius); font-family: var(--bodyFont); font-size: 16px; font-weight: 500; letter-spacing: 0.01em; text-decoration: none; border: 1px solid transparent; cursor: pointer; transition: background 0.15s, border-color 0.15s; box-sizing: border-box; }
.pdp-btn--primary { background: var(--buttonBackground); color: #ffffff; border-color: var(--buttonBorder); height: 48px; }
.pdp-btn--primary:hover { background: var(--saleBadgeBackground); border-color: var(--saleBadgeBackground); color: #ffffff; }
/* Secondary outline — 44px, smaller than primary 48px to signal secondary action */
.pdp-btn--outline { background: transparent; color: var(--textColor); border-color: var(--textColor); height: 44px; }
.pdp-btn--outline:hover { background: var(--alternateBackground); }
/* 2i: explicit white text — never inherit on red background */
/* Add-to-cart wrapper */
.pdp-atc-wrap { margin-bottom: 0; }
#pdp-add-to-cart { display: block; width: 100%; }

/* Quote strip — compact secondary block */
.pdp-quote-strip { border: 1px solid var(--borderColor); border-radius: var(--cardRadius); padding: 14px 16px; margin-top: 16px; }
.pdp-quote-strip__inner { display: flex; flex-direction: column; gap: 8px; }
.pdp-btn--quote-outline { background: transparent; color: var(--saleBadgeBackground); border-color: var(--saleBadgeBackground); height: 44px; font-size: 14px; }
.pdp-btn--quote-outline:hover { background: rgba(212,37,42,.06); }
.pdp-quote-strip__sub { font-size: 11px; line-height: 1.5; color: rgba(var(--textColor-rgb),0.45); margin: 0; text-align: center; font-family: "JetBrains Mono", ui-monospace, monospace; letter-spacing: 0.04em; }

/* Trust pills */
.pdp-trust { display: flex; flex-wrap: wrap; gap: 8px; margin-top: 20px; padding-top: 20px; border-top: 1px solid var(--borderColor); }
.pdp-trust__pill { font-size: 12px; font-weight: 500; color: rgba(var(--textColor-rgb),0.65); display: inline-flex; align-items: center; gap: 5px; }
.pdp-trust__pill::before { content: "✓"; color: #15803D; font-size: 13px; }

/* Standfirst */
.pdp-standfirst { font-size: 16px; line-height: 1.55; color: rgba(var(--textColor-rgb), 0.78); text-wrap: pretty; margin: 0 0 20px; }

/* Sold-out pill badge */
.pdp-badge--sold { display: inline-flex; align-items: center; padding: 4px 10px; border-radius: 20px; background: #5A5A5E; color: #fff; font-size: 11px; font-family: var(--font-mono, monospace); letter-spacing: 0.06em; text-transform: uppercase; }

/* Phone nudge */
.pdp-phone-nudge { margin-top: 12px; font-size: 13px; color: rgba(var(--textColor-rgb),0.5); text-align: center; }
.pdp-phone-nudge a { color: var(--textColor); font-weight: 500; text-decoration: none; }
.pdp-phone-nudge a:hover { color: var(--saleBadgeBackground); }

/* Price row — above variant chips */
.pdp-price-row {
  font-size: 22px;
  font-weight: 600;
  font-family: 'Inter Tight', sans-serif;
  margin: 12px 0 16px;
}


/* ── Below-fold About section ────────────────────────────────────────────── */
.pdp-about { border-top: 1px solid var(--borderColor); }
.pdp-about__inner { max-width: 1320px; margin: 0 auto; padding: 64px 24px; }
.pdp-about .pdp-section-eyebrow { margin: 0 0 16px; }
.pdp-about__tagline { font-family: 'Inter Tight', sans-serif; font-weight: 600; font-size: var(--fs-h2); letter-spacing: -0.015em; margin: 0 0 24px; max-width: 780px; }
.pdp-about__body { font-size: 17px; line-height: 1.6; color: rgba(var(--textColor-rgb),0.82); }
/* Constrain prose paragraphs only — headings, lists, tables use full container */
.pdp-about__body p { max-width: 640px; font-size: 17px; line-height: 1.6; color: rgba(var(--textColor-rgb), 0.82); margin: 0 0 16px; }
.pdp-about__body p:last-child { margin-bottom: 0; }
/* h2–h6 inside product description → eyebrow treatment, not giant headings */
.pdp-about__body h2,
.pdp-about__body h3,
.pdp-about__body h4,
.pdp-about__body h5,
.pdp-about__body h6 {
  font-family: "JetBrains Mono", ui-monospace, monospace;
  font-size: 11px;
  font-weight: 700;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: rgba(var(--textColor-rgb), 0.5);
  margin: 32px 0 8px;
}
.pdp-about__body h2::before,
.pdp-about__body h3::before,
.pdp-about__body h4::before,
.pdp-about__body h5::before,
.pdp-about__body h6::before {
  content: '';
  display: block;
  width: 18px;
  height: 1px;
  background: var(--saleBadgeBackground);
  margin-bottom: 8px;
}
.pdp-about__body h2:first-child,
.pdp-about__body h3:first-child,
.pdp-about__body h4:first-child,
.pdp-about__body h5:first-child,
.pdp-about__body h6:first-child { margin-top: 0; }
.pdp-about__bestfor { border-top: 1px solid var(--borderColor); margin-top: 32px; padding-top: 24px; }
.pdp-about__bestfor .pdp-section-eyebrow { margin: 0 0 8px; }
.pdp-about__bestfor-text { font-size: 17px; line-height: 1.6; font-family: 'Inter Tight', sans-serif; font-weight: 400 !important; color: rgba(var(--textColor-rgb), 0.82); max-width: 640px; margin: 0; }

/* ── Below-fold Specifications section ───────────────────────────────────── */
.pdp-specs-section { background: var(--alternateBackground); border-top: 1px solid var(--borderColor); padding: 64px 0; }
.pdp-specs-section__inner { max-width: 1320px; margin: 0 auto; padding: 0 24px; }
.pdp-specs-section .pdp-section-eyebrow { margin: 0 0 16px; }
.pdp-specs-section__heading { font-family: var(--headingFont); font-size: clamp(24px, 3vw, 32px); font-weight: 600; line-height: 1.15; letter-spacing: -0.015em; color: var(--headingColor); margin: 0 0 24px; }

/* Spec grid — CSS grid divs replacing legacy <table> */
.pdp-specs-table { border-top: 1px solid var(--textColor); }
.pdp-spec-row { display: grid; grid-template-columns: 28% 72%; gap: 24px; padding: 14px 0; border-bottom: 1px solid var(--borderColor); }
.pdp-spec-row__label { font-family: var(--font-mono, monospace); font-size: 11px; font-weight: 400; letter-spacing: 0.08em; text-transform: uppercase; color: rgba(var(--textColor-rgb), 0.6); }
.pdp-spec-row__value { font-size: 15px; line-height: 1.55; color: var(--textColor); }
.pdp-spec-row__value ul { list-style: none; padding: 0; margin: 0; }
.pdp-spec-row__value li { position: relative; padding-left: 20px; margin-bottom: 4px; }
.pdp-spec-row__value li::before { content: ''; position: absolute; left: 0; top: 50%; transform: translateY(-50%); width: 10px; height: 1px; background: var(--textColor); }
@media (max-width: 640px) {
  .pdp-spec-row { grid-template-columns: 1fr; gap: 4px; }
}

/* ── Related products ────────────────────────────────────────────────────── */
.pdp-related { padding: 56px 0; background: var(--alternateBackground); border-top: 1px solid var(--borderColor); }
.pdp-related__inner { max-width: 1320px; margin: 0 auto; padding: 0 24px; }
.pdp-related__header { display: flex; align-items: baseline; justify-content: space-between; gap: 16px; margin-bottom: 28px; flex-wrap: wrap; }
.pdp-related h2 { font-family: var(--headingFont); font-size: var(--fs-h2); font-weight: 600; color: var(--headingColor); margin: 0; letter-spacing: -0.01em; }
.pdp-related__view-all { font-size: 14px; font-weight: 500; color: rgba(var(--textColor-rgb),0.6); text-decoration: none; }
.pdp-related__view-all:hover { color: var(--saleBadgeBackground); }
.pdp-related__grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 16px; }
@media (min-width: 640px) { .pdp-related__grid { grid-template-columns: repeat(4, 1fr); } }

/* Product card (reused pattern — matches ds-cc-base product card) */
.pdp-prod-card { display: flex; flex-direction: column; border: 1px solid var(--borderColor); border-radius: var(--cardRadius); overflow: hidden; background: var(--cardBackground); text-decoration: none; color: var(--textColor); transition: box-shadow 160ms ease, border-color 160ms ease; }
.pdp-prod-card:hover { box-shadow: var(--shadow-sm); border-color: rgba(var(--textColor-rgb),0.2); }
.pdp-prod-card__img-wrap { aspect-ratio: 4/5; background: #FFFFFF; flex: 0 0 auto; display: flex; align-items: center; justify-content: center; padding: 12px; }
.pdp-prod-card__img { max-width: 100%; max-height: 100%; width: auto; height: auto; object-fit: contain; object-position: center; display: block; }

/* ── Gallery lightbox ────────────────────────────────────────────────────── */
.pdp-lightbox { display: none; position: fixed; inset: 0; z-index: 9000; background: rgba(0,0,0,0.92); align-items: center; justify-content: center; }
.pdp-lightbox.is-open { display: flex; }
.pdp-lightbox__img { max-width: min(90vw, 1200px); max-height: 90vh; width: auto; height: auto; object-fit: contain; display: block; border-radius: 2px; }
.pdp-lightbox__close { position: absolute; top: 20px; right: 24px; background: none; border: none; color: #fff; font-size: 28px; line-height: 1; cursor: pointer; padding: 8px; opacity: 0.75; transition: opacity 0.15s; }
.pdp-lightbox__close:hover { opacity: 1; }
.pdp-lightbox__arrow { position: absolute; top: 50%; transform: translateY(-50%); background: rgba(255,255,255,0.1); border: none; color: #fff; font-size: 22px; line-height: 1; cursor: pointer; padding: 16px 18px; border-radius: 4px; opacity: 0.75; transition: background 0.15s, opacity 0.15s; }
.pdp-lightbox__arrow:hover { background: rgba(255,255,255,0.2); opacity: 1; }
.pdp-lightbox__arrow--prev { left: 20px; }
.pdp-lightbox__arrow--next { right: 20px; }
.pdp-lightbox__counter { position: absolute; bottom: 20px; left: 50%; transform: translateX(-50%); color: rgba(255,255,255,0.5); font-size: 12px; font-family: "JetBrains Mono", ui-monospace, monospace; letter-spacing: 0.08em; }
.pdp-prod-card__body { padding: 12px 14px 16px; flex: 1; display: flex; flex-direction: column; gap: 4px; }
.pdp-prod-card__vendor { font-size: 11px; color: rgba(var(--textColor-rgb),0.45); text-transform: uppercase; letter-spacing: 0.06em; }
.pdp-prod-card__title { font-size: 14px; font-weight: 500; line-height: 1.3; color: var(--headingColor); }
.pdp-prod-card__price { font-size: 14px; font-weight: 600; }

/* ── Phone CTA closer ────────────────────────────────────────────────────── */
.pdp-cta-closer { padding: 56px 24px; text-align: center; border-top: 1px solid var(--borderColor); }
.pdp-cta-closer__inner { max-width: 560px; margin: 0 auto; }
.pdp-cta-closer h2 { font-family: var(--headingFont); font-size: var(--fs-h2); font-weight: 600; color: var(--headingColor); margin: 0 0 8px; letter-spacing: -0.01em; }
.pdp-cta-closer p { font-size: 16px; color: rgba(var(--textColor-rgb),0.7); margin: 0 0 24px; }
/* 2k: explicit #ffffff — never inherit on dark/red background */
.pdp-cta-closer__btn { display: inline-flex; align-items: center; justify-content: center; height: 48px; padding: 0 28px; background: var(--buttonBackground); color: #ffffff; border: 1px solid var(--buttonBorder); border-radius: var(--buttonRadius); font-family: var(--bodyFont); font-size: var(--fs-button); font-weight: 500; letter-spacing: var(--ls-button); text-decoration: none; transition: background 0.15s; }
.pdp-cta-closer__btn:hover { background: var(--saleBadgeBackground); border-color: var(--saleBadgeBackground); color: #ffffff; }
.pdp-cta-closer__phone { margin-top: 16px; font-size: 14px; color: rgba(var(--textColor-rgb),0.6); }
.pdp-cta-closer__phone a { color: var(--textColor); font-weight: 500; text-decoration: none; }
.pdp-cta-closer__phone a:hover { color: var(--saleBadgeBackground); }

/* ── Quantity selector ───────────────────────────────────────────────────── */
.pdp-quantity {
  display: flex;
  align-items: center;
  border: 1px solid var(--borderColor);
  border-radius: var(--cardRadius);
  overflow: hidden;
  width: fit-content;
  margin-bottom: 12px;
}
.pdp-quantity__btn {
  background: none;
  border: none;
  padding: 10px 16px;
  font-size: 18px;
  cursor: pointer;
  color: var(--textColor);
  line-height: 1;
  transition: background 0.15s;
}
.pdp-quantity__btn:hover {
  background: var(--alternateBackground);
}
.pdp-quantity__input {
  width: 48px;
  text-align: center;
  border: none;
  border-left: 1px solid var(--borderColor);
  border-right: 1px solid var(--borderColor);
  font-size: 15px;
  padding: 10px 0;
  -moz-appearance: textfield;
  color: var(--textColor);
  background: none;
}
.pdp-quantity__input::-webkit-outer-spin-button,
.pdp-quantity__input::-webkit-inner-spin-button {
  -webkit-appearance: none;
}

/* ── Buy Now button — secondary outline, below Add to Cart ──────────────── */
.pdp-btn--buy-now {
  width: 100%;
  margin-top: 8px;
}
</style>

{%- comment -%}
  Breadcrumb: derive category from product.type tag
  type:chairs → /collections/seating  "Seating"
  type:desks  → /collections/desks   "Desks & Workstations"
  etc.
{%- endcomment -%}
{%- liquid
  assign cat_handle = ''
  assign cat_label  = ''
  for tag in product.tags
    if tag == 'type:chairs'
      assign cat_handle = 'seating'
      assign cat_label  = 'Seating'
    elsif tag == 'type:desks'
      assign cat_handle = 'desks'
      assign cat_label  = 'Desks & Workstations'
    elsif tag == 'type:storage'
      assign cat_handle = 'storage'
      assign cat_label  = 'Storage & Filing'
    elsif tag == 'type:tables'
      assign cat_handle = 'tables'
      assign cat_label  = 'Tables'
    elsif tag == 'type:boardroom'
      assign cat_handle = 'boardroom'
      assign cat_label  = 'Boardroom'
    elsif tag == 'type:ergonomic'
      assign cat_handle = 'ergonomic-products'
      assign cat_label  = 'Ergonomic Products'
    elsif tag == 'type:panels'
      assign cat_handle = 'panels-room-dividers'
      assign cat_label  = 'Panels & Dividers'
    elsif tag == 'type:accessories'
      assign cat_handle = 'accessories'
      assign cat_label  = 'Accessories'
    elsif tag == 'type:quiet-spaces'
      assign cat_handle = 'quiet-spaces'
      assign cat_label  = 'Quiet Spaces'
    endif
  endfor
  assign is_unbuyable = false
  if product.price == 0 or product.available == false
    assign is_unbuyable = true
  endif
  assign all_cat_handle = ''
  if cat_handle == 'seating'
    assign all_cat_handle = 'all-seating'
  elsif cat_handle == 'desks'
    assign all_cat_handle = 'all-desks'
  elsif cat_handle == 'storage'
    assign all_cat_handle = 'all-storage'
  elsif cat_handle == 'tables'
    assign all_cat_handle = 'all-tables'
  elsif cat_handle == 'boardroom'
    assign all_cat_handle = 'all-boardroom'
  elsif cat_handle == 'ergonomic-products'
    assign all_cat_handle = 'all-ergonomic'
  elsif cat_handle == 'panels-room-dividers'
    assign all_cat_handle = 'all-panels'
  elsif cat_handle == 'accessories'
    assign all_cat_handle = 'all-accessories'
  elsif cat_handle == 'quiet-spaces'
    assign all_cat_handle = 'all-quiet-spaces'
  endif
-%}

{%- render 'bbi-product-jsonld', product: product, cat_handle: cat_handle, cat_label: cat_label -%}

<div class="bbi-pdp scheme-default">
  {%- render 'bbi-nav', logo: section.settings.logo, active: 'shop' -%}

  <main id="MainContent">

    <!-- Breadcrumb (4-level: Home > Shop Furniture > Category > Product) -->
    <nav class="pdp-breadcrumb" aria-label="Breadcrumb">
      <div class="pdp-breadcrumb__inner">
        <a href="/">Home</a>
        <span class="pdp-breadcrumb__sep" aria-hidden="true">/</span>
        <a href="/collections/business-furniture">Shop Furniture</a>
        <span class="pdp-breadcrumb__sep" aria-hidden="true">/</span>
        {%- if cat_handle != blank -%}
          <a href="/collections/{{ cat_handle }}">{{ cat_label }}</a>
        {%- else -%}
          <a href="/collections/other">Other</a>
        {%- endif -%}
        <span class="pdp-breadcrumb__sep" aria-hidden="true">/</span>
        <span aria-current="page">{{ product.title }}</span>
      </div>
    </nav>

    <!-- Product hero: gallery + info -->
    <div class="pdp-main">

      <!-- Gallery -->
      <bbi-pdp-gallery class="pdp-gallery">
        <div class="pdp-gallery__main">
          {%- if product.images.size > 0 -%}
            {{- product.images[0]
                | image_url: width: 1024
                | image_tag:
                    id: 'pdp-main-img',
                    class: 'pdp-gallery__main-img',
                    loading: 'eager',
                    width: product.images[0].width,
                    height: product.images[0].height,
                    alt: product.images[0].alt | default: product.title | escape -}}
          {%- else -%}
            <span class="pdp-gallery__no-image">No image available</span>
          {%- endif -%}
        </div>

        {%- if product.images.size > 1 -%}
          <div class="pdp-gallery__thumbs" role="list">
            {%- for image in product.images limit: 8 -%}
              <button
                class="pdp-gallery__thumb"
                type="button"
                aria-label="View image {{ forloop.index }}"
                aria-pressed="{{ forloop.first }}"
                data-src="{{ image | image_url: width: 1024 }}"
                data-full="{{ image | image_url: width: 1600 }}"
                role="listitem"
              >
                {{- image
                    | image_url: width: 144
                    | image_tag:
                        loading: 'lazy',
                        width: 72,
                        height: 72,
                        alt: image.alt | default: product.title | escape -}}
              </button>
            {%- endfor -%}
          </div>
        {%- endif -%}
      </bbi-pdp-gallery>

      <!-- Info panel -->
      <bbi-pdp-variants class="pdp-info">
        {%- if product.vendor != blank -%}
          <p class="pdp-info__vendor">{{ product.vendor }}</p>
        {%- endif -%}

        <h1 class="pdp-info__title">{{ product.title }}</h1>

        {%- if product.selected_or_first_available_variant.sku != blank -%}
          <p class="pdp-info__sku">SKU: {{ product.selected_or_first_available_variant.sku }}</p>
        {%- endif -%}
        {%- unless product.has_only_default_variant -%}
          <p class="pdp-info__variant-count">{{ product.variants.size }} configurations available</p>
        {%- endunless -%}

        <!-- Badges row: availability + OECM + Canadian-Made -->
        {%- liquid
          assign has_oecm = false
          assign has_canadian = false
          for tag in product.tags
            assign tag_down = tag | downcase
            if tag_down == 'oecm'
              assign has_oecm = true
            endif
            if tag_down == 'canadian-made'
              assign has_canadian = true
            endif
          endfor
        -%}
        <div class="pdp-badges-row">
          {%- if is_unbuyable -%}
            <span class="pdp-badge--sold">Sold out</span>
          {%- else -%}
            <span class="pdp-badge pdp-badge--available">
              <span class="pdp-badge__dot" aria-hidden="true"></span>
              In stock
            </span>
          {%- endif -%}
          {%- if has_oecm -%}
            <span class="pdp-tag-pill pdp-tag-pill--oecm">OECM Eligible</span>
          {%- endif -%}
          {%- if has_canadian -%}
            <span class="pdp-tag-pill pdp-tag-pill--canadian">Canadian Made</span>
          {%- endif -%}
        </div>

        <div class="pdp-price-row">
          {{ product.selected_or_first_available_variant.price | money }}
        </div>

        {%- assign standfirst = product.metafields.specs.standfirst.value -%}
        {%- if standfirst != blank -%}
          <p class="pdp-standfirst">{{ standfirst }}</p>
        {%- endif -%}

        <!-- Spec metafield assignments — reused in below-fold sections -->
        {%- liquid
          assign kf_inline = product.metafields.specs.key_features.value
          assign si_manufacturer = product.metafields.specs.manufacturer.value
          assign si_product_line = product.metafields.specs.product_line.value
          assign si_model_codes  = product.metafields.specs.model_codes.value
          assign si_dimensions   = product.metafields.specs.dimensions.value
          assign si_weight       = product.metafields.specs.weight.value
          assign si_weight_cap   = product.metafields.specs.weight_capacity.value
          assign si_materials    = product.metafields.specs.materials.value
          assign si_finishes     = product.metafields.specs.finishes_available.value
          assign si_certs        = product.metafields.specs.certifications.value
          assign si_warranty     = product.metafields.specs.warranty.value
          assign si_country      = product.metafields.specs.country_of_manufacture.value
          assign has_specs = false
          if si_manufacturer or si_product_line or si_model_codes or si_dimensions or si_weight or si_weight_cap or si_materials or si_finishes or si_certs or si_warranty or si_country
            assign has_specs = true
          endif
        -%}

        <!-- Variant options (non-colour) — 2b: wired to form via data attrs -->
        {%- unless product.has_only_default_variant -%}
          {%- for option in product.options_with_values -%}
            {%- assign _opt_down = option.name | downcase -%}
            {%- unless _opt_down contains 'color' or _opt_down contains 'colour' -%}
              <div class="pdp-variants" data-option-pos="{{ option.position | minus: 1 }}">
                <p class="pdp-variants__label">{{ option.name }}: <strong class="pdp-variants__selected-val">{{ option.values | first }}</strong></p>
                <div class="pdp-variants__options" role="group" aria-label="{{ option.name }}">
                  {%- for value in option.values -%}
                    <button type="button"
                      class="pdp-variant-opt{% if forloop.first %} selected{% endif %}"
                      data-option-pos="{{ option.position | minus: 1 }}"
                      data-value="{{ value | escape }}">{{ value }}</button>
                  {%- endfor -%}
                </div>
              </div>
            {%- endunless -%}
          {%- endfor -%}
          {%- comment -%}Variant data for JS chip wiring{%- endcomment -%}
          <script id="pdp-variants-data" type="application/json">
          {
            "numOptions": {{ product.options.size }},
            "variants": [
              {%- for variant in product.variants -%}
              {
                "id": {{ variant.id }},
                "available": {{ variant.available }},
                "price": {{ variant.price }},
                "compare_at_price": {{ variant.compare_at_price | default: 0 }},
                "options": {{ variant.options | json }}
              }{%- unless forloop.last -%},{%- endunless -%}
              {%- endfor -%}
            ]
          }
          </script>
        {%- endunless -%}

        <!-- Add to Cart + Buy now -->
        {%- unless is_unbuyable -%}
          <div class="pdp-atc-wrap">
            {%- form 'product', product, id: 'pdp-add-to-cart' -%}
              <input type="hidden" name="id" value="{{ product.selected_or_first_available_variant.id }}">
              <div class="pdp-quantity">
                <button class="pdp-quantity__btn" data-quantity-minus
                        aria-label="Decrease quantity" type="button">−</button>
                <input class="pdp-quantity__input"
                       type="number"
                       name="quantity"
                       id="pdp-quantity-input"
                       value="1"
                       min="1"
                       aria-label="Quantity">
                <button class="pdp-quantity__btn" data-quantity-plus
                        aria-label="Increase quantity" type="button">+</button>
              </div>
              <button type="submit" class="pdp-btn pdp-btn--primary"
                {%- if product.selected_or_first_available_variant.available == false %} disabled{%- endif -%}>
                {%- if product.selected_or_first_available_variant.available -%}Add to Cart{%- else -%}Unavailable{%- endif -%}
              </button>
              <button type="button"
                      class="pdp-btn pdp-btn--outline pdp-btn--buy-now"
                      data-buy-now>
                Buy now
              </button>
            {%- endform -%}
          </div>
        {%- endunless -%}

        <!-- Quote strip (compact) -->
        <div class="pdp-quote-strip">
          <div class="pdp-quote-strip__inner">
            <button type="button"
              class="pdp-btn pdp-btn--quote-outline"
              data-bbi-quote-trigger
              data-lead-type="quote"
              data-product-handle="{{ product.handle }}"
              data-product-title="{{ product.title | escape }}"
              data-variant-id="{{ product.selected_or_first_available_variant.id }}">
              Request a quote &rarr;
            </button>
            <p class="pdp-quote-strip__sub">Volume orders &middot; OECM PO eligibility &middot; confirmed within 1 business day</p>
          </div>
        </div>

        <!-- Trust pills -->
        <div class="pdp-trust">
          <span class="pdp-trust__pill">Delivered across Ontario</span>
          <span class="pdp-trust__pill">OECM-eligible supplier</span>
          <span class="pdp-trust__pill">Since 1964</span>
        </div>

        <p class="pdp-phone-nudge">
          Questions? Call <a href="tel:18008359565">1-800-835-9565</a>
        </p>
      </bbi-pdp-variants>
    </div>

    <!-- About this product (full-width, below fold) -->
    <section class="pdp-about">
      <div class="pdp-about__inner">
        <p class="pdp-section-eyebrow">About this product</p>
        {%- assign tagline = product.metafields.specs.tagline.value -%}
        {%- if tagline != blank -%}
          <h2 class="pdp-about__tagline">{{ tagline | escape }}</h2>
        {%- endif -%}
        {%- comment -%}
          Strip everything from the first <h3> onward — Key features / Who it's for /
          closing boilerplate all live in the Specs section or the BEST FOR block below.
          For legacy products with no <h3>, the split returns a single-item array and
          [0] is the full description — no content lost.
        {%- endcomment -%}
        {%- assign _desc_intro = product.description | split: '<h3>' | first -%}
        <div class="pdp-about__body">{{ _desc_intro }}</div>
        {%- assign who_its_for = product.metafields.specs.who_its_for.value -%}
        {%- if who_its_for != blank -%}
          <div class="pdp-about__bestfor">
            <p class="pdp-section-eyebrow">Who it's for</p>
            <p class="pdp-about__bestfor-text">{{ who_its_for }}</p>
          </div>
        {%- endif -%}
      </div>
    </section>

    <!-- Specifications (full-width, below fold) -->
    {%- if has_specs or kf_inline != blank -%}
      <section class="pdp-specs-section">
        <div class="pdp-specs-section__inner">
          <p class="pdp-section-eyebrow">Specifications</p>
          <h2 class="pdp-specs-section__heading">Everything we'd put on the spec sheet.</h2>
          <div class="pdp-specs-table">
            {%- if kf_inline != blank and kf_inline.size > 0 -%}
              <div class="pdp-spec-row">
                <span class="pdp-spec-row__label">Key Features</span>
                <span class="pdp-spec-row__value"><ul>{%- for f in kf_inline -%}<li>{{ f | escape }}</li>{%- endfor -%}</ul></span>
              </div>
            {%- endif -%}
            {%- if si_manufacturer != blank -%}
              <div class="pdp-spec-row"><span class="pdp-spec-row__label">Manufacturer</span><span class="pdp-spec-row__value">{{ si_manufacturer | escape }}</span></div>
            {%- endif -%}
            {%- if si_product_line != blank -%}
              <div class="pdp-spec-row"><span class="pdp-spec-row__label">Product Line</span><span class="pdp-spec-row__value">{{ si_product_line | escape }}</span></div>
            {%- endif -%}
            {%- if si_model_codes != blank and si_model_codes.size > 0 -%}
              <div class="pdp-spec-row"><span class="pdp-spec-row__label">Model</span><span class="pdp-spec-row__value">{{ si_model_codes | join: ', ' | escape }}</span></div>
            {%- endif -%}
            {%- if si_dimensions != blank -%}
              <div class="pdp-spec-row"><span class="pdp-spec-row__label">Dimensions</span><span class="pdp-spec-row__value">{{ si_dimensions | escape }}</span></div>
            {%- endif -%}
            {%- if si_weight != blank -%}
              <div class="pdp-spec-row"><span class="pdp-spec-row__label">Weight</span><span class="pdp-spec-row__value">{{ si_weight | escape }}</span></div>
            {%- endif -%}
            {%- if si_weight_cap != blank -%}
              <div class="pdp-spec-row"><span class="pdp-spec-row__label">Weight Capacity</span><span class="pdp-spec-row__value">{{ si_weight_cap | escape }}</span></div>
            {%- endif -%}
            {%- if si_materials != blank -%}
              <div class="pdp-spec-row"><span class="pdp-spec-row__label">Materials</span><span class="pdp-spec-row__value">{{ si_materials | escape | newline_to_br }}</span></div>
            {%- endif -%}
            {%- if si_finishes != blank and si_finishes.size > 0 -%}
              <div class="pdp-spec-row">
                <span class="pdp-spec-row__label">Finishes Available</span>
                <span class="pdp-spec-row__value"><ul>{%- for f in si_finishes -%}<li>{{ f | escape }}</li>{%- endfor -%}</ul></span>
              </div>
            {%- endif -%}
            {%- if si_certs != blank and si_certs.size > 0 -%}
              <div class="pdp-spec-row">
                <span class="pdp-spec-row__label">Certifications</span>
                <span class="pdp-spec-row__value"><ul>{%- for c in si_certs -%}<li>{{ c | escape }}</li>{%- endfor -%}</ul></span>
              </div>
            {%- endif -%}
            {%- if si_warranty != blank -%}
              <div class="pdp-spec-row"><span class="pdp-spec-row__label">Warranty</span><span class="pdp-spec-row__value">{{ si_warranty | escape }}</span></div>
            {%- endif -%}
            {%- if si_country != blank -%}
              <div class="pdp-spec-row"><span class="pdp-spec-row__label">Made In</span><span class="pdp-spec-row__value">{{ si_country | escape }}</span></div>
            {%- endif -%}
          </div>
        </div>
      </section>
    {%- endif -%}

    <!-- Related products — Tier 1 only: best sellers in same category -->
    {%- liquid
      assign _rc = nil
      assign _rv = ''
      assign _rl = ''

      if all_cat_handle != blank
        assign _t1 = collections[all_cat_handle]
        if _t1 != blank
          assign _rc = _t1
          assign _rv = '/collections/' | append: all_cat_handle
          assign _rl = 'View all ' | append: cat_label
        endif
      endif
    -%}
    {%- if _rc != blank -%}
      {%- capture _cards -%}
        {%- assign _shown = 0 -%}
        {%- for rp in _rc.products -%}
          {%- if rp.id != product.id and _shown < 4 -%}
            {%- assign _shown = _shown | plus: 1 -%}
            <a href="{{ rp.url }}" class="pdp-prod-card">
              {%- if rp.featured_image -%}
                <div class="pdp-prod-card__img-wrap">
                  {{- rp.featured_image
                      | image_url: width: 480
                      | image_tag:
                          class: 'pdp-prod-card__img',
                          loading: 'lazy',
                          width: rp.featured_image.width,
                          height: rp.featured_image.height,
                          alt: rp.featured_image.alt | default: rp.title | escape -}}
                </div>
              {%- endif -%}
              <div class="pdp-prod-card__body">
                {%- if rp.vendor != blank -%}
                  <p class="pdp-prod-card__vendor">{{ rp.vendor }}</p>
                {%- endif -%}
                <p class="pdp-prod-card__title">{{ rp.title }}</p>
                <p class="pdp-prod-card__price">
                  {%- if rp.price == 0 or rp.available == false -%}Quote only
                  {%- else -%}{{ rp.price | money }}{%- endif -%}
                </p>
              </div>
            </a>
          {%- endif -%}
        {%- endfor -%}
      {%- endcapture -%}
      {%- if _cards != blank -%}
        <section class="pdp-related">
          <div class="pdp-related__inner">
            <div class="pdp-related__header">
              <h2>Best sellers in {{ cat_label }}</h2>
              <a href="{{ _rv }}" class="pdp-related__view-all">{{ _rl }} &rarr;</a>
            </div>
            <div class="pdp-related__grid">{{ _cards }}</div>
          </div>
        </section>
      {%- endif -%}
    {%- endif -%}

    <!-- CTA closer -->
    <section class="pdp-cta-closer">
      <div class="pdp-cta-closer__inner">
        <h2>Need a custom configuration?</h2>
        <p>Our team quotes single items to full office buildouts — usually within one business day.</p>
        <button type="button" class="pdp-cta-closer__btn" data-bbi-quote-trigger data-lead-type="quote">Request a Quote</button>
        <p class="pdp-cta-closer__phone">Or call <a href="tel:18008359565">1-800-835-9565</a></p>
      </div>
    </section>

  </main>

  {%- render 'bbi-footer', logo: section.settings.logo -%}

  <!-- Gallery lightbox -->
  <div class="pdp-lightbox" id="pdp-lightbox" role="dialog" aria-modal="true" aria-label="Image viewer">
    <button class="pdp-lightbox__close" id="pdp-lightbox-close" aria-label="Close">&times;</button>
    <button class="pdp-lightbox__arrow pdp-lightbox__arrow--prev" id="pdp-lightbox-prev" aria-label="Previous image">&#8249;</button>
    <img class="pdp-lightbox__img" id="pdp-lightbox-img" src="" alt="">
    <button class="pdp-lightbox__arrow pdp-lightbox__arrow--next" id="pdp-lightbox-next" aria-label="Next image">&#8250;</button>
    <span class="pdp-lightbox__counter" id="pdp-lightbox-counter"></span>
  </div>
</div>

<script>
/* 2a: bbi-pdp-gallery — thumbnail click swaps main image; click main image opens lightbox */
class BbiPdpGallery extends HTMLElement {
  connectedCallback() {
    this.mainImg = this.querySelector('#pdp-main-img');
    if (!this.mainImg) return;

    /* Build ordered image list from thumbs (full-res URLs) */
    this._imgs = [];
    this.querySelectorAll('.pdp-gallery__thumb').forEach((btn, i) => {
      this._imgs.push({ src: btn.dataset.full || btn.dataset.src, alt: btn.querySelector('img')?.alt || '' });
      btn.addEventListener('click', () => this._swap(btn, i));
      btn.addEventListener('keydown', e => {
        if (e.key === 'Enter' || e.key === ' ') { e.preventDefault(); this._swap(btn, i); }
      });
    });

    /* If no thumbs, use main image itself */
    if (this._imgs.length === 0) {
      this._imgs = [{ src: this.mainImg.getAttribute('data-full') || this.mainImg.src, alt: this.mainImg.alt }];
    }
    this._current = 0;

    /* Click main image → open lightbox */
    this.mainImg.style.cursor = 'zoom-in';
    this.mainImg.addEventListener('click', () => this._openLightbox(this._current));

    /* Lightbox controls */
    this._lb     = document.getElementById('pdp-lightbox');
    this._lbImg  = document.getElementById('pdp-lightbox-img');
    this._lbCtr  = document.getElementById('pdp-lightbox-counter');
    document.getElementById('pdp-lightbox-close')?.addEventListener('click', () => this._closeLightbox());
    document.getElementById('pdp-lightbox-prev')?.addEventListener('click', () => this._lbNav(-1));
    document.getElementById('pdp-lightbox-next')?.addEventListener('click', () => this._lbNav(1));
    this._lb?.addEventListener('click', e => { if (e.target === this._lb) this._closeLightbox(); });
    document.addEventListener('keydown', e => {
      if (!this._lb?.classList.contains('is-open')) return;
      if (e.key === 'Escape') this._closeLightbox();
      if (e.key === 'ArrowLeft') this._lbNav(-1);
      if (e.key === 'ArrowRight') this._lbNav(1);
    });

    /* Hide arrows when single image */
    if (this._imgs.length <= 1) {
      document.getElementById('pdp-lightbox-prev')?.style.setProperty('display','none');
      document.getElementById('pdp-lightbox-next')?.style.setProperty('display','none');
    }
  }

  _swap(btn, idx) {
    this.mainImg.srcset = '';
    this.mainImg.src = btn.dataset.src;
    this.mainImg.setAttribute('data-full', btn.dataset.full || btn.dataset.src);
    this.querySelectorAll('.pdp-gallery__thumb').forEach(b => b.setAttribute('aria-pressed', 'false'));
    btn.setAttribute('aria-pressed', 'true');
    this._current = idx;
  }

  _openLightbox(idx) {
    if (!this._lb || !this._lbImg) return;
    this._lbIdx = idx;
    const item = this._imgs[idx];
    this._lbImg.src = item.src;
    this._lbImg.alt = item.alt;
    this._updateCounter();
    this._lb.classList.add('is-open');
    document.body.style.overflow = 'hidden';
    document.getElementById('pdp-lightbox-close')?.focus();
  }

  _closeLightbox() {
    this._lb?.classList.remove('is-open');
    document.body.style.overflow = '';
    this.mainImg?.focus();
  }

  _lbNav(dir) {
    this._lbIdx = (this._lbIdx + dir + this._imgs.length) % this._imgs.length;
    const item = this._imgs[this._lbIdx];
    this._lbImg.src = item.src;
    this._lbImg.alt = item.alt;
    this._updateCounter();
  }

  _updateCounter() {
    if (this._lbCtr && this._imgs.length > 1) {
      this._lbCtr.textContent = `${this._lbIdx + 1} / ${this._imgs.length}`;
    }
  }
}
customElements.define('bbi-pdp-gallery', BbiPdpGallery);

/* Format cents to match Shopify money filter output: $1,234.56 */
function _fmtMoney(cents) {
  const n = (cents / 100).toFixed(2);
  const [int, dec] = n.split('.');
  return '$' + int.replace(/\B(?=(\d{3})+(?!\d))/g, ',') + '.' + dec;
}

/* 2b: BbiPdpVariants — chip click updates hidden form id input */
class BbiPdpVariants extends HTMLElement {
  connectedCallback() {
    const dataEl = document.getElementById('pdp-variants-data');
    if (!dataEl) return;
    try {
      const data = JSON.parse(dataEl.textContent);
      this._variants = data.variants || [];
    } catch (e) { return; }

    /* Track currently selected value per option position */
    this._selected = {};
    this.querySelectorAll('.pdp-variant-opt').forEach(btn => {
      if (btn.classList.contains('selected')) {
        this._selected[btn.dataset.optionPos] = btn.dataset.value;
      }
      btn.addEventListener('click', () => this._select(btn));
    });
    this._updateFormId();
  }

  _select(btn) {
    const pos = btn.dataset.optionPos;
    /* Update selected state within this option group */
    this.querySelectorAll(`.pdp-variant-opt[data-option-pos="${pos}"]`).forEach(b => {
      b.classList.remove('selected');
    });
    btn.classList.add('selected');
    this._selected[pos] = btn.dataset.value;

    /* Update the label */
    const group = btn.closest('.pdp-variants');
    if (group) {
      const lbl = group.querySelector('.pdp-variants__selected-val');
      if (lbl) lbl.textContent = btn.dataset.value;
    }
    this._updateFormId();
  }

  _updateFormId() {
    /* Find variant matching all currently selected options */
    const match = this._variants.find(v => {
      return Object.keys(this._selected).every(pos => {
        return v.options[parseInt(pos)] === this._selected[pos];
      });
    });
    if (match) {
      /* Update hidden form input (only exists for in-stock products) */
      const form = document.getElementById('pdp-add-to-cart');
      if (form) {
        const idInput = form.querySelector('input[name="id"]');
        if (idInput) idInput.value = match.id;
        /* Reflect availability on the submit button */
        const submitBtn = form.querySelector('button[type="submit"]');
        if (submitBtn) {
          submitBtn.disabled = !match.available;
          submitBtn.textContent = match.available ? 'Add to Cart' : 'Unavailable';
        }
      }
      /* Update quote button variant id */
      const quoteBtn = this.querySelector('[data-bbi-quote-trigger]');
      if (quoteBtn) quoteBtn.dataset.variantId = match.id;
      /* Update price row above variant chips (Shopify prices are in cents) */
      const priceEl = this.querySelector('.pdp-price-row');
      if (priceEl && match.price != null) {
        priceEl.textContent = _fmtMoney(match.price);
      }
    }
  }
}
customElements.define('bbi-pdp-variants', BbiPdpVariants);

/* 2g: AJAX Add to Cart — validates options, posts to /cart/add.js, dispatches cart:updated */
(function() {
  const form = document.getElementById('pdp-add-to-cart');
  if (!form) return;

  /* Clear validation state on chip click */
  document.querySelectorAll('.pdp-variant-opt').forEach(btn => {
    btn.addEventListener('click', () => {
      btn.closest('.pdp-variants')?.classList.remove('needs-selection');
    });
  });

  form.addEventListener('submit', async function(e) {
    e.preventDefault();

    /* Validate all option groups have a selection */
    const groups = document.querySelectorAll('.pdp-variants');
    let valid = true;
    groups.forEach(group => {
      const hasSelected = group.querySelector('.pdp-variant-opt.selected');
      if (!hasSelected) { group.classList.add('needs-selection'); valid = false; }
      else group.classList.remove('needs-selection');
    });
    if (!valid) {
      const first = document.querySelector('.pdp-variants.needs-selection');
      if (first) first.scrollIntoView({ behavior: 'smooth', block: 'center' });
      return;
    }

    const submitBtn = form.querySelector('button[type="submit"]');
    const idInput   = form.querySelector('input[name="id"]');
    const qtyInput  = document.getElementById('pdp-quantity-input');
    const variantId = idInput?.value;
    const qty       = parseInt(qtyInput?.value || '1', 10);

    if (!variantId) return;

    const original = submitBtn?.textContent || 'Add to Cart';
    if (submitBtn) { submitBtn.disabled = true; submitBtn.textContent = 'Adding…'; }

    try {
      const res = await fetch('/cart/add.js', {
        method:  'POST',
        headers: { 'Content-Type': 'application/json', Accept: 'application/json' },
        body:    JSON.stringify({ id: variantId, quantity: qty })
      });
      if (!res.ok) throw new Error('Cart add failed');
      document.dispatchEvent(new CustomEvent('cart:updated'));
      if (submitBtn) { submitBtn.textContent = 'Added ✓'; }
      setTimeout(() => {
        if (submitBtn) { submitBtn.disabled = false; submitBtn.textContent = original; }
      }, 2000);
    } catch (err) {
      if (submitBtn) { submitBtn.disabled = false; submitBtn.textContent = original; }
      console.error('Add to cart error:', err);
    }
  });
})();

/* Quantity stepper */
document.addEventListener('DOMContentLoaded', function () {
  const minus = document.querySelector('[data-quantity-minus]');
  const plus  = document.querySelector('[data-quantity-plus]');
  const input = document.getElementById('pdp-quantity-input');
  if (!minus || !plus || !input) return;
  minus.addEventListener('click', function () {
    const val = parseInt(input.value, 10);
    if (val > 1) input.value = val - 1;
  });
  plus.addEventListener('click', function () {
    input.value = parseInt(input.value, 10) + 1;
  });
});

/* Buy Now */
document.addEventListener('DOMContentLoaded', function () {
  const buyNow = document.querySelector('[data-buy-now]');
  if (!buyNow) return;
  buyNow.addEventListener('click', async function () {
    buyNow.disabled = true;
    buyNow.textContent = 'Adding…';
    try {
      const variantInput = document.querySelector(
        '[name="id"], [data-selected-variant]'
      );
      const variantId = variantInput
        ? (variantInput.value || variantInput.dataset.selectedVariant)
        : null;
      const qty = parseInt(
        document.getElementById('pdp-quantity-input')?.value || '1', 10
      );
      if (!variantId) throw new Error('No variant selected');
      await fetch('/cart/add.js', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ id: variantId, quantity: qty })
      });
      window.location.href = '/checkout';
    } catch (e) {
      buyNow.disabled = false;
      buyNow.textContent = 'Buy now';
      console.error('Buy Now failed:', e);
    }
  });
});
