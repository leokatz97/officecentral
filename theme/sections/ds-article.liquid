{%- comment -%}
  Section: ds-article
  Purpose: BBI article/post detail page — hero image, prose body, related products,
           FAQPage schema (if article.metafields.faq exists), share buttons, metadata.
  Template: article.json
  Gate: template.name == 'article' (in bbi_landing gate in theme.liquid).
  Schema: logo (image_picker).
  Notes:
    - FAQPage JSON-LD auto-renders if article has a metafield `faq.items` (list.single_line_text).
    - Related products pulled from article tag matching a collection handle via
      article.metafields.custom.related_collection (single_line_text); graceful fallback.
    - First posts require DataForSEO keyword research before writing (CLAUDE.md rule).
{%- endcomment -%}

{% # theme-check-disable RemoteAsset %}
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Inter+Tight:wght@600&family=Inter:wght@400;500;600&family=JetBrains+Mono:wght@400&display=swap" rel="stylesheet">
{% # theme-check-enable RemoteAsset %}

<style>
/* ============================================================
   BBI Design Tokens — DS v2
   ============================================================ */
:root {
  --bodyFont: "Inter", system-ui, -apple-system, "Segoe UI", Roboto, sans-serif;
  --headingFont: "Inter Tight", "Inter", system-ui, sans-serif;
  --space-1: 4px; --space-2: 8px; --space-3: 12px; --space-4: 16px;
  --space-6: 24px; --space-8: 32px; --space-12: 48px; --space-16: 64px;
  --inputRadius: 4px; --buttonRadius: 4px; --cardRadius: 8px;
  --shadow-sm: 0 1px 2px rgba(11,11,12,.04), 0 2px 8px rgba(11,11,12,.05);
  --saleBadgeBackground: #D4252A;
  --saleBadgeBackground-rgb: 212,37,42;
  --fs-h1: 32px; --lh-h1: 1.1; --ls-h1: -0.015em;
  --fs-h2: 24px; --lh-h2: 1.15; --ls-h2: -0.01em;
  --fs-h3: 18px; --lh-h3: 1.25;
  --fs-body: 16px; --lh-body: 1.55;
  --fs-small: 13px;
  --fs-button: 15px; --lh-button: 1; --ls-button: 0.01em;
}
@media (min-width: 768px) {
  :root {
    --fs-h1: 48px; --lh-h1: 1.05;
    --fs-h2: 32px; --lh-h2: 1.1;
    --fs-h3: 22px; --lh-h3: 1.2;
    --fs-small: 14px;
  }
}
.bbi-article.scheme-default {
  --background: #FFFFFF; --background-rgb: 255,255,255;
  --alternateBackground: #FAFAFA;
  --cardBackground: #FFFFFF;
  --textColor: #0B0B0C; --textColor-rgb: 11,11,12;
  --linkColor: #0B0B0C; --headingColor: #0B0B0C; --headingColor-rgb: 11,11,12;
  --buttonBackground: #0B0B0C; --buttonColor: #FFFFFF; --buttonBorder: #0B0B0C;
  --buttonBackgroundHover: #D4252A; --buttonColorHover: #FFFFFF; --buttonBorderHover: #D4252A;
  --borderColor: #E5E5E7; --borderColor-rgb: 229,229,231;
  --shadowColor: #0B0B0C; --shadowColor-rgb: 11,11,12;
}

/* ── Base ────────────────────────────────────────────────────────────────── */
.bbi-article *, .bbi-article *::before, .bbi-article *::after { box-sizing: border-box; }
.bbi-article { font-family: var(--bodyFont); font-size: var(--fs-body); line-height: var(--lh-body); color: var(--textColor); background: var(--background); -webkit-font-smoothing: antialiased; }
.bbi-article img { display: block; max-width: 100%; height: auto; }
.bbi-article a { color: var(--linkColor); }

/* ── Article hero ────────────────────────────────────────────────────────── */
.article-header { padding: 48px 0 0; border-bottom: 1px solid var(--borderColor); }
.article-header__inner { max-width: 760px; margin: 0 auto; padding: 0 24px 40px; }
.article-header__breadcrumb { font-size: 13px; color: rgba(var(--textColor-rgb),0.5); margin: 0 0 20px; }
.article-header__breadcrumb a { color: inherit; text-decoration: none; }
.article-header__breadcrumb a:hover { color: var(--saleBadgeBackground); }
.article-header__tag { font-family: "JetBrains Mono", ui-monospace, monospace; font-size: 10px; letter-spacing: 0.08em; text-transform: uppercase; color: var(--saleBadgeBackground); margin: 0 0 16px; }
.article-header h1 { font-family: var(--headingFont); font-size: clamp(28px, 4vw, 44px); line-height: 1.1; letter-spacing: -0.02em; font-weight: 600; color: var(--headingColor); margin: 0 0 20px; text-wrap: balance; }
.article-header__meta { display: flex; flex-wrap: wrap; gap: 16px; font-size: 13px; color: rgba(var(--textColor-rgb),0.5); margin-bottom: 32px; }
.article-header__img-wrap { aspect-ratio: 16/9; border-radius: var(--cardRadius) var(--cardRadius) 0 0; overflow: hidden; background: var(--alternateBackground); max-width: 100%; }
.article-header__img { width: 100%; height: 100%; object-fit: cover; }

/* ── Article body ────────────────────────────────────────────────────────── */
.article-body { padding: 48px 0 64px; }
.article-body__inner { max-width: 760px; margin: 0 auto; padding: 0 24px; }

/* Prose typography */
.article-prose { font-size: 16px; line-height: 1.7; }
.article-prose h2 { font-family: var(--headingFont); font-size: var(--fs-h2); font-weight: 600; letter-spacing: -0.01em; color: var(--headingColor); margin: 2em 0 0.6em; }
.article-prose h3 { font-family: var(--headingFont); font-size: var(--fs-h3); font-weight: 600; color: var(--headingColor); margin: 1.75em 0 0.5em; }
.article-prose p { margin: 0 0 1.4em; }
.article-prose a { text-decoration: underline; }
.article-prose a:hover { color: var(--saleBadgeBackground); }
.article-prose ul, .article-prose ol { padding-left: 1.5em; margin: 0 0 1.4em; }
.article-prose li { margin-bottom: 0.4em; }
.article-prose blockquote { border-left: 3px solid var(--saleBadgeBackground); margin: 2em 0; padding: 0.25em 0 0.25em 1.25em; color: rgba(var(--textColor-rgb),0.75); font-size: 17px; }
.article-prose img { border-radius: var(--cardRadius); margin: 2em 0; }
.article-prose code { font-family: "JetBrains Mono", ui-monospace, monospace; font-size: 0.875em; background: var(--alternateBackground); padding: 2px 5px; border-radius: 3px; }

/* ── Share buttons ────────────────────────────────────────────────────────── */
.article-share { display: flex; align-items: center; gap: 12px; padding-top: 32px; margin-top: 32px; border-top: 1px solid var(--borderColor); flex-wrap: wrap; }
.article-share__label { font-size: 13px; font-weight: 500; color: rgba(var(--textColor-rgb),0.6); margin-right: 4px; }
.article-share__link { display: inline-flex; align-items: center; justify-content: center; height: 36px; padding: 0 14px; border: 1px solid var(--borderColor); border-radius: 100px; font-size: 13px; font-weight: 500; text-decoration: none; color: var(--textColor); transition: border-color 0.15s, background 0.15s; }
.article-share__link:hover { border-color: var(--saleBadgeBackground); color: var(--saleBadgeBackground); }

/* ── Related products ────────────────────────────────────────────────────── */
.article-related { padding: 56px 0; background: var(--alternateBackground); border-top: 1px solid var(--borderColor); }
.article-related__inner { max-width: 1200px; margin: 0 auto; padding: 0 24px; }
.article-related h2 { font-family: var(--headingFont); font-size: var(--fs-h2); font-weight: 600; color: var(--headingColor); margin: 0 0 28px; letter-spacing: -0.01em; }
.article-related__grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 16px; }
@media (min-width: 640px) { .article-related__grid { grid-template-columns: repeat(4, 1fr); } }
.prod-card { display: flex; flex-direction: column; border: 1px solid var(--borderColor); border-radius: var(--cardRadius); overflow: hidden; background: var(--cardBackground); text-decoration: none; color: var(--textColor); transition: box-shadow 0.15s, border-color 0.15s; }
.prod-card:hover { box-shadow: var(--shadow-sm); border-color: rgba(var(--textColor-rgb),0.25); }
.prod-card__img-wrap { aspect-ratio: 4/3; background: #FFFFFF; display: flex; align-items: center; justify-content: center; padding: 12px; }
.prod-card__img { max-width: 100%; max-height: 100%; width: auto; height: auto; object-fit: contain; object-position: center; display: block; }
.prod-card__body { padding: 12px 14px 16px; flex: 1; display: flex; flex-direction: column; gap: 4px; }
.prod-card__vendor { font-size: 11px; color: rgba(var(--textColor-rgb),0.45); text-transform: uppercase; letter-spacing: 0.06em; }
.prod-card__title { font-size: 14px; font-weight: 500; line-height: 1.3; color: var(--headingColor); }
.prod-card__price { font-size: 14px; font-weight: 600; color: var(--textColor); }

/* ── CTA band ────────────────────────────────────────────────────────────── */
.article-cta { padding: 56px 24px; text-align: center; border-top: 1px solid var(--borderColor); }
.article-cta__inner { max-width: 560px; margin: 0 auto; }
.article-cta h2 { font-family: var(--headingFont); font-size: var(--fs-h2); font-weight: 600; color: var(--headingColor); margin: 0 0 8px; letter-spacing: -0.01em; }
.article-cta p { font-size: 16px; color: rgba(var(--textColor-rgb),0.7); margin: 0 0 24px; }
.article-cta__btn { display: inline-flex; align-items: center; justify-content: center; height: 48px; padding: 0 28px; background: var(--buttonBackground); color: var(--buttonColor); border: 1px solid var(--buttonBorder); border-radius: var(--buttonRadius); font-family: var(--bodyFont); font-size: var(--fs-button); font-weight: 500; letter-spacing: var(--ls-button); text-decoration: none; transition: background 0.15s; }
.article-cta__btn:hover { background: var(--saleBadgeBackground); border-color: var(--saleBadgeBackground); color: #fff; }
.article-cta__phone { margin-top: 16px; font-size: 14px; color: rgba(var(--textColor-rgb),0.6); }
.article-cta__phone a { color: var(--textColor); font-weight: 500; text-decoration: none; }
.article-cta__phone a:hover { color: var(--saleBadgeBackground); }
</style>

{%- comment -%} FAQPage JSON-LD — rendered only when article has faq metafield items {%- endcomment -%}
{%- if article.metafields.faq.items != blank -%}
  {%- assign faq_items = article.metafields.faq.items.value -%}
  {%- if faq_items.size > 0 -%}
    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "FAQPage",
      "mainEntity": [
        {%- for item in faq_items -%}
          {%- assign parts = item | split: '||' -%}
          {%- assign q = parts[0] | strip -%}
          {%- assign a = parts[1] | strip -%}
          {
            "@type": "Question",
            "name": {{ q | json }},
            "acceptedAnswer": {
              "@type": "Answer",
              "text": {{ a | json }}
            }
          }{% unless forloop.last %},{% endunless %}
        {%- endfor -%}
      ]
    }
    </script>
  {%- endif -%}
{%- endif -%}

<div class="bbi-article scheme-default">
  {%- render 'bbi-nav', logo: section.settings.logo -%}

  <main id="MainContent">
    <!-- Article header -->
    <header class="article-header">
      <div class="article-header__inner">
        <!-- Breadcrumb -->
        <nav class="article-header__breadcrumb" aria-label="Breadcrumb">
          <a href="/">Home</a> &rsaquo;
          <a href="{{ blog.url }}">{{ blog.title }}</a> &rsaquo;
          <span>{{ article.title }}</span>
        </nav>

        {%- if article.tags.size > 0 -%}
          <p class="article-header__tag">{{ article.tags | first }}</p>
        {%- endif -%}

        <h1>{{ article.title }}</h1>

        <div class="article-header__meta">
          <span>
            <time datetime="{{ article.published_at | date: '%Y-%m-%d' }}">
              {{- article.published_at | date: '%B %-d, %Y' -}}
            </time>
          </span>
          {%- if article.author != blank -%}
            <span>By {{ article.author }}</span>
          {%- endif -%}
          {%- if article.read_time != blank -%}
            <span>{{ article.read_time }} min read</span>
          {%- endif -%}
        </div>

        {%- if article.image -%}
          <div class="article-header__img-wrap">
            {{- article.image | image_url: width: 1200
                | image_tag:
                    class: 'article-header__img',
                    loading: 'eager',
                    width: article.image.width,
                    height: article.image.height,
                    alt: article.image.alt | default: article.title | escape -}}
          </div>
        {%- endif -%}
      </div>
    </header>

    <!-- Article body -->
    <section class="article-body">
      <div class="article-body__inner">
        <div class="article-prose">
          {{ article.content }}
        </div>

        <!-- Share buttons -->
        <div class="article-share">
          <span class="article-share__label">Share:</span>
          <a href="https://www.linkedin.com/sharing/share-offsite/?url={{ shop.url }}{{ article.url | url_encode }}"
             class="article-share__link"
             target="_blank"
             rel="noopener noreferrer"
             aria-label="Share on LinkedIn">LinkedIn</a>
          <a href="https://twitter.com/intent/tweet?url={{ shop.url }}{{ article.url | url_encode }}&text={{ article.title | url_encode }}"
             class="article-share__link"
             target="_blank"
             rel="noopener noreferrer"
             aria-label="Share on X / Twitter">X</a>
        </div>
      </div>
    </section>

    <!-- Related products (from article.metafields.custom.related_collection handle) -->
    {%- assign related_handle = article.metafields.custom.related_collection | default: '' -%}
    {%- if related_handle != blank -%}
      {%- assign related_coll = collections[related_handle] -%}
      {%- if related_coll != blank and related_coll.products.size > 0 -%}
        <section class="article-related">
          <div class="article-related__inner">
            <h2>Shop related products</h2>
            <div class="article-related__grid">
              {%- for product in related_coll.products limit: 4 -%}
                <a href="{{ product.url }}" class="prod-card">
                  {%- if product.featured_image -%}
                    <div class="prod-card__img-wrap">
                      {{- product.featured_image | image_url: width: 480
                          | image_tag:
                              class: 'prod-card__img',
                              loading: 'lazy',
                              width: product.featured_image.width,
                              height: product.featured_image.height,
                              alt: product.featured_image.alt | default: product.title | escape -}}
                    </div>
                  {%- endif -%}
                  <div class="prod-card__body">
                    {%- if product.vendor != blank -%}
                      <p class="prod-card__vendor">{{ product.vendor }}</p>
                    {%- endif -%}
                    <p class="prod-card__title">{{ product.title }}</p>
                    <p class="prod-card__price">
                      {%- if product.price == 0 or product.available == false -%}
                        Quote only
                      {%- else -%}
                        {{ product.price | money }}
                      {%- endif -%}
                    </p>
                  </div>
                </a>
              {%- endfor -%}
            </div>
          </div>
        </section>
      {%- endif -%}
    {%- endif -%}

    <!-- CTA band -->
    <section class="article-cta">
      <div class="article-cta__inner">
        <h2>Ready to furnish your space?</h2>
        <p>Get an itemised quote from our team — usually within one business day.</p>
        <a href="/pages/quote" class="article-cta__btn">Request a Quote</a>
        <p class="article-cta__phone">Or call <a href="tel:18008359565">1-800-835-9565</a></p>
      </div>
    </section>
  </main>

  {%- render 'bbi-footer', logo: section.settings.logo -%}
</div>

{% schema %}
{
  "name": "Article",
  "class": "bbi-article-section",
  "settings": [
    {
      "type": "image_picker",
      "id": "logo",
      "label": "BBI Logo"
    }
  ],
  "presets": [
    {
      "name": "Article"
    }
  ]
}
{% endschema %}
