{%- comment -%}
  Section: ds-blog-list
  Purpose: BBI Resources hub — paginated article list with category filter chips.
  Template: blog.json
  Gate: template.name == 'blog' (in bbi_landing gate in theme.liquid).
  Schema: logo (image_picker), heading, lede.
  Note: No posts exist yet (BLOG-TPL-1). First posts require DataForSEO keyword
        research before writing (CLAUDE.md rule). This template is scaffolding only.
{%- endcomment -%}

{% # theme-check-disable RemoteAsset %}
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Inter+Tight:wght@600&family=Inter:wght@400;500;600&family=JetBrains+Mono:wght@400&display=swap" rel="stylesheet">
{% # theme-check-enable RemoteAsset %}

<style>
/* ============================================================
   BBI Design Tokens — DS v2
   ============================================================ */
:root {
  --bodyFont: "Inter", system-ui, -apple-system, "Segoe UI", Roboto, sans-serif;
  --headingFont: "Inter Tight", "Inter", system-ui, sans-serif;
  --space-1: 4px; --space-2: 8px; --space-3: 12px; --space-4: 16px;
  --space-6: 24px; --space-8: 32px; --space-12: 48px; --space-16: 64px;
  --inputRadius: 4px; --buttonRadius: 4px; --cardRadius: 8px;
  --shadow-sm: 0 1px 2px rgba(11,11,12,.04), 0 2px 8px rgba(11,11,12,.05);
  --saleBadgeBackground: #D4252A;
  --saleBadgeBackground-rgb: 212,37,42;
  --fs-h1: 32px; --lh-h1: 1.1; --ls-h1: -0.015em;
  --fs-h2: 24px; --lh-h2: 1.15; --ls-h2: -0.01em;
  --fs-h3: 18px; --lh-h3: 1.25;
  --fs-body: 16px; --lh-body: 1.55;
  --fs-small: 13px;
  --fs-button: 15px; --lh-button: 1; --ls-button: 0.01em;
}
@media (min-width: 768px) {
  :root {
    --fs-h1: 48px; --lh-h1: 1.05;
    --fs-h2: 32px; --lh-h2: 1.1;
    --fs-h3: 22px; --lh-h3: 1.2;
    --fs-small: 14px;
  }
}
.bbi-blog-list.scheme-default {
  --background: #FFFFFF; --background-rgb: 255,255,255;
  --alternateBackground: #FAFAFA;
  --cardBackground: #FFFFFF;
  --textColor: #0B0B0C; --textColor-rgb: 11,11,12;
  --linkColor: #0B0B0C; --headingColor: #0B0B0C; --headingColor-rgb: 11,11,12;
  --buttonBackground: #0B0B0C; --buttonColor: #FFFFFF; --buttonBorder: #0B0B0C;
  --buttonBackgroundHover: #D4252A; --buttonColorHover: #FFFFFF; --buttonBorderHover: #D4252A;
  --borderColor: #E5E5E7; --borderColor-rgb: 229,229,231;
  --shadowColor: #0B0B0C; --shadowColor-rgb: 11,11,12;
}

/* ── Base ────────────────────────────────────────────────────────────────── */
.bbi-blog-list *, .bbi-blog-list *::before, .bbi-blog-list *::after { box-sizing: border-box; }
.bbi-blog-list { font-family: var(--bodyFont); font-size: var(--fs-body); line-height: var(--lh-body); color: var(--textColor); background: var(--background); -webkit-font-smoothing: antialiased; }
.bbi-blog-list img { display: block; max-width: 100%; height: auto; }
.bbi-blog-list a { color: var(--linkColor); }

/* ── Hero ────────────────────────────────────────────────────────────────── */
.blog-hero { padding: 56px 0 48px; border-bottom: 1px solid var(--borderColor); }
.blog-hero__inner { max-width: 880px; margin: 0 auto; padding: 0 24px; }
.blog-hero__eyebrow { display: inline-flex; align-items: center; gap: 10px; font-family: "JetBrains Mono", ui-monospace, monospace; font-size: 11px; letter-spacing: 0.08em; text-transform: uppercase; color: rgba(var(--textColor-rgb),0.6); margin: 0 0 20px; }
.blog-hero__eyebrow::before { content: ""; display: inline-block; width: 18px; height: 1px; background: var(--saleBadgeBackground); }
.blog-hero h1 { font-family: var(--headingFont); font-size: clamp(32px, 5vw, 52px); line-height: 1.05; letter-spacing: -0.02em; font-weight: 600; color: var(--headingColor); margin: 0 0 16px; text-wrap: balance; }
.blog-hero__lede { font-size: 17px; line-height: 1.6; color: rgba(var(--textColor-rgb),0.72); margin: 0; text-wrap: pretty; }

/* ── Filter chips ────────────────────────────────────────────────────────── */
.blog-filters { padding: 24px 0; border-bottom: 1px solid var(--borderColor); background: var(--alternateBackground); }
.blog-filters__inner { max-width: 1200px; margin: 0 auto; padding: 0 24px; display: flex; flex-wrap: wrap; gap: 8px; align-items: center; }
.blog-filter-chip { display: inline-flex; align-items: center; height: 34px; padding: 0 14px; border-radius: 100px; font-size: 13px; font-weight: 500; text-decoration: none; border: 1px solid var(--borderColor); color: var(--textColor); background: var(--background); transition: border-color 0.15s, background 0.15s; white-space: nowrap; }
.blog-filter-chip:hover, .blog-filter-chip[aria-current="true"] { border-color: var(--saleBadgeBackground); background: var(--saleBadgeBackground); color: #fff; }

/* ── Article grid ────────────────────────────────────────────────────────── */
.blog-grid { padding: 56px 0; }
.blog-grid__inner { max-width: 1200px; margin: 0 auto; padding: 0 24px; }
.blog-grid__articles { display: grid; grid-template-columns: 1fr; gap: 32px; }
@media (min-width: 640px) { .blog-grid__articles { grid-template-columns: repeat(2, 1fr); } }
@media (min-width: 960px) { .blog-grid__articles { grid-template-columns: repeat(3, 1fr); } }

/* ── Article card ────────────────────────────────────────────────────────── */
.article-card { display: flex; flex-direction: column; border: 1px solid var(--borderColor); border-radius: var(--cardRadius); overflow: hidden; background: var(--cardBackground); transition: box-shadow 0.15s, border-color 0.15s; }
.article-card:hover { box-shadow: var(--shadow-sm); border-color: rgba(var(--textColor-rgb),0.25); }
.article-card__img-wrap { aspect-ratio: 16/9; overflow: hidden; background: var(--alternateBackground); }
.article-card__img { width: 100%; height: 100%; object-fit: cover; transition: transform 0.4s; }
.article-card:hover .article-card__img { transform: scale(1.03); }
.article-card__body { flex: 1; display: flex; flex-direction: column; padding: 20px; }
.article-card__tag { font-family: "JetBrains Mono", ui-monospace, monospace; font-size: 10px; letter-spacing: 0.08em; text-transform: uppercase; color: var(--saleBadgeBackground); margin: 0 0 8px; }
.article-card__title { font-family: var(--headingFont); font-size: 17px; font-weight: 600; line-height: 1.25; color: var(--headingColor); margin: 0 0 8px; text-decoration: none; }
.article-card__title:hover { color: var(--saleBadgeBackground); }
.article-card__excerpt { font-size: 14px; color: rgba(var(--textColor-rgb),0.65); line-height: 1.55; flex: 1; margin: 0 0 16px; }
.article-card__meta { font-size: 12px; color: rgba(var(--textColor-rgb),0.45); }

/* ── Empty state ─────────────────────────────────────────────────────────── */
.blog-empty { text-align: center; padding: 80px 24px; color: rgba(var(--textColor-rgb),0.55); }
.blog-empty h2 { font-family: var(--headingFont); font-size: var(--fs-h2); color: var(--headingColor); margin: 0 0 8px; }
.blog-empty p { font-size: 15px; }

/* ── Pagination ──────────────────────────────────────────────────────────── */
.blog-pagination { padding: 32px 24px 64px; display: flex; justify-content: center; gap: 8px; }
.blog-pagination a, .blog-pagination span { display: inline-flex; align-items: center; justify-content: center; height: 40px; min-width: 40px; padding: 0 12px; border: 1px solid var(--borderColor); border-radius: var(--buttonRadius); font-size: 14px; font-weight: 500; text-decoration: none; color: var(--textColor); background: var(--background); }
.blog-pagination a:hover { border-color: var(--saleBadgeBackground); color: var(--saleBadgeBackground); }
.blog-pagination span { background: var(--textColor); color: var(--background); border-color: var(--textColor); }

/* ── CTA band ────────────────────────────────────────────────────────────── */
.blog-cta { padding: 56px 24px; background: var(--alternateBackground); border-top: 1px solid var(--borderColor); text-align: center; }
.blog-cta__inner { max-width: 560px; margin: 0 auto; }
.blog-cta h2 { font-family: var(--headingFont); font-size: var(--fs-h2); font-weight: 600; color: var(--headingColor); margin: 0 0 8px; letter-spacing: -0.01em; }
.blog-cta p { font-size: 16px; color: rgba(var(--textColor-rgb),0.7); margin: 0 0 24px; }
.blog-cta__btn { display: inline-flex; align-items: center; justify-content: center; height: 48px; padding: 0 28px; background: var(--buttonBackground); color: var(--buttonColor); border: 1px solid var(--buttonBorder); border-radius: var(--buttonRadius); font-family: var(--bodyFont); font-size: var(--fs-button); font-weight: 500; letter-spacing: var(--ls-button); text-decoration: none; transition: background 0.15s; }
.blog-cta__btn:hover { background: var(--saleBadgeBackground); border-color: var(--saleBadgeBackground); color: #fff; }
.blog-cta__phone { margin-top: 16px; font-size: 14px; color: rgba(var(--textColor-rgb),0.6); }
.blog-cta__phone a { color: var(--textColor); font-weight: 500; text-decoration: none; }
.blog-cta__phone a:hover { color: var(--saleBadgeBackground); }
</style>

<div class="bbi-blog-list scheme-default">
  {%- render 'bbi-nav', logo: section.settings.logo -%}

  <main id="MainContent">
    <!-- Hero -->
    <header class="blog-hero">
      <div class="blog-hero__inner">
        <p class="blog-hero__eyebrow">{{ section.settings.eyebrow | default: 'Resources' }}</p>
        <h1>{{ section.settings.heading | default: blog.title }}</h1>
        {%- if section.settings.lede != blank -%}
          <p class="blog-hero__lede">{{ section.settings.lede }}</p>
        {%- endif -%}
      </div>
    </header>

    <!-- Category filter chips (tag-based) -->
    {%- if blog.articles_count > 0 -%}
      {%- assign all_tags = blog.all_tags -%}
      {%- if all_tags.size > 0 -%}
        <nav class="blog-filters" aria-label="Filter articles by topic">
          <div class="blog-filters__inner">
            <a href="{{ blog.url }}"
               class="blog-filter-chip"
               {% unless current_tags %}aria-current="true"{% endunless %}>All</a>
            {%- for tag in all_tags -%}
              <a href="{{ blog.url }}/tagged/{{ tag | handle }}"
                 class="blog-filter-chip"
                 {% if current_tags contains tag %}aria-current="true"{% endif %}>
                {{- tag -}}
              </a>
            {%- endfor -%}
          </div>
        </nav>
      {%- endif -%}
    {%- endif -%}

    <!-- Article grid -->
    <section class="blog-grid">
      <div class="blog-grid__inner">
        {%- if blog.articles_count > 0 -%}
          <div class="blog-grid__articles">
            {%- for article in blog.articles -%}
              <article class="article-card">
                {%- if article.image -%}
                  <a href="{{ article.url }}" class="article-card__img-wrap" tabindex="-1" aria-hidden="true">
                    {{- article.image | image_url: width: 640
                        | image_tag:
                            class: 'article-card__img',
                            loading: 'lazy',
                            width: article.image.width,
                            height: article.image.height,
                            alt: article.image.alt | default: article.title | escape -}}
                  </a>
                {%- endif -%}
                <div class="article-card__body">
                  {%- if article.tags.size > 0 -%}
                    <p class="article-card__tag">{{ article.tags | first }}</p>
                  {%- endif -%}
                  <a href="{{ article.url }}" class="article-card__title">{{ article.title }}</a>
                  {%- if article.excerpt != blank -%}
                    <p class="article-card__excerpt">{{ article.excerpt | strip_html | truncate: 120 }}</p>
                  {%- endif -%}
                  <p class="article-card__meta">
                    <time datetime="{{ article.published_at | date: '%Y-%m-%d' }}">
                      {{- article.published_at | date: '%B %-d, %Y' -}}
                    </time>
                    {%- if article.author != blank %} · {{ article.author }}{%- endif -%}
                  </p>
                </div>
              </article>
            {%- endfor -%}
          </div>

          <!-- Pagination -->
          {%- if paginate.pages > 1 -%}
            <nav class="blog-pagination" aria-label="Article pagination">
              {%- if paginate.previous -%}
                <a href="{{ paginate.previous.url }}">&larr; Previous</a>
              {%- endif -%}
              {%- for part in paginate.parts -%}
                {%- if part.is_link -%}
                  <a href="{{ part.url }}">{{ part.title }}</a>
                {%- else -%}
                  <span>{{ part.title }}</span>
                {%- endif -%}
              {%- endfor -%}
              {%- if paginate.next -%}
                <a href="{{ paginate.next.url }}">Next &rarr;</a>
              {%- endif -%}
            </nav>
          {%- endif -%}

        {%- else -%}
          <div class="blog-empty">
            <h2>Coming soon</h2>
            <p>New guides and resources are on the way. Check back shortly.</p>
          </div>
        {%- endif -%}
      </div>
    </section>

    <!-- CTA band -->
    <section class="blog-cta">
      <div class="blog-cta__inner">
        <h2>Ready to furnish your space?</h2>
        <p>Get an itemised quote from our team — usually within one business day.</p>
        <a href="/pages/quote" class="blog-cta__btn">Request a Quote</a>
        <p class="blog-cta__phone">Or call <a href="tel:18008359565">1-800-835-9565</a></p>
      </div>
    </section>
  </main>

  {%- render 'bbi-footer', logo: section.settings.logo -%}
</div>

{% schema %}
{
  "name": "Blog — Resources Hub",
  "class": "bbi-blog-list-section",
  "settings": [
    {
      "type": "image_picker",
      "id": "logo",
      "label": "BBI Logo"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow label",
      "default": "Resources"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Page heading",
      "default": "Guides, Tips & Industry Insights"
    },
    {
      "type": "text",
      "id": "lede",
      "label": "Intro copy",
      "default": "Practical advice on office furniture, ergonomics, and workplace design — written for Canadian institutional buyers."
    }
  ],
  "presets": [
    {
      "name": "Blog — Resources Hub"
    }
  ]
}
{% endschema %}
