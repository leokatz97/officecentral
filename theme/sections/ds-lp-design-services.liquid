<script>
(function() {
  var list = document.getElementById('ds-faq-list');
  if (!list) return;
  list.addEventListener('click', function(e) {
    var btn = e.target.closest('.lp-faq__trigger');
    if (!btn) return;
    var item = btn.closest('.lp-faq__item');
    var isOpen = item.classList.contains('lp-faq__item--open');
    list.querySelectorAll('.lp-faq__item--open').forEach(function(el) {
      el.classList.remove('lp-faq__item--open');
      el.querySelector('.lp-faq__trigger').setAttribute('aria-expanded', 'false');
    });
    if (!isOpen) {
      item.classList.add('lp-faq__item--open');
      btn.setAttribute('aria-expanded', 'true');
    }
  });
})();
</script>

