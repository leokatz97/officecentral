{{ 'product-list.css' | asset_url | stylesheet_tag }}

<div class="scheme-{{ section.settings.color_scheme }} section-padding{% if section.settings.enable_gradient %} gradiant{% endif %}" data-show-accordion="true">
    <div class="{{ settings.layout_style }}">
        {% if section.settings.heading != blank %}
            {%- capture highlightPrefix -%}
              <span class="line-marker {% if section.settings.highlight_style == 'background' %}highlight-background {% if section.settings.bg__color == 'gradient' %}highlight-background-gradient{% else %}highlight-background-solid{% endif %}{% endif %}">
            {%- endcapture -%}
            {%- capture highlightSuffix -%}
              {% if section.settings.highlight_style != 'background' %}
                {% render 'marker', marker: section.settings.highlight_style %}
              {% endif %}
              </span>
            {%- endcapture -%}
            <div class="section-title {{ section.settings.heading_alignment }}">
                  <{{ section.settings.seo_heading }} class="{{ section.settings.heading_size }} section-heading{% if section.settings.heading_animation %} linear-animation{% endif %}">
                    {% if section.settings.heading_animation %}
                      {{ section.settings.heading }}
                  {% else %} 
                  {{ section.settings.heading | replace:"[", highlightPrefix | replace:"]",highlightSuffix }}
                    {% endif %}
                </{{ section.settings.seo_heading }}>
            </div>
        {% endif %}
        {% if section.blocks.size > 0  %}
            <div class="product-list-wrapper{% if section.settings.enable_background %} enable-background{% endif %}">
                    {% for block in section.blocks %}
                       
                        {% if block.settings.collection_list != blank and block.settings.collection_list.products.count > 0 %}
                        <div class="product-list-item">
                            {% liquid
                                if block.settings.collection_heading != blank
                                    assign heading = block.settings.collection_heading
                                else 
                                   assign heading = block.settings.collection_list.title
                                endif
                            %}

                            <details class="product-list-item-inner" open data-accordion>
                                <summary class="h4 heading-font">{{ heading }}
                                    <span>
                                        <svg width="18" height="10" viewBox="0 0 18 10" fill="none">
                                        <path d="M1 0.999999L9 9L17 1" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round"></path>
                                        </svg>
                                    </span>
                                </summary>
                                
                                <div class="product-list-collapsible-content">
                                    {% for product in block.settings.collection_list.products limit: section.settings.products_limit %}
                                        <div class="horizontal-product-card">
                                          <a href="{{ product.url }}" class="horizontal-product-card-image">
                                            
                                            <div class="media" Style="--imageRatio:100%">
                                              {% liquid
                                                assign placeholder_image_index = forloop.index0 | modulo: 5 | plus: 1
                                                if product.featured_media != blank
                                                  render 'lazy-image', image: product.featured_media.preview_image, imageSize: 250
                                                else
                                                  echo 'product-apparel-' | append: placeholder_image_index | placeholder_svg_tag: 'placeholder-svg'
                                                endif
                                              %}
                                            </div>
                                          </a>
                                           
                                            {% if product.title != blank %}
                                                <div class="horizontal-product-card-info">
                                                    <a href="{{ product.url }}" class="product-title"><strong>{{ product.title }}</strong></a>
                                                    {% if product != blank %}
                                                      {% render 'price',
                                                        cardProduct: product
                                          
                                                      %}
                                                    {% else %}
                                                      <div class="product-price">
                                                        <span class="price-item actual-price">{{ 1999 | money}}</span>
                                                      </div>
                                                    {% endif %}
                                                    {% comment %} {% if product.price != blank %}
                                                        <div class="product-price">
                                                            <span class="price-item actual-price">{{ product.price | money }}</span>
                                                        </div>
                                                    {% endif %} {% endcomment %}
                                                </div>
                                            {% endif %}
                                        </div>
                                    {% endfor %}
                                </div>
                            </details>
                        </div>
                        {% else %}
                            <div class="product-list-item">
                                <details class="product-list-item-inner" open data-accordion>
                                    <summary class="h4 heading-font"> {{ 'onboarding.collection-title' | t }}
                                        <span>
                                            <svg width="18" height="10" viewBox="0 0 18 10" fill="none">
                                            <path d="M1 0.999999L9 9L17 1" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round"></path>
                                            </svg>
                                        </span>
                                    </summary>
                                <div class="product-list-collapsible-content">
                                    {% for i in (1.. section.settings.products_limit ) %}
                                      {% liquid
                                        capture placeholderIndex
                                          cycle cycleGroup: '1', '2', '3', '4'
                                        endcapture
                                      %}
                                        <div class="horizontal-product-card ff">
                                                <div class="horizontal-product-card-image">
                                                    <div class="media" style="--imageRatio:100%;">
                                                        {{  'product-apparel-' | append: placeholderIndex | placeholder_svg_tag: 'placeholder-svg'  }}
                                                    </div>
                                                </div>
                                                <div class="horizontal-product-card-info">
                                                    <div class="product-title text-medium">
                                                       <strong>{{ 'onboarding.product_title' | t }}</strong> 
                                                    </div>
                                                    
                                                        <div class="product-price text-medium">
                                                            <span class="price-item actual-price">{{ 1999 | money }}</span>
                                                        </div>
                                                </div>
                                        </div>
                                    {% endfor %}
                                </div>
                                </details>
                            </div>
                        {% endif %}
                    {% endfor %}
                  
            </div>
        {% endif %}
    </div>
</div>
<style>
   #shopify-section-{{ section.id }}{
    --padding-top: {{ section.settings.top_space_desktop}}px;
    --padding-bottom: {{ section.settings.bottom_space_desktop}}px;
  } 

  @media only screen and (max-width:767px) {
    #shopify-section-{{ section.id }}{
      --padding-top: {{ section.settings.top_space_mobile }}px !important;
      --padding-bottom: {{ section.settings.bottom_space_mobile }}px !important;
    }
  }
  {% if section.settings.section_visibility == 'large' %}
    @media (max-width: 767px) {
      #shopify-section-{{ section.id }}{
        display: none !important;
      }
    }
  {% elsif section.settings.section_visibility == 'small' %}
    @media (min-width: 768px) {
      #shopify-section-{{ section.id }}{
        display: none !important;
      }
    }
{% endif %}
</style>


{% schema %}
{
  "name": "Product list",
  "tag": "section",
  "class": "product-list-section",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "max_blocks": 4,
  "settings": [
      {
        "type": "header",
        "content": "t:global.general_labels.general"
      },
      {
        "type": "select",
        "id": "section_visibility",
        "label": "t:global.section_visibility.label",
        "default": "always",
        "options": [
          {
            "label": "t:global.section_visibility.options.always.label",
            "value": "always"
          },
          { 
            "label": "t:global.section_visibility.options.small.label",
            "value": "small"
          },
          {
            "label": "t:global.section_visibility.options.large.label",
            "value": "large"
          }
        ]
      },
      {
        "type": "inline_richtext",
        "id": "heading",
        "label": "t:global.heading.label",
        "info": "t:global.heading.info",
        "default": "Product list"
      },
      {
        "type": "select",
        "id": "highlight_style",
        "label": "t:global.highlight_style.label",
        "default": "underline",
        "options": [
          {
            "value": "underline",
            "label": "t:global.highlight_style.options.underline.label"
          },
          {
            "value": "shape_2",
            "label": "t:global.highlight_style.options.shape_2.label"
          },
          {
            "value": "shape_3",
            "label": "t:global.highlight_style.options.shape_3.label"
          },
          {
            "value": "shape_4",
            "label": "t:global.highlight_style.options.shape_4.label"
          },
          {
            "value": "shape_5",
            "label": "t:global.highlight_style.options.shape_5.label"
          },
          {
            "value": "shape_6",
            "label": "t:global.highlight_style.options.shape_6.label"
          },
          {
            "value": "background",
            "label": "t:global.highlight_style.options.background.label"
          },
            {
              "value": "no_shape",
              "label": "t:global.highlight_style.options.no_shape.label"
            }
        ]
      },
        {
            "type": "select",
            "id": "bg__color",
            "label": "t:global.bg__color.label",
            "default": "gradient",
            "options": [
            {
                "value": "gradient",
                "label": "t:global.bg__color.options.gradient.label"
            },
            {
                "value": "solid",
                "label": "t:global.bg__color.options.solid.label"
            }
            ]
        },
        {
            "type":"checkbox",
            "id":"heading_animation",
            "label":"t:global.heading_animation.label",
            "info":"t:global.heading_animation.info"
        },
        {
            "type": "select",
            "id": "heading_size",
            "label": "t:global.heading.heading_size.label",
            "default": "h2",
            "options": [
            {
                "value": "h1",
                "label": "H1"
            },
            {
                "value": "h2",
                "label": "H2"
            },
            {
                "value": "h3",
                "label": "H3"
            },
            {
                "value": "h4",
                "label": "H4"
            },
            {
                "value": "h5",
                "label": "H5"
            },
            {
                "value": "h6",
                "label": "H6"
            }
            ]
        },
        {
            "type": "select",
            "id": "seo_heading",
            "default": "h2",
            "label": "t:global.heading.heading_tag.label",
            "info": "t:global.heading.heading_tag.info",
            "options": [
            {
                "value": "h1",
                "label": "H1"
            },
            {
                "value": "h2",
                "label": "H2"
            },
            {
                "value": "h3",
                "label": "H3"
            },
            {
                "value": "h4",
                "label": "H4"
            },
            {
                "value": "h5",
                "label": "H5"
            },
            {
                "value": "h6",
                "label": "H6"
            }
            ]
        },
        {
            "type": "select",
            "id": "heading_alignment",
            "label": "t:global.heading_alignment.label",
            "default": "text-left",
            "options": [
            {
                "label": "t:global.heading_alignment.options.left.label",
                "value": "text-left"
            },
            {
                "label": "t:global.heading_alignment.options.center.label",
                "value": "text-center"
            },
            {
                "label": "t:global.heading_alignment.options.right.label",
                "value": "text-right"
            }
            ]
        },
       
       
        {
            "type": "header",
            "content": "t:global.general_labels.color"
        },
        {
            "type": "color_scheme",
            "id": "color_scheme",
            "default": "primary",
            "label": "t:global.color_scheme.label"
        },
        {
            "type": "checkbox",
            "id": "enable_gradient",
            "label": "t:global.general_labels.gradient",
            "default": false
        },
        {
            "type":"checkbox",
            "label":"t:sections.product-list.settings.enable_background.label",
            "default": true,
            "id": "enable_background"
        },
        {
            "type": "range",
            "id":"products_limit",
            "label": "t:sections.product-list.settings.products_limit.label",
            "min": 3,
            "max": 8,
            "default": 4,
            "step": 1
        },
        {
            "type": "header",
            "content": "t:global.section_padding.label"
        },
        {
            "type": "range",
            "id": "top_space_desktop",
            "label": "t:global.section_padding.options.top_space_desktop.label",
            "default": 70,
            "min": 0,
            "max": 150,
            "step": 5
        },
        {
            "type": "range",
            "id": "bottom_space_desktop",
            "label": "t:global.section_padding.options.bottom_space_desktop.label",
            "default": 70,
            "min": 0,
            "max": 150,
            "step": 5
        },
        {
            "type": "range",
            "id": "top_space_mobile",
            "label": "t:global.section_padding.options.top_space_mobile.label",
            "default": 40,
            "min": 0,
            "max": 100,
            "step": 5
        },
        {
            "type": "range",
            "id": "bottom_space_mobile",
            "label": "t:global.section_padding.options.bottom_space_mobile.label",
            "default": 40,
            "min": 0,
            "max": 100,
            "step": 5
        }
        
    ],
  "blocks": [
    {
      "type": "collection",
      "name": "t:sections.product-list.blocks.collection.name",
      "limit":4,
      "settings": [
          {
            "type": "text",
            "id":"collection_heading",
            "label":"t:sections.product-list.blocks.collection.settings.collection_heading.label",
            "info":"t:sections.product-list.blocks.collection.settings.collection_heading.info"
          },
          {
            "type": "collection",
            "id":"collection_list",
            "label": "t:sections.product-list.blocks.collection.settings.collection_list.label"
          }
      ]
    }
  ],
  "presets": [
    {
      "name": "t:sections.product-list.name",
      "blocks":[
        {
          "type":"collection"
        },
        {
          "type":"collection"
        },
        {
          "type":"collection"
        },
        {
          "type":"collection"
        }
      ]
    }
  ]
}
{% endschema %}
{% javascript %}
    document.addEventListener('DOMContentLoaded', () => {
      const applyAccordionState = () => {
        const showAccordionOnMobile =
          document.querySelector('[data-show-accordion]')?.getAttribute('data-show-accordion') === 'true';
        const isMobile = window.matchMedia('(max-width: 767px)').matches;
        document.querySelectorAll('details[data-accordion]').forEach((el) => {
          if (showAccordionOnMobile && isMobile) {
            // Show accordion on mobile if setting allows
            el.removeAttribute('open', '');
            document.querySelector('[data-show-accordion]').setAttribute('data-show-accordion','false');
          } else if (!showAccordionOnMobile && isMobile) {
            // Do not show accordion on mobile if setting disallows
           // el.setAttribute('open');
          } else if (!isMobile) {
            // On desktop, always open accordions
            el.setAttribute('open', '');
            document.querySelector('[data-show-accordion]').setAttribute('data-show-accordion','true');
          }
        });
      };
      applyAccordionState();
      window.addEventListener('resize', applyAccordionState);
      document.addEventListener('shopify:section:load', (event) => {
        // Apply accordion state when a new section is loaded
        applyAccordionState();
      });
    });
  {% endjavascript %}
  