/* Browse crosslinks */
.lp-reloc .lp-crosslinks{padding:var(--space-12) 0;border-top:1px solid rgba(var(--borderColor-rgb),0.6);}
.lp-reloc .lp-crosslinks__inner{max-width:1280px;margin:0 auto;padding:0 var(--space-6);}
