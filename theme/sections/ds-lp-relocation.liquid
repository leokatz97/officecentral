.lp-reloc .lp-product-card__cta{display:block;text-align:center;padding:10px 16px;border:1px solid var(--borderColor);border-radius:var(--buttonRadius);font-size:14px;font-weight:500;color:var(--textColor);text-decoration:none;transition:background-color 160ms;}
.lp-reloc .lp-product-card__cta:hover{background:var(--alternateBackground);}
/* Entity note */
.lp-reloc .lp-entity-note{padding:var(--space-6) 0;border-top:1px solid rgba(var(--borderColor-rgb),0.6);}
.lp-reloc .lp-entity-note__inner{max-width:1280px;margin:0 auto;padding:0 var(--space-6);}
.lp-reloc .lp-entity-note p{font-size:13px;line-height:1.55;color:rgba(var(--textColor-rgb),0.6);margin:0;text-wrap:pretty;max-width:92ch;}
