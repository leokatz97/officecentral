@media(max-width:1023px){.lp-reloc .lp-hero__inner{grid-template-columns:1fr;}.lp-reloc .lp-process__grid{grid-template-columns:repeat(2,1fr);}.lp-reloc .lp-crosslinks__grid{grid-template-columns:1fr;}.lp-reloc .lp-products__grid{grid-template-columns:repeat(2,1fr);}}
