.lp-reloc .lp-intro__eyebrow{display:inline-flex;align-items:center;gap:var(--space-2);color:rgba(var(--textColor-rgb),0.6);margin-bottom:var(--space-4);}
.lp-reloc .lp-intro__eyebrow::before{content:"";display:inline-block;width:18px;height:1px;background:var(--saleBadgeBackground);}
.lp-reloc .lp-intro h2{font-family:var(--headingFont);font-size:var(--fs-h2);font-weight:600;color:var(--headingColor);margin:0 0 var(--space-6);}
.lp-reloc .lp-intro__body p{font-size:17px;line-height:1.65;color:rgba(var(--textColor-rgb),0.78);margin:0 0 var(--space-4);}
.lp-reloc .lp-process{padding:var(--space-12) 0;background:var(--alternateBackground);border-top:1px solid rgba(var(--borderColor-rgb),0.5);border-bottom:1px solid rgba(var(--borderColor-rgb),0.5);}
.lp-reloc .lp-process__inner{max-width:1280px;margin:0 auto;padding:0 var(--space-6);}
.lp-reloc .lp-process__head{margin-bottom:var(--space-8);}
.lp-reloc .lp-process__eyebrow{display:inline-flex;align-items:center;gap:var(--space-2);color:rgba(var(--textColor-rgb),0.6);margin-bottom:var(--space-4);}
.lp-reloc .lp-process__eyebrow::before{content:"";display:inline-block;width:18px;height:1px;background:var(--saleBadgeBackground);}
.lp-reloc .lp-process h2{font-family:var(--headingFont);font-size:var(--fs-h2);font-weight:600;color:var(--headingColor);margin:0;max-width:44ch;}
.lp-reloc .lp-process__grid{display:grid;grid-template-columns:repeat(4,1fr);gap:var(--space-6);}
.lp-reloc .lp-process-card{background:var(--cardBackground);border:1px solid rgba(var(--borderColor-rgb),0.6);border-radius:var(--cardRadius);padding:var(--space-6);display:flex;flex-direction:column;gap:var(--space-3);}
.lp-reloc .lp-process-card__step{font-family:"JetBrains Mono",ui-monospace,monospace;font-size:11px;letter-spacing:0.08em;text-transform:uppercase;color:var(--saleBadgeBackground);margin:0;}
.lp-reloc .lp-process-card__title{font-family:var(--headingFont);font-size:var(--fs-h3);font-weight:600;color:var(--headingColor);margin:0;}
.lp-reloc .lp-process-card__body{font-size:15px;line-height:1.55;color:rgba(var(--textColor-rgb),0.72);margin:0;}
.lp-reloc .lp-oecm-bar{padding:var(--space-8) 0;background:rgba(var(--saleBadgeBackground-rgb),0.04);border-top:1px solid rgba(var(--saleBadgeBackground-rgb),0.12);border-bottom:1px solid rgba(var(--saleBadgeBackground-rgb),0.12);}
.lp-reloc .lp-oecm-bar__inner{max-width:1280px;margin:0 auto;padding:0 var(--space-6);display:flex;align-items:center;gap:var(--space-6);flex-wrap:wrap;}
.lp-reloc .lp-oecm-bar__badge{display:inline-flex;align-items:center;gap:var(--space-3);padding:6px 12px;background:var(--saleBadgeBackground);color:#fff;border-radius:4px;font-size:12px;font-weight:600;letter-spacing:0.04em;text-transform:uppercase;white-space:nowrap;}
.lp-reloc .lp-oecm-bar__text{font-size:15px;color:rgba(var(--textColor-rgb),0.78);}
.lp-reloc .lp-oecm-bar__text strong{color:var(--textColor);}
.lp-reloc .lp-faq{padding:var(--space-12) 0;}
.lp-reloc .lp-faq__inner{max-width:800px;margin:0 auto;padding:0 var(--space-6);}
.lp-reloc .lp-faq__head{margin-bottom:var(--space-8);}
.lp-reloc .lp-faq__eyebrow{display:inline-flex;align-items:center;gap:var(--space-2);color:rgba(var(--textColor-rgb),0.6);margin-bottom:var(--space-4);}
.lp-reloc .lp-faq__eyebrow::before{content:"";display:inline-block;width:18px;height:1px;background:var(--saleBadgeBackground);}
.lp-reloc .lp-faq h2{font-family:var(--headingFont);font-size:var(--fs-h2);font-weight:600;color:var(--headingColor);margin:0;}
.lp-reloc .lp-faq__list{list-style:none;margin:0;padding:0;display:flex;flex-direction:column;gap:0;}
.lp-reloc .lp-faq__item{border-top:1px solid rgba(var(--borderColor-rgb),0.6);}
.lp-reloc .lp-faq__item:last-child{border-bottom:1px solid rgba(var(--borderColor-rgb),0.6);}
.lp-reloc .lp-faq__q{width:100%;background:none;border:none;padding:var(--space-6) 0;display:flex;justify-content:space-between;align-items:center;gap:var(--space-4);font-family:var(--headingFont);font-size:var(--fs-h3);font-weight:600;color:var(--headingColor);text-align:left;cursor:pointer;}
.lp-reloc .lp-faq__q-icon{flex-shrink:0;width:20px;height:20px;position:relative;}
.lp-reloc .lp-faq__q-icon::before,.lp-reloc .lp-faq__q-icon::after{content:"";position:absolute;background:var(--textColor);border-radius:2px;}
.lp-reloc .lp-faq__q-icon::before{width:12px;height:1.5px;top:50%;left:50%;transform:translate(-50%,-50%);}
.lp-reloc .lp-faq__q-icon::after{width:1.5px;height:12px;top:50%;left:50%;transform:translate(-50%,-50%);transition:opacity 200ms ease;}
.lp-reloc .lp-faq__item.is-open .lp-faq__q-icon::after{opacity:0;}
.lp-reloc .lp-faq__a{display:none;padding:0 0 var(--space-6);}
.lp-reloc .lp-faq__item.is-open .lp-faq__a{display:block;}
.lp-reloc .lp-faq__a p{font-size:16px;line-height:1.65;color:rgba(var(--textColor-rgb),0.78);margin:0 0 var(--space-3);}
.lp-reloc .lp-faq__a p:last-child{margin-bottom:0;}
.lp-reloc .lp-closer{padding:var(--space-12) 0;}
.lp-reloc .lp-closer__inner{max-width:680px;margin:0 auto;padding:0 var(--space-6);text-align:center;}
.lp-reloc .lp-closer h2{font-family:var(--headingFont);font-size:var(--fs-h1);font-weight:600;color:var(--headingColor);margin:0 0 var(--space-4);}
.lp-reloc .lp-closer__sub{font-size:17px;line-height:1.55;color:rgba(var(--textColor-rgb),0.72);margin:0 0 var(--space-8);}
.lp-reloc .lp-closer__cta-row{display:flex;gap:var(--space-3);flex-wrap:wrap;justify-content:center;margin-bottom:var(--space-4);}
