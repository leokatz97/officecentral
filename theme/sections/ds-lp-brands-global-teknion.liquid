.lp-global .lp-closer__trust a{color:var(--textColor);text-decoration:underline;}
@media(max-width:1024px){.lp-global .lp-diff__grid{grid-template-columns:repeat(2,1fr);}.lp-global .lp-crosslinks__grid{grid-template-columns:repeat(2,1fr);}}
@media(max-width:768px){.lp-global .lp-hero__inner{grid-template-columns:1fr;}.lp-global .lp-hero__media{display:none;}.lp-global .lp-diff__grid{grid-template-columns:1fr;}.lp-global .lp-crosslinks__grid{grid-template-columns:1fr;}.lp-global .lp-closer__inner{grid-template-columns:1fr;padding:64px 24px;}.lp-global .bbi-header__nav{display:none;}}
</style>

<div class="lp-global scheme-default">

  {%- render 'bbi-nav', logo: section.settings.logo, active: 'brands' -%}
  {%- render 'bbi-crumbs', c2_label: 'Brands', c2_href: '/pages/brands', c3_label: 'Global / Teknion' -%}


  <section class="lp-hero" aria-label="Hero">
    <div class="lp-hero__inner">
      <div class="lp-hero__text">
        <p class="lp-hero__eyebrow bbi-mono">
          <span class="lp-hero__eyebrow-label">Brand &middot; Authorized Global Furniture Group Dealer</span>
        </p>
        <span class="lp-hero__badge">
          <span class="lp-hero__badge-dot"></span>
          Authorized Global Furniture Group Dealer &middot; Global flagship + Teknion premium tier
        </span>
        <h1>{{ section.settings.heading | default: 'Global Furniture Group — flagship contract furniture with Teknion premium tier and OTG value line.' }}</h1>
        <p class="lp-hero__standfirst">{{ section.settings.subheading | default: 'GFG is Canada&rsquo;s deepest single-family contract furniture portfolio — Global as the flagship for chairs, desks, tables, and storage; Teknion as the premium contract tier; OTG as the institutional value line. Authorized dealer; specified together under OECM Agreement 2025-470. Quote in 1 business day.' }}</p>
        <div class="lp-hero__cta-row">
          <a class="bbi-btn bbi-btn--primary bbi-btn--lg" href="/pages/quote">
            Request a Quote <span class="arrow">&#8594;</span>
          </a>
          <a class="bbi-btn bbi-btn--secondary bbi-btn--lg" href="/collections/gfg-chairs">
            Browse Global Seating
          </a>
        </div>
      </div>
      <div class="lp-hero__media" aria-hidden="true">
        {%- if section.settings.hero_image != blank -%}
          {%- assign gt_alt = 'Global Teknion workstations by Brant Business Interiors' -%}
          {{ section.settings.hero_image | image_url: width: 1200 | image_tag: loading: 'eager', alt: gt_alt, width: 1200 }}
        {%- else -%}
          <div class="lp-hero__ph">Hero image &middot; 5:4 &middot; upload global-teknion-space.jpg</div>
        {%- endif -%}
        <div class="lp-hero__caption">
          <span class="lp-hero__caption-dot"></span>
          <span>Global Furniture Group &mdash; flagship, Teknion premium, OTG value</span>
        </div>
      </div>
    </div>
  </section>

  <section class="lp-intro" aria-label="About Global Furniture Group">
    <div class="lp-intro__inner">
      <p class="lp-intro__eyebrow bbi-mono">About the GFG family</p>
      <h2>One contract-furniture portfolio, three tiers &mdash; institutional value to premium fit-out.</h2>
      <div class="lp-intro__body">
        <p>Global Furniture Group is the Canadian-headquartered contract furniture parent behind some of the most-specified lines in Ontario institutional procurement. The portfolio works as a tiered system: Global itself is the flagship for chairs, desks, tables, and storage at commercial quality; Teknion is the premium contract tier for executive suites and high-design environments; OTG (Offices to Go) is the high-volume value line for institutional budgets; and ObusForme covers the ergonomic-specialist niche within the family.</p>
        <p>Brant Business Interiors is an authorized dealer across the family. The advantage for a buyer: one specification, one quote, one delivery and install schedule across multiple tiers &mdash; instead of stitching together brands from different manufacturers. All GFG-family products are available under OECM Agreement 2025-470 for eligible Ontario institutional buyers.</p>
      </div>
    </div>
  </section>

  <section class="lp-diff" aria-label="Why Global Furniture Group">
    <div class="lp-diff__inner">
      <div class="lp-diff__head">
