.lp-global .lp-oecm-bar{background:var(--alternateBackground);border-top:1px solid rgba(var(--borderColor-rgb),0.5);border-bottom:1px solid rgba(var(--borderColor-rgb),0.5);padding:var(--space-8) 0;}
.lp-global .lp-oecm-bar__inner{max-width:1280px;margin:0 auto;padding:0 var(--space-6);display:flex;align-items:center;gap:var(--space-8);flex-wrap:wrap;}
.lp-global .lp-oecm-badge{display:inline-flex;align-items:center;gap:var(--space-2);padding:6px 12px;border:1px solid rgba(var(--borderColor-rgb),0.8);border-radius:999px;font-size:12px;white-space:nowrap;color:rgba(var(--textColor-rgb),0.78);}
.lp-global .lp-oecm-badge .dot{width:6px;height:6px;border-radius:50%;background:var(--saleBadgeBackground);flex-shrink:0;}
.lp-global .lp-oecm-bar__lead{display:flex;align-items:flex-start;gap:var(--space-4);flex:1 1 400px;flex-wrap:wrap;}
.lp-global .lp-oecm-bar__copy{font-size:15px;line-height:1.55;color:rgba(var(--textColor-rgb),0.78);margin:0;max-width:62ch;}
.lp-global .lp-oecm-bar__meta{flex-shrink:0;}
.lp-global .lp-faq{padding:var(--space-12) 0;border-top:1px solid rgba(var(--borderColor-rgb),0.5);}
.lp-global .lp-faq__inner{max-width:860px;margin:0 auto;padding:0 var(--space-6);}
.lp-global .lp-faq__head{margin-bottom:var(--space-8);}
.lp-global .lp-faq__eyebrow{display:inline-flex;align-items:center;gap:var(--space-2);color:rgba(var(--textColor-rgb),0.6);margin-bottom:var(--space-4);}
.lp-global .lp-faq__eyebrow::before{content:"";display:inline-block;width:18px;height:1px;background:var(--saleBadgeBackground);}
.lp-global .lp-faq h2{font-family:var(--headingFont);font-size:var(--fs-h2);line-height:var(--lh-h2);font-weight:600;color:var(--headingColor);margin:0 0 var(--space-4);}
.lp-global .lp-faq__cta{font-size:15px;color:rgba(var(--textColor-rgb),0.72);margin:0;}
.lp-global .lp-faq__cta a{color:var(--textColor);text-decoration:underline;}
.lp-global .lp-faq-item{border-bottom:1px solid rgba(var(--borderColor-rgb),0.6);}
.lp-global .lp-faq-item summary{list-style:none;display:flex;align-items:baseline;gap:var(--space-4);padding:var(--space-6) 0;cursor:pointer;}
.lp-global .lp-faq-item summary::-webkit-details-marker{display:none;}
.lp-global .lp-faq-item__num{font-family:"JetBrains Mono",ui-monospace,monospace;font-size:11px;color:rgba(var(--textColor-rgb),0.4);flex-shrink:0;width:24px;}
.lp-global .lp-faq-item__q{flex:1;font-size:16px;font-weight:500;color:var(--headingColor);line-height:1.4;}
.lp-global .lp-faq-item__icon{flex-shrink:0;width:20px;height:20px;border-radius:50%;border:1px solid rgba(var(--borderColor-rgb),0.8);display:flex;align-items:center;justify-content:center;font-size:14px;color:rgba(var(--textColor-rgb),0.5);transition:transform 160ms ease;}
.lp-global details[open] .lp-faq-item__icon{transform:rotate(45deg);}
.lp-global .lp-faq-item__icon::after{content:"+";}
.lp-global .lp-faq-item__body{padding:0 0 var(--space-6) calc(24px + var(--space-4));}
.lp-global .lp-faq-item__body p{font-size:15px;line-height:1.65;color:rgba(var(--textColor-rgb),0.78);margin:0;}
.lp-global .lp-closer{background:var(--background);color:var(--textColor);}
.lp-global .lp-closer__inner{max-width:1320px;margin:0 auto;padding:96px 32px;display:grid;grid-template-columns:1.2fr 1fr;gap:64px;align-items:center;}
.lp-global .lp-closer__eyebrow{font-family:"JetBrains Mono",ui-monospace,monospace;font-size:12px;letter-spacing:0.08em;text-transform:uppercase;color:rgba(var(--textColor-rgb),0.7);margin:0 0 16px;}
.lp-global .lp-closer__heading{font-family:var(--headingFont);font-size:clamp(32px,4.2vw,56px);line-height:1.05;letter-spacing:-0.015em;font-weight:600;margin:0 0 20px;text-wrap:balance;}
.lp-global .lp-closer__sub{font-size:17px;line-height:1.55;color:rgba(var(--textColor-rgb),0.78);max-width:52ch;margin:0;}
.lp-global .lp-closer__actions{display:flex;flex-direction:column;gap:16px;align-items:flex-start;}
.lp-global .lp-closer__trust{display:flex;align-items:flex-start;gap:10px;font-size:14px;color:rgba(var(--textColor-rgb),0.78);}
