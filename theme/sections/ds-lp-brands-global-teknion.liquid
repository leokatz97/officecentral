.lp-global .lp-intro{padding:var(--space-12) 0;}
.lp-global .lp-intro__inner{max-width:880px;margin:0 auto;padding:0 var(--space-6);}
.lp-global .lp-intro__eyebrow{display:inline-flex;align-items:center;gap:var(--space-2);color:rgba(var(--textColor-rgb),0.6);margin-bottom:var(--space-4);}
