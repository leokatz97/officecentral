        <h1>{{ section.settings.heading | default: 'Non-Profit Office Furniture — Commercial Grade, Institutional Pricing' }}</h1>
        <p class="lp-hero__standfirst">{{ section.settings.subheading | default: 'Do more with your budget — commercial-grade furniture at institutional pricing, without the tender burden. OECM-eligible. Staff offices, meeting rooms, reception, and training rooms across Ontario. Call 1-800-835-9565.' }}</p>
        <div class="lp-hero__cta-row">
          <a class="bbi-btn bbi-btn--primary bbi-btn--lg" href="/pages/quote">
            Request a Quote <span class="arrow">&#8594;</span>
          </a>
          <a class="bbi-btn bbi-btn--secondary bbi-btn--lg" href="tel:18008359565"
             aria-label="Call Brant Business Interiors at 1-800-835-9565">
            Call 1-800-835-9565
          </a>
        </div>
      </div>
      <div class="lp-hero__media" aria-hidden="true">
        {%- if section.settings.hero_image != blank -%}
