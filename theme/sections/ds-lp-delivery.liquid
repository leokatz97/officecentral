<script>
(function(){
  document.querySelectorAll('.lp-delivery .lp-faq__q').forEach(function(btn){
    btn.addEventListener('click',function(){
      var item=this.closest('.lp-faq__item');
      var open=item.classList.contains('is-open');
      document.querySelectorAll('.lp-delivery .lp-faq__item.is-open').forEach(function(i){i.classList.remove('is-open');i.querySelector('.lp-faq__q').setAttribute('aria-expanded','false');});
      if(!open){item.classList.add('is-open');this.setAttribute('aria-expanded','true');}
    });
  });
})();
</script>

