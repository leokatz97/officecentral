        </div>
        <div class="lp-photo-card">
          <div class="lp-photo-card__media">
            {%- if section.settings.photo_12 != blank -%}
              {{ section.settings.photo_12 | image_url: width: 800 | image_tag: loading: 'lazy', alt: 'Education classroom installation' }}
            {%- else -%}
              <div class="lp-photo-card__ph"><span>Education</span></div>
            {%- endif -%}
          </div>
