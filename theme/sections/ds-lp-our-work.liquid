            {%- endif -%}
          </div>
          <p class="lp-photo-card__caption">Reception lounge — Keilhauer soft seating</p>
        </div>

        {%- comment -%} Row 3 — standard + wide {%- endcomment -%}
        <div class="lp-photo-card">
          <div class="lp-photo-card__media">
            {%- if section.settings.photo_6 != blank -%}
              {{ section.settings.photo_6 | image_url: width: 800 | image_tag: loading: 'lazy', alt: 'Healthcare waiting area' }}
            {%- else -%}
              <div class="lp-photo-card__ph"><span>Healthcare Waiting</span></div>
            {%- endif -%}
          </div>
          <p class="lp-photo-card__caption">Healthcare waiting area — bariatric-rated seating</p>
        </div>
        <div class="lp-photo-card lp-photo-card--wide">
          <div class="lp-photo-card__media">
            {%- if section.settings.photo_7 != blank -%}
              {{ section.settings.photo_7 | image_url: width: 1400 | image_tag: loading: 'lazy', alt: 'Mattamy Homes — multi-office installation' }}
            {%- else -%}
              <div class="lp-photo-card__ph"><span>Mattamy Homes — Open Office</span></div>
            {%- endif -%}
          </div>
          <p class="lp-photo-card__caption">Mattamy Homes — Multi-office open floor, Milton, ON</p>
        </div>

        {%- comment -%} Row 4 — three standard {%- endcomment -%}
        <div class="lp-photo-card">
          <div class="lp-photo-card__media">
            {%- if section.settings.photo_8 != blank -%}
              {{ section.settings.photo_8 | image_url: width: 800 | image_tag: loading: 'lazy', alt: 'Ergonomic workstation setup' }}
            {%- else -%}
              <div class="lp-photo-card__ph"><span>Ergonomic Workstation</span></div>
            {%- endif -%}
          </div>
          <p class="lp-photo-card__caption">Ergonomic workstation — ergoCentric TechnoMesh, sit-stand desk</p>
        </div>
        <div class="lp-photo-card">
          <div class="lp-photo-card__media">
            {%- if section.settings.photo_9 != blank -%}
              {{ section.settings.photo_9 | image_url: width: 800 | image_tag: loading: 'lazy', alt: 'Breakroom installation' }}
            {%- else -%}
              <div class="lp-photo-card__ph"><span>Breakroom</span></div>
            {%- endif -%}
          </div>
          <p class="lp-photo-card__caption">Breakroom — café-height tables, stackable seating</p>
        </div>
        <div class="lp-photo-card">
          <div class="lp-photo-card__media">
            {%- if section.settings.photo_10 != blank -%}
              {{ section.settings.photo_10 | image_url: width: 800 | image_tag: loading: 'lazy', alt: 'Acoustic pods installation' }}
            {%- else -%}
              <div class="lp-photo-card__ph"><span>Acoustic Pods</span></div>
            {%- endif -%}
          </div>
          <p class="lp-photo-card__caption">Private focus pods — acoustic enclosures, open-plan office</p>
        </div>

        {%- comment -%} Row 5 — wide + standard {%- endcomment -%}
        <div class="lp-photo-card lp-photo-card--wide">
          <div class="lp-photo-card__media">
            {%- if section.settings.photo_11 != blank -%}
              {{ section.settings.photo_11 | image_url: width: 1400 | image_tag: loading: 'lazy', alt: 'Government office installation' }}
            {%- else -%}
              <div class="lp-photo-card__ph"><span>Government Office</span></div>
            {%- endif -%}
          </div>
