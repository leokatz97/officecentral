        </div>

      </div>
    </div>
  </section>

  {%- comment -%} CTA Closer {%- endcomment -%}
  <section class="lp-closer" style="background:var(--alternateBackground);padding:var(--space-12) 0;border-top:1px solid rgba(var(--borderColor-rgb),0.6);">
    <div class="lp-closer__inner">
      <h2>Have a project in mind?</h2>
      <p class="lp-closer__sub">Request a quote and tell us about your space. We'll put together a plan with product recommendations, a CAD layout if needed, and delivery &amp; installation pricing. OECM-eligible. No obligation.</p>
      <div class="lp-closer__cta-row">
        <a href="/pages/quote" class="bbi-btn bbi-btn--primary bbi-btn--lg">Request a Quote <span style="display:inline-block;transform:translateY(-0.5px);">→</span></a>
        <a href="tel:18008359565" class="bbi-btn bbi-btn--secondary bbi-btn--lg">Call 1-800-835-9565</a>
      </div>
      <p class="lp-closer__trust">OECM Agreement 2025-470 · Quote in 1 business day · Ontario-wide delivery</p>
    </div>
  </section>

  {%- comment -%} Footer {%- endcomment -%}
  <footer class="bbi-footer">
    <div class="bbi-footer__inner">
      <div class="bbi-footer__grid">
        <div>
          {%- if section.settings.logo != blank -%}
            {{ section.settings.logo | image_url: width: 180 | image_tag: loading: 'lazy', alt: 'Brant Business Interiors', class: 'bbi-footer__brand-logo' }}
          {%- else -%}
