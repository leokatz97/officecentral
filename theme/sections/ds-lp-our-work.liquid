          <div class="lp-photo-card__media">
            {%- if section.settings.photo_1 != blank -%}
              {{ section.settings.photo_1 | image_url: width: 1400 | image_tag: loading: 'eager', alt: 'Corporate boardroom installation, Ontario' }}
            {%- else -%}
              <div class="lp-photo-card__ph"><span>Corporate Boardroom</span></div>
            {%- endif -%}
          </div>
          <p class="lp-photo-card__caption">Corporate boardroom &mdash; Global Furniture Group tables, executive seating, Greater Toronto Area</p>
        </div>
        <div class="lp-photo-card">
          <div class="lp-photo-card__media">
            {%- if section.settings.photo_2 != blank -%}
