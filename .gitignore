.env
.env.*
theme/config/settings_data.json
.DS_Store

# Claude Code worktrees and local settings (may contain API tokens)
.claude/worktrees/
.claude/settings.local.json

# Generated script artifacts — regenerate with audit scripts, don't commit
data/backups/
data/logs/
data/exports/
data/specs.json
data/specs-run.log
data/theme-inventory.json
data/theme-coverage.md

# Transient drop zone for incoming design exports / zips before extraction
data/incoming/

# Root-level folders not part of this project
Design System Zips/
PE-review-2026-04-30/
Steve Claude Resume/

# Liquid backup files — use git history instead
theme/**/*.backup-*
theme/**/*-backup-*.liquid

# AI-generated images — runtime artefacts, regenerate with generate-*-images.py scripts
data/page-images/
data/generated-images/
data/generated-clean-images/
data/generated-img2img-images/
data/img2img/

# Raw screenshots dropped into oci-photos — only webp/jpg catalog files are committed
data/oci-photos/*.png
data/oci-photos/Screenshot*

# Generated logo option PNGs — regenerate with scripts/generate-logo-options.py
data/logos/options/*.png

# Review screenshots — reference only, not part of source
docs/reviews/*.png
